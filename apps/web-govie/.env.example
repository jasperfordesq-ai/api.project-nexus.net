# =============================================================================
# Nexus Community — GOV.IE Frontend Environment Configuration
# =============================================================================
# Copy this file to .env.development for local dev.
# NEVER commit .env files with real secrets.
#
# Variables prefixed with VITE_ are exposed to the browser bundle.
# Do NOT prefix sensitive server-side secrets with VITE_.
# =============================================================================

# Backend API base URL
# In local Docker dev this is proxied via Vite; in production set the full URL.
VITE_API_BASE_URL=http://localhost:5080

# Application metadata
VITE_APP_NAME=Nexus Community
VITE_APP_VERSION=0.1.0

# Tenant slug — identifies which time bank this frontend serves
VITE_TENANT_SLUG=acme

# Feature flags (optional)
VITE_FEATURE_AI=true
VITE_FEATURE_PASSKEYS=true
VITE_FEATURE_FEDERATION=false
