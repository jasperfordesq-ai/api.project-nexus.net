# NEXUS React Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# API Configuration (ASP.NET Core backend)
VITE_API_BASE=/api
VITE_API_URL=http://localhost:5080

# Default Tenant (for development)
VITE_DEFAULT_TENANT_ID=1
VITE_DEFAULT_TENANT_SLUG=hour-timebank

# Google Maps (Places Autocomplete)
VITE_GOOGLE_MAPS_API_KEY=

# Sentry error tracking (optional — leave blank to disable)
# DSN is build-time: rebuild required after changing.
# Frontend Sentry is also gated on user analytics-cookie consent (GDPR opt-in).
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# Optional: short SHA stamped onto Sentry releases
VITE_BUILD_COMMIT=
