# Project NEXUS UK Frontend - Environment Configuration

# Server port
PORT=3001

# Backend contract target. Laravel is the source-of-truth backend.
ACCESSIBLE_BACKEND_TARGET=laravel
LARAVEL_BASE_URL=http://127.0.0.1:8088

# Future ASP.NET target. Not certified.
ASPNET_BASE_URL=http://localhost:5080

# Optional explicit override. Prefer LARAVEL_BASE_URL for Laravel-first work.
# API_BASE_URL=http://127.0.0.1:8088

# REQUIRED: Secret for signed cookies (generate a strong random string)
COOKIE_SECRET=change-this-to-a-secure-random-string

# Secret for sessions (defaults to COOKIE_SECRET if not set)
SESSION_SECRET=change-this-to-a-secure-random-string

# Environment: development or production
NODE_ENV=development

# Cloudflare Turnstile (bot challenge on registration form).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
