{% extends "layouts/base.njk" %}

{% block content %}
  <a class="govuk-back-link" href="{{ urlFor('/nexus-score') }}">Back to NEXUS score</a>

  <span class="govuk-caption-xl">NEXUS score at {{ communityName }}</span>
  <h1 class="govuk-heading-xl">NEXUS tier ladder</h1>
  <p class="govuk-body-l">There are 9 tiers. Your tier rises as your NEXUS score grows.</p>

  {% if not tierScore.hasScore %}
    <div class="govuk-inset-text">
      <p class="govuk-body">Your NEXUS score is not available yet.</p>
    </div>
  {% else %}
    <div class="govuk-panel govuk-panel--confirmation nexus-alpha-panel govuk-!-margin-bottom-6">
      <div class="govuk-panel__body">
        {{ tierScore.scoreLabel }}
        {% if tierScore.currentTierLabel %}<br>{{ tierScore.currentTierLabel }}{% endif %}
      </div>
    </div>

    <div class="govuk-inset-text">{{ tierScore.nextTierLabel }}</div>

    <table class="govuk-table govuk-!-margin-top-4">
      <caption class="govuk-table__caption govuk-table__caption--s govuk-visually-hidden">NEXUS tier ladder</caption>
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header">Tier</th>
          <th scope="col" class="govuk-table__header govuk-table__header--numeric">Score needed</th>
          <th scope="col" class="govuk-table__header">Status</th>
        </tr>
      </thead>
      <tbody class="govuk-table__body">
        {% for row in tierScore.rows %}
          <tr class="govuk-table__row{% if row.isCurrent %} nexus-alpha-row--active{% endif %}">
            <td class="govuk-table__cell">{{ row.name }}</td>
            <td class="govuk-table__cell govuk-table__cell--numeric">{{ row.thresholdLabel }}</td>
            <td class="govuk-table__cell">
              <strong class="govuk-tag {{ row.statusClass }}">{{ row.statusLabel }}</strong>
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% endif %}
{% endblock %}
