{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a class="govuk-back-link" href="/listings/{{ listing.id }}">Back</a>

  {% if status %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            <li><a href="#reason-inappropriate">{{ status.message }}</a></li>
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  <span class="govuk-caption-l">{{ listing.title or listing.name or "" }}</span>
  <h1 class="govuk-heading-xl">Report listing</h1>
  <p class="govuk-body-l">Tell us why you are reporting this listing. We review all reports and take action where needed.</p>

  <form method="post" action="/listings/{{ listing.id }}/report" novalidate>
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    <div class="govuk-form-group{% if status %} govuk-form-group--error{% endif %}">
      <fieldset class="govuk-fieldset"{% if status %} aria-describedby="reason-error"{% endif %}>
        <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
          <h2 class="govuk-fieldset__heading">Reason for report</h2>
        </legend>
        {% if status %}
          <p id="reason-error" class="govuk-error-message"><span class="govuk-visually-hidden">Error:</span> {{ status.message }}</p>
        {% endif %}
        <div class="govuk-radios" data-module="govuk-radios" id="reason">
          {% for reason in reasons %}
            <div class="govuk-radios__item">
              <input class="govuk-radios__input" id="reason-{{ reason.value }}" name="reason" type="radio" value="{{ reason.value }}">
              <label class="govuk-label govuk-radios__label" for="reason-{{ reason.value }}">{{ reason.label }}</label>
            </div>
          {% endfor %}
        </div>
      </fieldset>
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label" for="details">Additional details (optional)</label>
      <div id="details-hint" class="govuk-hint">Give us any other information that will help us investigate.</div>
      <textarea class="govuk-textarea" id="details" name="details" rows="5" aria-describedby="details-hint" maxlength="500"></textarea>
    </div>

    <div class="govuk-button-group">
      <button class="govuk-button govuk-button--warning" data-module="govuk-button">Send report</button>
      <a class="govuk-link" href="/listings/{{ listing.id }}">Cancel</a>
    </div>
  </form>
{% endblock %}
