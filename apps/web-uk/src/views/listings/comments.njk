{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a class="govuk-back-link" href="/listings/{{ listing.id }}">Back to listing</a>

  {% if status and status.type == "error" %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">{{ status.title }}</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            <li><a href="#{{ status.anchor or 'body' }}">{{ status.message }}</a></li>
          </ul>
        </div>
      </div>
    </div>
  {% elseif status and status.type == "success" %}
    <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="comment-status-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="comment-status-title">{{ status.title }}</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ status.message }}</p>
      </div>
    </div>
  {% endif %}

  <span class="govuk-caption-xl">{{ listingTitle }}</span>
  <h1 class="govuk-heading-xl">Comments <span class="govuk-!-font-weight-regular">({{ commentsCount }})</span></h1>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h2 class="govuk-heading-l">Comments</h2>

      {% if comments.length %}
        <ul class="govuk-list nexus-alpha-comments-list">
          {% for comment in comments %}
            {% include "listings/_comment.njk" %}
          {% endfor %}
        </ul>
      {% else %}
        <div class="govuk-inset-text"><p class="govuk-body">No comments yet. Be the first to start the conversation.</p></div>
      {% endif %}

      <h2 class="govuk-heading-m govuk-!-margin-top-6" id="add-comment">Add a comment</h2>
      <form method="post" action="/listings/{{ listing.id }}/comments" class="govuk-!-margin-top-2">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <div class="govuk-form-group{% if status and status.anchor == 'body' %} govuk-form-group--error{% endif %}">
          <label class="govuk-label govuk-label--s" for="body">Your comment</label>
          <div id="body-hint" class="govuk-hint">Be kind and keep it relevant to this listing.</div>
          {% if status and status.anchor == 'body' %}
            <p id="body-error" class="govuk-error-message"><span class="govuk-visually-hidden">Error:</span> {{ status.message }}</p>
          {% endif %}
          <textarea class="govuk-textarea{% if status and status.anchor == 'body' %} govuk-textarea--error{% endif %}" id="body" name="body" rows="4" maxlength="5000" aria-describedby="body-hint{% if status and status.anchor == 'body' %} body-error{% endif %}"></textarea>
        </div>
        <button type="submit" class="govuk-button" data-module="govuk-button">Post comment</button>
      </form>
    </div>
  </div>
{% endblock %}
