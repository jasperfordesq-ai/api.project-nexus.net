{% extends "layouts/base.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/pagination/macro.njk" import govukPagination %}
{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">

      {% if successMessage %}
        {% set notificationMessage = successMessage %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      {% if errorMessage %}
        {% set notificationMessage = errorMessage %}
        {% set notificationType = "" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      <h1 class="govuk-heading-xl">Listings</h1>

      <div class="govuk-grid-row govuk-!-margin-bottom-6">
        <div class="govuk-grid-column-full">
          <form method="get" action="{{ urlFor('/listings') }}" class="app-filter-form">
            <div class="govuk-grid-row">
              <div class="govuk-grid-column-one-third">
                {{ govukInput({
                  label: { text: "Search" },
                  id: "search",
                  name: "search",
                  value: filters.search or ""
                }) }}
              </div>
              <div class="govuk-grid-column-one-third">
                {{ govukSelect({
                  id: "type",
                  name: "type",
                  label: { text: "Type" },
                  items: [
                    { value: "", text: t("feed.subtypes.all"), selected: not filters.type },
                    { value: "offer", text: "Offers", selected: filters.type == "offer" },
                    { value: "request", text: "Requests", selected: filters.type == "request" }
                  ]
                }) }}
              </div>
              <div class="govuk-grid-column-one-third app-filter-buttons">
                {{ govukButton({
                  text: t("goals.templates_filter_button"),
                  classes: "govuk-button--secondary"
                }) }}
                {% if filters.search or filters.type %}
                  <a href="{{ urlFor('/listings') }}" class="govuk-link govuk-!-margin-left-2">Clear</a>
                {% endif %}
              </div>
            </div>
          </form>
        </div>
      </div>

      {% if isAuthenticated %}
        <p class="govuk-body"><a href="{{ urlFor('/listings/new') }}" class="govuk-button">Create listing</a></p>
      {% endif %}

      {% if listings and listings.length > 0 %}
        <table class="govuk-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">{{ t("group_exchanges.form_title_label") }}</th>
              <th scope="col" class="govuk-table__header">Status</th>
              <th scope="col" class="govuk-table__header">Created</th>
              {% if isAuthenticated %}<th scope="col" class="govuk-table__header">Actions</th>{% endif %}
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for listing in listings %}
              {% if listing.status == "active" %}
                {% set tagColour = "green" %}
              {% elif listing.status == "draft" %}
                {% set tagColour = "grey" %}
              {% else %}
                {% set tagColour = "red" %}
              {% endif %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">
                  <a href="{{ urlFor('/listings/' + (listing.id | string)) }}" class="govuk-link">
                    {{ listing.title or listing.name or "Untitled" }}
                  </a>
                </td>
                {% if isAuthenticated %}<td class="govuk-table__cell">
                  <strong class="govuk-tag govuk-tag--{{ tagColour }}">
                    {{ listing.status or "N/A" }}
                  </strong>
                </td>{% endif %}
                <td class="govuk-table__cell">{{ (listing.createdAt or listing.created_at) | formatDate if listing.createdAt or listing.created_at else "N/A" }}</td>
                <td class="govuk-table__cell">
                  {% set listingOwnerId = listing.user_id or listing.userId or listing.author_id or listing.authorId or (listing.user.id if listing.user and listing.user.id else null) %}
                  {% set currentUserId = currentUser.id if currentUser and currentUser.id else null %}
                  {% if listing.can_edit or (listingOwnerId and currentUserId and (listingOwnerId | string) == (currentUserId | string)) %}
                    <a href="{{ urlFor('/listings/' + (listing.id | string) + '/edit') }}" class="govuk-link govuk-!-margin-right-2">{{ t("jobs_t3.edit_button") }}</a>
                  {% endif %}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>

        {% if pagination.hasMore and pagination.cursor %}
          {{ govukPagination({
            next: {
              labelText: t("listings.more_results_label"),
              href: urlFor("/listings?" + ("search=" + (filters.search | urlencode) + "&" if filters.search else "") + ("type=" + filters.type + "&" if filters.type else "") + "cursor=" + (pagination.cursor | urlencode))
            },
            landmarkLabel: t("listings.pagination_label")
          }) }}
        {% endif %}

      {% else %}
        <div class="govuk-inset-text">
          <h2 class="govuk-heading-m">{{ t("states.empty_title") }}</h2>
          <p class="govuk-body">{{ t("listings.empty") }}</p>
          {% if hasFilters %}
            <p class="govuk-body">
              <a class="govuk-link" href="{{ urlFor('/listings') }}">{{ t("actions.clear_filters") }}</a>
            </p>
          {% endif %}
        </div>
      {% endif %}

    </div>
  </div>
{% endblock %}
