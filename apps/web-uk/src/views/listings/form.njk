{% extends "layouts/base.njk" %}

{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}

{% block beforeContent %}
  {{ super() }}
  {{ govukBreadcrumbs({
    items: [
      { text: t("nav.home"), href: urlFor("/") },
      { text: "Listings", href: urlFor("/listings") },
      { text: t("listings.edit.edit_listing") if listing else "New listing" }
    ]
  }) }}
{% endblock %}

{% block mainContent %}
  {% if values %}
    {% set currentTitle = values.title %}
    {% set currentDescription = values.description %}
    {% set currentType = values.type %}
    {% set currentCategoryId = values.category_id %}
    {% set currentHours = values.hours_estimate %}
    {% set currentServiceType = values.service_type %}
    {% set currentLocation = values.location %}
    {% set currentSkillTags = values.skill_tags %}
  {% elif listing %}
    {% set currentTitle = listing.title %}
    {% set currentDescription = listing.description %}
    {% set currentType = listing.type %}
    {% set currentCategoryId = listing.category_id or (listing.category.id if listing.category else "") %}
    {% set currentHours = listing.hours_estimate if listing.hours_estimate is not none else listing.estimated_hours %}
    {% set currentServiceType = listing.service_type or "physical_only" %}
    {% set currentLocation = listing.location %}
    {% set currentSkillTags = listing.skill_tags | join(", ") if listing.skill_tags else "" %}
  {% else %}
    {% set currentTitle = "" %}
    {% set currentDescription = "" %}
    {% set currentType = "offer" %}
    {% set currentCategoryId = "" %}
    {% set currentHours = "" %}
    {% set currentServiceType = "physical_only" %}
    {% set currentLocation = "" %}
    {% set currentSkillTags = "" %}
  {% endif %}
  {% set listingFormAction = "/listings/" + (listing.id | string) + "/edit" if listing and listing.id else "/listings/new" %}
  {% set typeItems = [] %}
  {% if config.allowOffers %}
    {% set typeItems = (typeItems.push({ value: "offer", text: "Offer", checked: currentType == "offer" }), typeItems) %}
  {% endif %}
  {% if config.allowRequests %}
    {% set typeItems = (typeItems.push({ value: "request", text: "Request", checked: currentType == "request" }), typeItems) %}
  {% endif %}
  {% set categoryItems = [{ value: "", text: t("listings.create.category_none"), selected: not currentCategoryId }] %}
  {% for category in categories %}
    {% set categoryItems = (categoryItems.push({
      value: category.id | string,
      text: category.name,
      selected: (currentCategoryId | string) == (category.id | string)
    }), categoryItems) %}
  {% endfor %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if errors and errors.length %}
        {{ govukErrorSummary({
          titleText: t("states.error_title"),
          errorList: errors,
          attributes: { tabindex: "-1" }
        }) }}
      {% endif %}

      {% if setupErrorMessage %}
        <div class="govuk-notification-banner" role="region" aria-labelledby="listing-setup-title">
          <div class="govuk-notification-banner__header">
            <h2 class="govuk-notification-banner__title" id="listing-setup-title">{{ t("states.error_title") }}</h2>
          </div>
          <div class="govuk-notification-banner__content">
            <p class="govuk-notification-banner__heading">{{ setupErrorMessage }}</p>
          </div>
        </div>
      {% endif %}

      <h1 class="govuk-heading-xl">{% if listing %}Edit listing{% else %}Create listing{% endif %}</h1>
      <p class="govuk-body-l">Share an offer or request with your community.</p>

      <form method="post" action="{{ urlFor(listingFormAction) }}" enctype="multipart/form-data" novalidate>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        {% if (values and values.has_existing_image) or (listing and listing.image_url) %}
          <input type="hidden" name="has_existing_image" value="1">
        {% endif %}

        {{ govukRadios({
          idPrefix: "type",
          name: "type",
          fieldset: {
            legend: {
              text: "What are you listing?",
              classes: "govuk-fieldset__legend--m"
            }
          },
          hint: { text: "Choose whether you are offering help or asking for help." },
          items: typeItems,
          errorMessage: { text: fieldErrors.type } if fieldErrors.type else undefined
        }) }}

        {{ govukInput({
          label: {
            text: t("group_exchanges.form_title_label"),
            classes: "govuk-label--m"
          },
          hint: { text: "Use a short, clear title. At least " + (config.minTitleLength | string) + " characters." },
          id: "title",
          name: "title",
          value: currentTitle,
          attributes: { maxlength: "255" },
          errorMessage: { text: fieldErrors.title } if fieldErrors.title else undefined
        }) }}

        {{ govukTextarea({
          label: {
            text: "Description",
            classes: "govuk-label--m"
          },
          hint: { text: "Explain what is offered or needed. At least " + (config.minDescriptionLength | string) + " characters." },
          id: "description",
          name: "description",
          rows: 6,
          value: currentDescription,
          attributes: { maxlength: "10000" },
          errorMessage: { text: fieldErrors.description } if fieldErrors.description else undefined
        }) }}

        {{ govukSelect({
          id: "category_id",
          name: "category_id",
          label: {
            text: "Category" + ("" if config.requireCategory else " (optional)"),
            classes: "govuk-label--m"
          },
          hint: { text: "Choose the closest category for this listing." },
          items: categoryItems,
          errorMessage: { text: fieldErrors.category_id } if fieldErrors.category_id else undefined
        }) }}

        {{ govukInput({
          label: {
            text: "Estimated hours" + ("" if config.requireHours else " (optional)"),
            classes: "govuk-label--m"
          },
          hint: { text: "Enter an estimate between 0.5 and 2,000 hours." },
          id: "hours_estimate",
          name: "hours_estimate",
          type: "number",
          classes: "govuk-input--width-5",
          value: currentHours,
          attributes: { min: "0.5", max: "2000", step: "0.5", inputmode: "decimal" },
          errorMessage: { text: fieldErrors.hours_estimate } if fieldErrors.hours_estimate else undefined
        }) }}

        {% if config.enableServiceType %}
          {{ govukRadios({
            idPrefix: "service_type",
            name: "service_type",
            classes: "govuk-radios--small",
            fieldset: {
              legend: {
                text: "How can the service be delivered?",
                classes: "govuk-fieldset__legend--m"
              }
            },
            items: [
              { value: "physical_only", text: "In person only", checked: currentServiceType == "physical_only" },
              { value: "remote_only", text: t("jobs_t2.remote_label"), checked: currentServiceType == "remote_only" },
              { value: "hybrid", text: "In person or remote", checked: currentServiceType == "hybrid" },
              { value: "location_dependent", text: "Depends on the service", checked: currentServiceType == "location_dependent" }
            ],
            errorMessage: { text: fieldErrors.service_type } if fieldErrors.service_type else undefined
          }) }}
        {% else %}
          <input type="hidden" name="service_type" value="{{ currentServiceType or 'physical_only' }}">
        {% endif %}

        {{ govukInput({
          label: {
            text: "Location" + ("" if config.requireLocation else " (optional)"),
            classes: "govuk-label--m"
          },
          hint: { text: "For example, a town, neighbourhood or meeting place." },
          id: "location",
          name: "location",
          value: currentLocation,
          attributes: { maxlength: "255", autocomplete: "off" },
          errorMessage: { text: fieldErrors.location } if fieldErrors.location else undefined
        }) }}

        <div class="govuk-form-group{% if fieldErrors.image %} govuk-form-group--error{% endif %}">
          <label class="govuk-label govuk-label--m" for="image">Image{% if not config.requireImage %} (optional){% endif %}</label>
          {% if listing and listing.image_url %}
            <p class="govuk-body-s govuk-!-margin-bottom-1">Current image</p>
            <img src="{{ listing.image_url }}" alt="{{ currentTitle }}" width="160" height="120" loading="lazy" decoding="async" class="govuk-!-margin-bottom-2">
          {% endif %}
          <div id="image-hint" class="govuk-hint">JPEG, PNG, GIF or WebP, up to {{ config.maxImageSizeMb }} MB. If the upload fails after saving, the listing itself is kept and you will be told.</div>
          {% if fieldErrors.image %}
            <p id="image-error" class="govuk-error-message"><span class="govuk-visually-hidden">{{ t("states.error_prefix") }}</span> {{ fieldErrors.image }}</p>
          {% endif %}
          <input class="govuk-file-upload{% if fieldErrors.image %} govuk-file-upload--error{% endif %}" id="image" name="image" type="file" accept="image/jpeg,image/png,image/gif,image/webp" aria-describedby="image-hint{% if fieldErrors.image %} image-error{% endif %}">
        </div>

        {% if config.enableSkillTags %}
          {{ govukInput({
            label: {
              text: "Skill tags (optional)",
              classes: "govuk-label--m"
            },
            hint: { text: "Enter up to 10 skills separated by commas. Skill tags are saved separately after the listing." },
            id: "skill_tags",
            name: "skill_tags",
            value: currentSkillTags,
            attributes: { maxlength: "600" },
            errorMessage: { text: fieldErrors.skill_tags } if fieldErrors.skill_tags else undefined
          }) }}
        {% endif %}

        <div class="govuk-button-group">
          {{ govukButton({ text: t("polish_listings.save_listing") }) }}
          <a href="{{ urlFor('/listings') }}" class="govuk-link">{{ t("polish_federation.transfer_cancel") }}</a>
        </div>
      </form>
    </div>
  </div>
{% endblock %}
