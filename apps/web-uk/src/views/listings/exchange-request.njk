{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a class="govuk-back-link" href="/listings/{{ listing.id }}">Back to listings</a>

  {% if status %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <p>{{ status.message }}</p>
        </div>
      </div>
    </div>
  {% endif %}

  <span class="govuk-caption-l">Request an exchange</span>
  <h1 class="govuk-heading-xl">{{ listing.title or listing.name or "Listing" }}</h1>
  <p class="govuk-body-l">Tell the member what you need and how many hours you expect the exchange to take.</p>

  <dl class="govuk-summary-list govuk-!-margin-bottom-7">
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Type</dt>
      <dd class="govuk-summary-list__value">{{ "Request" if listingType == "request" else "Offer" }}</dd>
    </div>
    {% if listing.category_name or listing.categoryName %}
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Category</dt>
        <dd class="govuk-summary-list__value">{{ listing.category_name or listing.categoryName }}</dd>
      </div>
    {% endif %}
    {% if listing.location %}
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Location</dt>
        <dd class="govuk-summary-list__value">{{ listing.location }}</dd>
      </div>
    {% endif %}
    {% if listing.hours_estimate or listing.estimated_hours %}
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Hours</dt>
        <dd class="govuk-summary-list__value">{{ listing.hours_estimate or listing.estimated_hours }} hours</dd>
      </div>
    {% endif %}
    {% if authorName %}
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Posted by</dt>
        <dd class="govuk-summary-list__value">{{ authorName }}</dd>
      </div>
    {% endif %}
  </dl>

  {% if walletBalance !== null and walletBalance !== undefined %}
    <div class="govuk-inset-text">
      Your current balance is {{ walletBalanceLabel }} hours.
    </div>
    {% if walletBalance < suggestedHours %}
      <div class="govuk-warning-text">
        <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
        <strong class="govuk-warning-text__text">
          <span class="govuk-visually-hidden">Important</span>
          This listing is estimated at {{ suggestedHoursLabel }} hours, which is more than your current balance. You can still send the request; your community decides how balances are managed.
        </strong>
      </div>
    {% endif %}
  {% endif %}

  <form method="post" action="/listings/{{ listing.id }}/exchange-request" novalidate>
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    <div class="govuk-form-group">
      <label class="govuk-label" for="proposed_hours">Hours</label>
      <div id="proposed-hours-hint" class="govuk-hint">Use a number between 0.25 and 24.</div>
      <input class="govuk-input govuk-input--width-5" id="proposed_hours" name="proposed_hours" type="number" min="0.25" max="24" step="0.25" value="{{ suggestedHours }}" aria-describedby="proposed-hours-hint" required>
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label" for="prep_time">Preparation time</label>
      <div id="prep-time-hint" class="govuk-hint">Optional. Include any setup or travel time.</div>
      <input class="govuk-input govuk-input--width-5" id="prep_time" name="prep_time" type="number" min="0" max="24" step="0.25" aria-describedby="prep-time-hint">
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label" for="message">Message to the member</label>
      <div id="message-hint" class="govuk-hint">Include the details the member needs to decide whether to accept.</div>
      <textarea class="govuk-textarea" id="message" name="message" rows="6" aria-describedby="message-hint"></textarea>
    </div>

    <button class="govuk-button" data-module="govuk-button">Send request</button>
  </form>
{% endblock %}
