{% extends "layouts/base.njk" %}

{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}

{% block beforeContent %}
  {{ super() }}
  <a class="govuk-back-link" href="{{ urlFor('/listings') }}">{{ t("actions.back_to_listings") }}</a>
{% endblock %}

{% block mainContent %}
  {% if listing.status == "active" %}
    {% set tagColour = "green" %}
  {% elif listing.status == "draft" %}
    {% set tagColour = "grey" %}
  {% else %}
    {% set tagColour = "grey" %}
  {% endif %}
  {% set listingType = "request" if listing.type == "request" else "offer" %}
  {% set typeColour = "purple" if listingType == "request" else "blue" %}
  {% set statusHtml %}<strong class="govuk-tag govuk-tag--{{ tagColour }}">{{ t("listings.status_values." + listing.status) if listing.status else "" }}</strong>{% endset %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if successMessage %}
        {% set notificationMessage = successMessage %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      {% if errorMessage %}
        {% set notificationMessage = errorMessage %}
        {% set notificationType = "" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      <span class="govuk-caption-l">{{ t("listings.detail_title") }}</span>
      <h1 class="govuk-heading-xl">{{ listing.title or listing.name or t("listings.detail_title") }}</h1>
      <p class="nexus-alpha-actions govuk-!-margin-bottom-4">
        <strong class="govuk-tag govuk-tag--{{ typeColour }}">{{ t("listings." + listingType) }}</strong>
        {% if listing.is_featured %}<strong class="govuk-tag govuk-tag--yellow">{{ t("listings.featured") }}</strong>{% endif %}
        {% if listing.service_type and listing.service_type != "physical_only" %}<strong class="govuk-tag govuk-tag--turquoise">{{ t("listings.service_types." + listing.service_type) }}</strong>{% endif %}
      </p>

      {% if listingImageUrl %}
        <figure class="nexus-alpha-detail-hero">
          <img src="{{ listingImageUrl }}" alt="{{ t('listings.image_alt', { title: listing.title }) }}" width="640" height="360" decoding="async">
        </figure>
      {% endif %}

      <h2 class="govuk-heading-l govuk-!-margin-top-7">{{ t("listings.description_title") }}</h2>
      <div class="govuk-body">{{ listing.description | nl2br }}</div>

      {# Rating summary if available #}
      {% if reviewSummary and reviewSummary.average_rating %}
        <p class="govuk-body-l govuk-!-margin-bottom-6">
          <span class="app-star-display" role="img" aria-label="{{ reviewSummary.average_rating }} out of 5 stars">
            {% for i in [1, 2, 3, 4, 5] %}
              <svg class="app-star-display__star {% if i <= reviewSummary.average_rating %}app-star-display__star--filled{% endif %}" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            {% endfor %}
          </span>
          <span class="govuk-!-margin-left-2">
            {{ reviewSummary.average_rating | round(1) }} ({{ reviewSummary.total_reviews }} review{% if reviewSummary.total_reviews != 1 %}s{% endif %})
          </span>
        </p>
      {% endif %}

      <h2 class="govuk-heading-l">{{ t("listings.summary_title") }}</h2>
      {% set summaryRows = [{ key: { text: t("listings.type") }, value: { text: t("listings." + listingType) } }] %}
      {% if listing.service_type %}
        {% set summaryRows = (summaryRows.push({ key: { text: t("listings.service_type_label") }, value: { text: t("listings.service_types." + listing.service_type) } }), summaryRows) %}
      {% endif %}
      {% if listing.status %}
        {% set summaryRows = (summaryRows.push({ key: { text: t("listings.status_label") }, value: { html: statusHtml } }), summaryRows) %}
      {% endif %}
      {% if listing.category_name or listing.category.name %}
        {% set summaryRows = (summaryRows.push({ key: { text: t("listings.category") }, value: { text: listing.category_name or listing.category.name } }), summaryRows) %}
      {% endif %}
      {% if listing.location %}
        {% set summaryRows = (summaryRows.push({ key: { text: t("listings.location") }, value: { text: listing.location } }), summaryRows) %}
      {% endif %}
      {% if listing.hours_estimate %}
        {% set summaryRows = (summaryRows.push({ key: { text: t("listings.hours_label") }, value: { text: tc("listings.hours", listing.hours_estimate, { count: listing.hours_estimate }) } }), summaryRows) %}
      {% endif %}
      {% if listing.createdAt or listing.created_at %}
        {% set summaryRows = (summaryRows.push({ key: { text: t("listings.created") }, value: { text: (listing.createdAt or listing.created_at) | formatDate } }), summaryRows) %}
      {% endif %}
      {{ govukSummaryList({ rows: summaryRows }) }}

      {% if listing.can_edit %}
        <div class="govuk-button-group">
          {{ govukButton({
            text: t("listings.edit.edit_listing"),
            href: urlFor("/listings/" + (listing.id | string) + "/edit"),
            classes: "govuk-button--secondary"
          }) }}
        </div>
        <hr class="govuk-section-break govuk-section-break--visible govuk-section-break--m govuk-!-margin-top-4">
        <h2 class="govuk-heading-s">{{ t("listings.edit.delete_heading") }}</h2>
        <div class="govuk-warning-text">
          <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
          <strong class="govuk-warning-text__text"><span class="govuk-warning-text__assistive">{{ t("states.warning_prefix") }}</span> {{ t("listings.edit.delete_warning") }}</strong>
        </div>
        <form method="post" action="{{ urlFor('/listings/' + (listing.id | string) + '/delete') }}">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <button type="submit" class="govuk-button govuk-button--warning" data-module="govuk-button">{{ t("listings.edit.delete_button") }}</button>
        </form>
      {% else %}
        {% if isAuthenticated %}
          <p class="govuk-body">
            {% set reportType = "listing" %}
            {% set reportId = listing.id %}
            {% set returnTo = urlFor("/listings/" + (listing.id | string)) %}
            {% include "partials/report-link.njk" %}
          </p>
        {% endif %}
      {% endif %}

      <section class="govuk-!-margin-top-7 govuk-!-margin-bottom-7" aria-labelledby="listing-exchange-title">
        <h2 class="govuk-heading-l" id="listing-exchange-title">{{ t("listings.exchange_title") }}</h2>

        {% if not isAuthenticated %}
          <div class="govuk-notification-banner" data-module="govuk-notification-banner" role="region" aria-labelledby="listing-auth-required-title">
            <div class="govuk-notification-banner__header">
              <h3 class="govuk-notification-banner__title" id="listing-auth-required-title">{{ t("states.auth_required") }}</h3>
            </div>
            <div class="govuk-notification-banner__content">
              <p class="govuk-body">{{ t("listings.auth_required_detail") }}</p>
              <div class="govuk-button-group">
                <a class="govuk-button" href="{{ urlFor('/login') }}" role="button" draggable="false" data-module="govuk-button">{{ t("nav.login") }}</a>
                <a class="govuk-button govuk-button--secondary" href="{{ urlFor('/register') }}" role="button" draggable="false" data-module="govuk-button">{{ t("nav.register") }}</a>
              </div>
            </div>
          </div>
        {% elif listing.can_edit %}
          <div class="govuk-inset-text">{{ t("listings.own_listing_detail") }}</div>
        {% elif exchangeWorkflowEnabled and exchangeContextReady %}
          {% if activeExchange %}
            <div class="govuk-inset-text">
              <p class="govuk-body">{{ t("listings.active_exchange_detail") }}</p>
              <a class="govuk-button" href="{{ urlFor('/exchanges/' + (activeExchange.id | string)) }}" role="button" draggable="false" data-module="govuk-button">{{ t("actions.view_exchange") }}</a>
            </div>
          {% else %}
            <p class="govuk-body">{{ t("listings.exchange_detail") }}</p>
            <a class="govuk-button" href="{{ urlFor('/listings/' + (listing.id | string) + '/exchange-request') }}" role="button" draggable="false" data-module="govuk-button">{{ t("actions.request_exchange") }}</a>
          {% endif %}
        {% elif not exchangeWorkflowEnabled and exchangeContextReady and directMessagingEnabled and ownerId %}
          <p class="govuk-body">{{ t("listings.direct_message_detail") }}</p>
          <a class="govuk-button" href="{{ urlFor('/messages/' + (ownerId | string) + '?listing=' + (listing.id | string)) }}" role="button" draggable="false" data-module="govuk-button">{{ t("actions.send_message") }}</a>
        {% elif not exchangeContextReady %}
          <div class="govuk-inset-text">Exchange options could not be checked. Try again before sending a request.</div>
        {% else %}
          <div class="govuk-inset-text">{{ t("listings.messaging_unavailable") }}</div>
        {% endif %}
      </section>

    </div>
  </div>
{% endblock %}
