{% extends "layouts/base.njk" %}

{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}

{% block beforeContent %}
  {{ super() }}
  {{ govukBreadcrumbs({
    items: [
      { text: "Home", href: urlFor("/") },
      { text: "Listings", href: urlFor("/listings") },
      { text: listing.title or listing.name or "Listing details" }
    ]
  }) }}
{% endblock %}

{% block mainContent %}
  {% if listing.status == "active" %}
    {% set tagColour = "green" %}
  {% elif listing.status == "draft" %}
    {% set tagColour = "grey" %}
  {% else %}
    {% set tagColour = "red" %}
  {% endif %}
  {% set statusHtml %}<strong class="govuk-tag govuk-tag--{{ tagColour }}">{{ listing.status or "N/A" }}</strong>{% endset %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if successMessage %}
        {% set notificationMessage = successMessage %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      {% if errorMessage %}
        {% set notificationMessage = errorMessage %}
        {% set notificationType = "" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      <h1 class="govuk-heading-xl">{{ listing.title or listing.name or "Listing details" }}</h1>

      {# Rating summary if available #}
      {% if reviewSummary and reviewSummary.average_rating %}
        <p class="govuk-body-l govuk-!-margin-bottom-6">
          <span class="app-star-display" aria-label="{{ reviewSummary.average_rating }} out of 5 stars">
            {% for i in [1, 2, 3, 4, 5] %}
              <svg class="app-star-display__star {% if i <= reviewSummary.average_rating %}app-star-display__star--filled{% endif %}" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            {% endfor %}
          </span>
          <span class="govuk-!-margin-left-2">
            {{ reviewSummary.average_rating | round(1) }} ({{ reviewSummary.total_reviews }} review{% if reviewSummary.total_reviews != 1 %}s{% endif %})
          </span>
        </p>
      {% endif %}

      {{ govukSummaryList({
        rows: [
          {
            key: { text: "ID" },
            value: { text: listing.id }
          },
          {
            key: { text: "Title" },
            value: { text: listing.title or listing.name or "N/A" }
          },
          {
            key: { text: "Type" },
            value: { text: listing.type or listing.listingType or "N/A" }
          },
          {
            key: { text: "Description" },
            value: { text: listing.description or "N/A" }
          },
          {
            key: { text: "Status" },
            value: { html: statusHtml }
          },
          {
            key: { text: "Created" },
            value: { text: (listing.createdAt or listing.created_at) | formatDate if listing.createdAt or listing.created_at else "N/A" }
          },
          {
            key: { text: "Updated" },
            value: { text: (listing.updatedAt or listing.updated_at) | formatDate if listing.updatedAt or listing.updated_at else "N/A" }
          }
        ]
      }) }}

      {% if listing.can_edit %}
        <div class="govuk-button-group">
          {{ govukButton({
            text: "Edit",
            href: urlFor("/listings/" + (listing.id | string) + "/edit"),
            classes: "govuk-button--secondary"
          }) }}
          <form method="post" action="{{ urlFor('/listings/' + (listing.id | string) + '/delete') }}">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <button type="submit" class="govuk-button govuk-button--warning" data-module="govuk-button">Delete</button>
          </form>
        </div>
      {% else %}
        <p class="govuk-body">
          {% set reportType = "listing" %}
          {% set reportId = listing.id %}
          {% set returnTo = urlFor("/listings/" + (listing.id | string)) %}
          {% include "partials/report-link.njk" %}
        </p>
      {% endif %}

      {# Reviews Section #}
      <hr class="govuk-section-break govuk-section-break--xl govuk-section-break--visible">

      <h2 class="govuk-heading-l">Reviews</h2>

      {% if reviews and reviews.length > 0 %}
        <ul class="govuk-list app-reviews-list">
          {% for review in reviews %}
            <li class="app-review govuk-!-margin-bottom-6">
              <div class="app-review__header">
                <span class="app-star-display" aria-label="{{ review.rating }} out of 5 stars">
                  {% for i in [1, 2, 3, 4, 5] %}
                    <svg class="app-star-display__star {% if i <= review.rating %}app-star-display__star--filled{% endif %}" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  {% endfor %}
                </span>
                <strong class="govuk-!-margin-left-2">
                  {% if review.reviewer %}
                    {{ review.reviewer.first_name or review.reviewer.firstName }} {{ review.reviewer.last_name or review.reviewer.lastName }}
                  {% else %}
                    Anonymous
                  {% endif %}
                </strong>
                <span class="govuk-body-s govuk-!-margin-left-2" style="color: #505a5f;">
                  {{ (review.createdAt or review.created_at) | formatDate }}
                </span>
              </div>
              {% if review.comment %}
                <p class="govuk-body govuk-!-margin-top-2 govuk-!-margin-bottom-0">
                  {{ review.comment }}
                </p>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <p class="govuk-body">No reviews yet. Be the first to leave a review!</p>
      {% endif %}

      <p class="govuk-body govuk-!-margin-top-6">
        <a href="{{ urlFor('/listings') }}" class="govuk-link">Back to listings</a>
      </p>

    </div>
  </div>
{% endblock %}
