{% extends "layouts/base.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <span class="govuk-caption-xl">{{ t("features.caption", { community: communityName }) }}</span>
      <h1 class="govuk-heading-xl">{{ t("features.title") }}</h1>
      <p class="govuk-body-l">{{ t("features.intro") }}</p>

      <ul class="govuk-list govuk-list--bullet govuk-list--spaced">
        {% for feature in features %}
          <li>{{ feature }}</li>
        {% endfor %}
      </ul>

      <a class="govuk-button govuk-!-margin-top-4" href="{{ urlFor('/guide') }}" role="button" draggable="false" data-module="govuk-button">{{ t("guide.title") }}</a>
    </div>
  </div>
{% endblock %}
