{% extends "layouts/base.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <span class="govuk-caption-xl">{{ communityName }}</span>
      <h1 class="govuk-heading-xl">{{ t("guide.title") }}</h1>
      <p class="govuk-body-l">{{ t("guide.intro") }}</p>

      <h2 class="govuk-heading-l">{{ t("guide.equal_title") }}</h2>
      <p class="govuk-body">{{ t("guide.equal_body") }}</p>

      <h2 class="govuk-heading-l">{{ t("guide.steps_title") }}</h2>
      <ol class="govuk-list govuk-list--number govuk-list--spaced">
        <li><span class="govuk-!-font-weight-bold">Give your time.</span> Offer a skill or lend a hand to another member - anything from teaching a language to helping in a garden.</li>
        <li><span class="govuk-!-font-weight-bold">Earn time credits.</span> {{ t("guide.step2_body") }}</li>
        <li><span class="govuk-!-font-weight-bold">Spend your credits.</span> {{ t("guide.step3_body") }}</li>
      </ol>

      <h2 class="govuk-heading-l">{{ t("guide.getting_started_title") }}</h2>
      <p class="govuk-body">{{ t("guide.getting_started_body") }}</p>

      <div class="govuk-button-group govuk-!-margin-top-4">
        {% if isAuthenticated %}
          <a class="govuk-button" href="{{ urlFor('/listings') }}" role="button" draggable="false" data-module="govuk-button">{{ t("guide.browse_listings") }}</a>
          <a class="govuk-button govuk-button--secondary" href="{{ urlFor('/wallet') }}" role="button" draggable="false" data-module="govuk-button">{{ t("guide.go_to_wallet") }}</a>
        {% else %}
          <a class="govuk-button" href="{{ urlFor('/register') }}" role="button" draggable="false" data-module="govuk-button">{{ t("guide.create_account") }}</a>
          <a class="govuk-button govuk-button--secondary" href="{{ urlFor('/listings') }}" role="button" draggable="false" data-module="govuk-button">{{ t("guide.browse_listings") }}</a>
        {% endif %}
      </div>
    </div>
  </div>
{% endblock %}
