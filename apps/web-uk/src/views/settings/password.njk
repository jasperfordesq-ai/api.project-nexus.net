{% extends "layouts/base.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}

{% block beforeContent %}
  {{ super() }}
  {{ govukBreadcrumbs({
    items: [
      { text: "Home", href: "/" },
      { text: "Settings", href: "/settings" },
      { text: "Change password" }
    ]
  }) }}
{% endblock %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if errors and errors.length %}
        {{ govukErrorSummary({
          titleText: "There is a problem",
          errorList: errors
        }) }}
      {% endif %}

      <h1 class="govuk-heading-xl">Change password</h1>

      <form method="post" action="/settings/password">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        {{ govukInput({
          id: "current_password",
          name: "current_password",
          type: "password",
          label: { text: "Current password" },
          autocomplete: "current-password",
          errorMessage: { text: fieldErrors.current_password } if fieldErrors.current_password else undefined
        }) }}

        {{ govukInput({
          id: "new_password",
          name: "new_password",
          type: "password",
          label: { text: "New password" },
          hint: { text: "Must be at least 8 characters" },
          autocomplete: "new-password",
          errorMessage: { text: fieldErrors.new_password } if fieldErrors.new_password else undefined
        }) }}

        {{ govukInput({
          id: "confirm_password",
          name: "confirm_password",
          type: "password",
          label: { text: "Confirm new password" },
          autocomplete: "new-password",
          errorMessage: { text: fieldErrors.confirm_password } if fieldErrors.confirm_password else undefined
        }) }}

        <div class="govuk-button-group">
          {{ govukButton({ text: "Change password" }) }}
          <a href="/settings" class="govuk-link">Cancel</a>
        </div>
      </form>

    </div>
  </div>
{% endblock %}
