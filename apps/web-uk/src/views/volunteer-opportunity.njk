{% extends "layouts/base.njk" %}

{% set opportunityTitle = opportunity.title or "Volunteering opportunity" %}

{% block mainContent %}
  <a class="govuk-back-link" href="/volunteering">Back to volunteering</a>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <span class="govuk-caption-xl">Volunteering opportunity</span>
      <h1 class="govuk-heading-xl">{{ opportunityTitle }}</h1>

      {% if opportunity.is_remote %}
        <strong class="govuk-tag govuk-tag--turquoise">Remote</strong>
      {% endif %}

      {% if opportunity.description %}
        <p class="govuk-body govuk-!-margin-top-5">{{ opportunity.description }}</p>
      {% endif %}
    </div>

    <div class="govuk-grid-column-one-third">
      <div class="govuk-inset-text">
        {% if opportunity.organization.logo_url %}
          <img class="nexus-alpha-org-logo govuk-!-margin-bottom-2" src="{{ opportunity.organization.logo_url }}" alt="{{ opportunity.organisationName or "Organisation" }} logo" width="96" height="96" loading="lazy" decoding="async">
        {% endif %}
        {% if opportunity.organisationId %}
          <p class="govuk-body govuk-!-margin-bottom-0">
            <a class="govuk-link" href="/organisations/{{ opportunity.organisationId }}">{{ opportunity.organisationName or "Organisation" }}</a>
          </p>
        {% else %}
          <p class="govuk-body govuk-!-margin-bottom-0">{{ opportunity.organisationName or "Organisation" }}</p>
        {% endif %}
      </div>
    </div>
  </div>

  <h2 class="govuk-heading-l">About this opportunity</h2>
  <dl class="govuk-summary-list">
    {% if opportunity.organisationName %}
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Organisation</dt>
        <dd class="govuk-summary-list__value">{{ opportunity.organisationName }}</dd>
      </div>
    {% endif %}
    {% if opportunity.location %}
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Location</dt>
        <dd class="govuk-summary-list__value">{{ opportunity.location }}</dd>
      </div>
    {% endif %}
    {% if opportunity.categoryName %}
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Category</dt>
        <dd class="govuk-summary-list__value">{{ opportunity.categoryName }}</dd>
      </div>
    {% endif %}
    {% if opportunity.skills_needed %}
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Skills needed</dt>
        <dd class="govuk-summary-list__value">{{ opportunity.skills_needed }}</dd>
      </div>
    {% endif %}
    {% if opportunity.start_date %}
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Start date</dt>
        <dd class="govuk-summary-list__value">{{ opportunity.start_date | date }}</dd>
      </div>
    {% endif %}
    {% if opportunity.end_date %}
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">End date</dt>
        <dd class="govuk-summary-list__value">{{ opportunity.end_date | date }}</dd>
      </div>
    {% endif %}
  </dl>

  <h2 class="govuk-heading-l">Available shifts</h2>
  {% if opportunity.shifts and opportunity.shifts.length %}
    <div class="nexus-alpha-card-list govuk-!-margin-bottom-7">
      {% for shift in opportunity.shifts %}
        <article class="nexus-alpha-card">
          <h3 class="govuk-heading-m govuk-!-margin-bottom-2">
            {% if shift.start_time %}
              {{ shift.start_time | formatEventDate }}
            {% else %}
              Shift
            {% endif %}
          </h3>

          <dl class="nexus-alpha-inline-list">
            {% if shift.end_time %}
              <div>
                <dt>Ends</dt>
                <dd>{{ shift.end_time | formatEventDate }}</dd>
              </div>
            {% endif %}
            {% if shift.capacity %}
              <div>
                <dt>{{ shift.capacity }} places</dt>
                <dd>{{ shift.spots_available or shift.capacity }} places left</dd>
              </div>
            {% endif %}
          </dl>
        </article>
      {% endfor %}
    </div>
  {% else %}
    <div class="govuk-inset-text">No scheduled shifts are listed for this opportunity.</div>
  {% endif %}

  {% if authRequired %}
    <div class="govuk-notification-banner govuk-!-margin-top-7" data-module="govuk-notification-banner" role="region" aria-labelledby="volunteering-detail-auth-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="volunteering-detail-auth-title">Sign in required</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-body">Sign in to apply for opportunities and track your volunteering.</p>
      </div>
    </div>
  {% elseif opportunity.hasApplied %}
    <div class="govuk-inset-text govuk-!-margin-top-7">You have already applied for this opportunity.</div>
  {% endif %}

  <div class="govuk-button-group govuk-!-margin-top-6">
    <a class="govuk-button" data-module="govuk-button" href="/organisations/opportunities/{{ opportunityId }}/apply">Apply for this opportunity</a>
    <a class="govuk-link" href="/volunteering">Back to volunteering</a>
  </div>
{% endblock %}
