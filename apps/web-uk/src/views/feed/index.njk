{% extends "layouts/base.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/pagination/macro.njk" import govukPagination %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if successMessage %}
        {% set notificationMessage = successMessage %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      {% if errorMessage %}
        {% set notificationMessage = errorMessage %}
        {% set notificationType = null %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      <div class="app-page-header">
        <h1 class="govuk-heading-xl govuk-!-margin-bottom-2">Feed</h1>
        <div class="app-page-header__actions">
          {{ govukButton({
            text: "Write a post",
            href: "#content",
            classes: "govuk-!-margin-bottom-0"
          }) }}
        </div>
      </div>

      <form method="post" action="{{ urlFor('/feed/posts') }}" enctype="multipart/form-data" class="govuk-!-margin-bottom-7" novalidate>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <div class="govuk-form-group">
          <label class="govuk-label govuk-label--m" for="content">Share an update</label>
          <div id="content-hint" class="govuk-hint">Post a community update, question, or thought.</div>
          <textarea class="govuk-textarea" id="content" name="content" rows="4" aria-describedby="content-hint"></textarea>
        </div>
        <div class="govuk-form-group">
          <label class="govuk-label" for="image">Image</label>
          <div id="image-hint" class="govuk-hint">Upload an optional JPG, PNG, GIF or WebP image.</div>
          <input class="govuk-file-upload" id="image" name="image" type="file" accept="image/jpeg,image/png,image/gif,image/webp" aria-describedby="image-hint">
        </div>
        <div class="govuk-form-group">
          <label class="govuk-label" for="image_alt">Image description</label>
          <div id="image-alt-hint" class="govuk-hint">Describe the image for people who cannot see it.</div>
          <input class="govuk-input" id="image_alt" name="image_alt" type="text" maxlength="500" aria-describedby="image-alt-hint">
        </div>
        {{ govukButton({
          text: "Post"
        }) }}
      </form>

      {# Group filter #}
      {% if myGroups.length > 0 %}
        {% set groupItems = [{value: "", text: "All posts", selected: not groupId}] %}
        {% for group in myGroups %}
          {% set groupItems = (groupItems.push({
            value: group.id | string,
            text: group.name,
            selected: groupId and (group.id | string) == (groupId | string)
          }), groupItems) %}
        {% endfor %}
        <form action="{{ urlFor('/feed') }}" method="get" class="govuk-!-margin-bottom-6">
          <div class="app-filter-row">
            {{ govukSelect({
              id: "group_id",
              name: "group_id",
              label: {
                text: "Filter by group"
              },
              items: groupItems,
              formGroup: {
                classes: "govuk-!-margin-bottom-0"
              }
            }) }}
            {{ govukButton({
              text: "Filter",
              classes: "govuk-button--secondary govuk-!-margin-bottom-0 govuk-!-margin-left-2"
            }) }}
            {% if groupId %}
              <a href="{{ urlFor('/feed') }}" class="govuk-link govuk-!-margin-left-3">Clear filter</a>
            {% endif %}
          </div>
        </form>
      {% endif %}

      {# Posts list #}
      {% if posts.length > 0 %}
        <div class="app-feed">
          {% for post in posts %}
            <article class="app-post {% if post.isPinned or post.is_pinned %}app-post--pinned{% endif %}">
              {% if post.isPinned or post.is_pinned %}
                <div class="app-post__pinned-badge">
                  {{ govukTag({ text: "Pinned", classes: "govuk-tag--yellow" }) }}
                </div>
              {% endif %}

              <header class="app-post__header">
                <div class="app-post__author">
                  {% set user = post.user %}
                  {% include "partials/avatar.njk" %}
                  <div class="app-post__author-info">
                    <a href="{{ urlFor('/members/' + (post.user.id | string)) }}" class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold">
                      {{ post.user.first_name or post.user.firstName }} {{ post.user.last_name or post.user.lastName }}
                    </a>
                    <span class="govuk-body-s govuk-!-margin-bottom-0 app-post__meta">
                      {{ (post.createdAt or post.created_at) | formatDate }}
                      {% if post.group %}
                        in <a href="{{ urlFor('/groups/' + (post.group.id | string)) }}" class="govuk-link">{{ post.group.name }}</a>
                      {% endif %}
                    </span>
                  </div>
                </div>
              </header>

              <div class="app-post__content">
                <p class="govuk-body">{{ post.content | truncate(500) }}</p>
                {% if post.imageUrl or post.image_url %}
                  <img src="{{ post.imageUrl or post.image_url }}" alt="Image attached to post by {{ post.user.first_name or post.user.firstName }}" class="app-post__image">
                {% endif %}
              </div>

              <footer class="app-post__footer">
                <div class="app-post__actions">
                  {# Like button #}
                  {% if post.isLiked or post.is_liked %}
                    <form action="{{ urlFor('/feed/items/post/' + (post.id | string) + '/like') }}" method="post" class="app-post__action-form">
                      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                      <button type="submit" class="app-link-button app-post__action-button app-post__action-button--active">
                        <span aria-hidden="true">&#9829;</span> {{ post.likeCount or post.like_count }} Like{{ 's' if post.likeCount or post.like_count != 1 else '' }}
                      </button>
                    </form>
                  {% else %}
                    <form action="{{ urlFor('/feed/items/post/' + (post.id | string) + '/like') }}" method="post" class="app-post__action-form">
                      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                      <button type="submit" class="app-link-button app-post__action-button">
                        <span aria-hidden="true">&#9825;</span> {{ post.likeCount or post.like_count }} Like{{ 's' if post.likeCount or post.like_count != 1 else '' }}
                      </button>
                    </form>
                  {% endif %}

                  {# Comment link #}
                  <a href="{{ urlFor('/feed/posts/' + (post.id | string)) }}" class="govuk-link app-post__action-button">
                    <span aria-hidden="true">&#128172;</span> {{ post.commentCount or post.comment_count }} Comment{{ 's' if post.commentCount or post.comment_count != 1 else '' }}
                  </a>
                </div>

                <a href="{{ urlFor('/feed/posts/' + (post.id | string)) }}" class="govuk-link">View post</a>
              </footer>
            </article>
          {% endfor %}
        </div>

        {# Pagination #}
        {% set feedTotalPages = pagination.totalPages or pagination.total_pages %}
        {% if feedTotalPages > 1 %}
          {% set paginationItems = [] %}
          {% for i in range(1, feedTotalPages + 1) %}
            {% set paginationItems = (paginationItems.push({
              number: i,
              href: urlFor("/feed?page=" + i + ("&group_id=" + groupId if groupId else "")),
              current: i == pagination.page
            }), paginationItems) %}
          {% endfor %}

          {{ govukPagination({
            previous: {
              href: urlFor("/feed?page=" + (pagination.page - 1) + ("&group_id=" + groupId if groupId else ""))
            } if pagination.page > 1 else undefined,
            next: {
              href: urlFor("/feed?page=" + (pagination.page + 1) + ("&group_id=" + groupId if groupId else ""))
            } if pagination.page < feedTotalPages else undefined,
            items: paginationItems
          }) }}
        {% endif %}
      {% else %}
        <div class="app-empty-state">
          <p class="govuk-heading-m app-empty-state__heading">No posts yet</p>
          <p class="govuk-body app-empty-state__message">
            {% if groupId %}
              This group doesn't have any posts yet. Be the first to share something!
            {% else %}
              The feed is empty. Create a post to get the conversation started.
            {% endif %}
          </p>
          {{ govukButton({
            text: "Write a post",
            href: "#content"
          }) }}
        </div>
      {% endif %}

    </div>

    <div class="govuk-grid-column-one-third">
      {# Sidebar - My Groups #}
      {% if myGroups.length > 0 %}
        <div class="app-sidebar-card">
          <h2 class="govuk-heading-m">My groups</h2>
          <ul class="govuk-list">
            {% for group in myGroups | take(5) %}
              <li>
                <a href="{{ urlFor('/feed?group_id=' + (group.id | string)) }}" class="govuk-link">{{ group.name }}</a>
              </li>
            {% endfor %}
          </ul>
          {% if myGroups.length > 5 %}
            <p class="govuk-body-s">
              <a href="{{ urlFor('/groups') }}" class="govuk-link">View all {{ myGroups.length }} groups</a>
            </p>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
{% endblock %}
