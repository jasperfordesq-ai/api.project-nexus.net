{% extends "layouts/base.njk" %}

{% set typeLabels = {
  all: "All",
  following: "Following",
  saved: "Saved",
  posts: "Posts",
  listings: "Listings",
  events: "Events",
  goals: "Goals",
  polls: "Polls",
  jobs: "Jobs",
  challenges: "Challenges",
  volunteering: "Volunteering",
  blogs: "Blogs",
  discussions: "Discussions"
} %}

{% block mainContent %}
  {% if successMessage %}
    {% set notificationMessage = successMessage %}
    {% set notificationType = "success" %}
    {% include "partials/notification-banner.njk" %}
  {% endif %}

  {% if errorMessage %}
    {% set notificationMessage = errorMessage %}
    {% set notificationType = null %}
    {% include "partials/notification-banner.njk" %}
  {% endif %}

  <span class="govuk-caption-l">{{ communityName }}</span>
  <h1 class="govuk-heading-xl">Feed</h1>
  <p class="govuk-body-l">Community updates, conversations and activity.</p>

  <p class="govuk-body govuk-!-margin-bottom-6">
    <a class="govuk-link" href="/feed/hashtags">Hashtags</a>
  </p>

  <div class="govuk-inset-text">
    <p class="govuk-body">Use listings for offers and requests. Use posts for short community updates.</p>
    <a class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" href="/listings/new" role="button" draggable="false" data-module="govuk-button">Post an offer or request</a>
  </div>

  <form method="post" action="/feed/new" enctype="multipart/form-data" class="govuk-!-margin-bottom-7">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--m" for="content">Write a post</label>
      <div id="content-hint" class="govuk-hint">Share a short update with your community.</div>
      <textarea class="govuk-textarea" id="content" name="content" rows="4" aria-describedby="content-hint"></textarea>
    </div>
    <div class="govuk-form-group">
      <label class="govuk-label" for="image_url">Add a photo URL (optional)</label>
      <div id="image-hint" class="govuk-hint">Paste a safe image URL if you want to include a photo.</div>
      <input class="govuk-input" id="image_url" name="image_url" type="url" aria-describedby="image-hint">
    </div>
    <button class="govuk-button" data-module="govuk-button">Post</button>
  </form>

  <form method="get" action="/feed" class="govuk-!-margin-bottom-6">
    <fieldset class="govuk-fieldset" aria-describedby="feed-filter-hint">
      <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
        <h2 class="govuk-fieldset__heading">Filter the feed</h2>
      </legend>
      <div id="feed-filter-hint" class="govuk-hint">Choose the kind of community activity you want to read.</div>
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-one-third">
          <div class="govuk-form-group">
            <label class="govuk-label" for="type">Feed type</label>
            <select class="govuk-select" id="type" name="type">
              {% for type in typeOptions %}
                <option value="{{ type }}"{% if selectedType == type %} selected{% endif %}>{{ typeLabels[type] or type }}</option>
              {% endfor %}
            </select>
          </div>
        </div>
        <div class="govuk-grid-column-one-third">
          <div class="govuk-form-group">
            <label class="govuk-label" for="mode">Feed order</label>
            <select class="govuk-select" id="mode" name="mode">
              <option value="ranking"{% if selectedMode == "ranking" %} selected{% endif %}>Recommended</option>
              <option value="recent"{% if selectedMode == "recent" %} selected{% endif %}>Most recent</option>
            </select>
          </div>
        </div>
        <div class="govuk-grid-column-one-third">
          <div class="govuk-form-group">
            <label class="govuk-label" for="subtype">Listing subtype</label>
            <div id="subtype-hint" class="govuk-hint">Only applies when the feed type is Listings.</div>
            <select class="govuk-select" id="subtype" name="subtype" aria-describedby="subtype-hint">
              <option value=""{% if not selectedSubtype %} selected{% endif %}>All listings</option>
              <option value="offer"{% if selectedSubtype == "offer" %} selected{% endif %}>Offers</option>
              <option value="request"{% if selectedSubtype == "request" %} selected{% endif %}>Requests</option>
            </select>
          </div>
        </div>
      </div>
      <input type="hidden" name="per_page" value="{{ perPage }}">
      <button class="govuk-button govuk-button--secondary" data-module="govuk-button">Apply filters</button>
    </fieldset>
  </form>

  {% if error %}
    <div class="govuk-notification-banner" role="region" aria-labelledby="feed-load-error-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="feed-load-error-title">There is a problem</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ error }}</p>
      </div>
    </div>
  {% elif not items or items.length == 0 %}
    <h2 class="govuk-heading-l">Results</h2>
    <p class="govuk-body nexus-alpha-result-count" aria-live="polite">No feed items shown</p>
    <div class="govuk-inset-text">
      <h3 class="govuk-heading-m">Nothing to show yet</h3>
      <p class="govuk-body">There are no feed items to show yet.</p>
    </div>
  {% else %}
    <h2 class="govuk-heading-l">Results</h2>
    <p class="govuk-body nexus-alpha-result-count" aria-live="polite">{{ items.length }} feed item{% if items.length != 1 %}s{% endif %} shown</p>
    <div class="nexus-alpha-card-list">
      {% for item in items %}
        <article class="nexus-alpha-card" id="feed-item-{{ item.type }}-{{ item.id }}">
          <div class="nexus-alpha-feed-row">
            <div>
              <strong class="govuk-tag {{ item.typeClass }}">{{ item.typeLabel }}</strong>
              <h3 class="govuk-heading-m govuk-!-margin-top-2 govuk-!-margin-bottom-2">
                {% if item.detailUrl %}
                  <a class="govuk-link" href="{{ item.detailUrl }}">{{ item.title }}</a>
                {% else %}
                  {{ item.title }}
                {% endif %}
              </h3>
              <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-2">
                {% if item.authorAvatar %}
                  <img class="nexus-alpha-avatar nexus-alpha-avatar--small" src="{{ item.authorAvatar }}" alt="" loading="lazy" decoding="async" width="32" height="32">
                {% endif %}
                Posted by {{ item.authorName }}
                {% if item.createdAt %}
                  <span aria-hidden="true"> | </span>
                  <span class="govuk-visually-hidden">Posted on</span>
                  <time datetime="{{ item.createdAt }}">{{ item.createdAt | formatDate }}</time>
                {% endif %}
              </p>
            </div>
            {% if item.detailUrl %}
              <p class="govuk-body-s govuk-!-margin-bottom-0">
                <a class="govuk-link" href="{{ item.detailUrl }}">View details</a>
              </p>
            {% endif %}
          </div>
          {% if item.content %}
            <p class="govuk-body">{{ item.content }}</p>
          {% endif %}
          {% if item.imageUrl %}
            <img class="nexus-alpha-card-thumb" src="{{ item.imageUrl }}" alt="Image for {{ item.title }}" width="120" height="90" loading="lazy" decoding="async">
          {% endif %}
          <p class="govuk-body-s nexus-alpha-meta">
            {{ item.likesCount }} like{% if item.likesCount != 1 %}s{% endif %}
            <span aria-hidden="true"> - </span>
            {{ item.commentsCount }} comment{% if item.commentsCount != 1 %}s{% endif %}
          </p>
        </article>
      {% endfor %}
    </div>
    {% if meta.hasMore and meta.cursor %}
      <nav class="govuk-pagination govuk-pagination--block govuk-!-margin-top-6" aria-label="Feed pages">
        <div class="govuk-pagination__next">
          <a class="govuk-link govuk-pagination__link" href="/feed?type={{ selectedType }}&amp;mode={{ selectedMode }}{% if selectedSubtype %}&amp;subtype={{ selectedSubtype }}{% endif %}&amp;cursor={{ meta.cursor }}&amp;per_page={{ perPage }}" rel="next">
            <span class="govuk-pagination__link-title">Load more</span>
            <span class="govuk-visually-hidden">:</span>
            <span class="govuk-pagination__link-label">More feed items</span>
          </a>
        </div>
      </nav>
    {% endif %}
  {% endif %}
{% endblock %}
