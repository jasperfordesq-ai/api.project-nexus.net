{% extends "layouts/base.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "feed/_comments.njk" import commentList %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">

      {% if successMessage %}
        {% set notificationMessage = successMessage %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      {% if errorMessage %}
        {% set notificationMessage = errorMessage %}
        {% set notificationType = null %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      <span class="govuk-caption-l">{{ t("feed.caption", { community: communityName }) }}</span>
      <h1 class="govuk-heading-xl">{{ t("feed.title") }}</h1>
      <p class="govuk-body-l">{{ t("feed.description") }}</p>
      <p class="govuk-body govuk-!-margin-bottom-6">
        <a class="govuk-link" href="{{ urlFor('/feed/hashtags') }}">{{ t("govuk_alpha_feed.nav.hashtags") }}</a>
      </p>

      {% if requiresAuth %}
        <div class="govuk-notification-banner" data-module="govuk-notification-banner" role="region" aria-labelledby="feed-auth-required-title">
          <div class="govuk-notification-banner__header">
            <h2 class="govuk-notification-banner__title" id="feed-auth-required-title">{{ t("states.error_title") }}</h2>
          </div>
          <div class="govuk-notification-banner__content">
            <p class="govuk-notification-banner__heading">{{ t("states.auth_required") }}</p>
            <p class="govuk-body">{{ t("feed.auth_required_detail", { community: communityName }) }}</p>
            <div class="govuk-button-group">
              {{ govukButton({ text: t("nav.login"), href: urlFor('/login') }) }}
              {{ govukButton({ text: t("nav.register"), href: urlFor('/register'), classes: "govuk-button--secondary" }) }}
            </div>
          </div>
        </div>
      {% endif %}

      {% if statusMessage %}
        {% if postErrorMessage %}
          <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
            <div role="alert">
              <h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2>
              <div class="govuk-error-summary__body">
                <ul class="govuk-list govuk-error-summary__list">
                  <li><a href="#content">{{ t("polish_discovery.feed_error_link_text") }}</a> — {{ postErrorMessage }}</li>
                </ul>
              </div>
            </div>
          </div>
        {% elif statusMessage.type == "success" %}
          {% set notificationMessage = statusMessage.text %}
          {% set notificationType = "success" %}
          {% include "partials/notification-banner.njk" %}
        {% else %}
          <div class="govuk-notification-banner" data-module="govuk-notification-banner" role="region" aria-labelledby="feed-action-error-title">
            <div class="govuk-notification-banner__header">
              <h2 class="govuk-notification-banner__title" id="feed-action-error-title">{{ t("states.error_title") }}</h2>
            </div>
            <div class="govuk-notification-banner__content">
              <p class="govuk-notification-banner__heading">{{ statusMessage.text }}</p>
            </div>
          </div>
        {% endif %}
      {% endif %}

      {% if not requiresAuth %}
      {% if listingsEnabled %}
      <div class="govuk-inset-text">
        <p class="govuk-body">{{ t("feed.compose_listing_notice") }}</p>
        <a class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" role="button" draggable="false" data-module="govuk-button" href="{{ urlFor('/listings/new') }}">{{ t("feed.post_offer_request") }}</a>
      </div>
      {% endif %}
      <form method="post" action="{{ urlFor('/feed/posts') }}" enctype="multipart/form-data" class="govuk-!-margin-bottom-7" novalidate>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <div class="govuk-form-group{% if postErrorMessage %} govuk-form-group--error{% endif %}">
          <label class="govuk-label govuk-label--m" for="content">{{ t("feed.post_label") }}</label>
          <div id="content-hint" class="govuk-hint">{{ t("feed.post_hint") }}</div>
          {% if postErrorMessage %}
            <p id="content-error" class="govuk-error-message"><span class="govuk-visually-hidden">{{ t("states.error_prefix") }}</span> {{ postErrorMessage }}</p>
          {% endif %}
          <textarea class="govuk-textarea{% if postErrorMessage %} govuk-textarea--error{% endif %}" id="content" name="content" rows="4" aria-describedby="content-hint{% if postErrorMessage %} content-error{% endif %}"></textarea>
        </div>
        <div class="govuk-form-group">
          <label class="govuk-label" for="image">{{ t("feed.image_label") }}</label>
          <div id="image-hint" class="govuk-hint">{{ t("feed.image_hint") }}</div>
          <input class="govuk-file-upload" id="image" name="image" type="file" accept="image/jpeg,image/png,image/gif,image/webp" aria-describedby="image-hint">
        </div>
        <div class="govuk-form-group">
          <label class="govuk-label" for="image_alt">{{ t("feed.image_alt_label") }}</label>
          <div id="image-alt-hint" class="govuk-hint">{{ t("feed.image_alt_hint") }}</div>
          <input class="govuk-input" id="image_alt" name="image_alt" type="text" maxlength="500" aria-describedby="image-alt-hint">
        </div>
        {{ govukButton({ text: t("actions.post") }) }}
      </form>
      {% endif %}

      {% set typeItems = [] %}
      {% for option in typeOptions %}
        {% set typeItems = (typeItems.push({
          value: option,
          text: t("feed.types." + option),
          selected: selectedType == option
        }), typeItems) %}
      {% endfor %}
      {% set modeItems = [] %}
      {% for option in ["ranking", "recent"] %}
        {% set modeItems = (modeItems.push({
          value: option,
          text: t("feed.modes." + option),
          selected: selectedMode == option
        }), modeItems) %}
      {% endfor %}
      {% set subtypeItems = [{ value: "", text: t("feed.subtypes.all"), selected: not selectedSubtype }] %}
      {% for option in ["offer", "request"] %}
        {% set subtypeItems = (subtypeItems.push({
          value: option,
          text: t("feed.subtypes." + option),
          selected: selectedSubtype == option
        }), subtypeItems) %}
      {% endfor %}

      <form method="get" action="{{ urlFor('/feed') }}" class="govuk-!-margin-bottom-6">
        <fieldset class="govuk-fieldset" aria-describedby="feed-filter-hint">
          <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
            <h2 class="govuk-fieldset__heading">{{ t("feed.filters_title") }}</h2>
          </legend>
          <div id="feed-filter-hint" class="govuk-hint">{{ t("feed.filters_hint") }}</div>
          <div class="govuk-grid-row">
            <div class="govuk-grid-column-one-third">
              {{ govukSelect({ id: "type", name: "type", label: { text: t("feed.filter_label") }, items: typeItems }) }}
            </div>
            <div class="govuk-grid-column-one-third">
              {{ govukSelect({ id: "mode", name: "mode", label: { text: t("feed.mode_label") }, items: modeItems }) }}
            </div>
            <div class="govuk-grid-column-one-third">
              {{ govukSelect({
                id: "subtype",
                name: "subtype",
                label: { text: t("feed.subtype_label") },
                hint: { text: t("feed.subtype_hint") },
                items: subtypeItems
              }) }}
            </div>
          </div>
          {{ govukButton({ text: t("actions.apply_filters"), classes: "govuk-button--secondary" }) }}
        </fieldset>
      </form>

      {% if feedLoadError %}
        <div class="govuk-notification-banner" data-module="govuk-notification-banner" role="region" aria-labelledby="feed-load-error-title">
          <div class="govuk-notification-banner__header">
            <h2 class="govuk-notification-banner__title" id="feed-load-error-title">{{ t("states.error_title") }}</h2>
          </div>
          <div class="govuk-notification-banner__content">
            <p class="govuk-notification-banner__heading">{{ feedLoadError }}</p>
          </div>
        </div>
      {% else %}
        <h2 class="govuk-heading-l">{{ t("feed.results_title") }}</h2>
        <p class="govuk-body nexus-alpha-result-count" aria-live="polite">
          {{ tc("feed.result_count", posts.length, { count: posts.length }) }}
        </p>

        {# Posts list #}
        {% if posts.length > 0 %}
        <div class="nexus-alpha-card-list">
          {% for post in posts %}
            <article id="feed-item-{{ post.type }}-{{ post.id }}" class="nexus-alpha-card">
              <div class="nexus-alpha-feed-row">
                <div>
              <strong class="govuk-tag {% if post.type == 'listing' %}govuk-tag--blue{% elif post.type == 'event' %}govuk-tag--green{% elif post.type == 'goal' %}govuk-tag--purple{% elif post.type == 'poll' %}govuk-tag--yellow{% else %}govuk-tag--grey{% endif %}">
                {{ t("feed.item_types." + post.type) if post.type in ["post", "listing", "event", "goal", "poll", "review", "job", "challenge", "volunteer", "blog", "discussion", "badge_earned", "level_up", "transaction", "connection", "group", "achievement", "resource"] else t("feed.item_types.activity") }}
              </strong>
              <h3 class="govuk-heading-m govuk-!-margin-top-2 govuk-!-margin-bottom-2">
                {% if post.deepLink and post.type != "post" %}<a class="govuk-link" href="{{ urlFor(post.deepLink.href) }}">{{ post.title or post.typeLabel }}</a>{% else %}{{ post.title or post.typeLabel }}{% endif %}
              </h3>

              <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-2">
                {% if post.authorAvatar %}<img class="nexus-alpha-avatar nexus-alpha-avatar--small" src="{{ post.authorAvatar }}" alt="" loading="lazy" decoding="async" width="32" height="32">{% endif %}
                {{ t("feed.posted_by", { name: post.authorName }) }}
                {% if post.createdAt %}
                  <span aria-hidden="true"> | </span>
                  <span class="govuk-visually-hidden">{{ t("feed.posted_on_prefix") }}</span>
                  <time datetime="{{ post.createdAt }}">{{ post.createdAt | formatDate }}</time>
                {% endif %}
                      {% if post.group %}
                        <span aria-hidden="true"> · </span><a href="{{ urlFor('/groups/' + (post.group.id | string)) }}" class="govuk-link">{{ post.group.name }}</a>
                      {% endif %}
              </p>
                </div>
                {% if post.deepLink and post.type != "post" %}
                  <div class="nexus-alpha-feed-row__action">
                    <a class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" role="button" draggable="false" data-module="govuk-button" href="{{ urlFor(post.deepLink.href) }}">
                      {{ t(post.deepLink.labelKey) }}<span class="govuk-visually-hidden">{{ t("feed.detail_for", { title: post.title or post.typeLabel }) }}</span>
                    </a>
                  </div>
                {% endif %}
              </div>

              <div>
                {% for paragraph in post.contentParagraphs %}
                  <p class="govuk-body">{{ paragraph }}</p>
                {% endfor %}
                {% if post.media.length > 0 %}
                  <ul class="nexus-alpha-feed-media" data-count="{{ post.media.length }}">
                    {% for media in post.media %}
                      <li>
                        <a href="{{ media.fileUrl }}" target="_blank" rel="noopener noreferrer">
                          <span class="govuk-visually-hidden"> {{ t("opens_new_tab") }}</span>
                          <img src="{{ media.thumbnailUrl }}" alt="{{ media.altText or t('feed.image_alt', { title: post.title or post.typeLabel }) }}" class="nexus-alpha-feed-image" loading="lazy" decoding="async">
                          {% if loop.last and post.mediaExtra > 0 %}
                            <span class="nexus-alpha-feed-media__more" aria-hidden="true">+{{ post.mediaExtra }}</span>
                            <span class="govuk-visually-hidden">{{ t("feed.media_more", { count: post.mediaExtra }) }}</span>
                          {% endif %}
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </div>

              {% if post.type == "poll" and post.poll and post.poll.options.length > 0 %}
                {% if post.poll.canVote %}
                  <form method="post" action="{{ urlFor('/feed/polls/' + (post.id | string) + '/vote') }}" class="govuk-!-margin-bottom-3">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                    <input type="hidden" name="type" value="{{ selectedType }}">
                    <input type="hidden" name="mode" value="{{ selectedMode }}">
                    <input type="hidden" name="per_page" value="{{ perPage }}">
                    {% if selectedSubtype %}<input type="hidden" name="subtype" value="{{ selectedSubtype }}">{% endif %}
                    {% if cursor %}<input type="hidden" name="cursor" value="{{ cursor }}">{% endif %}
                    <fieldset class="govuk-fieldset">
                      <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">{{ t("feed.poll_vote_legend") }}</legend>
                      <div class="govuk-radios govuk-radios--small" data-module="govuk-radios">
                        {% for option in post.poll.options %}
                          <div class="govuk-radios__item">
                            <input class="govuk-radios__input" id="poll-{{ post.id }}-opt-{{ option.id }}" name="option_id" type="radio" value="{{ option.id }}" required>
                            <label class="govuk-label govuk-radios__label" for="poll-{{ post.id }}-opt-{{ option.id }}">{{ option.label }}</label>
                          </div>
                        {% endfor %}
                      </div>
                    </fieldset>
                    <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("feed.poll_vote_submit") }}</button>
                  </form>
                {% else %}
                  <ul class="govuk-list govuk-!-margin-bottom-2">
                    {% for option in post.poll.options %}
                      <li>
                        <span class="govuk-!-font-weight-bold">{{ option.label }}</span>
                        {% if option.isUserChoice %}<strong class="govuk-tag govuk-tag--blue">{{ t("feed.poll_your_choice") }}</strong>{% endif %}
                        <span class="govuk-body-s nexus-alpha-meta">{{ tc("feed.poll_votes", option.voteCount, { count: option.voteCount }) }}{% if option.percentage != null %} ({{ option.percentage }}%){% endif %}</span>
                        {% if option.percentage != null %}<progress class="nexus-alpha-poll-bar" max="100" value="{{ option.percentage }}" aria-label="{{ t('feed.poll_result_share', { option: option.label, percent: option.percentage }) }}">{{ option.percentage }}%</progress>{% endif %}
                      </li>
                    {% endfor %}
                  </ul>
                  <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-2">{% if post.poll.userVoteOptionId %}{{ t("feed.poll_you_voted") }}{% elif not post.poll.isActive %}{{ t("feed.poll_closed") }}{% endif %}</p>
                {% endif %}
              {% endif %}

              <p class="govuk-body-s nexus-alpha-meta">
                {{ tc("feed.likes", post.likeCount, { count: post.likeCount }) }}
                <span aria-hidden="true"> &middot; </span>
                {{ tc("feed.comments", post.commentCount, { count: post.commentCount }) }}
              </p>
              <div class="govuk-button-group govuk-!-margin-bottom-3">
                <form action="{{ urlFor('/feed/items/' + post.type + '/' + (post.id | string) + '/like') }}" method="post">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <input type="hidden" name="type" value="{{ selectedType }}">
                  <input type="hidden" name="mode" value="{{ selectedMode }}">
                  <input type="hidden" name="per_page" value="{{ perPage }}">
                  {% if selectedSubtype %}<input type="hidden" name="subtype" value="{{ selectedSubtype }}">{% endif %}
                  {% if cursor %}<input type="hidden" name="cursor" value="{{ cursor }}">{% endif %}
                  <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">
                    {{ t("actions.unlike") if post.isLiked else t("actions.like") }}
                    <span class="govuk-visually-hidden">{{ t("feed.action_for", { title: post.title or post.typeLabel }) }}</span>
                  </button>
                </form>
              </div>

              {% if post.type == "post" %}
                <div class="nexus-alpha-reactions govuk-!-margin-bottom-3">
                  <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1" aria-live="polite">{{ tc("feed_t1.reaction_count", post.reactionTotal, { count: post.reactionTotal }) }}</p>
                  <fieldset class="govuk-fieldset">
                    <legend class="govuk-fieldset__legend govuk-fieldset__legend--s govuk-visually-hidden">{{ t("feed_t1.reactions_legend") }}</legend>
                    <div class="nexus-alpha-actions govuk-button-group govuk-!-margin-bottom-0">
                      {% for reaction in [{ type: "like", symbol: "&#128077;" }, { type: "love", symbol: "&#10084;" }, { type: "celebrate", symbol: "&#127881;" }] %}
                        <form method="post" action="{{ urlFor('/feed/posts/' + (post.id | string) + '/react') }}" class="nexus-alpha-reaction-form">
                          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                          <input type="hidden" name="type" value="{{ selectedType }}">
                          <input type="hidden" name="mode" value="{{ selectedMode }}">
                          <input type="hidden" name="per_page" value="{{ perPage }}">
                          {% if selectedSubtype %}<input type="hidden" name="subtype" value="{{ selectedSubtype }}">{% endif %}
                          {% if cursor %}<input type="hidden" name="cursor" value="{{ cursor }}">{% endif %}
                          <input type="hidden" name="emoji" value="{{ reaction.type }}">
                          <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0{% if post.userReaction == reaction.type %} nexus-alpha-reaction--active{% endif %}" data-module="govuk-button" aria-pressed="{{ 'true' if post.userReaction == reaction.type else 'false' }}">
                            <span aria-hidden="true">{{ reaction.symbol | safe }}</span>
                            {{ t("feed_t1.reaction_" + reaction.type) }}{% if post.reactionCounts[reaction.type] %} ({{ post.reactionCounts[reaction.type] }}){% endif %}
                            <span class="govuk-visually-hidden"> {{ t("feed_t1.reaction_for", { name: post.authorName }) }}</span>
                          </button>
                        </form>
                      {% endfor %}
                    </div>
                  </fieldset>
                </div>

                <div class="nexus-alpha-actions govuk-button-group govuk-!-margin-bottom-3">
                  {% if not post.isOwn %}
                    <form method="post" action="{{ urlFor('/feed/posts/' + (post.id | string) + '/share') }}">
                      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                      <input type="hidden" name="type" value="{{ selectedType }}"><input type="hidden" name="mode" value="{{ selectedMode }}"><input type="hidden" name="per_page" value="{{ perPage }}">{% if selectedSubtype %}<input type="hidden" name="subtype" value="{{ selectedSubtype }}">{% endif %}{% if cursor %}<input type="hidden" name="cursor" value="{{ cursor }}">{% endif %}
                      <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button" aria-pressed="{{ 'true' if post.isShared else 'false' }}">{{ t("feed_t1.unshare_button") if post.isShared else t("feed_t1.share_button") }}<span class="govuk-visually-hidden"> {{ post.title or post.typeLabel }}</span></button>
                    </form>
                  {% endif %}
                  <form method="post" action="{{ urlFor('/feed/posts/' + (post.id | string) + '/save') }}">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                    <input type="hidden" name="type" value="{{ selectedType }}"><input type="hidden" name="mode" value="{{ selectedMode }}"><input type="hidden" name="per_page" value="{{ perPage }}">{% if selectedSubtype %}<input type="hidden" name="subtype" value="{{ selectedSubtype }}">{% endif %}{% if cursor %}<input type="hidden" name="cursor" value="{{ cursor }}">{% endif %}
                    <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button" aria-pressed="{{ 'true' if post.isBookmarked else 'false' }}">{{ t("feed_t1.unsave_button") if post.isBookmarked else t("feed_t1.save_button") }}<span class="govuk-visually-hidden"> {{ post.title or post.typeLabel }}</span></button>
                  </form>
                </div>
                {% if post.shareCount > 0 %}<p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-3">{{ tc("feed_t1.shares_count", post.shareCount, { count: post.shareCount }) }}</p>{% endif %}

                <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-3">
                  <a class="govuk-link govuk-link--no-visited-state" href="{{ urlFor('/feed/posts/' + (post.id | string)) }}">
                    {{ t("feed_t1.view_post") }}
                    <span class="govuk-visually-hidden">{{ t("feed_t1.view_post_for", { name: post.authorName }) }}</span>
                  </a>
                </p>

                {% if post.isOwn %}
                  <details class="govuk-details" data-module="govuk-details">
                    <summary class="govuk-details__summary"><span class="govuk-details__summary-text">{{ t("feed.edit_post") }}</span></summary>
                    <div class="govuk-details__text">
                      <form method="post" action="{{ urlFor('/feed/posts/' + (post.id | string) + '/update') }}">
                        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                        <div class="govuk-form-group">
                          <label class="govuk-label" for="edit-post-{{ post.id }}">{{ t("feed.edit_post_label") }}</label>
                          <div id="edit-post-{{ post.id }}-hint" class="govuk-hint">{{ t("feed.edit_post_hint") }}</div>
                          <textarea class="govuk-textarea" id="edit-post-{{ post.id }}" name="content" rows="4" aria-describedby="edit-post-{{ post.id }}-hint" required>{{ post.content }}</textarea>
                        </div>
                        <button class="govuk-button govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("actions.save_changes") }}</button>
                      </form>
                    </div>
                  </details>
                  <details class="govuk-details" data-module="govuk-details">
                    <summary class="govuk-details__summary"><span class="govuk-details__summary-text">{{ t("feed.delete_post") }}</span></summary>
                    <div class="govuk-details__text">
                      <div class="govuk-warning-text">
                        <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
                        <strong class="govuk-warning-text__text">
                          <span class="govuk-visually-hidden">{{ t("states.warning_prefix") }}</span>
                          {{ t("polish_discovery.delete_post_warning") }}
                        </strong>
                      </div>
                      <form method="post" action="{{ urlFor('/feed/posts/' + (post.id | string) + '/delete') }}">
                        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                        <button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("feed.delete_post_button") }}</button>
                      </form>
                    </div>
                  </details>
                {% endif %}
              {% endif %}

              {% if currentUserId and not post.isOwn and post.authorId != currentUserId %}
                <div class="govuk-!-margin-bottom-3">
                  <details class="govuk-details govuk-!-margin-bottom-0" data-module="govuk-details">
                    <summary class="govuk-details__summary"><span class="govuk-details__summary-text">{{ t("feed.moderation_summary") }}</span></summary>
                    <div class="govuk-details__text">
                      <form method="post" action="{{ urlFor('/feed/posts/' + (post.id | string) + '/hide') }}" class="govuk-!-margin-bottom-4">
                        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                        <input type="hidden" name="type" value="{{ post.type }}">
                        <p class="govuk-body govuk-!-margin-bottom-2">{{ t("feed.hide_hint") }}</p>
                        <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("feed.hide_button") }}</button>
                      </form>
                      {% if post.authorId %}
                        <form method="post" action="{{ urlFor('/feed/users/' + (post.authorId | string) + '/mute') }}" class="govuk-!-margin-bottom-4">
                          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                          <p class="govuk-body govuk-!-margin-bottom-2">{{ t("feed.mute_hint", { name: post.authorName }) }}</p>
                          <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("feed.mute_button") }}<span class="govuk-visually-hidden"> {{ post.authorName }}</span></button>
                        </form>
                      {% endif %}
                      <form method="post" action="{{ urlFor('/feed/posts/' + (post.id | string) + '/report') }}">
                        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                        <input type="hidden" name="type" value="{{ post.type }}">
                        <div class="govuk-form-group govuk-!-margin-bottom-2">
                          <label class="govuk-label" for="report-reason-{{ post.type }}-{{ post.id }}">{{ t("feed.report_reason_label") }}</label>
                          <div class="govuk-hint" id="report-hint-{{ post.type }}-{{ post.id }}">{{ t("feed.report_hint") }}</div>
                          <input class="govuk-input" id="report-reason-{{ post.type }}-{{ post.id }}" name="reason" type="text" maxlength="500" aria-describedby="report-hint-{{ post.type }}-{{ post.id }}" required>
                        </div>
                        <button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("feed.report_button") }}</button>
                      </form>
                    </div>
                  </details>
                </div>
              {% endif %}

              {% if post.isCommentable %}
                <details class="govuk-details govuk-!-margin-bottom-0" data-module="govuk-details"{% if status == "comment-created" %} open{% endif %}>
                  <summary class="govuk-details__summary"><span class="govuk-details__summary-text">{{ t("feed.comments_summary") }}</span></summary>
                  <div class="govuk-details__text">
                    {% if post.comments.length > 0 %}
                      {{ commentList(post.comments, 0, post, requiresAuth, currentUserId, csrfToken, urlFor, t) }}
                    {% else %}
                      <p class="govuk-body">{{ t("feed.no_comments") }}</p>
                    {% endif %}
                    <form method="post" action="{{ urlFor('/feed/items/' + post.type + '/' + (post.id | string) + '/comments') }}">
                      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                      <input type="hidden" name="type" value="{{ selectedType }}">
                      <input type="hidden" name="mode" value="{{ selectedMode }}">
                      <input type="hidden" name="per_page" value="{{ perPage }}">
                      {% if selectedSubtype %}<input type="hidden" name="subtype" value="{{ selectedSubtype }}">{% endif %}
                      {% if cursor %}<input type="hidden" name="cursor" value="{{ cursor }}">{% endif %}
                      <div class="govuk-form-group">
                        <label class="govuk-label" for="comment-{{ post.type }}-{{ post.id }}">{{ t("feed.comment_label") }}</label>
                        <div id="comment-{{ post.type }}-{{ post.id }}-hint" class="govuk-hint">{{ t("feed.comment_hint") }}</div>
                        <textarea class="govuk-textarea" id="comment-{{ post.type }}-{{ post.id }}" name="content" rows="3" aria-describedby="comment-{{ post.type }}-{{ post.id }}-hint"></textarea>
                      </div>
                      <button class="govuk-button" data-module="govuk-button">{{ t("actions.comment") }}</button>
                    </form>
                  </div>
                </details>
              {% endif %}
            </article>
          {% endfor %}
        </div>

        {# Laravel v2 feed uses opaque cursor pagination. #}
        {% if nextHref %}
          <nav class="govuk-pagination govuk-pagination--block govuk-!-margin-top-6" aria-label="{{ t('feed.pagination_label') }}">
            <div class="govuk-pagination__next">
              <a class="govuk-link govuk-pagination__link" href="{{ urlFor(nextHref) }}" rel="next">
                <svg class="govuk-pagination__icon govuk-pagination__icon--next" xmlns="http://www.w3.org/2000/svg" height="13" width="15" aria-hidden="true" focusable="false" viewBox="0 0 15 13"><path d="m8.107-0.0078125-1.4136 1.414 4.2926 4.293h-12.986v2h12.896l-4.1855 3.9766 1.377 1.4492 6.7441-6.4062-6.7246-6.7266z"></path></svg>
                <span class="govuk-pagination__link-title">{{ t("actions.load_more") }}</span>
                <span class="govuk-visually-hidden">:</span>
                <span class="govuk-pagination__link-label">{{ t("feed.more_results_label") }}</span>
              </a>
            </div>
          </nav>
        {% endif %}
        {% else %}
          <div class="govuk-inset-text">
            <h3 class="govuk-heading-m">{{ t("states.empty_title") }}</h3>
            <p class="govuk-body">{{ t("feed.empty") }}</p>
          </div>
        {% endif %}
      {% endif %}

    </div>
  </div>
{% endblock %}
