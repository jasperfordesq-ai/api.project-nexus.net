{% extends "layouts/base.njk" %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <a href="{{ urlFor('/feed') }}" class="govuk-back-link">{{ t("feed_t1.permalink_back") }}</a>

      <span class="govuk-caption-l">Community feed at {{ communityName }}</span>
      <h1 class="govuk-heading-xl">{% if item.title %}{{ item.title }}{% else %}Activity{% endif %}</h1>

      {% if statusMessage %}
        <div class="govuk-notification-banner{% if statusMessage.type == 'success' %} govuk-notification-banner--success{% endif %}" data-module="govuk-notification-banner" role="{% if statusMessage.type == 'success' %}alert{% else %}region{% endif %}" aria-labelledby="item-status-title">
          <div class="govuk-notification-banner__header">
            <h2 class="govuk-notification-banner__title" id="item-status-title">{% if statusMessage.type == 'success' %}Success{% else %}There is a problem{% endif %}</h2>
          </div>
          <div class="govuk-notification-banner__content">
            <p class="govuk-notification-banner__heading">{{ statusMessage.text }}</p>
          </div>
        </div>
      {% endif %}

      {% if requiresAuth %}
        <div class="govuk-notification-banner" data-module="govuk-notification-banner" role="region" aria-labelledby="item-auth-title">
          <div class="govuk-notification-banner__header">
            <h2 class="govuk-notification-banner__title" id="item-auth-title">{{ t("states.error_title") }}</h2>
          </div>
          <div class="govuk-notification-banner__content">
            <p class="govuk-notification-banner__heading">Sign in to take part in the feed.</p>
            <div class="govuk-button-group">
              <a class="govuk-button" href="{{ urlFor('/login') }}" role="button" draggable="false" data-module="govuk-button">{{ t("auth.login_action") }}</a>
            </div>
          </div>
        </div>
      {% endif %}

      {% if itemUnavailable %}
        <div class="govuk-inset-text">
          <h2 class="govuk-heading-m">{{ t("states.not_available") }}</h2>
          <p class="govuk-body">{{ t("feed_t1.permalink_not_available") }}</p>
        </div>
      {% else %}
      <article class="nexus-alpha-card" id="feed-item-{{ item.type }}-{{ item.id }}">
        <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-2">
          <strong class="govuk-tag govuk-tag--grey">{{ item.typeLabel }}</strong>
          {% if item.authorAvatar %}
            <img class="nexus-alpha-avatar nexus-alpha-avatar--small" src="{{ item.authorAvatar }}" alt="" loading="lazy" decoding="async" width="32" height="32">
          {% endif %}
          Posted by {{ item.authorName }}
          {% if item.createdAt %}
            <span aria-hidden="true"> | </span>
            <span class="govuk-visually-hidden">Posted on </span>
            <time datetime="{{ item.createdAt }}">{{ item.createdAt | formatDate }}</time>
          {% endif %}
        </p>

        {% for paragraph in item.contentParagraphs %}
          <p class="govuk-body">{{ paragraph }}</p>
        {% endfor %}

        {% if item.media and item.media.length %}
          <ul class="nexus-alpha-feed-media" data-count="{{ item.media.length }}">
            {% for media in item.media %}
              <li>
                <a href="{{ media.fileUrl }}" target="_blank" rel="noopener noreferrer">
                  <span class="govuk-visually-hidden"> Opens in a new tab</span>
                  <img src="{{ media.thumbnailUrl }}" alt="{{ media.altText or t('govuk_alpha_feed.item.image_alt') }}" class="nexus-alpha-feed-image" loading="lazy">
                </a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}

        {% if item.deepLink %}
          <p class="govuk-body-s nexus-alpha-meta">
            <a class="govuk-link govuk-link--no-visited-state" href="{{ urlFor(item.deepLink.href) }}">{{ t(item.deepLink.labelKey) }}</a>
          </p>
        {% endif %}

        <p class="govuk-body-s nexus-alpha-meta">
          {{ item.likeLabel }} &middot; {{ item.commentLabel }}
        </p>

        {% if not requiresAuth %}
          <div class="nexus-alpha-actions govuk-button-group govuk-!-margin-bottom-3">
            <form method="post" action="{{ urlFor('/feed/items/' + item.type + '/' + (item.id | string) + '/like') }}">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}">
              <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">
                {% if item.isLiked %}Remove like{% else %}Like{% endif %}
              </button>
            </form>
          </div>

          <details class="govuk-details govuk-!-margin-bottom-3" data-module="govuk-details">
            <summary class="govuk-details__summary">
              <span class="govuk-details__summary-text">Not interested</span>
            </summary>
            <div class="govuk-details__text">
              <p class="govuk-body-s">We will use this feedback to show you less like this.</p>
              <form method="post" action="{{ urlFor('/feed/items/' + item.type + '/' + (item.id | string) + '/not-interested') }}">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">Not interested</button>
              </form>
            </div>
          </details>
        {% endif %}

        {% if item.isCommentable %}
          <h2 class="govuk-heading-m govuk-!-margin-top-4">Comments</h2>
          {% if comments and comments.length %}
            <ul class="govuk-list nexus-alpha-card-list">
              {% for comment in comments %}
                <li class="nexus-alpha-card">
                  <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">
                    Posted by {{ comment.author.name or comment.author_name or "A community member" }}
                  </p>
                  <p class="govuk-body">{{ comment.content or comment.body }}</p>
                </li>
              {% endfor %}
            </ul>
          {% else %}
            <p class="govuk-body">No comments yet.</p>
          {% endif %}

          {% if not requiresAuth %}
            <form method="post" action="{{ urlFor('/feed/items/' + item.type + '/' + (item.id | string) + '/comments') }}">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}">
              <div class="govuk-form-group">
                <label class="govuk-label" for="item-comment-{{ item.id }}">{{ t("blog.comment_body_label") }}</label>
                <div id="item-comment-{{ item.id }}-hint" class="govuk-hint">Be respectful. Comments are visible to other members.</div>
                <textarea class="govuk-textarea" id="item-comment-{{ item.id }}" name="content" rows="3" aria-describedby="item-comment-{{ item.id }}-hint"></textarea>
              </div>
              <button class="govuk-button" data-module="govuk-button">{{ t("actions.comment") }}</button>
            </form>
          {% endif %}
        {% endif %}
      </article>
      {% endif %}
    </div>
  </div>
{% endblock %}
