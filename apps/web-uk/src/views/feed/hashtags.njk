{% extends "layouts/base.njk" %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <a href="{{ urlFor('/feed') }}" class="govuk-back-link">Back to the feed</a>

      {% if errorMessage %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
          <div role="alert">
            <h2 class="govuk-error-summary__title">There is a problem</h2>
            <div class="govuk-error-summary__body">
              <p class="govuk-body">{{ errorMessage }}</p>
            </div>
          </div>
        </div>
      {% endif %}

      <span class="govuk-caption-l">Discover topics at {{ communityName }}</span>
      <h1 class="govuk-heading-xl">Hashtags</h1>
      <p class="govuk-body-l">Browse trending hashtags or search for a topic.</p>

      <form method="get" action="{{ urlFor('/feed/hashtags') }}" class="govuk-!-margin-bottom-6">
        <div class="govuk-form-group">
          <label class="govuk-label" for="hashtag-search">Search hashtags</label>
          <div id="hashtag-search-hint" class="govuk-hint">Enter at least one character to search by topic.</div>
          <input class="govuk-input govuk-!-width-two-thirds" id="hashtag-search" name="q" type="search" maxlength="100" value="{{ searchQuery }}" aria-describedby="hashtag-search-hint">
        </div>
        <button class="govuk-button govuk-button--secondary" data-module="govuk-button" type="submit">Search</button>
        {% if isSearching %}
          <a class="govuk-link govuk-!-margin-left-3" href="{{ urlFor('/feed/hashtags') }}">Clear search and show trending</a>
        {% endif %}
      </form>

      <h2 class="govuk-heading-m">{% if isSearching %}Search results{% else %}Trending hashtags{% endif %}</h2>

      {% if hashtags and hashtags.length %}
        <ul class="govuk-list nexus-alpha-card-list">
          {% for hashtag in hashtags %}
            <li class="nexus-alpha-card">
              <h3 class="govuk-heading-s govuk-!-margin-bottom-1">
                <a class="govuk-link" href="{{ urlFor('/feed/hashtag/' + (hashtag.tag | urlencode)) }}">#{{ hashtag.tag }}</a>
              </h3>
              <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-0">
                <span class="govuk-visually-hidden">View posts tagged #{{ hashtag.tag }}. </span>{{ hashtag.postCountLabel }}
              </p>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <div class="govuk-inset-text">
          {% if isSearching %}No hashtags match {{ searchQuery }}.{% else %}There are no trending hashtags yet.{% endif %}
        </div>
      {% endif %}
    </div>
  </div>
{% endblock %}
