{% extends "layouts/base.njk" %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <a href="{{ urlFor('/feed') }}" class="govuk-back-link">{{ t("feed_t1.permalink_back") }}</a>

      {% if errorMessage %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
          <div role="alert">
            <h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2>
            <div class="govuk-error-summary__body">
              <p class="govuk-body">{{ errorMessage }}</p>
            </div>
          </div>
        </div>
      {% endif %}

      <span class="govuk-caption-l">{{ t("govuk_alpha_feed.hashtags.caption", { community: communityName }) }}</span>
      <h1 class="govuk-heading-xl">{{ t("govuk_alpha_feed.hashtags.title") }}</h1>
      <p class="govuk-body-l">{{ t("govuk_alpha_feed.hashtags.subtitle") }}</p>

      <form method="get" action="{{ urlFor('/feed/hashtags') }}" class="govuk-!-margin-bottom-6">
        <div class="govuk-form-group">
          <label class="govuk-label" for="hashtag-search">{{ t("govuk_alpha_feed.hashtags.search_label") }}</label>
          <div id="hashtag-search-hint" class="govuk-hint">{{ t("govuk_alpha_feed.hashtags.search_hint") }}</div>
          <input class="govuk-input govuk-input--width-20" id="hashtag-search" name="q" type="text" maxlength="100" value="{{ searchQuery }}" aria-describedby="hashtag-search-hint">
        </div>
        <div class="govuk-button-group">
          <button class="govuk-button" data-module="govuk-button" type="submit">{{ t("govuk_alpha_feed.hashtags.search_button") }}</button>
          {% if isSearching %}<a class="govuk-link" href="{{ urlFor('/feed/hashtags') }}">{{ t("govuk_alpha_feed.hashtags.clear_search") }}</a>{% endif %}
        </div>
      </form>

      <h2 class="govuk-heading-l">{{ t("govuk_alpha_feed.hashtags.results_heading") if isSearching else t("govuk_alpha_feed.hashtags.trending_heading") }}</h2>

      {% if hashtags and hashtags.length %}
        <ul class="govuk-list nexus-alpha-card-list">
          {% for hashtag in hashtags %}
            <li class="nexus-alpha-card">
              <h3 class="govuk-heading-s govuk-!-margin-bottom-1">
                <a class="govuk-link govuk-link--no-visited-state" href="{{ urlFor('/feed/hashtag/' + (hashtag.tag | urlencode)) }}">#{{ hashtag.tag }}<span class="govuk-visually-hidden">{{ t("govuk_alpha_feed.hashtags.view_tag", { tag: "#" + hashtag.tag }) }}</span></a>
              </h3>
              <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-0">
                {{ tc("govuk_alpha_feed.hashtags.post_count", hashtag.postCount, { count: hashtag.postCount }) }}
              </p>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <p class="govuk-body">{{ t("govuk_alpha_feed.hashtags.empty_search", { query: searchQuery }) if isSearching else t("govuk_alpha_feed.hashtags.empty_trending") }}</p>
      {% endif %}
    </div>
  </div>
{% endblock %}
