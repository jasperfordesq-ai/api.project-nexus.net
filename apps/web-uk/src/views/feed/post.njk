{% extends "layouts/base.njk" %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <a href="{{ urlFor('/feed') }}" class="govuk-back-link">{{ t("feed_t1.permalink_back") }}</a>

      <span class="govuk-caption-l">{{ t("feed.caption", { community: communityName }) }}</span>
      <h1 class="govuk-heading-xl">{{ t("feed_t1.permalink_heading") }}</h1>

      {% if statusMessage %}
        <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="permalink-status-title">
          <div class="govuk-notification-banner__header">
            <h2 class="govuk-notification-banner__title" id="permalink-status-title">{{ t("states.success_title") }}</h2>
          </div>
          <div class="govuk-notification-banner__content">
            <p class="govuk-notification-banner__heading">{{ statusMessage.text }}</p>
          </div>
        </div>
      {% endif %}

      {% if requiresAuth %}
        <div class="govuk-notification-banner" data-module="govuk-notification-banner" role="region" aria-labelledby="permalink-auth-title">
          <div class="govuk-notification-banner__header">
            <h2 class="govuk-notification-banner__title" id="permalink-auth-title">{{ t("states.error_title") }}</h2>
          </div>
          <div class="govuk-notification-banner__content">
            <p class="govuk-notification-banner__heading">{{ t("states.auth_required") }}</p>
            <div class="govuk-button-group">
              <a class="govuk-button" href="{{ urlFor('/login') }}" role="button" draggable="false" data-module="govuk-button">{{ t("auth.login_action") }}</a>
            </div>
          </div>
        </div>
      {% endif %}

      {% if itemUnavailable %}
        <div class="govuk-inset-text">
          <h2 class="govuk-heading-m">{{ t("states.not_available") }}</h2>
          <p class="govuk-body">{{ t("feed_t1.permalink_not_available") }}</p>
        </div>
      {% else %}
      <article class="nexus-alpha-card" id="feed-item-post-{{ item.id }}">
        <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-2">
          {% if item.authorAvatar %}
            <img class="nexus-alpha-avatar nexus-alpha-avatar--small" src="{{ item.authorAvatar }}" alt="" loading="lazy" decoding="async" width="32" height="32">
          {% endif %}
          {{ t("feed.posted_by", { name: item.authorName }) }}
          {% if item.createdAt %}
            <span aria-hidden="true"> | </span>
            <span class="govuk-visually-hidden">{{ t("feed.posted_on_prefix") }}</span>
            <time datetime="{{ item.createdAt }}">{{ item.createdAt | formatDate }}</time>
          {% endif %}
        </p>

        {% for paragraph in item.contentParagraphs %}
          <p class="govuk-body">{{ paragraph }}</p>
        {% endfor %}

        {% if item.media and item.media.length %}
          <ul class="nexus-alpha-feed-media" data-count="{{ item.media.length }}">
            {% for media in item.media %}
              <li>
                <a href="{{ media.fileUrl }}" target="_blank" rel="noopener noreferrer">
                  <span class="govuk-visually-hidden"> {{ t("opens_new_tab") }}</span>
                  <img src="{{ media.thumbnailUrl }}" alt="{{ media.altText or t('govuk_alpha_feed.item.image_alt') }}" class="nexus-alpha-feed-image" loading="lazy">
                </a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}

        <p class="govuk-body-s nexus-alpha-meta">
          {{ item.likeLabel }} &middot; {{ item.commentLabel }}
        </p>

        {% if not requiresAuth %}
          <div class="nexus-alpha-actions govuk-!-margin-bottom-3">
            <form method="post" action="{{ urlFor('/feed/items/post/' + (item.id | string) + '/like') }}">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}">
              <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">
                {% if item.isLiked %}Remove like{% else %}Like{% endif %}
              </button>
            </form>
          </div>

          <div class="nexus-alpha-reactions govuk-!-margin-bottom-3">
            <fieldset class="govuk-fieldset">
              <legend class="govuk-fieldset__legend govuk-fieldset__legend--s govuk-visually-hidden">{{ t("feed_t1.reactions_legend") }}</legend>
              <div class="govuk-button-group govuk-!-margin-bottom-0">
                {% for reaction in [{ type: "like", symbol: "&#128077;" }, { type: "love", symbol: "&#10084;" }, { type: "celebrate", symbol: "&#127881;" }] %}
                  <form method="post" action="{{ urlFor('/feed/posts/' + (item.id | string) + '/react') }}">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                    <input type="hidden" name="emoji" value="{{ reaction.type }}">
                    <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0{% if item.userReaction == reaction.type %} nexus-alpha-reaction--active{% endif %}" data-module="govuk-button">
                      <span aria-hidden="true">{{ reaction.symbol | safe }}</span> {{ t("feed_t1.reaction_" + reaction.type) }}{% if item.reactionCounts[reaction.type] %} ({{ item.reactionCounts[reaction.type] }}){% endif %}
                    </button>
                  </form>
                {% endfor %}
              </div>
            </fieldset>
          </div>

          <div class="govuk-button-group govuk-!-margin-bottom-3">
            {% if currentUserId != item.authorId %}
              <form method="post" action="{{ urlFor('/feed/posts/' + (item.id | string) + '/share') }}">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("feed_t1.unshare_button") if item.isShared else t("feed_t1.share_button") }}</button>
              </form>
            {% endif %}
            <form method="post" action="{{ urlFor('/feed/posts/' + (item.id | string) + '/save') }}">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}">
              <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("feed_t1.unsave_button") if item.isBookmarked else t("feed_t1.save_button") }}</button>
            </form>
          </div>
        {% endif %}

        <h2 class="govuk-heading-m govuk-!-margin-top-4">{{ t("feed.comments_summary") }}</h2>
        {% if comments and comments.length %}
          <ul class="govuk-list nexus-alpha-card-list">
            {% for comment in comments %}
              <li class="nexus-alpha-card">
                <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">
                  {{ t("feed.posted_by", { name: comment.author.name or comment.author_name or t("feed.unknown_author") }) }}
                </p>
                <p class="govuk-body">{{ comment.content or comment.body }}</p>
                {% if not requiresAuth and comment.id %}
                  <div class="govuk-button-group govuk-!-margin-bottom-2">
                    {% for reaction in [{ type: "like", symbol: "&#128077;" }, { type: "love", symbol: "&#10084;" }, { type: "celebrate", symbol: "&#127881;" }] %}
                      <form method="post" action="{{ urlFor('/feed/comments/' + (comment.id | string) + '/react') }}">
                        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                        <input type="hidden" name="emoji" value="{{ reaction.type }}">
                        <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button"><span aria-hidden="true">{{ reaction.symbol | safe }}</span> {{ t("feed_t1.reaction_" + reaction.type) }}</button>
                      </form>
                    {% endfor %}
                  </div>
                {% endif %}
                {% set commentAuthorId = comment.author.id or comment.author_id or comment.user_id %}
                {% if currentUserId and commentAuthorId == currentUserId %}
                  <details class="govuk-details govuk-!-margin-bottom-2" data-module="govuk-details">
                    <summary class="govuk-details__summary"><span class="govuk-details__summary-text">{{ t("feed.edit_comment") }}</span></summary>
                    <div class="govuk-details__text">
                      <form method="post" action="{{ urlFor('/feed/comments/' + (comment.id | string) + '/update') }}">
                        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                        <div class="govuk-form-group">
                          <label class="govuk-label" for="edit-comment-{{ comment.id }}">{{ t("feed.edit_comment_label") }}</label>
                          <textarea class="govuk-textarea" id="edit-comment-{{ comment.id }}" name="content" rows="3" required>{{ comment.content or comment.body }}</textarea>
                        </div>
                        <button class="govuk-button govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("actions.save_changes") }}</button>
                      </form>
                    </div>
                  </details>
                  <details class="govuk-details govuk-!-margin-bottom-2" data-module="govuk-details">
                    <summary class="govuk-details__summary"><span class="govuk-details__summary-text">{{ t("feed.delete_comment") }}</span></summary>
                    <div class="govuk-details__text">
                      <p class="govuk-body">{{ t("feed.delete_comment_confirm") }}</p>
                      <form method="post" action="{{ urlFor('/feed/comments/' + (comment.id | string) + '/delete') }}">
                        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                        <button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("feed.delete_comment_button") }}</button>
                      </form>
                    </div>
                  </details>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        {% else %}
          <p class="govuk-body">{{ t("feed.no_comments") }}</p>
        {% endif %}

        {% if not requiresAuth %}
          <form method="post" action="{{ urlFor('/feed/items/post/' + (item.id | string) + '/comments') }}">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <div class="govuk-form-group">
              <label class="govuk-label" for="permalink-comment-{{ item.id }}">{{ t("blog.comment_body_label") }}</label>
              <div id="permalink-comment-{{ item.id }}-hint" class="govuk-hint">{{ t("feed.comment_hint") }}</div>
              <textarea class="govuk-textarea" id="permalink-comment-{{ item.id }}" name="content" rows="3" aria-describedby="permalink-comment-{{ item.id }}-hint"></textarea>
            </div>
            <button class="govuk-button" data-module="govuk-button">{{ t("actions.comment") }}</button>
          </form>
        {% endif %}
      </article>
      {% endif %}
    </div>
  </div>
{% endblock %}
