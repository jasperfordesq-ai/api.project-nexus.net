{% extends "layouts/base.njk" %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <a href="{{ urlFor('/feed/hashtags') }}" class="govuk-back-link">{{ t("govuk_alpha_feed.hashtag.back_to_hashtags") }}</a>

      {% if errorMessage %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1" role="alert">
          <h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2>
          <div class="govuk-error-summary__body">
            <p class="govuk-body">{{ errorMessage }}</p>
          </div>
        </div>
      {% endif %}

      <span class="govuk-caption-l">{{ t("govuk_alpha_feed.hashtag.caption", { community: communityName }) }}</span>
      <h1 class="govuk-heading-xl">#{{ tag }}</h1>
      <p class="govuk-body-l">{{ tc("govuk_alpha_feed.hashtag.total_posts", totalCount, { count: totalCount }) }}</p>

      {% if statusMessage %}
        <div class="govuk-notification-banner{% if statusMessage.type == 'success' %} govuk-notification-banner--success{% endif %}" data-module="govuk-notification-banner" role="{% if statusMessage.type == 'success' %}alert{% else %}region{% endif %}" aria-labelledby="hashtag-status-title">
          <div class="govuk-notification-banner__header">
            <h2 class="govuk-notification-banner__title" id="hashtag-status-title">{{ t("govuk_alpha_feed.states.success_title") if statusMessage.type == 'success' else t("govuk_alpha_feed.states.error_title") }}</h2>
          </div>
          <div class="govuk-notification-banner__content">
            <p class="govuk-notification-banner__heading">{{ statusMessage.text }}</p>
          </div>
        </div>
      {% endif %}

      {% if items and items.length %}
        {% for item in items %}
          <article class="nexus-alpha-card" id="feed-item-post-{{ item.id }}">
            <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-2">
              {% if item.authorAvatar %}
                <img class="nexus-alpha-avatar nexus-alpha-avatar--small" src="{{ item.authorAvatar }}" alt="" loading="lazy" decoding="async" width="32" height="32">
              {% endif %}
              {{ t("govuk_alpha_feed.item.posted_by", { name: item.authorName }) }}
              {% if item.createdAt %}
                <span aria-hidden="true"> | </span>
                <span class="govuk-visually-hidden">{{ t("govuk_alpha_feed.item.posted_on") }} </span>
                <time datetime="{{ item.createdAt }}">{{ item.createdAt | formatDate }}</time>
              {% endif %}
            </p>

            {% for paragraph in item.contentParagraphs %}
              <p class="govuk-body">{{ paragraph }}</p>
            {% endfor %}

            {% if item.media and item.media.length %}
              <ul class="nexus-alpha-feed-media" data-count="{{ item.media.length }}">
                {% for media in item.media %}
                  <li>
                    <a href="{{ media.fileUrl }}" target="_blank" rel="noopener noreferrer">
                      <span class="govuk-visually-hidden"> {{ t("opens_new_tab") }}</span>
                      <img src="{{ media.thumbnailUrl }}" alt="{{ media.altText or t('govuk_alpha_feed.item.image_alt') }}" class="nexus-alpha-feed-image" loading="lazy">
                    </a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}

            <p class="govuk-body-s nexus-alpha-meta">
              {{ tc("govuk_alpha_feed.engagement.likes", item.likeCount, { count: item.likeCount }) }} &middot;
              {{ tc("govuk_alpha_feed.engagement.comments", item.commentCount, { count: item.commentCount }) }}
            </p>

            {% if not requiresAuth %}
              <div class="nexus-alpha-actions govuk-button-group govuk-!-margin-bottom-3">
                <form method="post" action="{{ urlFor('/feed/items/post/' + (item.id | string) + '/like') }}">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">
                    {{ t("govuk_alpha_feed.engagement.unlike") if item.isLiked else t("govuk_alpha_feed.engagement.like") }}
                  </button>
                </form>
              </div>

              <div class="nexus-alpha-reactions govuk-!-margin-bottom-3">
                <fieldset class="govuk-fieldset">
                  <legend class="govuk-fieldset__legend govuk-fieldset__legend--s govuk-visually-hidden">{{ t("govuk_alpha_feed.engagement.reactions_legend") }}</legend>
                  <div class="govuk-button-group govuk-!-margin-bottom-0">
                    {% for reaction in [{ type: "like", symbol: "&#128077;" }, { type: "love", symbol: "&#10084;" }, { type: "celebrate", symbol: "&#127881;" }] %}
                      <form method="post" action="{{ urlFor('/feed/posts/' + (item.id | string) + '/react') }}">
                        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                        <input type="hidden" name="emoji" value="{{ reaction.type }}">
                        <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0{% if item.userReaction == reaction.type %} nexus-alpha-reaction--active{% endif %}" data-module="govuk-button"><span aria-hidden="true">{{ reaction.symbol | safe }}</span> {{ t("feed_t1.reaction_" + reaction.type) }}{% if item.reactionCounts[reaction.type] %} ({{ item.reactionCounts[reaction.type] }}){% endif %}</button>
                      </form>
                    {% endfor %}
                  </div>
                </fieldset>
              </div>
            {% endif %}

            <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-0">
              <a class="govuk-link govuk-link--no-visited-state" href="{{ urlFor('/feed/posts/' + (item.id | string)) }}">{{ t("feed_t1.view_post") }}</a>
            </p>
          </article>
        {% endfor %}

        {% if nextHref %}
          <p class="govuk-body">
            <a class="govuk-link govuk-link--no-visited-state" href="{{ urlFor(nextHref) }}">{{ t("govuk_alpha_feed.hashtag.show_more") }}</a>
          </p>
        {% endif %}
      {% else %}
        <div class="nexus-alpha-card">
          <h2 class="govuk-heading-m">{{ t("govuk_alpha_feed.hashtag.empty_title") }}</h2>
          <p class="govuk-body">{{ t("govuk_alpha_feed.hashtag.empty_body", { tag: "#" + tag }) }}</p>
        </div>
      {% endif %}
    </div>
  </div>
{% endblock %}
