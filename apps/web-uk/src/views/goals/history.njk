{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a class="govuk-back-link" href="{{ urlFor('/goals/' + (goal.id | string)) }}">Back to goal</a>

  <span class="govuk-caption-xl">Goal: {{ goal.title }}</span>
  <h1 class="govuk-heading-xl govuk-!-margin-bottom-2">Progress history</h1>
  <p class="govuk-body-l">A chronological record of every event for this goal &mdash; check-ins, milestones, buddy activity and more.</p>

  {% if items.length === 0 %}
    <div class="govuk-inset-text">
      <p class="govuk-body">No events have been recorded for this goal yet.</p>
    </div>
  {% else %}
    <ol class="govuk-list govuk-list--number nexus-alpha-card-list" aria-label="Goal progress history">
      {% for item in items %}
        <li class="nexus-alpha-card">
          <div class="nexus-alpha-module-row govuk-!-margin-bottom-2">
            <strong class="govuk-tag {{ item.tagClass }}">{{ item.label }}</strong>
            {% if item.createdAtLabel %}
              <span class="govuk-body-s nexus-alpha-meta" aria-label="{{ item.createdAtLabel }}">
                <time datetime="{{ item.createdAt }}" title="{{ item.createdAtLabel }}">{{ item.createdAtLabel }}</time>
              </span>
            {% endif %}
          </div>
          {% if item.description %}
            <p class="govuk-body govuk-!-margin-bottom-0">{{ item.description }}</p>
          {% endif %}
        </li>
      {% endfor %}
    </ol>

    {% if hasMore and nextHref %}
      <p class="govuk-body govuk-!-margin-top-4">
        <a class="govuk-link" href="{{ urlFor(nextHref) }}">Load older events</a>
      </p>
    {% endif %}
  {% endif %}

  <p class="govuk-body govuk-!-margin-top-6">
    <a class="govuk-link" href="{{ urlFor('/goals/' + (goal.id | string)) }}">Back to goal</a>
  </p>
{% endblock %}
