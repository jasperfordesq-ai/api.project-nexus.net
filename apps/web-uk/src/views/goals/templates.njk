{% extends "layouts/base.njk" %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <a class="govuk-back-link" href="{{ urlFor('/goals') }}">{{ t("goals.back_to_goals") }}</a>

      {% if errorMessage %}
        {{ govukErrorSummary({
          titleText: t("states.error_title"),
          errorList: [
            {
              text: errorMessage,
              href: "#templates-list"
            }
          ]
        }) }}
      {% endif %}

      <span class="govuk-caption-xl">{{ t("goals.templates_caption") }}</span>
      <h1 class="govuk-heading-xl">{{ t("goals.templates_title") }}</h1>

      {% if categories and categories.length %}
        <form method="get" action="{{ urlFor('/goals/templates') }}" class="govuk-!-margin-bottom-6">
          <div class="govuk-form-group">
            <label class="govuk-label" for="category">{{ t("goals.templates_category_label") }}</label>
            <select class="govuk-select" id="category" name="category">
              <option value="">{{ t("goals.templates_category_all") }}</option>
              {% for item in categories %}
                <option value="{{ item }}"{% if category == item %} selected{% endif %}>{{ item }}</option>
              {% endfor %}
            </select>
          </div>
          <button class="govuk-button govuk-button--secondary" data-module="govuk-button" type="submit">{{ t("goals.templates_filter_button") }}</button>
        </form>
      {% endif %}

      <div id="templates-list">
        {% if not templates or not templates.length %}
          <div class="govuk-inset-text">
            <p class="govuk-body">{{ t("goals.templates_empty") }}</p>
          </div>
        {% else %}
          <div class="nexus-alpha-card-list">
            {% for template in templates %}
              <article class="nexus-alpha-card">
                <div class="nexus-alpha-module-row">
                  <h2 class="govuk-heading-s govuk-!-margin-bottom-1">{{ template.title }}</h2>
                  {% if template.category %}
                    <strong class="govuk-tag govuk-tag--grey">{{ template.category }}</strong>
                  {% endif %}
                </div>

                {% if template.description %}
                  <p class="govuk-body-s">{{ template.description }}</p>
                {% endif %}

                {% if template.targetText %}
                  <p class="govuk-body-s nexus-alpha-meta">{{ t("goals.template_target", { target: template.targetText }) }}</p>
                {% endif %}

                <form method="post" action="{{ urlFor('/goals/templates/' + (template.id | string)) }}">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <div class="govuk-form-group">
                    <label class="govuk-label" for="title-{{ template.id }}">{{ t("goals.template_title_override_label") }}</label>
                    <div id="title-hint-{{ template.id }}" class="govuk-hint">{{ t("goals.template_title_override_hint") }}</div>
                    <input class="govuk-input" id="title-{{ template.id }}" name="title" type="text" maxlength="255" aria-describedby="title-hint-{{ template.id }}">
                  </div>

                  <div class="govuk-checkboxes govuk-checkboxes--small govuk-form-group" data-module="govuk-checkboxes">
                    <div class="govuk-checkboxes__item">
                      <input class="govuk-checkboxes__input" id="is_public-{{ template.id }}" name="is_public" type="checkbox" value="1" checked>
                      <label class="govuk-label govuk-checkboxes__label" for="is_public-{{ template.id }}">{{ t("goals.public_label") }}</label>
                    </div>
                  </div>

                  <button class="govuk-button govuk-!-margin-bottom-0" data-module="govuk-button" type="submit">{{ t("goals.template_use_button") }}</button>
                </form>
              </article>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      {% if nextHref %}
        <p class="govuk-body govuk-!-margin-top-6">
          <a class="govuk-link" href="{{ urlFor(nextHref) }}">{{ t("actions.load_more") }}</a>
        </p>
      {% endif %}
    </div>
  </div>
{% endblock %}
