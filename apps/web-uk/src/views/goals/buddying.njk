{% extends "layouts/base.njk" %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <a class="govuk-back-link" href="/goals">Back to goals</a>

      {% if successMessage %}
        {{ govukNotificationBanner({
          type: "success",
          titleText: "Success",
          text: successMessage
        }) }}
      {% endif %}

      {% if errorMessage %}
        {{ govukErrorSummary({
          titleText: "There is a problem",
          errorList: [
            {
              text: errorMessage,
              href: errorHref
            }
          ]
        }) }}
      {% endif %}

      <span class="govuk-caption-xl">Goals you support and public goals you can offer to buddy.</span>
      <h1 class="govuk-heading-xl">Goals you buddy</h1>

      <h2 class="govuk-heading-l" id="your-buddied-goals">Goals you are buddying</h2>
      {% if not buddying or not buddying.length %}
        <div class="govuk-inset-text">
          <p class="govuk-body">You are not buddying any goals yet.</p>
        </div>
      {% else %}
        <div class="nexus-alpha-card-list govuk-!-margin-bottom-8">
          {% for goal in buddying %}
            <article class="nexus-alpha-card">
              <div class="nexus-alpha-module-row">
                <h3 class="govuk-heading-s govuk-!-margin-bottom-1">
                  <a class="govuk-link" href="/goals/{{ goal.id }}">{{ goal.title }}</a>
                </h3>
                <strong class="govuk-tag {{ goal.statusClass }}">{{ goal.statusLabel }}</strong>
              </div>
              <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">Owned by {{ goal.ownerName }}</p>
              <progress max="100" value="{{ goal.progressPercent }}" aria-label="{{ goal.progressPercent }}%">{{ goal.progressPercent }}%</progress>

              {% if goal.statusLabel != "Completed" %}
                <form method="post" action="/goals/{{ goal.id }}/buddy-nudge" class="govuk-!-margin-top-2">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button" type="submit">Send encouragement</button>
                </form>
              {% endif %}
            </article>
          {% endfor %}
        </div>
      {% endif %}

      <h2 class="govuk-heading-l" id="available-goals">Public goals looking for a buddy</h2>
      {% if not available or not available.length %}
        <div class="govuk-inset-text">
          <p class="govuk-body">There are no public goals looking for a buddy right now.</p>
        </div>
      {% else %}
        <div class="nexus-alpha-card-list">
          {% for goal in available %}
            <article class="nexus-alpha-card">
              <h3 class="govuk-heading-s govuk-!-margin-bottom-1">
                <a class="govuk-link" href="/goals/{{ goal.id }}">{{ goal.title }}</a>
              </h3>
              <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">Owned by {{ goal.ownerName }}</p>
              <progress max="100" value="{{ goal.progressPercent }}" aria-label="{{ goal.progressPercent }}%">{{ goal.progressPercent }}%</progress>

              <form method="post" action="/goals/{{ goal.id }}/buddy" class="govuk-!-margin-top-2">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <button class="govuk-button govuk-!-margin-bottom-0" data-module="govuk-button" type="submit">Become a buddy</button>
              </form>
            </article>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
{% endblock %}
