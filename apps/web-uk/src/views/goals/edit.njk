{% extends "layouts/base.njk" %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block mainContent %}
  <a class="govuk-back-link" href="/goals/{{ goal.id }}">Back to goal</a>

  {% if errorMessage %}
    {{ govukErrorSummary({
      titleText: "There is a problem",
      errorList: [
        {
          text: errorMessage,
          href: "#title"
        }
      ]
    }) }}
  {% endif %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <span class="govuk-caption-xl">Update the details of your goal.</span>
      <h1 class="govuk-heading-xl">Edit your goal</h1>

      <form method="post" action="/goals/{{ goal.id }}/edit" novalidate>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        <div class="govuk-form-group">
          <label class="govuk-label" for="title">Goal</label>
          <input class="govuk-input" id="title" name="title" type="text" maxlength="255" value="{{ goal.rawTitle }}" required>
        </div>

        <div class="govuk-form-group">
          <label class="govuk-label" for="target_value">Target</label>
          <div id="tv-hint" class="govuk-hint">Use a number that can be tracked over time.</div>
          <input class="govuk-input govuk-input--width-5" id="target_value" name="target_value" type="number" min="0.25" step="0.25" inputmode="decimal" value="{{ goal.targetValue }}" required aria-describedby="tv-hint">
        </div>

        <div class="govuk-form-group">
          <label class="govuk-label" for="description">Description</label>
          <textarea class="govuk-textarea" id="description" name="description" rows="3" maxlength="1000">{{ goal.rawDescription }}</textarea>
        </div>

        <div class="govuk-form-group">
          <label class="govuk-label" for="deadline">Deadline</label>
          <input class="govuk-input govuk-input--width-10" id="deadline" name="deadline" type="date" value="{{ goal.deadlineValue }}">
        </div>

        <div class="govuk-form-group">
          <label class="govuk-label" for="checkin_frequency">Check-in reminders</label>
          <div id="freq-hint" class="govuk-hint">How often we remind you to check in on this goal.</div>
          <select class="govuk-select" id="checkin_frequency" name="checkin_frequency" aria-describedby="freq-hint">
            {% for frequency in frequencies %}
              <option value="{{ frequency.value }}"{% if goal.checkinFrequency == frequency.value %} selected{% endif %}>{{ frequency.label }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="govuk-checkboxes govuk-checkboxes--small govuk-form-group" data-module="govuk-checkboxes">
          <div class="govuk-checkboxes__item">
            <input class="govuk-checkboxes__input" id="is_public" name="is_public" type="checkbox" value="1"{% if goal.isPublic %} checked{% endif %}>
            <label class="govuk-label govuk-checkboxes__label" for="is_public">Share this goal with the community</label>
          </div>
        </div>

        <button class="govuk-button" data-module="govuk-button" type="submit">Save changes</button>
      </form>

      <h2 class="govuk-heading-l govuk-!-margin-top-7">Delete this goal</h2>
      <div class="govuk-warning-text">
        <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
        <strong class="govuk-warning-text__text">
          <span class="govuk-visually-hidden">Warning</span>
          Deleting a goal removes it and its progress history for good. This cannot be undone.
        </strong>
      </div>
      <form method="post" action="/goals/{{ goal.id }}/delete">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <button class="govuk-button govuk-button--warning" data-module="govuk-button" type="submit">Delete goal</button>
      </form>
    </div>
  </div>
{% endblock %}
