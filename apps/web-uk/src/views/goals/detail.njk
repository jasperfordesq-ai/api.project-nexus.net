{% extends "layouts/base.njk" %}

{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/table/macro.njk" import govukTable %}

{% block beforeContent %}
  {{ super() }}
  {% set breadcrumbs = [
    { text: "Goals", href: "/goals" },
    { text: goal.title }
  ] %}
  {% include "partials/breadcrumbs.njk" %}
{% endblock %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if successMessage %}
        {% set notificationMessage = successMessage %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      <div class="app-page-header">
        <h1 class="govuk-heading-xl govuk-!-margin-bottom-2">{{ goal.title }}</h1>
        {% if goal.status == 'completed' or goal.is_completed or goal.isCompleted %}
          {{ govukTag({ text: "Completed", classes: "govuk-tag--green" }) }}
        {% elif goal.status == 'in_progress' or goal.status == 'active' %}
          {{ govukTag({ text: "In progress", classes: "govuk-tag--blue" }) }}
        {% else %}
          {{ govukTag({ text: goal.status or "Active", classes: "govuk-tag--grey" }) }}
        {% endif %}
      </div>

      {% if goal.description %}
        <p class="govuk-body-l">{{ goal.description }}</p>
      {% endif %}

      {# Overall progress #}
      {% set progress = goal.progress or goal.progress_percent or 0 %}
      <div class="govuk-!-margin-bottom-6">
        <h2 class="govuk-heading-m">Overall progress</h2>
        <p class="govuk-body govuk-!-margin-bottom-1">{{ progress }}% complete</p>
        <div style="background: #f3f2f1; height: 20px; border-radius: 4px; overflow: hidden;">
          <div style="background: {% if progress >= 100 %}#00703c{% else %}#1d70b8{% endif %}; height: 100%; width: {{ progress }}%; min-width: {% if progress > 0 %}2px{% else %}0{% endif %};"></div>
        </div>
      </div>

      {{ govukSummaryList({
        rows: [
          {
            key: { text: "Target date" },
            value: { text: (goal.target_date or goal.targetDate) | date if goal.target_date or goal.targetDate else "Not set" }
          },
          {
            key: { text: "Created" },
            value: { text: (goal.created_at or goal.createdAt) | formatDate if goal.created_at or goal.createdAt else "Unknown" }
          }
        ]
      }) }}

      {# Milestones #}
      {% set milestones = goal.milestones or [] %}
      {% if milestones.length > 0 %}
        <h2 class="govuk-heading-m govuk-!-margin-top-6">Milestones</h2>

        <ol class="govuk-list govuk-list--number">
          {% for milestone in milestones %}
            <li class="govuk-!-margin-bottom-4">
              <div>
                <strong class="govuk-!-font-weight-bold">{{ milestone.title }}</strong>
                {% if milestone.is_completed or milestone.isCompleted %}
                  {{ govukTag({ text: "Done", classes: "govuk-tag--green govuk-!-margin-left-1" }) }}
                {% endif %}
              </div>
              {% if milestone.description %}
                <p class="govuk-body-s govuk-!-margin-top-1 govuk-!-margin-bottom-0">{{ milestone.description }}</p>
              {% endif %}
              {% if milestone.target_date or milestone.targetDate %}
                <p class="govuk-body-s govuk-!-margin-top-1 govuk-!-margin-bottom-0" style="color: #505a5f;">
                  Due: {{ (milestone.target_date or milestone.targetDate) | date }}
                </p>
              {% endif %}
            </li>
          {% endfor %}
        </ol>
      {% endif %}

      <p class="govuk-body govuk-!-margin-top-6">
        <a href="/goals" class="govuk-link">Back to goals</a>
      </p>

    </div>
  </div>
{% endblock %}
