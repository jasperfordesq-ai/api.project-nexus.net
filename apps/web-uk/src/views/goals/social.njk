{% extends "layouts/base.njk" %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% macro renderComment(comment, goal, csrfToken, isReply) %}
  <li class="nexus-alpha-comment" id="comment-{{ comment.id }}">
    <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">
      <strong>{{ comment.authorName }}</strong>
      {% if comment.isOwn %}
        <span class="govuk-!-font-weight-regular"> (You)</span>
      {% endif %}
      {% if comment.edited %}
        <span class="govuk-!-font-weight-regular"> (Edited)</span>
      {% endif %}
      {% if comment.createdAtLabel %}
        <span aria-hidden="true"> | </span>
        <time datetime="{{ comment.createdAt }}">{{ comment.createdAtLabel }}</time>
      {% endif %}
    </p>
    <p class="govuk-body govuk-!-margin-bottom-2">{{ comment.content }}</p>

    {% if comment.id and not isReply %}
      <div class="nexus-alpha-comment-actions govuk-!-margin-bottom-2">
        <details class="govuk-details govuk-!-margin-bottom-0" data-module="govuk-details">
          <summary class="govuk-details__summary">
            <span class="govuk-details__summary-text">Reply</span>
          </summary>
          <div class="govuk-details__text">
            <form method="post" action="/goals/{{ goal.id }}/comments">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}">
              <input type="hidden" name="parent_id" value="{{ comment.id }}">
              <div class="govuk-form-group">
                <label class="govuk-label govuk-label--s" for="reply-{{ comment.id }}">Your reply</label>
                <textarea class="govuk-textarea" id="reply-{{ comment.id }}" name="body" rows="3" maxlength="5000" required></textarea>
              </div>
              <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">Post reply</button>
            </form>
          </div>
        </details>

        {% if comment.isOwn %}
          <details class="govuk-details govuk-!-margin-bottom-0" data-module="govuk-details">
            <summary class="govuk-details__summary">
              <span class="govuk-details__summary-text">Delete</span>
            </summary>
            <div class="govuk-details__text">
              <div class="govuk-warning-text">
                <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
                <strong class="govuk-warning-text__text">
                  <span class="govuk-visually-hidden">Warning</span>
                  Deleting a comment also removes any replies to it. This cannot be undone.
                </strong>
              </div>
              <form method="post" action="/goals/{{ goal.id }}/comments/{{ comment.id }}/delete">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button">Delete</button>
              </form>
            </div>
          </details>
        {% endif %}
      </div>
    {% elseif comment.id and comment.isOwn %}
      <details class="govuk-details govuk-!-margin-bottom-0" data-module="govuk-details">
        <summary class="govuk-details__summary">
          <span class="govuk-details__summary-text">Delete</span>
        </summary>
        <div class="govuk-details__text">
          <div class="govuk-warning-text">
            <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
            <strong class="govuk-warning-text__text">
              <span class="govuk-visually-hidden">Warning</span>
              Deleting a comment also removes any replies to it. This cannot be undone.
            </strong>
          </div>
          <form method="post" action="/goals/{{ goal.id }}/comments/{{ comment.id }}/delete">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button">Delete</button>
          </form>
        </div>
      </details>
    {% endif %}

    {% if comment.replies.length %}
      <ul class="govuk-list nexus-alpha-comments-list--nested">
        {% for reply in comment.replies %}
          {{ renderComment(reply, goal, csrfToken, true) }}
        {% endfor %}
      </ul>
    {% endif %}
  </li>
{% endmacro %}

{% block mainContent %}
  <a class="govuk-back-link" href="/goals/{{ goal.id }}">Back to goal</a>

  {% if statusBanner and statusBanner.type == "success" %}
    {{ govukNotificationBanner({
      type: "success",
      titleText: statusBanner.title,
      text: statusBanner.message
    }) }}
  {% elif statusBanner and statusBanner.type == "error" %}
    {{ govukErrorSummary({
      titleText: statusBanner.title,
      errorList: [
        {
          text: statusBanner.message,
          href: "#body"
        }
      ]
    }) }}
  {% endif %}

  <span class="govuk-caption-xl">Goal: {{ goal.title }}</span>
  <h1 class="govuk-heading-xl govuk-!-margin-bottom-2">Likes and comments</h1>
  <p class="govuk-body-l">Show your support for this goal and join the conversation.</p>

  <section id="likes" class="govuk-!-margin-bottom-6">
    <h2 class="govuk-heading-l">Support</h2>
    <p class="govuk-body nexus-alpha-meta govuk-!-margin-bottom-2" aria-live="polite">{{ likeCountLabel }}</p>
    <form method="post" action="/goals/{{ goal.id }}/like">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
      <button class="govuk-button{% if not liked %} govuk-button--secondary{% endif %} govuk-!-margin-bottom-0" data-module="govuk-button" aria-pressed="{% if liked %}true{% else %}false{% endif %}">
        <span aria-hidden="true">{% if liked %}&hearts;{% else %}&#9825;{% endif %}</span>
        {% if liked %}Remove your like{% else %}Like this goal{% endif %}
      </button>
    </form>
  </section>

  <hr class="govuk-section-break govuk-section-break--visible govuk-section-break--l">

  <section id="comments">
    <h2 class="govuk-heading-l">
      Comments
      <span class="govuk-!-font-weight-regular">({{ commentsTotal }})</span>
    </h2>
    <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-3" aria-live="polite">{{ commentsTotalLabel }}</p>

    {% if not comments.length %}
      <div class="govuk-inset-text"><p class="govuk-body">No comments yet. Be the first to leave one.</p></div>
    {% else %}
      <ul class="govuk-list nexus-alpha-comments-list">
        {% for comment in comments %}
          {{ renderComment(comment, goal, csrfToken, false) }}
        {% endfor %}
      </ul>
    {% endif %}

    <h3 class="govuk-heading-m govuk-!-margin-top-6">Add a comment</h3>
    <form method="post" action="/goals/{{ goal.id }}/comments">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
      <div class="govuk-form-group{% if statusBanner and statusBanner.message == 'Please enter a comment before posting.' %} govuk-form-group--error{% endif %}">
        <label class="govuk-label govuk-label--s" for="body">Your comment</label>
        <div id="body-hint" class="govuk-hint">Keep it kind and supportive.</div>
        {% if statusBanner and statusBanner.message == 'Please enter a comment before posting.' %}
          <p id="body-error" class="govuk-error-message"><span class="govuk-visually-hidden">Error:</span> Please enter a comment before posting.</p>
        {% endif %}
        <textarea class="govuk-textarea{% if statusBanner and statusBanner.message == 'Please enter a comment before posting.' %} govuk-textarea--error{% endif %}" id="body" name="body" rows="4" maxlength="5000" aria-describedby="body-hint{% if statusBanner and statusBanner.message == 'Please enter a comment before posting.' %} body-error{% endif %}"></textarea>
      </div>
      <button type="submit" class="govuk-button" data-module="govuk-button">Post comment</button>
    </form>
  </section>
{% endblock %}
