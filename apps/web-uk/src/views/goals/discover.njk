{% extends "layouts/base.njk" %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <a class="govuk-back-link" href="{{ urlFor('/goals') }}">Back to goals</a>

      {% if successMessage %}
        {{ govukNotificationBanner({
          type: "success",
          titleText: "Success",
          text: successMessage
        }) }}
      {% endif %}

      {% if errorMessage %}
        {{ govukErrorSummary({
          titleText: "There is a problem",
          errorList: [
            {
              text: errorMessage,
              href: "#discover-goals"
            }
          ]
        }) }}
      {% endif %}

      <span class="govuk-caption-xl">Community goals</span>
      <h1 class="govuk-heading-xl" id="discover-goals">Discover goals</h1>
      <p class="govuk-body-l">Browse public goals from community members and offer to become a buddy.</p>

      {% if not goals or not goals.length %}
        <div class="govuk-inset-text">
          <p class="govuk-body">There are no public goals available for buddying right now.</p>
        </div>
      {% else %}
        <div class="nexus-alpha-card-list">
          {% for goal in goals %}
            <article class="nexus-alpha-card">
              <h2 class="govuk-heading-s govuk-!-margin-bottom-1">
                <a class="govuk-link" href="{{ urlFor('/goals/' + (goal.id | string)) }}">{{ goal.title }}</a>
              </h2>
              <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">Owned by {{ goal.ownerName }}</p>

              {% if goal.description %}
                <p class="govuk-body-s govuk-!-margin-bottom-1">{{ goal.description }}</p>
              {% endif %}

              <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">{{ goal.currentText }} of {{ goal.targetText }}</p>
              <progress max="100" value="{{ goal.progressPercent }}" aria-label="{{ goal.progressPercent }}%">{{ goal.progressPercent }}%</progress>

              <form method="post" action="{{ urlFor('/goals/' + (goal.id | string) + '/buddy') }}" class="govuk-!-margin-top-2">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <button class="govuk-button govuk-!-margin-bottom-0" data-module="govuk-button" type="submit">Become buddy</button>
              </form>
            </article>
          {% endfor %}
        </div>
      {% endif %}

      {% if nextHref %}
        <p class="govuk-body govuk-!-margin-top-6">
          <a class="govuk-link" href="{{ urlFor(nextHref) }}">Load more goals</a>
        </p>
      {% endif %}
    </div>
  </div>
{% endblock %}
