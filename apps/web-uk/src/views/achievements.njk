{% extends "layouts/base.njk" %}

{% block mainContent %}
  {% set profile = achievementProfile or {} %}
  {% set daily = dailyReward or {} %}
  {% set level = profile.level or 0 %}
  {% set xp = profile.xp or 0 %}
  {% set badgesCount = profile.badgesCount or 0 %}
  {% set levelProgressPercent = profile.levelProgressPercent or 0 %}

  <span class="govuk-caption-xl">{{ tenantName }}</span>
  <h1 class="govuk-heading-xl">Achievements</h1>
  <p class="govuk-body-l">Your level, experience and the badges you have earned in this community.</p>

  <dl class="govuk-summary-list govuk-!-margin-bottom-4">
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Level</dt>
      <dd class="govuk-summary-list__value">
        {{ level }}{% if profile.levelName %} &mdash; {{ profile.levelName }}{% endif %}
      </dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Experience points</dt>
      <dd class="govuk-summary-list__value">{{ xp }}</dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Badges earned</dt>
      <dd class="govuk-summary-list__value">{{ badgesCount }}</dd>
    </div>
  </dl>

  {% if profile.atMaxLevel %}
    <p class="govuk-body">You have reached the top level.</p>
  {% else %}
    <p class="govuk-body govuk-!-margin-bottom-1">{{ levelProgressPercent }}% of the way to the next level</p>
    <span class="govuk-body-s govuk-!-margin-right-2">{{ levelProgressPercent }}%</span><progress max="100" value="{{ levelProgressPercent }}" aria-label="{{ levelProgressPercent }}%">{{ levelProgressPercent }}%</progress>
  {% endif %}

  <h2 class="govuk-heading-l govuk-!-margin-top-7">Daily reward</h2>
  <p class="govuk-body">Claim your daily login reward to build your streak and earn bonus XP.</p>

  {% if status == "daily-reward-claimed" %}
    <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="daily-reward-status">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="daily-reward-status">Success</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">Daily reward claimed! You earned {{ daily.rewardXp or 5 }} XP.</p>
      </div>
    </div>
  {% elif status == "daily-reward-failed" %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            <li>Unable to claim your reward. Please try again later.</li>
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  <dl class="govuk-summary-list govuk-!-margin-bottom-4">
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Current streak: {{ daily.streak or 0 }} day(s)</dt>
      <dd class="govuk-summary-list__value">Claim today to earn {{ daily.nextXp or 5 }} XP</dd>
    </div>
  </dl>

  {% if daily.canClaim %}
    <form method="post" action="{{ alphaRoutePrefix }}/achievements/daily-reward">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
      <button class="govuk-button" data-module="govuk-button" type="submit">Claim daily reward</button>
    </form>
  {% else %}
    <p class="govuk-body"><strong class="govuk-tag govuk-tag--green">Daily reward already claimed today.</strong></p>
  {% endif %}

  <h2 class="govuk-heading-l govuk-!-margin-top-7">Active challenges</h2>
  <p class="govuk-body">Complete these challenges to earn XP rewards.</p>

  {% if status == "challenge-claimed" %}
    <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="challenge-status">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="challenge-status">Success</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">Challenge reward claimed!</p>
      </div>
    </div>
  {% elif status == "challenge-claim-failed" %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            <li>Unable to claim reward. Please try again.</li>
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  {% if not challenges or challenges.length == 0 %}
    <div class="govuk-inset-text"><p class="govuk-body">There are no active challenges right now.</p></div>
  {% else %}
    <div class="nexus-alpha-card-list govuk-!-margin-bottom-8">
      {% for challenge in challenges %}
        <article class="nexus-alpha-card">
          <div class="nexus-alpha-module-row">
            <h3 class="govuk-heading-s govuk-!-margin-bottom-1">{{ challenge.name }}</h3>
            {% if challenge.rewardClaimed %}
              <strong class="govuk-tag govuk-tag--green">Reward claimed</strong>
            {% elif challenge.isCompleted %}
              <strong class="govuk-tag govuk-tag--blue">Completed</strong>
            {% endif %}
          </div>
          {% if challenge.description %}
            <p class="govuk-body-s govuk-!-margin-bottom-1">{{ challenge.description }}</p>
          {% endif %}
          <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">
            {{ challenge.progress or 0 }} of {{ challenge.target or 0 }}
            &middot; Reward: {{ challenge.rewardXp or 0 }} XP
            {% if challenge.daysRemaining %}&middot; {{ challenge.daysRemaining }} day(s) left{% endif %}
          </p>
          <span class="govuk-body-s govuk-!-margin-right-2">{{ challenge.percent or 0 }}%</span><progress max="100" value="{{ challenge.percent or 0 }}" aria-label="{{ challenge.percent or 0 }}%">{{ challenge.percent or 0 }}%</progress>
          {% if challenge.isCompleted and not challenge.rewardClaimed and challenge.id %}
            <form method="post" action="{{ alphaRoutePrefix }}/achievements/challenges/{{ challenge.id }}/claim" class="govuk-!-margin-top-2">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}">
              <button class="govuk-button govuk-!-margin-bottom-0" data-module="govuk-button" type="submit">Claim reward</button>
            </form>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% endif %}

  <h2 class="govuk-heading-l govuk-!-margin-top-7">Your badges</h2>
  {% if not earnedBadges or earnedBadges.length == 0 %}
    <div class="govuk-inset-text"><p class="govuk-body">You have not earned any badges yet. Take part in the community to start earning them.</p></div>
  {% else %}
    <div class="nexus-alpha-card-list">
      {% for badge in earnedBadges %}
        <article class="nexus-alpha-card">
          <h3 class="govuk-heading-s govuk-!-margin-bottom-1">{{ badge.icon }} {{ badge.name }}</h3>
          {% if badge.description %}
            <p class="govuk-body-s govuk-!-margin-bottom-0">{{ badge.description }}</p>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% endif %}

  {% if badgeProgress and badgeProgress.length > 0 %}
    <h2 class="govuk-heading-l govuk-!-margin-top-7">Almost there</h2>
    {% for item in badgeProgress %}
      <div class="govuk-!-margin-bottom-3">
        <p class="govuk-body govuk-!-margin-bottom-1">{{ item.name }} &mdash; {{ item.remaining or 0 }} to go</p>
        <span class="govuk-body-s govuk-!-margin-right-2">{{ item.percent or 0 }}%</span><progress max="100" value="{{ item.percent or 0 }}" aria-label="{{ item.percent or 0 }}%">{{ item.percent or 0 }}%</progress>
      </div>
    {% endfor %}
  {% endif %}
{% endblock %}
