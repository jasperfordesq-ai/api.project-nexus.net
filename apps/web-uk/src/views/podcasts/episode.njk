{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a href="{{ urlFor('/podcasts/' + (show.id | string)) }}" class="govuk-back-link">Back to podcast</a>

  <span class="govuk-caption-xl">{{ show.title }}</span>
  <h1 class="govuk-heading-xl">{{ episode.title }}</h1>

  {% if episode.description %}
    <div class="govuk-body-l">{{ episode.description | nl2br | safe }}</div>
  {% endif %}

  {% if episode.audioUrl %}
    <div class="govuk-!-margin-bottom-6">
      <audio controls preload="metadata" class="nexus-alpha-audio" src="{{ episode.audioUrl }}" aria-label="Listen to {{ episode.title }}">
        <a class="govuk-link" href="{{ episode.audioUrl }}">Download episode: {{ episode.title }}</a>
      </audio>
    </div>
  {% else %}
    <div class="govuk-inset-text">
      <p class="govuk-body">No audio is available for this episode.</p>
    </div>
  {% endif %}

  {% if episode.transcript %}
    <h2 class="govuk-heading-m">Read transcript</h2>
    <div class="govuk-body">{{ episode.transcript | nl2br | safe }}</div>
  {% endif %}
{% endblock %}
