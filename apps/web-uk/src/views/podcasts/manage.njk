{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a class="govuk-back-link" href="{{ urlFor('/podcasts/studio') }}">{{ t("govuk_alpha_commerce.podcast_studio.back_to_studio") }}</a>

  {% if status %}
    {% if status.type == "success" %}
      <div class="govuk-notification-banner govuk-notification-banner--success" role="alert" aria-labelledby="podcast-manage-status-heading" data-module="govuk-notification-banner">
        <div class="govuk-notification-banner__header">
          <h2 class="govuk-notification-banner__title" id="podcast-manage-status-heading">{{ t("states.success_title") }}</h2>
        </div>
        <div class="govuk-notification-banner__content">
          <p class="govuk-notification-banner__heading">{{ status.message }}</p>
        </div>
      </div>
    {% else %}
      <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
        <div role="alert">
          <h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2>
          <div class="govuk-error-summary__body">
            <ul class="govuk-list govuk-error-summary__list">
              <li>{{ status.message }}</li>
            </ul>
          </div>
        </div>
      </div>
    {% endif %}
  {% endif %}

  <h1 class="govuk-heading-xl">{{ t("govuk_alpha_commerce.podcast_studio.title_edit") }}</h1>

  {% if show.status != "published" %}
    <p class="govuk-body">{{ t("govuk_alpha_commerce.podcast_studio.publish_hint") }}</p>
  {% endif %}

  <form method="post" action="{{ urlFor('/podcasts/studio/' + (show.id | string) + '/update') }}" novalidate>
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--s" for="title">{{ t("govuk_alpha_commerce.podcast_studio.show_title_label") }}</label>
      <input class="govuk-input" id="title" name="title" type="text" maxlength="200" value="{{ show.title }}">
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--s" for="summary">{{ t("govuk_alpha_commerce.podcast_studio.summary_label") }} <span class="govuk-hint govuk-!-display-inline">({{ t("govuk_alpha_commerce.common.optional") }})</span></label>
      <input class="govuk-input" id="summary" name="summary" type="text" maxlength="600" value="{{ show.summary }}">
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--s" for="description">{{ t("govuk_alpha_commerce.podcast_studio.description_label") }} <span class="govuk-hint govuk-!-display-inline">({{ t("govuk_alpha_commerce.common.optional") }})</span></label>
      <textarea class="govuk-textarea" id="description" name="description" rows="5">{{ show.description }}</textarea>
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--s" for="category">{{ t("govuk_alpha_commerce.podcast_studio.category_label") }} <span class="govuk-hint govuk-!-display-inline">({{ t("govuk_alpha_commerce.common.optional") }})</span></label>
      <input class="govuk-input govuk-input--width-20" id="category" name="category" type="text" maxlength="120" value="{{ show.category }}">
    </div>

    <div class="govuk-form-group">
      <fieldset class="govuk-fieldset">
        <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">{{ t("govuk_alpha_commerce.podcast_studio.visibility_label") }}</legend>
        <div class="govuk-radios govuk-radios--small" data-module="govuk-radios">
          <div class="govuk-radios__item">
            <input class="govuk-radios__input" id="visibility" name="visibility" type="radio" value="public" {% if show.visibility == "public" %}checked{% endif %}>
            <label class="govuk-label govuk-radios__label" for="visibility">{{ t("govuk_alpha_commerce.podcast_studio.visibility_public") }}</label>
          </div>
          <div class="govuk-radios__item">
            <input class="govuk-radios__input" id="visibility-members" name="visibility" type="radio" value="members" {% if show.visibility == "members" %}checked{% endif %}>
            <label class="govuk-label govuk-radios__label" for="visibility-members">{{ t("govuk_alpha_commerce.podcast_studio.visibility_members") }}</label>
          </div>
          <div class="govuk-radios__item">
            <input class="govuk-radios__input" id="visibility-private" name="visibility" type="radio" value="private" {% if show.visibility == "private" %}checked{% endif %}>
            <label class="govuk-label govuk-radios__label" for="visibility-private">{{ t("govuk_alpha_commerce.podcast_studio.visibility_private") }}</label>
          </div>
        </div>
      </fieldset>
    </div>

    <button class="govuk-button" data-module="govuk-button">{{ t("govuk_alpha_commerce.podcast_studio.submit_edit") }}</button>
  </form>

  <h2 class="govuk-heading-m govuk-!-margin-top-8">{{ t("govuk_alpha_commerce.podcast_studio.episodes_heading") }}</h2>

  {% if not episodes.length %}
    <p class="govuk-inset-text">{{ t("govuk_alpha_commerce.podcast_studio.no_episodes") }}</p>
  {% else %}
    <ul class="govuk-list">
      {% for episode in episodes %}
        <li class="nexus-alpha-card govuk-!-margin-bottom-3">
          <div class="nexus-alpha-module-row">
            <span>
              {% if episode.episodeNumberLabel %}<span class="govuk-body-s nexus-alpha-meta">{{ episode.episodeNumberLabel }} - </span>{% endif %}
              {{ episode.title }}
            </span>
            <strong class="govuk-tag {{ episode.statusTag }}">{{ episode.statusLabel }}</strong>
          </div>
          <div class="nexus-alpha-actions govuk-!-margin-top-2">
            {% if episode.status != "published" %}
              <form method="post" action="{{ urlFor('/podcasts/studio/' + (show.id | string) + '/episodes/' + (episode.id | string) + '/publish') }}" class="govuk-!-display-inline">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
              <button class="govuk-button govuk-button--secondary govuk-button--small" data-module="govuk-button">{{ t("govuk_alpha_commerce.podcast_studio.episode_action_publish") }}</button>
              </form>
            {% endif %}
            <form method="post" action="{{ urlFor('/podcasts/studio/' + (show.id | string) + '/episodes/' + (episode.id | string) + '/delete') }}" class="govuk-!-display-inline">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}">
              <button class="govuk-button govuk-button--warning govuk-button--small" data-module="govuk-button">{{ t("govuk_alpha_commerce.podcast_studio.episode_action_delete") }}</button>
            </form>
          </div>
        </li>
      {% endfor %}
    </ul>
  {% endif %}

  <h3 class="govuk-heading-s govuk-!-margin-top-4">{{ t("govuk_alpha_commerce.podcast_studio.add_episode_heading") }}</h3>
  <form method="post" action="{{ urlFor(episodeStoreAction) }}" enctype="multipart/form-data" novalidate class="govuk-!-margin-bottom-6">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--s" for="episode_title">{{ t("govuk_alpha_commerce.podcast_studio.episode_title_label") }}</label>
      <div id="episode_title-hint" class="govuk-hint">{{ t("govuk_alpha_commerce.podcast_studio.episode_title_hint") }}</div>
      <input class="govuk-input" id="episode_title" name="episode_title" type="text" maxlength="200" aria-describedby="episode_title-hint">
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--s" for="episode_number">{{ t("govuk_alpha_commerce.podcast_studio.episode_number_label") }} <span class="govuk-hint govuk-!-display-inline">({{ t("govuk_alpha_commerce.common.optional") }})</span></label>
      <div id="episode_number-hint" class="govuk-hint">{{ t("govuk_alpha_commerce.podcast_studio.episode_number_hint") }}</div>
      <input class="govuk-input govuk-input--width-5" id="episode_number" name="episode_number" type="text" inputmode="numeric" aria-describedby="episode_number-hint">
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--s" for="episode_summary">{{ t("govuk_alpha_commerce.podcast_studio.episode_summary_label") }} <span class="govuk-hint govuk-!-display-inline">({{ t("govuk_alpha_commerce.common.optional") }})</span></label>
      <div id="episode_summary-hint" class="govuk-hint">{{ t("govuk_alpha_commerce.podcast_studio.episode_summary_hint") }}</div>
      <input class="govuk-input" id="episode_summary" name="episode_summary" type="text" maxlength="600" aria-describedby="episode_summary-hint">
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--s" for="episode_description">{{ t("govuk_alpha_commerce.podcast_studio.episode_description_label") }} <span class="govuk-hint govuk-!-display-inline">({{ t("govuk_alpha_commerce.common.optional") }})</span></label>
      <div id="episode_description-hint" class="govuk-hint">{{ t("govuk_alpha_commerce.podcast_studio.episode_description_hint") }}</div>
      <textarea class="govuk-textarea" id="episode_description" name="episode_description" rows="3" aria-describedby="episode_description-hint"></textarea>
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--s" for="audio">{{ t("govuk_alpha_commerce.podcast_studio.audio_file_label") }}</label>
      <div id="audio-hint" class="govuk-hint">{{ t("govuk_alpha_commerce.podcast_studio.audio_file_hint") }}</div>
      <input class="govuk-file-upload" id="audio" name="audio" type="file" accept="audio/*" aria-describedby="audio-hint">
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--s" for="audio_url">{{ t("govuk_alpha_commerce.podcast_studio.audio_url_label") }} <span class="govuk-hint govuk-!-display-inline">({{ t("govuk_alpha_commerce.common.optional") }})</span></label>
      <div id="audio_url-hint" class="govuk-hint">{{ t("govuk_alpha_commerce.podcast_studio.audio_url_hint") }}</div>
      <input class="govuk-input" id="audio_url" name="audio_url" type="url" inputmode="url" aria-describedby="audio_url-hint">
    </div>

    <button class="govuk-button govuk-button--secondary" data-module="govuk-button">{{ t("govuk_alpha_commerce.podcast_studio.add_episode_button") }}</button>
  </form>

  {% if show.status != "published" %}
    <h2 class="govuk-heading-m govuk-!-margin-top-6">{{ t("govuk_alpha_commerce.podcast_studio.action_publish_heading") }}</h2>
    <form method="post" action="{{ urlFor('/podcasts/studio/' + (show.id | string) + '/publish') }}">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
      <button class="govuk-button govuk-button--secondary" data-module="govuk-button">{{ t("govuk_alpha_commerce.podcast_studio.action_publish") }}</button>
    </form>
  {% endif %}

  <h2 class="govuk-heading-m govuk-!-margin-top-6">{{ t("govuk_alpha_commerce.podcast_studio.delete_heading") }}</h2>
  <div class="govuk-warning-text">
    <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
    <strong class="govuk-warning-text__text">
      <span class="govuk-visually-hidden">{{ t("govuk_alpha_commerce.common.notice_title") }}</span>
      {{ t("govuk_alpha_commerce.podcast_studio.delete_warning") }}
    </strong>
  </div>
  <form method="post" action="{{ urlFor('/podcasts/studio/' + (show.id | string) + '/delete') }}">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    <button class="govuk-button govuk-button--warning" data-module="govuk-button">{{ t("govuk_alpha_commerce.podcast_studio.action_delete") }}</button>
  </form>
{% endblock %}
