{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a href="{{ urlFor('/podcasts') }}" class="govuk-back-link">Back to podcasts</a>

  {% if status %}
    {% if status.type == "success" %}
      <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="podcast-status-heading">
        <div class="govuk-notification-banner__header">
          <h2 class="govuk-notification-banner__title" id="podcast-status-heading">Success</h2>
        </div>
        <div class="govuk-notification-banner__content">
          <p class="govuk-notification-banner__heading">{{ status.message }}</p>
        </div>
      </div>
    {% else %}
      <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
        <div role="alert">
          <h2 class="govuk-error-summary__title">There is a problem</h2>
          <div class="govuk-error-summary__body">
            <ul class="govuk-list govuk-error-summary__list">
              <li>{{ status.message }}</li>
            </ul>
          </div>
        </div>
      </div>
    {% endif %}
  {% endif %}

  {% if show.artworkUrl %}
    <img class="nexus-alpha-avatar nexus-alpha-avatar--xl govuk-!-margin-bottom-4" src="{{ show.artworkUrl }}" alt="" aria-hidden="true" loading="lazy" decoding="async">
  {% endif %}

  <span class="govuk-caption-xl">{% if show.byLabel %}{{ show.byLabel }}{% else %}Project NEXUS Accessible{% endif %}</span>
  <h1 class="govuk-heading-xl">{{ show.title }}</h1>

  {% if show.description %}
    <div class="govuk-body-l">{{ show.description | nl2br | safe }}</div>
  {% endif %}

  {% if show.rssEnabled %}
    <p class="govuk-body-s">
      <a class="govuk-link" href="{{ show.rssUrl }}" target="_blank" rel="noopener noreferrer">RSS feed<span class="govuk-visually-hidden"> opens in a new tab</span></a>
    </p>
  {% endif %}

  <form method="post" action="{{ urlFor('/podcasts/' + (show.id | string) + '/subscribe') }}" class="govuk-!-margin-bottom-6">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">
      {% if isSubscribed %}Unsubscribe from this podcast{% else %}Subscribe to this podcast{% endif %}
    </button>
  </form>

  <h2 class="govuk-heading-l govuk-!-margin-top-6">Episodes</h2>
  {% if not episodes.length %}
    <div class="govuk-inset-text">
      <p class="govuk-body">No episodes have been published yet.</p>
    </div>
  {% else %}
    <div class="nexus-alpha-card-list">
      {% for episode in episodes %}
        <article class="nexus-alpha-card">
          <h3 class="govuk-heading-s govuk-!-margin-bottom-1">
            <a class="govuk-link" href="{{ urlFor('/podcasts/' + (show.id | string) + '/episodes/' + (episode.id | string)) }}">{{ episode.title }}</a>
          </h3>
          {% if episode.description %}
            <p class="govuk-body govuk-!-margin-bottom-2">{{ episode.description }}</p>
          {% endif %}
          {% if episode.audioUrl %}
            <audio controls preload="none" class="nexus-alpha-audio" src="{{ episode.audioUrl }}" aria-label="{{ episode.title }}">
              <a class="govuk-link" href="{{ episode.audioUrl }}">Download episode: {{ episode.title }}</a>
            </audio>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
