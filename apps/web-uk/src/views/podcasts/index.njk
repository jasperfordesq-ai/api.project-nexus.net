{% extends "layouts/base.njk" %}

{% block mainContent %}
  <span class="govuk-caption-xl">Project NEXUS Accessible</span>
  <h1 class="govuk-heading-xl">{{ t("podcasts.title") }}</h1>
  <p class="govuk-body-l">{{ t("podcasts.description") }}</p>

  <p class="govuk-body">
    <a class="govuk-link" href="{{ urlFor('/podcasts/studio') }}">Podcast studio</a>
  </p>

  <form method="get" action="{{ urlFor('/podcasts') }}" class="govuk-!-margin-bottom-6">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-one-third">
        <div class="govuk-form-group">
          <label class="govuk-label" for="q">{{ t("polish_commerce.podcast_search_label") }}</label>
          <div id="podcast-q-hint" class="govuk-hint">Search by title or description.</div>
          <input class="govuk-input" id="q" name="q" type="search" value="{{ query }}" aria-describedby="podcast-q-hint">
        </div>
      </div>
      <div class="govuk-grid-column-one-third">
        <div class="govuk-form-group">
          <label class="govuk-label" for="sort">Sort by</label>
          <select class="govuk-select" id="sort" name="sort">
            <option value="newest" {% if sort == "newest" %}selected{% endif %}>{{ t("polish_commerce.podcast_sort_newest") }}</option>
            <option value="title" {% if sort == "title" %}selected{% endif %}>{{ t("polish_commerce.podcast_sort_title") }}</option>
            <option value="episodes" {% if sort == "episodes" %}selected{% endif %}>{{ t("polish_commerce.podcast_sort_episodes") }}</option>
            <option value="followers" {% if sort == "followers" %}selected{% endif %}>{{ t("polish_commerce.podcast_sort_followers") }}</option>
          </select>
        </div>
      </div>
      {% if category %}
        <div class="govuk-grid-column-one-third">
          <div class="govuk-form-group">
            <label class="govuk-label" for="category">Category</label>
            <input class="govuk-input" id="category" name="category" type="text" value="{{ category }}">
          </div>
        </div>
      {% endif %}
    </div>
    <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">Search</button>
  </form>

  {% if not shows.length %}
    <div class="govuk-inset-text">
      <p class="govuk-body">{{ t("podcasts.empty") }}</p>
    </div>
  {% else %}
    <div class="nexus-alpha-card-list">
      {% for show in shows %}
        <article class="nexus-alpha-card">
          {% if show.artworkUrl %}
            <img class="nexus-alpha-avatar" src="{{ show.artworkUrl }}" alt="" aria-hidden="true" loading="lazy" decoding="async">
          {% endif %}
          <h2 class="govuk-heading-s govuk-!-margin-bottom-1">
            <a class="govuk-link" href="{{ urlFor('/podcasts/' + (show.id | string)) }}">{{ show.title }}</a>
          </h2>
          {% if show.description %}
            <p class="govuk-body govuk-!-margin-bottom-1">{{ show.description }}</p>
          {% elseif show.summary %}
            <p class="govuk-body govuk-!-margin-bottom-1">{{ show.summary }}</p>
          {% endif %}
          <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-0">
            {% if show.byLabel %}{{ show.byLabel }} - {% endif %}{{ show.episodeCount }} episodes
          </p>
        </article>
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
