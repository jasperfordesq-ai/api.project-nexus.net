{% extends "layouts/base.njk" %}

{% block mainContent %}
  {% set impact = communityImpact or {} %}

  <span class="govuk-caption-xl">{{ tenantName }}</span>
  <h1 class="govuk-heading-xl">Leaderboard</h1>
  <p class="govuk-body-l">See how members are contributing to the community.</p>

  <h2 class="govuk-heading-m govuk-!-margin-top-2">Community impact</h2>
  <p class="govuk-body govuk-!-margin-bottom-4">Aggregate activity across this timebank community.</p>
  <div class="nexus-alpha-stat-grid govuk-!-margin-bottom-6">
    <dl class="nexus-alpha-stat">
      <dt class="govuk-body-s nexus-alpha-meta">Total members</dt>
      <dd class="govuk-heading-m govuk-!-margin-bottom-0">{{ impact.totalMembers or 0 }}</dd>
    </dl>
    <dl class="nexus-alpha-stat">
      <dt class="govuk-body-s nexus-alpha-meta">Exchanges completed</dt>
      <dd class="govuk-heading-m govuk-!-margin-bottom-0">{{ impact.totalExchanges or 0 }}</dd>
    </dl>
    <dl class="nexus-alpha-stat">
      <dt class="govuk-body-s nexus-alpha-meta">Hours exchanged</dt>
      <dd class="govuk-heading-m govuk-!-margin-bottom-0">{{ impact.totalVolunteerHours or "0.0" }}</dd>
    </dl>
    <dl class="nexus-alpha-stat">
      <dt class="govuk-body-s nexus-alpha-meta">Active listings</dt>
      <dd class="govuk-heading-m govuk-!-margin-bottom-0">{{ impact.totalListings or 0 }}</dd>
    </dl>
    <dl class="nexus-alpha-stat">
      <dt class="govuk-body-s nexus-alpha-meta">Connections made</dt>
      <dd class="govuk-heading-m govuk-!-margin-bottom-0">{{ impact.totalConnections or 0 }}</dd>
    </dl>
    <dl class="nexus-alpha-stat">
      <dt class="govuk-body-s nexus-alpha-meta">Badges awarded</dt>
      <dd class="govuk-heading-m govuk-!-margin-bottom-0">{{ impact.totalBadgesAwarded or 0 }}</dd>
    </dl>
  </div>

  <form method="get" action="{{ alphaRoutePrefix }}/leaderboard" data-alpha-auto-submit class="govuk-!-margin-bottom-6">
    <fieldset class="govuk-fieldset">
      <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
        <h2 class="govuk-fieldset__heading">Filter leaderboard</h2>
      </legend>
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-one-half">
          <div class="govuk-form-group">
            <label class="govuk-label" for="type">Ranked by</label>
            <select class="govuk-select" id="type" name="type">
              {% for type in leaderboardTypes %}
                <option value="{{ type.value }}"{% if type.value == leaderboardType %} selected{% endif %}>{{ type.label }}</option>
              {% endfor %}
            </select>
          </div>
        </div>
        <div class="govuk-grid-column-one-half">
          <div class="govuk-form-group">
            <label class="govuk-label" for="period">Period</label>
            <select class="govuk-select" id="period" name="period">
              {% for period in leaderboardPeriods %}
                <option value="{{ period.value }}"{% if period.value == leaderboardPeriod %} selected{% endif %}>{{ period.label }}</option>
              {% endfor %}
            </select>
          </div>
        </div>
      </div>
      <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">Update</button>
    </fieldset>
  </form>

  {% if not leaderboardRows or leaderboardRows.length == 0 %}
    <div class="govuk-inset-text"><p class="govuk-body">There is nothing to show here yet.</p></div>
  {% else %}
    <table class="govuk-table">
      <caption class="govuk-table__caption govuk-table__caption--s govuk-visually-hidden">{{ leaderboardType }}</caption>
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header govuk-table__header--numeric">Rank</th>
          <th scope="col" class="govuk-table__header">Member</th>
          <th scope="col" class="govuk-table__header govuk-table__header--numeric">Score</th>
        </tr>
      </thead>
      <tbody class="govuk-table__body">
        {% for row in leaderboardRows %}
          <tr class="govuk-table__row {% if row.isCurrentUser %}nexus-alpha-row--active{% endif %}">
            <td class="govuk-table__cell govuk-table__cell--numeric">{{ row.rank or 0 }}</td>
            <td class="govuk-table__cell">
              {% if row.userId %}
                <a class="govuk-link" href="{{ alphaRoutePrefix }}/members/{{ row.userId }}">{{ row.name }}</a>
              {% else %}
                {{ row.name }}
              {% endif %}
              {% if row.isCurrentUser %}<strong class="govuk-tag govuk-tag--blue">You</strong>{% endif %}
            </td>
            <td class="govuk-table__cell govuk-table__cell--numeric">{{ row.scoreDisplay or row.score or 0 }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% endif %}
{% endblock %}
