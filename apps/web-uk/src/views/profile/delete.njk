{% extends "layouts/base.njk" %}

{% block beforeContent %}
  {{ super() }}
  <a class="govuk-back-link" href="/profile/settings">Back to profile</a>
{% endblock %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">Delete your account</h1>

      {% if errorMessage %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
          <div role="alert">
            <h2 class="govuk-error-summary__title">There is a problem</h2>
            <div class="govuk-error-summary__body">
              <ul class="govuk-list govuk-error-summary__list">
                <li><a href="#{{ 'confirm' if confirmError else 'password' }}">{{ errorMessage }}</a></li>
              </ul>
            </div>
          </div>
        </div>
      {% endif %}

      <div class="govuk-warning-text">
        <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
        <strong class="govuk-warning-text__text">
          <span class="govuk-visually-hidden">Warning</span>
          This will permanently remove your account and personal data from {{ communityName }}. You cannot undo this.
        </strong>
      </div>

      <h2 class="govuk-heading-m">What happens when you delete your account</h2>
      <p class="govuk-body">Your profile, messages and personal details will be deleted or anonymised. We may keep some records where the law requires it.</p>

      <form method="post" action="/profile/delete-account" novalidate>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        <div class="govuk-form-group{% if passwordError %} govuk-form-group--error{% endif %}">
          <label class="govuk-label" for="password">Confirm your password to continue</label>
          <div id="password-hint" class="govuk-hint">For your security, enter your password so we know it is you.</div>
          {% if passwordError %}
            <p id="password-error" class="govuk-error-message">
              <span class="govuk-visually-hidden">Error:</span> {{ errorMessage }}
            </p>
          {% endif %}
          <input class="govuk-input govuk-input--width-20{% if passwordError %} govuk-input--error{% endif %}" id="password" name="password" type="password" autocomplete="current-password" aria-describedby="password-hint{% if passwordError %} password-error{% endif %}">
        </div>

        <div class="govuk-form-group">
          <label class="govuk-label" for="reason">Tell us why you are leaving (optional)</label>
          <textarea class="govuk-textarea" id="reason" name="reason" rows="3"></textarea>
        </div>

        <div class="govuk-form-group{% if confirmError %} govuk-form-group--error{% endif %}">
          {% if confirmError %}
            <p id="confirm-error" class="govuk-error-message">
              <span class="govuk-visually-hidden">Error:</span> {{ errorMessage }}
            </p>
          {% endif %}
          <div class="govuk-checkboxes" data-module="govuk-checkboxes">
            <div class="govuk-checkboxes__item">
              <input class="govuk-checkboxes__input" id="confirm" name="confirm" type="checkbox" value="1"{% if confirmError %} aria-describedby="confirm-error"{% endif %}>
              <label class="govuk-label govuk-checkboxes__label" for="confirm">I understand that my account and data will be permanently deleted</label>
            </div>
          </div>
        </div>

        <div class="govuk-button-group">
          <button class="govuk-button govuk-button--warning" data-module="govuk-button" type="submit">Delete my account</button>
          <a class="govuk-link" href="/profile/settings">Cancel and keep my account</a>
        </div>
      </form>
    </div>
  </div>
{% endblock %}
