{% extends "layouts/base.njk" %}

{% block beforeContent %}
  {{ super() }}
  <a class="govuk-back-link" href="{{ urlFor('/profile/settings') }}">{{ t("actions.back_to_profile") }}</a>
{% endblock %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">{{ t("actions.delete_account") }}</h1>

      {% if errorMessage %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
          <div role="alert">
            <h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2>
            <div class="govuk-error-summary__body">
              <ul class="govuk-list govuk-error-summary__list">
                <li><a href="#{{ 'confirm' if confirmError else 'password' }}">{{ errorMessage }}</a></li>
              </ul>
            </div>
          </div>
        </div>
      {% endif %}

      <div class="govuk-warning-text">
        <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
        <strong class="govuk-warning-text__text">
          <span class="govuk-visually-hidden">Warning</span>
          This will permanently remove your account and personal data from {{ communityName }}. You cannot undo this.
        </strong>
      </div>

      <h2 class="govuk-heading-m">{{ t("delete_account.what_happens_title") }}</h2>
      <p class="govuk-body">{{ t("delete_account.what_happens") }}</p>

      <form method="post" action="{{ urlFor('/profile/delete-account') }}" novalidate>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        <div class="govuk-form-group{% if passwordError %} govuk-form-group--error{% endif %}">
          <label class="govuk-label" for="password">{{ t("delete_account.password_label") }}</label>
          <div id="password-hint" class="govuk-hint">{{ t("delete_account.password_hint") }}</div>
          {% if passwordError %}
            <p id="password-error" class="govuk-error-message">
              <span class="govuk-visually-hidden">{{ t("states.error_prefix") }}</span> {{ errorMessage }}
            </p>
          {% endif %}
          <input class="govuk-input govuk-input--width-20{% if passwordError %} govuk-input--error{% endif %}" id="password" name="password" type="password" autocomplete="current-password" aria-describedby="password-hint{% if passwordError %} password-error{% endif %}">
        </div>

        <div class="govuk-form-group">
          <label class="govuk-label" for="reason">{{ t("delete_account.reason_label") }}</label>
          <textarea class="govuk-textarea" id="reason" name="reason" rows="3"></textarea>
        </div>

        <div class="govuk-form-group{% if confirmError %} govuk-form-group--error{% endif %}">
          {% if confirmError %}
            <p id="confirm-error" class="govuk-error-message">
              <span class="govuk-visually-hidden">{{ t("states.error_prefix") }}</span> {{ errorMessage }}
            </p>
          {% endif %}
          <div class="govuk-checkboxes" data-module="govuk-checkboxes">
            <div class="govuk-checkboxes__item">
              <input class="govuk-checkboxes__input" id="confirm" name="confirm" type="checkbox" value="1"{% if confirmError %} aria-describedby="confirm-error"{% endif %}>
              <label class="govuk-label govuk-checkboxes__label" for="confirm">{{ t("delete_account.confirm_label") }}</label>
            </div>
          </div>
        </div>

        <div class="govuk-button-group">
          <button class="govuk-button govuk-button--warning" data-module="govuk-button" type="submit">{{ t("delete_account.submit") }}</button>
          <a class="govuk-link" href="{{ urlFor('/profile/settings') }}">{{ t("delete_account.cancel") }}</a>
        </div>
      </form>
    </div>
  </div>
{% endblock %}
