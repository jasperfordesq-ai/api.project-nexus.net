{% extends "layouts/base.njk" %}

{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}

{% block beforeContent %}
  {{ super() }}
  {{ govukBreadcrumbs({
    items: [
      { text: t("nav.home"), href: urlFor("/") },
      { text: "Your profile" }
    ]
  }) }}
{% endblock %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if successMessage %}
        {% set notificationMessage = successMessage %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      <h1 class="govuk-heading-xl">Your profile</h1>

      {{ govukSummaryList({
        rows: [
          {
            key: { text: "Name" },
            value: { text: ((profile.first_name or profile.firstName or "") + " " + (profile.last_name or profile.lastName or "")).trim() or "Not set" },
            actions: {
              items: [
                { href: urlFor("/profile/settings"), text: "Change", visuallyHiddenText: "name" }
              ]
            }
          },
          {
            key: { text: "Email address" },
            value: { text: profile.email or "Not set" },
            actions: {
              items: [
                { href: urlFor("/profile/settings"), text: "Change", visuallyHiddenText: "email address" }
              ]
            }
          },
          {
            key: { text: "Phone number" },
            value: { text: profile.phone or "Not set" },
            actions: {
              items: [
                { href: urlFor("/profile/settings"), text: "Change", visuallyHiddenText: "phone number" }
              ]
            }
          }
        ]
      }) }}

      {% if profile.bio %}
        <h2 class="govuk-heading-m govuk-!-margin-top-8">{{ t("onboarding.confirm.bio_row") }}</h2>
        <p class="govuk-body">{{ profile.bio }}</p>
      {% endif %}

      <h2 class="govuk-heading-m govuk-!-margin-top-8">{{ t("home.summary_account_key") }}</h2>
      <ul class="govuk-list">
        <li>
          <a href="{{ urlFor('/achievements') }}" class="govuk-link">Achievements and rewards</a>
        </li>
        <li>
          <a href="{{ urlFor('/leaderboard') }}" class="govuk-link">{{ t("leaderboard.title") }}</a>
        </li>
      </ul>

      <p class="govuk-body govuk-!-margin-top-6">
        <a href="{{ urlFor('/dashboard') }}" class="govuk-link">Back to dashboard</a>
      </p>

    </div>
  </div>
{% endblock %}
