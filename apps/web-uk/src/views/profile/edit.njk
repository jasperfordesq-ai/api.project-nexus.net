{% extends "layouts/base.njk" %}

{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}

{% block beforeContent %}
  {{ super() }}
  {{ govukBreadcrumbs({
    items: [
      { text: "Home", href: "/" },
      { text: "Your profile", href: "/profile" },
      { text: "Edit" }
    ]
  }) }}
{% endblock %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if errors and errors.length %}
        {{ govukErrorSummary({
          titleText: "There is a problem",
          errorList: errors
        }) }}
      {% endif %}

      <h1 class="govuk-heading-xl">Edit your profile</h1>

      <form method="post" novalidate>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        {{ govukInput({
          label: {
            text: "First name",
            classes: "govuk-label--m"
          },
          id: "first_name",
          name: "first_name",
          value: values.first_name if values else (profile.firstName or profile.first_name if profile else ""),
          autocomplete: "given-name",
          errorMessage: { text: fieldErrors.first_name } if fieldErrors.first_name else undefined
        }) }}

        {{ govukInput({
          label: {
            text: "Last name",
            classes: "govuk-label--m"
          },
          id: "last_name",
          name: "last_name",
          value: values.last_name if values else (profile.lastName or profile.last_name if profile else ""),
          autocomplete: "family-name",
          errorMessage: { text: fieldErrors.last_name } if fieldErrors.last_name else undefined
        }) }}

        {{ govukInput({
          label: {
            text: "Email address",
            classes: "govuk-label--m"
          },
          hint: {
            text: "Your email address cannot be changed here"
          },
          id: "email",
          name: "email",
          type: "email",
          value: values.email if values else (profile.email if profile else ""),
          autocomplete: "email",
          attributes: {
            readonly: "readonly"
          },
          errorMessage: { text: fieldErrors.email } if fieldErrors.email else undefined
        }) }}

        {{ govukInput({
          label: {
            text: "Phone number",
            classes: "govuk-label--m"
          },
          hint: {
            text: "Optional"
          },
          id: "phone",
          name: "phone",
          type: "tel",
          value: values.phone if values else (profile.phone if profile else ""),
          autocomplete: "tel",
          errorMessage: { text: fieldErrors.phone } if fieldErrors.phone else undefined
        }) }}

        {{ govukTextarea({
          label: {
            text: "Bio",
            classes: "govuk-label--m"
          },
          hint: {
            text: "Optional - tell the community a bit about yourself"
          },
          id: "bio",
          name: "bio",
          value: values.bio if values else (profile.bio if profile else ""),
          rows: 4,
          errorMessage: { text: fieldErrors.bio } if fieldErrors.bio else undefined
        }) }}

        <div class="govuk-button-group">
          {{ govukButton({
            text: "Save changes"
          }) }}
          <a href="/profile" class="govuk-link">Cancel</a>
        </div>
      </form>

    </div>
  </div>
{% endblock %}
