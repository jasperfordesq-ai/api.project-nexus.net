{% extends "layouts/base.njk" %}

{% block mainContent %}
  {% include "marketplace/_nav.njk" %}

  <span class="govuk-caption-xl">{{ t("marketplace.caption", { community: tenantName or serviceName }) }}</span>
  <h1 class="govuk-heading-xl">{{ t("marketplace.title") }}</h1>
  <p class="govuk-body-l">{{ t("marketplace.description") }}</p>

  <form method="get" action="{{ urlFor('/marketplace') }}" class="govuk-!-margin-bottom-6">
    <fieldset class="govuk-fieldset">
      <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
        <h2 class="govuk-fieldset__heading">{{ t("polish_commerce.marketplace_filter_heading") }}</h2>
      </legend>
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-one-half">
          <div class="govuk-form-group">
            <label class="govuk-label" for="q">{{ t("marketplace.search_label") }}</label>
            <div id="q-hint" class="govuk-hint">{{ t("marketplace.search_hint") }}</div>
            <input class="govuk-input" id="q" name="q" type="search" value="{{ query }}" aria-describedby="q-hint">
          </div>
        </div>
        {% if categories.length %}
          <div class="govuk-grid-column-one-half">
            <div class="govuk-form-group">
              <label class="govuk-label" for="category_id">{{ t("polish_commerce.marketplace_category_label") }}</label>
              <select class="govuk-select" id="category_id" name="category_id">
                <option value="">{{ t("polish_commerce.marketplace_category_all") }}</option>
                {% for category in categories %}
                  <option value="{{ category.id }}" {% if category.id == categoryId %}selected{% endif %}>{{ category.name }}</option>
                {% endfor %}
              </select>
            </div>
          </div>
        {% endif %}
      </div>
    </fieldset>
    <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">{{ t("polish_commerce.marketplace_filter_submit") }}</button>
    <a class="govuk-link govuk-!-margin-left-3" href="{{ urlFor('/marketplace/search') }}">{{ t("govuk_alpha_commerce.marketplace_advanced.title") }}</a>
  </form>

  {% if categories.length %}
    <h2 class="govuk-heading-s">{{ t("govuk_alpha_commerce.category.browse_heading") }}</h2>
    <ul class="nexus-alpha-inline-list govuk-!-margin-bottom-6">
      {% for category in categories %}
        {% if category.href %}
          <li><a class="govuk-link" href="{{ urlFor(category.href) }}">{{ category.name }}</a></li>
        {% endif %}
      {% endfor %}
    </ul>
  {% endif %}

  {% if not listings.length %}
    <div class="govuk-inset-text">
      <p class="govuk-body">{{ t("marketplace.empty") }}</p>
    </div>
  {% else %}
    <div class="nexus-alpha-card-list">
      {% for item in listings %}
        <article class="nexus-alpha-card">
          <div class="nexus-alpha-listing-row">
            {% if item.primaryImage %}
              <div class="nexus-alpha-listing-row__media">
                <img class="nexus-alpha-card-thumb" src="{{ item.primaryImage }}" alt="{{ item.title }}" width="120" height="90" loading="lazy" decoding="async">
              </div>
            {% endif %}
            <div class="nexus-alpha-listing-row__body">
              <div class="nexus-alpha-module-row">
                <h2 class="govuk-heading-s govuk-!-margin-bottom-1"><a class="govuk-link" href="{{ urlFor(item.href) }}">{{ item.title }}</a></h2>
                <strong class="govuk-tag {{ item.cardPriceTagClass }}">{{ item.cardPriceLabel }}</strong>
              </div>
              {% if item.summary %}
                <p class="govuk-body govuk-!-margin-bottom-1">{{ item.summary }}</p>
              {% endif %}
              {% if item.location %}
                <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-0">{{ item.location }}</p>
              {% endif %}
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
