{% extends "layouts/base.njk" %}

{% block mainContent %}
  {% if backHref %}
    <a class="govuk-back-link" href="{{ urlFor(backHref) }}">{{ backLabel or 'Back to marketplace' }}</a>
  {% endif %}

  {% include "marketplace/_nav.njk" %}

  {% if mode == 'saved' %}
    <span class="govuk-caption-xl">{{ t("govuk_alpha_commerce.saved.caption", { community: tenantName or serviceName }) }}</span>
    <h1 class="govuk-heading-xl">{{ t("govuk_alpha_commerce.saved.title") }}</h1>
    <p class="govuk-body-l">{{ t("govuk_alpha_commerce.saved.description") }}</p>

    {% if status %}
      <div class="govuk-notification-banner govuk-notification-banner--success" role="region" aria-labelledby="commerce-saved-status" data-module="govuk-notification-banner">
        <div class="govuk-notification-banner__header">
          <h2 class="govuk-notification-banner__title" id="commerce-saved-status">{{ t("govuk_alpha_commerce.common.notice_title") }}</h2>
        </div>
        <div class="govuk-notification-banner__content">
          <p class="govuk-notification-banner__heading">{{ status.message }}</p>
        </div>
      </div>
    {% endif %}
  {% else %}
    {% include "marketplace/_status-banner.njk" %}
    <span class="govuk-caption-xl">{{ caption }} at {{ tenantName or serviceName }}</span>
    <h1 class="govuk-heading-xl">{{ heading }}</h1>
    <p class="govuk-body-l">{{ description }}</p>
  {% endif %}

  {% if mode == 'category' %}
    <form method="get" action="{{ urlFor('/marketplace/category/' + category.slug) }}" class="govuk-!-margin-bottom-6">
      <div class="govuk-form-group">
        <label class="govuk-label" for="q">Search within this category</label>
        <div id="q-hint" class="govuk-hint">Find an item by name or keyword.</div>
        <input class="govuk-input govuk-input--width-20" id="q" name="q" type="search" value="{{ query }}" aria-describedby="q-hint">
      </div>
      <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">Search</button>
    </form>
  {% endif %}

  {% if not listings.length %}
    <div class="govuk-inset-text">
      <p class="govuk-body">{{ t("govuk_alpha_commerce.saved.empty") if mode == 'saved' else emptyMessage }}</p>
    </div>
  {% else %}
    <div class="nexus-alpha-card-list">
      {% for item in listings %}
        {% include "marketplace/_listing-card.njk" %}
        {% if mode == 'saved' %}
          <form method="post" action="{{ urlFor('/marketplace/' + (item.id | string) + '/unsave') }}" class="govuk-!-margin-bottom-6">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <input type="hidden" name="redirect_to" value="saved">
            <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("govuk_alpha_commerce.saved.remove") }}</button>
          </form>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
