{% extends "layouts/base.njk" %}

{% block mainContent %}
  {% include "marketplace/_nav.njk" %}
  {% include "marketplace/_status-banner.njk" %}

  <span class="govuk-caption-xl">Offers at {{ tenantName or serviceName }}</span>
  <h1 class="govuk-heading-xl">My offers</h1>
  <p class="govuk-body-l">Offers you have received on your items and offers you have sent to other sellers.</p>

  <nav class="govuk-tabs govuk-!-margin-bottom-4" aria-label="My offers">
    <ul class="govuk-tabs__list">
      <li class="govuk-tabs__list-item{% if tab == 'received' %} govuk-tabs__list-item--selected{% endif %}">
        <a class="govuk-tabs__tab" href="/marketplace/offers?tab=received" {% if tab == 'received' %}aria-current="page"{% endif %}>Received</a>
      </li>
      <li class="govuk-tabs__list-item{% if tab == 'sent' %} govuk-tabs__list-item--selected{% endif %}">
        <a class="govuk-tabs__tab" href="/marketplace/offers?tab=sent" {% if tab == 'sent' %}aria-current="page"{% endif %}>Sent</a>
      </li>
    </ul>
  </nav>

  {% if not offers.length %}
    <div class="govuk-inset-text">
      <p class="govuk-body">{% if tab == 'sent' %}You have not sent any offers.{% else %}You have not received any offers.{% endif %}</p>
    </div>
  {% else %}
    <div class="nexus-alpha-card-list">
      {% for offer in offers %}
        <article class="nexus-alpha-card">
          <div class="nexus-alpha-module-row">
            <h2 class="govuk-heading-s govuk-!-margin-bottom-1">
              {% if offer.href %}
                <a class="govuk-link" href="{{ offer.href }}">{{ offer.listingTitle }}</a>
              {% else %}
                {{ offer.listingTitle }}
              {% endif %}
            </h2>
            <strong class="govuk-tag {{ offer.statusTagClass }}">{{ offer.statusLabel }}</strong>
          </div>
          <p class="govuk-body govuk-!-margin-bottom-1"><strong>Offer:</strong> {{ offer.amountLabel }}</p>
          {% if offer.counterparty %}
            <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">{{ offer.counterpartyLabel }}: {{ offer.counterparty }}</p>
          {% endif %}
          {% if offer.message %}
            <p class="govuk-body govuk-!-margin-bottom-2">{{ offer.message }}</p>
          {% endif %}
          {% if offer.canAct %}
            <div class="nexus-alpha-actions">
              {% if tab == 'received' %}
                <form method="post" action="/marketplace/offers/{{ offer.id }}/accept" class="nexus-alpha-inline-form">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <button class="govuk-button govuk-!-margin-bottom-0" data-module="govuk-button">Accept</button>
                </form>
                <form method="post" action="/marketplace/offers/{{ offer.id }}/decline" class="nexus-alpha-inline-form">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">Decline</button>
                </form>
              {% else %}
                <form method="post" action="/marketplace/offers/{{ offer.id }}/withdraw" class="nexus-alpha-inline-form">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button">Withdraw</button>
                </form>
              {% endif %}
            </div>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
