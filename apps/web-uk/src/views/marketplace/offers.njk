{% extends "layouts/base.njk" %}

{% block mainContent %}
  {% include "marketplace/_nav.njk" %}

  <span class="govuk-caption-xl">{{ t("govuk_alpha_commerce.offers.caption", { community: tenantName or serviceName }) }}</span>
  <h1 class="govuk-heading-xl">{{ t("govuk_alpha_commerce.offers.title") }}</h1>
  <p class="govuk-body-l">{{ t("govuk_alpha_commerce.offers.description") }}</p>

  {% if status %}
    <div class="govuk-notification-banner{% if status.type != 'error' %} govuk-notification-banner--success{% endif %}" role="region" aria-labelledby="commerce-offers-status" data-module="govuk-notification-banner">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="commerce-offers-status">{{ t("govuk_alpha_commerce.common.notice_title") }}</h2>
      </div>
      <div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ status.message }}</p></div>
    </div>
  {% endif %}

  <nav class="govuk-tabs govuk-!-margin-bottom-4" aria-label="{{ t('govuk_alpha_commerce.offers.title') }}">
    <ul class="govuk-tabs__list">
      <li class="govuk-tabs__list-item{% if tab == 'received' %} govuk-tabs__list-item--selected{% endif %}">
        <a class="govuk-tabs__tab" href="{{ urlFor('/marketplace/offers?tab=received') }}" {% if tab == 'received' %}aria-current="page"{% endif %}>{{ t("govuk_alpha_commerce.offers.tab_received") }}</a>
      </li>
      <li class="govuk-tabs__list-item{% if tab == 'sent' %} govuk-tabs__list-item--selected{% endif %}">
        <a class="govuk-tabs__tab" href="{{ urlFor('/marketplace/offers?tab=sent') }}" {% if tab == 'sent' %}aria-current="page"{% endif %}>{{ t("govuk_alpha_commerce.offers.tab_sent") }}</a>
      </li>
    </ul>
  </nav>

  {% if not offers.length %}
    <div class="govuk-inset-text">
      <p class="govuk-body">{{ t("govuk_alpha_commerce.offers.empty_sent" if tab == 'sent' else "govuk_alpha_commerce.offers.empty_received") }}</p>
    </div>
  {% else %}
    <div class="nexus-alpha-card-list">
      {% for offer in offers %}
        <article class="nexus-alpha-card">
          <div class="nexus-alpha-module-row">
            <h2 class="govuk-heading-s govuk-!-margin-bottom-1">
              {% if offer.href %}
                <a class="govuk-link" href="{{ urlFor(offer.href) }}">{{ offer.listingTitle }}</a>
              {% else %}
                {{ offer.listingTitle }}
              {% endif %}
            </h2>
            <strong class="govuk-tag {{ offer.statusTagClass }}">{{ offer.statusLabel }}</strong>
          </div>
          <p class="govuk-body govuk-!-margin-bottom-1"><strong>{{ t("govuk_alpha_commerce.offers.amount_label") }}:</strong> {{ offer.amountLabel }}</p>
          {% if offer.counterparty %}
            <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">{{ offer.counterpartyLabel }}: {{ offer.counterparty }}</p>
          {% endif %}
          {% if offer.message %}
            <p class="govuk-body govuk-!-margin-bottom-2">{{ offer.message }}</p>
          {% endif %}
          {% if offer.canAct %}
            <div class="nexus-alpha-actions">
              {% if tab == 'received' %}
                <form method="post" action="{{ urlFor('/marketplace/offers/' + (offer.id | string) + '/accept') }}" class="nexus-alpha-inline-form">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <button class="govuk-button govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("govuk_alpha_commerce.offers.accept") }}</button>
                </form>
                <form method="post" action="{{ urlFor('/marketplace/offers/' + (offer.id | string) + '/decline') }}" class="nexus-alpha-inline-form">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("govuk_alpha_commerce.offers.decline") }}</button>
                </form>
              {% else %}
                <form method="post" action="{{ urlFor('/marketplace/offers/' + (offer.id | string) + '/withdraw') }}" class="nexus-alpha-inline-form">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("govuk_alpha_commerce.offers.withdraw") }}</button>
                </form>
              {% endif %}
            </div>
          {% endif %}
          {% if offer.canPurchase %}<p class="govuk-body govuk-!-margin-bottom-0"><a class="govuk-button govuk-!-margin-bottom-0" href="{{ urlFor('/marketplace/offers/' + (offer.id | string) + '/buy') }}">{{ t("govuk_alpha_commerce.offers.complete_purchase") }}</a></p>{% endif %}
        </article>
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
