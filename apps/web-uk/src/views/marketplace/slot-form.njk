{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a class="govuk-back-link" href="/marketplace/slots">Back to pickup slots</a>
  {% include "marketplace/_nav.njk" %}
  {% include "marketplace/_status-banner.njk" %}

  <h1 class="govuk-heading-xl">Edit pickup slot</h1>
  {% include "marketplace/_slot-form.njk" %}

  {% if slot.id %}
    <h2 class="govuk-heading-m govuk-!-margin-top-6">Delete this slot</h2>
    <div class="govuk-warning-text">
      <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
      <strong class="govuk-warning-text__text">
        <span class="govuk-visually-hidden">Important</span>
        Deleting a slot cannot be undone. Buyers will no longer be able to book it.
      </strong>
    </div>
    <form method="post" action="/marketplace/slots/{{ slot.id }}/delete">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
      <button class="govuk-button govuk-button--warning" data-module="govuk-button">Delete slot</button>
    </form>
  {% endif %}
{% endblock %}
