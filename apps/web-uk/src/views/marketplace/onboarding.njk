{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a class="govuk-back-link" href="{{ urlFor('/marketplace') }}">{{ t("govuk_alpha_commerce.common.back_to_marketplace") }}</a>
  {% include "marketplace/_nav.njk" %}
  {% if status and status.type == "success" %}
    <div class="govuk-notification-banner govuk-notification-banner--success" role="alert" aria-labelledby="govuk-notification-banner-title" data-module="govuk-notification-banner">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="govuk-notification-banner-title">{{ t("govuk_alpha.states.success_title") }}</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ status.message }}</p>
      </div>
    </div>
  {% endif %}

  {% if formErrors.length or (status and status.type == "error") %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">{{ t("govuk_alpha_commerce.common.error_title") }}</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            {% for message in formErrors %}<li><a href="#display_name">{{ message }}</a></li>{% endfor %}
            {% if status and status.type == "error" %}<li>{{ status.message }}</li>{% endif %}
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  <span class="govuk-caption-l">{{ t("govuk_alpha_commerce.onboarding.caption", { community: tenantName or serviceName }) }}</span>
  <h1 class="govuk-heading-xl">{{ t("govuk_alpha_commerce.onboarding.title") }}</h1>
  <p class="govuk-body-l">{{ t("govuk_alpha_commerce.onboarding.description") }}</p>

  {% if completed %}
    <div class="govuk-notification-banner" role="region" aria-labelledby="onboarding-complete-banner" data-module="govuk-notification-banner">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="onboarding-complete-banner">{{ t("govuk_alpha_commerce.common.notice_title") }}</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ t("govuk_alpha_commerce.onboarding.completed_banner") }}</p>
      </div>
    </div>
  {% endif %}

  <form method="post" action="{{ urlFor('/marketplace/onboarding') }}" novalidate>
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    <fieldset class="govuk-fieldset">
      <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
        <h2 class="govuk-fieldset__heading">{{ t("govuk_alpha_commerce.onboarding.section_identity") }}</h2>
      </legend>

      <div class="govuk-form-group">
        <fieldset class="govuk-fieldset">
          <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">{{ t("govuk_alpha_commerce.onboarding.seller_type_label") }}</legend>
          <div class="govuk-radios govuk-radios--small" data-module="govuk-radios">
            {% for sellerType in sellerTypes %}
              <div class="govuk-radios__item">
                {% set sellerTypeId = "seller_type" if loop.first else "seller_type-" + sellerType.value %}
                <input class="govuk-radios__input" id="{{ sellerTypeId }}" name="seller_type" type="radio" value="{{ sellerType.value }}" {% if profile.seller_type == sellerType.value %}checked{% endif %}>
                <label class="govuk-label govuk-radios__label" for="{{ sellerTypeId }}">{{ sellerType.label }}</label>
              </div>
            {% endfor %}
          </div>
        </fieldset>
      </div>

      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--s" for="display_name">{{ t("govuk_alpha_commerce.onboarding.display_name_label") }}</label>
        <div id="display_name-hint" class="govuk-hint">{{ t("govuk_alpha_commerce.onboarding.display_name_hint") }}</div>
        <input class="govuk-input" id="display_name" name="display_name" type="text" maxlength="200" value="{{ profile.display_name }}" aria-describedby="display_name-hint">
      </div>

      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--s" for="business_name">{{ t("govuk_alpha_commerce.onboarding.business_name_label") }}</label>
        <div id="business_name-hint" class="govuk-hint">{{ t("govuk_alpha_commerce.onboarding.business_name_hint") }}</div>
        <input class="govuk-input" id="business_name" name="business_name" type="text" maxlength="200" value="{{ profile.business_name }}" aria-describedby="business_name-hint">
      </div>

      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--s" for="bio">{{ t("govuk_alpha_commerce.onboarding.bio_label") }} <span class="govuk-hint govuk-!-display-inline">({{ t("govuk_alpha_commerce.common.optional") }})</span></label>
        <div id="bio-hint" class="govuk-hint">{{ t("govuk_alpha_commerce.onboarding.bio_hint") }}</div>
        <textarea class="govuk-textarea" id="bio" name="bio" rows="3" aria-describedby="bio-hint">{{ profile.bio }}</textarea>
      </div>

      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--s" for="business_registration">{{ t("govuk_alpha_commerce.onboarding.registration_label") }} <span class="govuk-hint govuk-!-display-inline">({{ t("govuk_alpha_commerce.common.optional") }})</span></label>
        <div id="business_registration-hint" class="govuk-hint">{{ t("govuk_alpha_commerce.onboarding.registration_hint") }}</div>
        <input class="govuk-input govuk-input--width-20" id="business_registration" name="business_registration" type="text" maxlength="120" value="{{ profile.business_registration }}" aria-describedby="business_registration-hint">
      </div>
    </fieldset>

    <fieldset class="govuk-fieldset govuk-!-margin-top-4">
      <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
        <h2 class="govuk-fieldset__heading">{{ t("govuk_alpha_commerce.onboarding.section_location") }}</h2>
      </legend>
      <p class="govuk-body">{{ t("govuk_alpha_commerce.onboarding.location_description") }}</p>

      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--s" for="address_street">{{ t("govuk_alpha_commerce.onboarding.address_street_label") }}</label>
        <input class="govuk-input" id="address_street" name="address_street" type="text" maxlength="200" value="{{ address.street }}" autocomplete="street-address">
      </div>
      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--s" for="address_city">{{ t("govuk_alpha_commerce.onboarding.address_city_label") }}</label>
        <input class="govuk-input govuk-input--width-20" id="address_city" name="address_city" type="text" maxlength="120" value="{{ address.city }}" autocomplete="address-level2">
      </div>
      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--s" for="address_postal_code">{{ t("govuk_alpha_commerce.onboarding.address_postal_code_label") }}</label>
        <input class="govuk-input govuk-input--width-10" id="address_postal_code" name="address_postal_code" type="text" maxlength="40" value="{{ address.postal_code }}" autocomplete="postal-code">
      </div>
      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--s" for="address_country">{{ t("govuk_alpha_commerce.onboarding.address_country_label") }}</label>
        <input class="govuk-input govuk-input--width-20" id="address_country" name="address_country" type="text" maxlength="120" value="{{ address.country }}" autocomplete="country-name">
      </div>
    </fieldset>

    <div class="govuk-button-group govuk-!-margin-top-4">
      <button class="govuk-button" data-module="govuk-button">{{ t("govuk_alpha_commerce.onboarding.submit") }}</button>
      <a class="govuk-link" href="{{ urlFor('/marketplace') }}">{{ t("govuk_alpha_commerce.common.cancel") }}</a>
    </div>
  </form>
{% endblock %}
