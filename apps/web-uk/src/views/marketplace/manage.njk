{% extends "layouts/base.njk" %}

{% block mainContent %}
  {% include "marketplace/_nav.njk" %}
  {% include "marketplace/_status-banner.njk" %}

  <span class="govuk-caption-xl">Your items at {{ tenantName or serviceName }}</span>
  <h1 class="govuk-heading-xl">My listings</h1>
  <p class="govuk-body-l">Manage the items you are selling, edit details, renew expired listings or remove them.</p>

  <p class="govuk-body">
    <a class="govuk-button" href="{{ urlFor('/marketplace/create') }}" role="button" draggable="false" data-module="govuk-button">Create a listing</a>
  </p>

  <nav class="govuk-tabs govuk-!-margin-bottom-4" aria-label="My listings">
    <ul class="govuk-tabs__list">
      {% for tabItem in tabs %}
        <li class="govuk-tabs__list-item{% if tabItem.active %} govuk-tabs__list-item--selected{% endif %}">
          <a class="govuk-tabs__tab" href="{{ urlFor(tabItem.href) }}" {% if tabItem.active %}aria-current="page"{% endif %}>{{ tabItem.label }} ({{ tabItem.count }})</a>
        </li>
      {% endfor %}
    </ul>
  </nav>

  {% if not listings.length %}
    <div class="govuk-inset-text">
      <p class="govuk-body">You have no {{ tab }} listings.</p>
    </div>
  {% else %}
    <div class="nexus-alpha-card-list">
      {% for item in listings %}
        {% include "marketplace/_listing-card.njk" %}
        <div class="nexus-alpha-actions govuk-!-margin-bottom-6">
          <a class="govuk-link govuk-!-margin-right-3" href="{{ urlFor('/marketplace/' + (item.id | string)) }}">View</a>
          <a class="govuk-link govuk-!-margin-right-3" href="{{ urlFor('/marketplace/' + (item.id | string) + '/edit') }}">{{ t("jobs_t3.edit_button") }}</a>
          {% if tab == 'expired' %}
            <form method="post" action="{{ urlFor('/marketplace/' + (item.id | string) + '/renew') }}" class="nexus-alpha-inline-form">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}">
              <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("jobs_t3.renew_button") }}</button>
            </form>
          {% endif %}
          <form method="post" action="{{ urlFor('/marketplace/' + (item.id | string) + '/delete') }}" class="nexus-alpha-inline-form">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("jobs_t3.delete_button") }}</button>
          </form>
        </div>
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
