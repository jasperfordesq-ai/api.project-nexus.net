{% extends "layouts/base.njk" %}

{% block mainContent %}
  {% include "marketplace/_nav.njk" %}

  <span class="govuk-caption-xl">{{ t("govuk_alpha_commerce.my_listings.caption", { community: tenantName or serviceName }) }}</span>
  <h1 class="govuk-heading-xl">{{ t("govuk_alpha_commerce.my_listings.title") }}</h1>
  <p class="govuk-body-l">{{ t("govuk_alpha_commerce.my_listings.description") }}</p>

  {% if status %}
    <div class="govuk-notification-banner{% if status.type != 'error' %} govuk-notification-banner--success{% endif %}" role="region" aria-labelledby="commerce-status-title" data-module="govuk-notification-banner">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="commerce-status-title">{{ t("govuk_alpha_commerce.common.notice_title") }}</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ status.message }}</p>
      </div>
    </div>
  {% endif %}

  <p class="govuk-body">
    <a class="govuk-button" href="{{ urlFor('/marketplace/create') }}" role="button" draggable="false" data-module="govuk-button">{{ t("govuk_alpha_commerce.my_listings.create_button") }}</a>
  </p>

  <nav class="govuk-tabs govuk-!-margin-bottom-4" aria-label="{{ t('govuk_alpha_commerce.my_listings.title') }}">
    <ul class="govuk-tabs__list">
      {% for tabItem in tabs %}
        <li class="govuk-tabs__list-item{% if tabItem.active %} govuk-tabs__list-item--selected{% endif %}">
          <a class="govuk-tabs__tab" href="{{ urlFor(tabItem.href) }}" {% if tabItem.active %}aria-current="page"{% endif %}>{{ tabItem.label }} ({{ tabItem.count }})</a>
        </li>
      {% endfor %}
    </ul>
  </nav>

  {% if not listings.length %}
    <div class="govuk-inset-text">
      <p class="govuk-body">{{ t("govuk_alpha_commerce.my_listings.empty_" + tab) }}</p>
    </div>
  {% else %}
    <div class="nexus-alpha-card-list">
      {% for item in listings %}
        {% include "marketplace/_listing-card.njk" %}
        <div class="nexus-alpha-actions govuk-!-margin-bottom-6">
          <a class="govuk-link govuk-!-margin-right-3" href="{{ urlFor('/marketplace/' + (item.id | string)) }}">{{ t("govuk_alpha_commerce.my_listings.action_view") }}</a>
          <a class="govuk-link govuk-!-margin-right-3" href="{{ urlFor('/marketplace/' + (item.id | string) + '/edit') }}">{{ t("govuk_alpha_commerce.my_listings.action_edit") }}</a>
          {% if tab == 'expired' %}
            <form method="post" action="{{ urlFor('/marketplace/' + (item.id | string) + '/renew') }}" class="nexus-alpha-inline-form">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}">
              <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("govuk_alpha_commerce.my_listings.action_renew") }}</button>
            </form>
          {% endif %}
          <form method="post" action="{{ urlFor('/marketplace/' + (item.id | string) + '/delete') }}" class="nexus-alpha-inline-form">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("govuk_alpha_commerce.my_listings.action_delete") }}</button>
          </form>
        </div>
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
