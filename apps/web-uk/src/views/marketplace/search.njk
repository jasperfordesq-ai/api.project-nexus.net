{% extends "layouts/base.njk" %}

{% block mainContent %}
  {% include "marketplace/_nav.njk" %}

  <span class="govuk-caption-xl">Marketplace at {{ tenantName or serviceName }}</span>
  <h1 class="govuk-heading-xl">Advanced search</h1>
  <p class="govuk-body-l">Narrow your search by price, condition, delivery and more.</p>

  <form method="get" action="{{ urlFor('/marketplace/search') }}" class="govuk-!-margin-bottom-6">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-one-half">
        <div class="govuk-form-group">
          <label class="govuk-label" for="q">{{ t("marketplace.search_label") }}</label>
          <input class="govuk-input" id="q" name="q" type="search" value="{{ state.query }}">
        </div>
      </div>
      {% if categories.length %}
        <div class="govuk-grid-column-one-half">
          <div class="govuk-form-group">
            <label class="govuk-label" for="category_id">Category</label>
            <select class="govuk-select" id="category_id" name="category_id">
              <option value="">All categories</option>
              {% for category in categories %}
                <option value="{{ category.id }}" {% if category.id == state.categoryId %}selected{% endif %}>{{ category.name }}</option>
              {% endfor %}
            </select>
          </div>
        </div>
      {% endif %}
    </div>

    <div class="govuk-grid-row">
      <div class="govuk-grid-column-one-half">
        <div class="govuk-form-group">
          <label class="govuk-label" for="price_min">Lowest price</label>
          <input class="govuk-input govuk-input--width-10" id="price_min" name="price_min" type="number" min="0" step="0.01" inputmode="decimal" value="{{ state.priceMin }}">
        </div>
      </div>
      <div class="govuk-grid-column-one-half">
        <div class="govuk-form-group">
          <label class="govuk-label" for="price_max">Highest price</label>
          <input class="govuk-input govuk-input--width-10" id="price_max" name="price_max" type="number" min="0" step="0.01" inputmode="decimal" value="{{ state.priceMax }}">
        </div>
      </div>
    </div>

    <div class="govuk-form-group">
      <fieldset class="govuk-fieldset">
        <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">{{ t("marketplace.condition_label") }}</legend>
        <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
          {% for option in conditionOptions %}
            <div class="govuk-checkboxes__item">
              <input class="govuk-checkboxes__input" id="condition-{{ option.value }}" name="condition" type="checkbox" value="{{ option.value }}" {% if option.value in state.selectedConditions %}checked{% endif %}>
              <label class="govuk-label govuk-checkboxes__label" for="condition-{{ option.value }}">{{ option.label }}</label>
            </div>
          {% endfor %}
        </div>
      </fieldset>
    </div>

    <div class="govuk-grid-row">
      <div class="govuk-grid-column-one-third">
        <div class="govuk-form-group">
          <label class="govuk-label" for="seller_type">{{ t("marketplace.seller_label") }}</label>
          <select class="govuk-select" id="seller_type" name="seller_type">
            {% for option in sellerTypeOptions %}
              <option value="{{ option.value }}" {% if option.value == state.sellerType %}selected{% endif %}>{{ option.label }}</option>
            {% endfor %}
          </select>
        </div>
      </div>
      <div class="govuk-grid-column-one-third">
        <div class="govuk-form-group">
          <label class="govuk-label" for="delivery_method">{{ t("marketplace.delivery_label") }}</label>
          <select class="govuk-select" id="delivery_method" name="delivery_method">
            {% for option in deliveryOptions %}
              <option value="{{ option.value }}" {% if option.value == state.deliveryMethod %}selected{% endif %}>{{ option.label }}</option>
            {% endfor %}
          </select>
        </div>
      </div>
      <div class="govuk-grid-column-one-third">
        <div class="govuk-form-group">
          <label class="govuk-label" for="posted_within">Posted within</label>
          <select class="govuk-select" id="posted_within" name="posted_within">
            {% for option in postedWithinOptions %}
              <option value="{{ option.value }}" {% if option.value == state.postedWithin %}selected{% endif %}>{{ option.label }}</option>
            {% endfor %}
          </select>
        </div>
      </div>
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label" for="sort">Sort by</label>
      <select class="govuk-select" id="sort" name="sort">
        {% for option in sortOptions %}
          <option value="{{ option.value }}" {% if option.value == state.sort %}selected{% endif %}>{{ option.label }}</option>
        {% endfor %}
      </select>
    </div>

    <button type="submit" class="govuk-button" data-module="govuk-button">Search</button>
    <a class="govuk-link govuk-!-margin-left-3" href="{{ urlFor('/marketplace') }}">Back to browse</a>
  </form>

  {% if not listings.length %}
    <div class="govuk-inset-text">
      <p class="govuk-body">No items match your filters. Try widening your search.</p>
    </div>
  {% else %}
    <h2 class="govuk-heading-l">{{ t("listings.results_title") }}</h2>
    <div class="nexus-alpha-card-list">
      {% for item in listings %}
        {% include "marketplace/_listing-card.njk" %}
        {% if item.conditionLabel %}
          <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-top-1 govuk-!-margin-bottom-4">{{ item.conditionLabel }}</p>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
