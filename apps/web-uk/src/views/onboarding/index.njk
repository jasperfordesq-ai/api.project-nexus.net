{% extends "layouts/base.njk" %}

{% block mainContent %}
  {% set bagInterests = bag.interests or [] %}
  {% set bagOffers = bag.offers or [] %}
  {% set bagNeeds = bag.needs or [] %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <span class="govuk-caption-l">{{ t("govuk_alpha.onboarding.caption", { community: communityName }) }} — {{ t("govuk_alpha.onboarding.progress", { current: stepNumber, total: totalSteps }) }}</span>

      {% if statusBanner and statusBanner.type == "error" %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
          <div role="alert">
            <h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2>
            <div class="govuk-error-summary__body">
              <ul class="govuk-list govuk-error-summary__list">
                <li>
                  {% if statusBanner.anchor %}
                    <a href="#{{ statusBanner.anchor }}">{{ statusBanner.message }}</a>
                  {% else %}
                    {{ statusBanner.message }}
                  {% endif %}
                </li>
              </ul>
            </div>
          </div>
        </div>
      {% elif statusBanner and statusBanner.type == "success" %}
        <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="ob-status">
          <div class="govuk-notification-banner__header">
            <h2 class="govuk-notification-banner__title" id="ob-status">{{ t("states.success_title") }}</h2>
          </div>
          <div class="govuk-notification-banner__content">
            <p class="govuk-notification-banner__heading">{{ statusBanner.message }}</p>
          </div>
        </div>
      {% endif %}

      {% if step == "welcome" %}
        <h1 class="govuk-heading-xl">{{ t("onboarding.welcome.title") }}</h1>
        <p class="govuk-body-l">{{ t("onboarding.welcome.body") }}</p>
        <ul class="govuk-list govuk-list--bullet">
          <li>{{ t("onboarding.welcome.benefit_earn") }}</li>
          <li>{{ t("onboarding.welcome.benefit_community") }}</li>
          <li>{{ t("onboarding.welcome.benefit_skills") }}</li>
        </ul>
        <form method="post" action="{{ urlFor('/onboarding/welcome') }}">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <button class="govuk-button" data-module="govuk-button">{{ t("onboarding.welcome.start") }}</button>
        </form>

      {% elif step == "profile" %}
        <h1 class="govuk-heading-xl">{{ t("govuk_alpha.onboarding.profile.title") }}</h1>
        <p class="govuk-body">{{ t("onboarding.profile.hint") }}</p>

        <form method="post" action="{{ urlFor('/onboarding/avatar') }}" enctype="multipart/form-data" class="govuk-!-margin-bottom-6">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <div class="govuk-form-group{% if statusBanner and statusBanner.anchor == 'avatar' %} govuk-form-group--error{% endif %}">
            <label class="govuk-label govuk-label--s" for="avatar">{{ t("govuk_alpha.onboarding.profile.avatar_label") }}</label>
            <div id="avatar-hint" class="govuk-hint">{{ t("onboarding.profile.avatar_hint") }}</div>
            {% if statusBanner and statusBanner.anchor == "avatar" %}
              <p id="avatar-error" class="govuk-error-message"><span class="govuk-visually-hidden">{{ t("states.error_prefix") }}</span> {{ statusBanner.message }}</p>
            {% endif %}
            {% if onboardingUser.avatar_url %}
              <p class="govuk-body-s nexus-alpha-meta">{{ t("govuk_alpha.onboarding.profile.current_photo") }}</p>
              <img class="nexus-alpha-avatar nexus-alpha-avatar--large govuk-!-margin-bottom-2" src="{{ onboardingUser.avatar_url }}" alt="" width="96" height="96">
            {% endif %}
            <input class="govuk-file-upload" id="avatar" name="avatar" type="file" accept="image/jpeg,image/png,image/gif,image/webp" aria-describedby="avatar-hint">
          </div>
          <button class="govuk-button govuk-button--secondary" data-module="govuk-button">{{ t("onboarding.profile.upload_button") }}</button>
        </form>

        <form method="post" action="{{ urlFor('/onboarding/profile') }}">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <div class="govuk-form-group{% if statusBanner and statusBanner.anchor == 'bio' %} govuk-form-group--error{% endif %}">
            <label class="govuk-label govuk-label--s" for="bio">{{ t("govuk_alpha.onboarding.profile.bio_label") }}</label>
            <div id="bio-hint" class="govuk-hint">{{ t("onboarding.profile.bio_hint") }}</div>
            {% if statusBanner and statusBanner.anchor == "bio" %}
              <p id="bio-error" class="govuk-error-message"><span class="govuk-visually-hidden">{{ t("states.error_prefix") }}</span> {{ statusBanner.message }}</p>
            {% endif %}
            <textarea class="govuk-textarea" id="bio" name="bio" rows="4" maxlength="2000" aria-describedby="bio-hint">{{ onboardingUser.bio or "" }}</textarea>
          </div>
          <button class="govuk-button" data-module="govuk-button">{{ t("onboarding.profile.save_continue") }}</button>
        </form>

      {% elif step == "interests" %}
        <h1 class="govuk-heading-xl">{{ t("onboarding.interests.title") }}</h1>
        <p class="govuk-body">{{ t("onboarding.interests.hint") }}</p>
        <form method="post" action="{{ urlFor('/onboarding/interests') }}">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <div class="govuk-form-group">
            <fieldset class="govuk-fieldset">
              <legend class="govuk-fieldset__legend govuk-visually-hidden">{{ t("onboarding.interests.title") }}</legend>
              <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
                {% for category in categories %}
                  <div class="govuk-checkboxes__item">
                    <input class="govuk-checkboxes__input" id="interest-{{ category.id }}" name="interests[]" type="checkbox" value="{{ category.id }}"{% if category.id in bagInterests %} checked{% endif %}>
                    <label class="govuk-label govuk-checkboxes__label" for="interest-{{ category.id }}">{{ category.name }}</label>
                  </div>
                {% endfor %}
              </div>
            </fieldset>
          </div>
          <button class="govuk-button" data-module="govuk-button">{{ t("onboarding.continue") }}</button>
        </form>

      {% elif step == "skills" %}
        <h1 class="govuk-heading-xl">{{ t("govuk_alpha.onboarding.skills.title") }}</h1>
        <form method="post" action="{{ urlFor('/onboarding/skills') }}">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <div class="govuk-form-group">
            <fieldset class="govuk-fieldset" aria-describedby="offers-hint">
              <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">{{ t("onboarding.skills.offers_label") }}</legend>
              <div id="offers-hint" class="govuk-hint">{{ t("onboarding.skills.offers_hint") }}</div>
              <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
                {% for category in categories %}
                  <div class="govuk-checkboxes__item">
                    <input class="govuk-checkboxes__input" id="offer-{{ category.id }}" name="offers[]" type="checkbox" value="{{ category.id }}"{% if category.id in bagOffers %} checked{% endif %}>
                    <label class="govuk-label govuk-checkboxes__label" for="offer-{{ category.id }}">{{ category.name }}</label>
                  </div>
                {% endfor %}
              </div>
            </fieldset>
          </div>

          <div class="govuk-form-group">
            <fieldset class="govuk-fieldset" aria-describedby="needs-hint">
              <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">{{ t("onboarding.skills.needs_label") }}</legend>
              <div id="needs-hint" class="govuk-hint">{{ t("onboarding.skills.needs_hint") }}</div>
              <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
                {% for category in categories %}
                  <div class="govuk-checkboxes__item">
                    <input class="govuk-checkboxes__input" id="need-{{ category.id }}" name="needs[]" type="checkbox" value="{{ category.id }}"{% if category.id in bagNeeds %} checked{% endif %}>
                    <label class="govuk-label govuk-checkboxes__label" for="need-{{ category.id }}">{{ category.name }}</label>
                  </div>
                {% endfor %}
              </div>
            </fieldset>
          </div>

          <button class="govuk-button" data-module="govuk-button">{{ t("onboarding.continue") }}</button>
        </form>

      {% elif step == "safeguarding" %}
        {% set noneOption = null %}
        <h1 class="govuk-heading-xl">{{ t("govuk_alpha.onboarding.safeguarding.title") }}</h1>
        <p class="govuk-body">{{ t("onboarding.safeguarding.intro") }}</p>
        <div class="govuk-inset-text">{{ t("onboarding.safeguarding.gdpr_notice") }}</div>

        <form method="post" action="{{ urlFor('/onboarding/safeguarding') }}">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <fieldset class="govuk-fieldset">
            <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">{{ t("govuk_alpha.onboarding.safeguarding.options_legend") }}</legend>
            <div class="govuk-checkboxes" data-module="govuk-checkboxes">
              {% for option in safeguardingOptions %}
                {% if option.option_key == "none_apply" %}
                  {% set noneOption = option %}
                {% elif option.option_type == "info" %}
                  <div class="govuk-inset-text govuk-!-margin-top-2">
                    <p class="govuk-body govuk-!-margin-bottom-0">{{ option.label }}{% if option.description %} — {{ option.description }}{% endif %}</p>
                  </div>
                {% elif option.option_type == "select" %}
                  <div class="govuk-form-group">
                    <label class="govuk-label" for="sg-{{ option.id }}">{{ option.label }}</label>
                    {% if option.description %}<div class="govuk-hint">{{ option.description }}</div>{% endif %}
                    <select class="govuk-select" id="sg-{{ option.id }}" name="safeguarding[{{ option.id }}]">
                      <option value="">{{ t("govuk_alpha.onboarding.safeguarding.select_none") }}</option>
                      {% for value, label in option.select_options %}
                        <option value="{{ value }}">{{ label }}</option>
                      {% endfor %}
                    </select>
                  </div>
                {% else %}
                  <div class="govuk-checkboxes__item">
                    <input class="govuk-checkboxes__input" id="sg-{{ option.id }}" name="safeguarding[{{ option.id }}]" type="checkbox" value="1">
                    <label class="govuk-label govuk-checkboxes__label" for="sg-{{ option.id }}">{{ option.label }}</label>
                    {% if option.description %}<div class="govuk-hint">{{ option.description }}</div>{% endif %}
                    {% if option.help_url %}<div class="govuk-hint"><a class="govuk-link" href="{{ option.help_url }}" rel="noopener">{{ t("govuk_alpha.help.title") }}</a></div>{% endif %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </fieldset>

          {% if noneOption %}
            <hr class="govuk-section-break govuk-section-break--visible govuk-section-break--m">
            <p class="govuk-body govuk-!-font-weight-bold">{{ t("onboarding.safeguarding.none_separator") }}</p>
            <div class="govuk-checkboxes" data-module="govuk-checkboxes">
              <div class="govuk-checkboxes__item">
                <input class="govuk-checkboxes__input" id="sg-{{ noneOption.id }}" name="safeguarding[{{ noneOption.id }}]" type="checkbox" value="1">
                <label class="govuk-label govuk-checkboxes__label" for="sg-{{ noneOption.id }}">{{ noneOption.label or t("govuk_alpha.onboarding.safeguarding.none_label") }}</label>
              </div>
            </div>
          {% endif %}

          <div class="govuk-button-group govuk-!-margin-top-4">
            <button class="govuk-button" data-module="govuk-button">{{ t("onboarding.continue") }}</button>
            {% if not stepRequired %}
              <button class="govuk-button govuk-button--secondary" name="skip" value="1" data-module="govuk-button">{{ t("onboarding.skip") }}</button>
            {% endif %}
          </div>
        </form>

      {% else %}
        <h1 class="govuk-heading-xl">{{ t("onboarding.confirm.title") }}</h1>
        <dl class="govuk-summary-list">
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t("govuk_alpha.onboarding.confirm.photo_row") }}</dt>
            <dd class="govuk-summary-list__value">{% if onboardingUser.avatar_url %}{{ t("govuk_alpha.onboarding.confirm.photo_added") }}{% else %}{{ t("govuk_alpha.onboarding.confirm.photo_missing") }}{% endif %}</dd>
            <dd class="govuk-summary-list__actions"><a class="govuk-link" href="{{ urlFor('/onboarding/profile') }}">{{ t("govuk_alpha.onboarding.confirm.change") }}</a></dd>
          </div>
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t("onboarding.confirm.bio_row") }}</dt>
            <dd class="govuk-summary-list__value">{{ (onboardingUser.bio or "") | truncate(120, true, '...') }}</dd>
            <dd class="govuk-summary-list__actions"><a class="govuk-link" href="{{ urlFor('/onboarding/profile') }}">{{ t("govuk_alpha.onboarding.confirm.change") }}</a></dd>
          </div>
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t("onboarding.confirm.interests_row") }}</dt>
            <dd class="govuk-summary-list__value">{{ t("govuk_alpha.onboarding.count_selected", { count: bagInterests.length }) }}</dd>
            <dd class="govuk-summary-list__actions"><a class="govuk-link" href="{{ urlFor('/onboarding/interests') }}">{{ t("govuk_alpha.onboarding.confirm.change") }}</a></dd>
          </div>
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t("onboarding.confirm.skills_offers_row") }}</dt>
            <dd class="govuk-summary-list__value">{{ t("govuk_alpha.onboarding.count_selected", { count: bagOffers.length }) }}</dd>
            <dd class="govuk-summary-list__actions"><a class="govuk-link" href="{{ urlFor('/onboarding/skills') }}">{{ t("govuk_alpha.onboarding.confirm.change") }}</a></dd>
          </div>
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t("onboarding.confirm.skills_needs_row") }}</dt>
            <dd class="govuk-summary-list__value">{{ t("govuk_alpha.onboarding.count_selected", { count: bagNeeds.length }) }}</dd>
            <dd class="govuk-summary-list__actions"><a class="govuk-link" href="{{ urlFor('/onboarding/skills') }}">{{ t("govuk_alpha.onboarding.confirm.change") }}</a></dd>
          </div>
        </dl>
        <p class="govuk-body">{{ t("onboarding.confirm.finish_note") }}</p>
        <form method="post" action="{{ urlFor('/onboarding/confirm') }}">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <button class="govuk-button" data-module="govuk-button">{{ t("onboarding.confirm.complete_button") }}</button>
        </form>
      {% endif %}
    </div>
  </div>
{% endblock %}
