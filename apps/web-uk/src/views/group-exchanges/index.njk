{% extends "layouts/base.njk" %}

{% block content %}
  <span class="govuk-caption-xl">{{ t("group_exchanges.caption", { community: tenantName }) }}</span>
  <h1 class="govuk-heading-xl">{{ t("group_exchanges.title") }}</h1>
  <p class="govuk-body-l">{{ t("group_exchanges.description") }}</p>

  {% if successMessage %}
    <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="ge-list-status">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="ge-list-status">{{ t("states.success_title") }}</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ successMessage }}</p>
      </div>
    </div>
  {% endif %}

  <p class="govuk-body">
    <a class="govuk-button" href="{{ urlFor('/group-exchanges/new') }}" role="button" draggable="false" data-module="govuk-button">{{ t("group_exchanges.create_button") }}</a>
  </p>

  <nav class="govuk-!-margin-bottom-4" aria-label="{{ t('group_exchanges.filter_label') }}">
    <ul class="govuk-list nexus-alpha-filter-tabs">
      {% set tabs = [
        { value: "", label: t("group_exchanges.filter_all"), path: "/group-exchanges" },
        { value: "draft", label: t("group_exchanges.statuses.draft"), path: "/group-exchanges?state=draft" },
        { value: "pending", label: t("group_exchanges.statuses.pending"), path: "/group-exchanges?state=pending" },
        { value: "active", label: t("group_exchanges.statuses.active"), path: "/group-exchanges?state=active" },
        { value: "completed", label: t("group_exchanges.statuses.completed"), path: "/group-exchanges?state=completed" },
        { value: "cancelled", label: t("group_exchanges.statuses.cancelled"), path: "/group-exchanges?state=cancelled" }
      ] %}
      {% for tab in tabs %}
        <li class="govuk-!-display-inline-block govuk-!-margin-right-3">
          {% if exchangeState == tab.value %}
            <strong>{{ tab.label }}</strong>
          {% else %}
            <a class="govuk-link" href="{{ urlFor(tab.path) }}">{{ tab.label }}</a>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  </nav>

  {% if exchanges and exchanges.length %}
    <table class="govuk-table">
      <caption class="govuk-table__caption govuk-table__caption--s govuk-visually-hidden">{{ t("group_exchanges.title") }}</caption>
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header">{{ t("group_exchanges.form_title_label") }}</th>
          <th scope="col" class="govuk-table__header">{{ t("group_exchanges.status_label") }}</th>
          <th scope="col" class="govuk-table__header govuk-table__header--numeric">{{ t("group_exchanges.total_hours_label") }}</th>
        </tr>
      </thead>
      <tbody class="govuk-table__body">
        {% for exchange in exchanges %}
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">
              <a class="govuk-link" href="{{ urlFor('/group-exchanges/' + (exchange.id | string)) }}">{{ exchange.title }}</a>
            </td>
            <td class="govuk-table__cell">
              <strong class="govuk-tag {{ exchange.statusClass }}">{{ exchange.statusLabel }}</strong>
            </td>
            <td class="govuk-table__cell govuk-table__cell--numeric">{{ exchange.totalHours }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% else %}
    <div class="govuk-inset-text">{{ t("group_exchanges.empty") }}</div>
  {% endif %}
{% endblock %}
