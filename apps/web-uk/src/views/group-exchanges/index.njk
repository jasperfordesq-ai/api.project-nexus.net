{% extends "layouts/base.njk" %}

{% block content %}
  <span class="govuk-caption-xl">{{ tenant.name or tenant.slug or "Community" }}</span>
  <h1 class="govuk-heading-xl">Group exchanges</h1>
  <p class="govuk-body-l">Exchanges of time between several members at once - for example a group of people sharing or pooling a task.</p>

  {% if successMessage %}
    <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="ge-list-status">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="ge-list-status">Success</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ successMessage }}</p>
      </div>
    </div>
  {% endif %}

  <p class="govuk-body">
    <a class="govuk-button" href="/group-exchanges/new" role="button" draggable="false" data-module="govuk-button">Start a group exchange</a>
  </p>

  <nav class="govuk-!-margin-bottom-4" aria-label="Filter by status">
    <ul class="govuk-list nexus-alpha-filter-tabs">
      {% set tabs = [
        { value: "", label: "All", href: "/group-exchanges" },
        { value: "draft", label: "Draft", href: "/group-exchanges?state=draft" },
        { value: "pending", label: "Awaiting approval", href: "/group-exchanges?state=pending" },
        { value: "active", label: "Active", href: "/group-exchanges?state=active" },
        { value: "completed", label: "Completed", href: "/group-exchanges?state=completed" },
        { value: "cancelled", label: "Cancelled", href: "/group-exchanges?state=cancelled" }
      ] %}
      {% for tab in tabs %}
        <li class="govuk-!-display-inline-block govuk-!-margin-right-3">
          {% if exchangeState == tab.value %}
            <strong>{{ tab.label }}</strong>
          {% else %}
            <a class="govuk-link" href="{{ tab.href }}">{{ tab.label }}</a>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  </nav>

  {% if exchanges and exchanges.length %}
    <table class="govuk-table">
      <caption class="govuk-table__caption govuk-table__caption--s govuk-visually-hidden">Group exchanges</caption>
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header">Title</th>
          <th scope="col" class="govuk-table__header">Status</th>
          <th scope="col" class="govuk-table__header govuk-table__header--numeric">Total hours</th>
        </tr>
      </thead>
      <tbody class="govuk-table__body">
        {% for exchange in exchanges %}
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">
              <a class="govuk-link" href="/group-exchanges/{{ exchange.id }}">{{ exchange.title }}</a>
            </td>
            <td class="govuk-table__cell">
              <strong class="govuk-tag {{ exchange.statusClass }}">{{ exchange.statusLabel }}</strong>
            </td>
            <td class="govuk-table__cell govuk-table__cell--numeric">{{ exchange.totalHours }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% else %}
    <div class="govuk-inset-text">You have no group exchanges yet.</div>
  {% endif %}
{% endblock %}
