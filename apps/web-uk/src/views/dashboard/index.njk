{% extends "layouts/base.njk" %}

{% block mainContent %}
  {% if status == "onboarding-complete" or successMessage %}
    <div class="govuk-notification-banner govuk-notification-banner--success" role="alert" aria-labelledby="dashboard-success-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="dashboard-success-title">Success</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ successMessage or "Your profile setup is complete." }}</p>
      </div>
    </div>
  {% endif %}

  <span class="govuk-caption-l">{{ communityName }}</span>
  <h1 class="govuk-heading-xl">Dashboard</h1>
  <p class="govuk-body-l">Welcome back, {{ firstName }}.</p>

  {% if not onboardingCompleted %}
    <div class="govuk-notification-banner" role="region" aria-labelledby="dashboard-onboarding-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="dashboard-onboarding-title">Finish setting up your profile</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">Add a few details so other members can find and connect with you.</p>
        <p class="govuk-body">
          <a class="govuk-notification-banner__link" href="/onboarding">Complete your profile</a>
        </p>
      </div>
    </div>
  {% endif %}

  {% if exchangeAttention and exchangeAttention.count > 0 %}
    <div class="govuk-notification-banner" role="region" aria-labelledby="dashboard-reviews-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="dashboard-reviews-title">Exchanges need your attention</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ exchangeAttention.body }}</p>
        <p class="govuk-body">
          <a class="govuk-notification-banner__link" href="/exchanges">View your exchanges</a>
        </p>
      </div>
    </div>
  {% endif %}

  <div class="govuk-button-group govuk-!-margin-bottom-6">
    <a class="govuk-button" data-module="govuk-button" href="/listings/new">Create a listing</a>
  </div>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h2 class="govuk-heading-l">Your time bank</h2>
      <dl class="nexus-alpha-stat-grid">
        <div class="nexus-alpha-stat">
          <dt>Time-credit balance</dt>
          <dd>{{ balanceLabel }}</dd>
        </div>
        <div class="nexus-alpha-stat">
          <dt>Hours given</dt>
          <dd>{{ profileStats.hoursGivenLabel }}</dd>
        </div>
        <div class="nexus-alpha-stat">
          <dt>Hours received</dt>
          <dd>{{ profileStats.hoursReceivedLabel }}</dd>
        </div>
        <div class="nexus-alpha-stat">
          <dt>Active listings</dt>
          <dd>{{ profileStats.listingsCountLabel }}</dd>
        </div>
      </dl>

      <h2 class="govuk-heading-l govuk-!-margin-top-7">Your progress</h2>
      <p class="govuk-body govuk-!-margin-bottom-1">
        <strong>Level {{ gamification.level }}</strong>
        {% if gamification.levelName %}
          <span class="nexus-alpha-meta">({{ gamification.levelName }})</span>
        {% endif %}
        <span class="nexus-alpha-meta">{{ gamification.xpLabel }} XP</span>
      </p>
      <progress id="xp-progress" max="100" value="{{ gamification.progressPct }}" aria-label="{{ gamification.progressLabel }}">{{ gamification.progressPct }}%</progress>
      <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-top-1">{{ gamification.progressLabel }}</p>

      <h3 class="govuk-heading-m">Badges ({{ gamification.badgesCountLabel }})</h3>
      {% if badges and badges.length %}
        <ul class="govuk-list nexus-alpha-actions">
          {% for badge in badges %}
            <li>
              <strong class="govuk-tag govuk-tag--blue">{{ badge.name or badge.title }}</strong>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <p class="govuk-body">You have not earned any badges yet. Take part in your community to start earning them.</p>
      {% endif %}

      {% if upcomingEvents and upcomingEvents.length %}
        <h2 class="govuk-heading-l govuk-!-margin-top-7">Upcoming events</h2>
        <ul class="govuk-list govuk-list--spaced">
          {% for event in upcomingEvents %}
            <li>
              <a class="govuk-link" href="/events/{{ event.id }}">{{ event.title }}</a>
              {% if event.start or event.location %}
                <br>
                <span class="govuk-body-s nexus-alpha-meta">
                  {% if event.start %}{{ event.start | formatDate }}{% endif %}
                  {% if event.start and event.location %} - {% endif %}
                  {% if event.location %}{{ event.location }}{% endif %}
                </span>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      {% endif %}

      {% if endorsements and endorsements.length %}
        <h2 class="govuk-heading-l govuk-!-margin-top-7">Your skill endorsements</h2>
        <ul class="govuk-list nexus-alpha-skill-list">
          {% for endorsement in endorsements %}
            <li>
              <span class="govuk-!-font-weight-bold">{{ endorsement.skillName }}</span>
              <strong class="govuk-tag govuk-tag--green">{{ endorsement.countLabel }}</strong>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>

    <div class="govuk-grid-column-one-third">
      <h2 class="govuk-heading-l">Quick links</h2>
      <ul class="govuk-list govuk-list--spaced">
        <li><a class="govuk-link" href="/profile">View your profile</a></li>
        <li><a class="govuk-link" href="/profile/settings">Edit your profile</a></li>
        <li><a class="govuk-link" href="/feed">View all feed items</a></li>
        <li><a class="govuk-link" href="/messages">Messages</a></li>
        <li><a class="govuk-link" href="/members">Members</a></li>
        <li><a class="govuk-link" href="/listings">View all listings</a></li>
        <li><a class="govuk-link" href="/events">Events</a></li>
        <li><a class="govuk-link" href="/volunteering">Volunteering</a></li>
      </ul>
    </div>
  </div>

  <div class="govuk-grid-row govuk-!-margin-top-8">
    <div class="govuk-grid-column-one-half">
      <h2 class="govuk-heading-l">Recent feed</h2>
      {% if not feedItems or not feedItems.length %}
        <div class="govuk-inset-text">There are no recent feed items to show.</div>
      {% else %}
        <div class="nexus-alpha-card-list">
          {% for item in feedItems %}
            <article class="nexus-alpha-card">
              <strong class="govuk-tag govuk-tag--grey">{{ item.typeLabel }}</strong>
              <h3 class="govuk-heading-m govuk-!-margin-top-2 govuk-!-margin-bottom-2">
                <a class="govuk-link" href="/feed">{{ item.title }}</a>
              </h3>
              <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-2">Posted by {{ item.authorName }}</p>
              {% if item.content %}
                <p class="govuk-body">{{ item.content }}</p>
              {% endif %}
              {% if item.imageUrl %}
                <img class="nexus-alpha-card-thumb" src="{{ item.imageUrl }}" alt="Image for {{ item.title }}" width="120" height="90" loading="lazy" decoding="async">
              {% endif %}
            </article>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="govuk-grid-column-one-half">
      <h2 class="govuk-heading-l">Recent listings</h2>
      {% if not listings or not listings.length %}
        <div class="govuk-inset-text">There are no recent listings to show.</div>
      {% else %}
        <div class="nexus-alpha-card-list">
          {% for listing in listings %}
            <article class="nexus-alpha-card">
              <strong class="govuk-tag {% if listing.type == "request" %}govuk-tag--purple{% else %}govuk-tag--blue{% endif %}">{{ listing.type | capitalize }}</strong>
              <h3 class="govuk-heading-m govuk-!-margin-top-2 govuk-!-margin-bottom-2">
                <a class="govuk-link" href="/listings/{{ listing.id }}">{{ listing.title }}</a>
              </h3>
              {% if listing.description %}
                <p class="govuk-body">{{ listing.description }}</p>
              {% endif %}
              {% if listing.imageUrl %}
                <img class="nexus-alpha-card-thumb" src="{{ listing.imageUrl }}" alt="Image for {{ listing.title }}" width="120" height="90" loading="lazy" decoding="async">
              {% endif %}
            </article>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
{% endblock %}
