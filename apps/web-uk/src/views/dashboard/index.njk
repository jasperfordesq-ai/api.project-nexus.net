{% extends "layouts/base.njk" %}

{% block mainContent %}
  {% if successMessage %}
    {% set notificationMessage = successMessage %}
    {% set notificationType = "success" %}
    {% include "partials/notification-banner.njk" %}
  {% endif %}

  {% if status == "onboarding-complete" %}
    <div class="govuk-notification-banner govuk-notification-banner--success" role="alert" aria-labelledby="dashboard-onboarding-complete-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="dashboard-onboarding-complete-title">Success</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">Your profile setup is complete.</p>
      </div>
    </div>
  {% endif %}

  <span class="govuk-caption-l">{{ communityName }}</span>
  <h1 class="govuk-heading-xl">Dashboard</h1>

  {% if firstName %}
    <p class="govuk-body-l">Welcome back, {{ firstName }}.</p>
  {% else %}
    <p class="govuk-body-l">A read-only overview of your account, time bank and recent community activity.</p>
  {% endif %}

  {% if not onboardingCompleted %}
    <div class="govuk-notification-banner" role="region" aria-labelledby="dashboard-onboarding-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="dashboard-onboarding-title">Finish setting up your profile</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">Complete onboarding so other members can understand how you want to take part.</p>
        <p class="govuk-body">
          <a class="govuk-notification-banner__link" href="/onboarding">Continue onboarding</a>
        </p>
      </div>
    </div>
  {% endif %}

  {% if exchangeAttentionCount > 0 %}
    <div class="govuk-notification-banner" role="region" aria-labelledby="dashboard-reviews-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="dashboard-reviews-title">Exchanges need your attention</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ exchangeAttentionCount }} exchange requires a response, confirmation or review.</p>
        <p class="govuk-body">
          <a class="govuk-notification-banner__link" href="/exchanges">Review exchanges</a>
        </p>
      </div>
    </div>
  {% endif %}

  <div class="govuk-button-group govuk-!-margin-bottom-6">
    <a class="govuk-button" data-module="govuk-button" href="/listings/new">Create a listing</a>
  </div>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h2 class="govuk-heading-l">Your time bank</h2>
      <dl class="nexus-alpha-stat-grid">
        <div class="nexus-alpha-stat">
          <dt>Time-credit balance</dt>
          <dd>{{ wallet.balance }} hours</dd>
        </div>
        <div class="nexus-alpha-stat">
          <dt>Hours given</dt>
          <dd>{{ profileStats.hoursGiven }}</dd>
        </div>
        <div class="nexus-alpha-stat">
          <dt>Hours received</dt>
          <dd>{{ profileStats.hoursReceived }}</dd>
        </div>
        <div class="nexus-alpha-stat">
          <dt>Active listings</dt>
          <dd>{{ profileStats.listingsCount }}</dd>
        </div>
      </dl>

      <h2 class="govuk-heading-l govuk-!-margin-top-7">Your progress</h2>
      <p class="govuk-body govuk-!-margin-bottom-1">
        <strong>Level {{ gamification.level }}</strong>
        {% if gamification.levelName %}
          <span class="nexus-alpha-meta">({{ gamification.levelName }})</span>
        {% endif %}
        <span aria-hidden="true"> - </span>
        <span class="nexus-alpha-meta">{{ gamification.xp }} XP</span>
      </p>
      <progress id="xp-progress" max="100" value="{{ gamification.progressPercent }}" aria-label="{{ gamification.progressPercent }}% of the way to the next level">{{ gamification.progressPercent }}%</progress>
      <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-top-1" aria-hidden="true">{{ gamification.progressPercent }}% of the way to the next level</p>

      <h3 class="govuk-heading-m">Badges ({{ gamification.badgesCount }})</h3>
      {% if badges and badges.length > 0 %}
        <ul class="govuk-list nexus-alpha-actions">
          {% for badge in badges %}
            <li>
              {% if badge.icon %}
                <span aria-hidden="true">{{ badge.icon }}</span>
              {% endif %}
              <strong class="govuk-tag govuk-tag--blue">{{ badge.name }}</strong>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <p class="govuk-body">Badges you earn will appear here.</p>
      {% endif %}

      {% if upcomingEvents and upcomingEvents.length > 0 %}
        <h2 class="govuk-heading-l govuk-!-margin-top-7">Upcoming events</h2>
        <ul class="govuk-list govuk-list--spaced">
          {% for event in upcomingEvents %}
            <li>
              <a class="govuk-link" href="/events/{{ event.id }}">{{ event.title }}</a>
              {% if event.startsAt or event.location %}
                <br>
                <span class="govuk-body-s nexus-alpha-meta">
                  {% if event.startsAt %}{{ event.startsAt | formatDate }}{% endif %}
                  {% if event.startsAt and event.location %}<span aria-hidden="true"> - </span>{% endif %}
                  {% if event.location %}{{ event.location }}{% endif %}
                </span>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      {% endif %}

      {% if endorsements and endorsements.length > 0 %}
        <h2 class="govuk-heading-l govuk-!-margin-top-7">Endorsements</h2>
        <ul class="govuk-list nexus-alpha-skill-list">
          {% for endorsement in endorsements %}
            <li>
              <span class="govuk-!-font-weight-bold">{{ endorsement.skillName }}</span>
              <strong class="govuk-tag govuk-tag--green">{{ endorsement.count }}</strong>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>

    <div class="govuk-grid-column-one-third">
      <h2 class="govuk-heading-l">Quick links</h2>
      <ul class="govuk-list govuk-list--spaced">
        <li><a class="govuk-link" href="/profile">View your profile</a></li>
        <li><a class="govuk-link" href="/settings">Edit your profile</a></li>
        <li><a class="govuk-link" href="/feed">View all feed items</a></li>
        <li><a class="govuk-link" href="/messages">Messages</a></li>
        <li><a class="govuk-link" href="/members">Members</a></li>
        <li><a class="govuk-link" href="/listings">View listings</a></li>
        <li><a class="govuk-link" href="/events">Events</a></li>
        <li><a class="govuk-link" href="/volunteering">Volunteering</a></li>
      </ul>
    </div>
  </div>

  <div class="govuk-grid-row govuk-!-margin-top-8">
    <div class="govuk-grid-column-one-half">
      <h2 class="govuk-heading-l">Recent feed</h2>
      {% if not feedItems or feedItems.length == 0 %}
        <div class="govuk-inset-text">There are no recent feed items yet.</div>
      {% else %}
        <div class="nexus-alpha-card-list">
          {% for item in feedItems %}
            <article class="nexus-alpha-card">
              <strong class="govuk-tag govuk-tag--grey">{{ item.typeLabel }}</strong>
              <h3 class="govuk-heading-m govuk-!-margin-top-2 govuk-!-margin-bottom-2">
                <a class="govuk-link" href="{{ item.url }}">{{ item.title }}</a>
              </h3>
              <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-2">
                {% if item.authorAvatar %}
                  <img class="nexus-alpha-avatar nexus-alpha-avatar--small" src="{{ item.authorAvatar }}" alt="" loading="lazy" decoding="async" width="32" height="32">
                {% endif %}
                Posted by {{ item.authorName }}
              </p>
              {% if item.content %}
                <p class="govuk-body">{{ item.content }}</p>
              {% endif %}
              {% if item.imageUrl %}
                <img class="nexus-alpha-card-thumb" src="{{ item.imageUrl }}" alt="Image for {{ item.title }}" width="120" height="90" loading="lazy" decoding="async">
              {% endif %}
            </article>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="govuk-grid-column-one-half">
      <h2 class="govuk-heading-l">Recent listings</h2>
      {% if not listings or listings.length == 0 %}
        <div class="govuk-inset-text">There are no recent listings yet.</div>
      {% else %}
        <div class="nexus-alpha-card-list">
          {% for listing in listings %}
            <article class="nexus-alpha-card">
              <strong class="govuk-tag {{ listing.typeClass }}">{{ listing.typeLabel }}</strong>
              <h3 class="govuk-heading-m govuk-!-margin-top-2 govuk-!-margin-bottom-2">
                <a class="govuk-link" href="/listings/{{ listing.id }}">{{ listing.title }}</a>
              </h3>
              {% if listing.description %}
                <p class="govuk-body">{{ listing.description }}</p>
              {% endif %}
              {% if listing.imageUrl %}
                <img class="nexus-alpha-card-thumb" src="{{ listing.imageUrl }}" alt="Image for {{ listing.title }}" width="120" height="90" loading="lazy" decoding="async">
              {% endif %}
            </article>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
{% endblock %}
