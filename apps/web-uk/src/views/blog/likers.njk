{% extends "layouts/base.njk" %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <a class="govuk-back-link" href="{{ urlFor('/blog/' + post.slug + '/comments') }}">Back to the discussion</a>

      <span class="govuk-caption-l">Blog reactions</span>
      <h1 class="govuk-heading-xl">People who reacted {{ reactionEmoji }}</h1>

      <p class="govuk-body-l">
        {% if likersTotal == 0 %}No people{% elif likersTotal == 1 %}1 person{% else %}{{ likersTotal }} people{% endif %}
      </p>

      {% if not likers.length %}
        <div class="govuk-inset-text"><p class="govuk-body">No one has reacted with this yet.</p></div>
      {% else %}
        <ul class="govuk-list nexus-alpha-card-list">
          {% for liker in likers %}
            <li class="nexus-alpha-module-row">
              {% if liker.id %}
                <a class="govuk-link" href="{{ urlFor('/members/' + (liker.id | string)) }}">{{ liker.name }}</a>
              {% else %}
                {{ liker.name }}
              {% endif %}
            </li>
          {% endfor %}
        </ul>

        {% if likersHasMore %}
          <a class="govuk-button govuk-button--secondary" data-module="govuk-button" role="button" href="{{ urlFor('/blog/' + post.slug + '/likers/' + reaction + '?page=' + ((likersPage + 1) | string)) }}">Show more people</a>
        {% endif %}
      {% endif %}
    </div>
  </div>
{% endblock %}
