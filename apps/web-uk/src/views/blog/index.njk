{% extends "layouts/base.njk" %}

{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/pagination/macro.njk" import govukPagination %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if successMessage %}
        {% set notificationMessage = successMessage %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      <h1 class="govuk-heading-xl">Blog</h1>
      <p class="govuk-body-l">News and updates from the community.</p>

      {% if posts and posts.length > 0 %}
        {% for post in posts %}
          <div class="govuk-!-margin-bottom-6">
            <h2 class="govuk-heading-m govuk-!-margin-bottom-1">
              <a href="/blog/{{ post.id }}" class="govuk-link govuk-link--no-visited-state">
                {{ post.title }}
              </a>
            </h2>
            <p class="govuk-body-s govuk-!-margin-bottom-2" style="color: #505a5f;">
              {{ (post.created_at or post.createdAt) | formatDate }}
              {% if post.category or post.category_name %}
                - {{ govukTag({ text: post.category or post.category_name, classes: "govuk-tag--blue" }) }}
              {% endif %}
            </p>
            {% if post.excerpt or post.summary %}
              <p class="govuk-body">{{ post.excerpt or post.summary }}</p>
            {% elif post.content %}
              <p class="govuk-body">{{ post.content | truncate(200) }}</p>
            {% endif %}
            <hr class="govuk-section-break govuk-section-break--visible">
          </div>
        {% endfor %}

        {# Pagination #}
        {% set totalPages = pagination.totalPages or pagination.total_pages or 1 %}
        {% if totalPages > 1 %}
          {% set paginationItems = [] %}
          {% for i in range(1, totalPages + 1) %}
            {% set paginationItems = (paginationItems.push({
              number: i,
              href: "/blog?page=" + i + ("&category=" + category if category else ""),
              current: i == pagination.page
            }), paginationItems) %}
          {% endfor %}
          {{ govukPagination({
            previous: { href: "/blog?page=" + (pagination.page - 1) } if pagination.page > 1 else undefined,
            next: { href: "/blog?page=" + (pagination.page + 1) } if pagination.page < totalPages else undefined,
            items: paginationItems
          }) }}
        {% endif %}
      {% else %}
        {% set emptyState = {
          icon: "📝",
          heading: "No blog posts yet",
          message: "Check back soon for community news and updates."
        } %}
        {% include "partials/empty-state.njk" %}
      {% endif %}

    </div>
  </div>
{% endblock %}
