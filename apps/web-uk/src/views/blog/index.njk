{% extends "layouts/base.njk" %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <span class="govuk-caption-l">This community</span>
      <h1 class="govuk-heading-xl">Blog</h1>
      <p class="govuk-body-l">News, stories and updates from this community.</p>

      <form method="get" action="/blog" class="govuk-!-margin-bottom-6">
        <div class="govuk-form-group">
          <label class="govuk-label" for="q">Search the blog</label>
          <div id="q-hint" class="govuk-hint">Search by title or content.</div>
          <input class="govuk-input govuk-!-width-two-thirds" id="q" name="q" type="search" value="{{ searchQuery }}" aria-describedby="q-hint">
        </div>
        {% if categories.length %}
          <div class="govuk-form-group">
            <label class="govuk-label" for="category">Category</label>
            <select class="govuk-select" id="category" name="category">
              <option value="">All categories</option>
              {% for category in categories %}
                <option value="{{ category.id }}"{% if categoryId == category.id %} selected{% endif %}>{{ category.name }}</option>
              {% endfor %}
            </select>
          </div>
        {% endif %}
        <button class="govuk-button govuk-button--secondary" data-module="govuk-button" type="submit">Search</button>
      </form>

      <h2 class="govuk-heading-m">Posts</h2>

      {% if not posts.length %}
        <div class="govuk-inset-text">
          {% if searchQuery or categoryId %}No posts match your search.{% else %}No blog posts have been published yet.{% endif %}
        </div>
      {% else %}
        <ul class="govuk-list nexus-alpha-card-list">
          {% for post in posts %}
            <li class="nexus-alpha-card">
              {% if post.featuredImage %}
                <p class="govuk-!-margin-bottom-2">
                  <img class="nexus-alpha-card-thumb" src="{{ post.featuredImage }}" alt="Image for {{ post.title }}" width="120" height="90" loading="lazy" decoding="async">
                </p>
              {% endif %}
              {% if loop.first %}
                <strong class="govuk-tag govuk-tag--blue govuk-!-margin-bottom-2">Featured</strong>
              {% endif %}
              <h3 class="govuk-heading-m govuk-!-margin-bottom-1">
                <a class="govuk-link" href="/blog/{{ post.slug }}">{{ post.title }}</a>
              </h3>
              {% if post.excerpt %}
                <p class="govuk-body govuk-!-margin-bottom-1">{{ post.excerpt }}</p>
              {% endif %}
              <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-0">
                {% if post.category.name %}{{ post.category.name }} - {% endif %}
                {% if post.author.name %}{{ post.author.name }} - {% endif %}
                {% if post.publishedAt %}{{ post.publishedAt | formatDate }} - {% endif %}
                {% if post.readingTime %}{{ post.readingTime }} min read{% endif %}
              </p>
            </li>
          {% endfor %}
        </ul>

        {% if hasMore and nextCursor %}
          <nav class="govuk-pagination govuk-pagination--block" role="navigation" aria-label="More posts">
            <div class="govuk-pagination__next">
              <a class="govuk-link govuk-pagination__link" href="/blog?q={{ searchQuery | urlencode }}{% if categoryId %}&category={{ categoryId }}{% endif %}&cursor={{ nextCursor | urlencode }}" rel="next">
                <span class="govuk-pagination__link-title">Load more</span>
              </a>
            </div>
          </nav>
        {% endif %}
      {% endif %}
    </div>
  </div>
{% endblock %}
