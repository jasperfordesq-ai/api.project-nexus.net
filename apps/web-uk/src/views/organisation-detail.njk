{% extends "layouts/base.njk" %}

{% set organisationName = organisation.name or "Organisations" %}
{% set organisationDescription = organisation.description or organisation.excerpt or "" %}
{% set opportunities = orgOpportunities or [] %}
{% set reviews = orgReviews or [] %}

{% block mainContent %}
  <a class="govuk-back-link" href="{{ urlFor('/organisations') }}">Organisations</a>

  <span class="govuk-caption-xl">{{ tenantName }}</span>
  <h1 class="govuk-heading-xl">{{ organisationName }}</h1>

  {% if organisationDescription %}
    <p class="govuk-body-l">{{ organisationDescription }}</p>
  {% endif %}

  {% if contactEmail or website %}
    <dl class="govuk-summary-list">
      {% if contactEmail %}
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Contact email (optional)</dt>
          <dd class="govuk-summary-list__value">
            <a class="govuk-link" href="mailto:{{ contactEmail }}">{{ contactEmail }}</a>
          </dd>
        </div>
      {% endif %}
      {% if website %}
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">{{ t("organisations.website_label") }}</dt>
          <dd class="govuk-summary-list__value">
            <a class="govuk-link" href="{{ websiteHref }}" rel="nofollow noopener noreferrer" target="_blank">
              {{ website }}<span class="govuk-visually-hidden"> opens in a new tab</span>
            </a>
          </dd>
        </div>
      {% endif %}
    </dl>
  {% endif %}

  {% if organisation.id %}
    <p class="govuk-body">
      <a class="govuk-link" href="{{ urlFor('/organisations/' + (organisation.id | string) + '/jobs') }}">View job openings</a>
    </p>
  {% endif %}

  <h2 class="govuk-heading-l">{{ t("org_depth.stats_heading") }}</h2>
  <dl class="nexus-alpha-inline-list">
    <div>
      <dt>{{ t("org_depth.stat_opportunities") }}</dt>
      <dd>{{ orgStats.opportunity_count or 0 }}</dd>
    </div>
    <div>
      <dt>{{ t("org_depth.stat_volunteers") }}</dt>
      <dd>{{ orgStats.volunteer_count or 0 }}</dd>
    </div>
    <div>
      <dt>{{ t("org_depth.stat_hours") }}</dt>
      <dd>{{ orgStats.total_hours or 0 }}</dd>
    </div>
    <div>
      <dt>Reviews</dt>
      <dd>{{ orgStats.review_count or 0 }}</dd>
    </div>
    {% if orgStats.review_count and orgStats.average_rating %}
      <div>
        <dt>Average rating</dt>
        <dd>
          <progress max="5" value="{{ orgStats.average_rating }}" aria-label="{{ orgStats.average_rating }} out of 5">
            {{ orgStats.average_rating }} out of 5
          </progress>
          <span class="govuk-!-margin-left-2">{{ orgStats.average_rating }} out of 5</span>
        </dd>
      </div>
    {% endif %}
  </dl>

  <h2 class="govuk-heading-l">{{ t("org_depth.opportunities_heading") }}</h2>
  {% if opportunities and opportunities.length %}
    <p class="govuk-body">Open volunteering opportunities posted by {{ organisationName }}.</p>
    <div class="nexus-alpha-card-list">
      {% for opportunity in opportunities %}
        {% if opportunity.id %}
          <article class="nexus-alpha-card">
            <h3 class="govuk-heading-m govuk-!-margin-bottom-2">
              <a class="govuk-link" href="{{ urlFor('/volunteering/opportunities/' + (opportunity.id | string)) }}">{{ opportunity.title or "Organisations" }}</a>
            </h3>

            {% if opportunity.is_remote %}
              <p class="govuk-!-margin-bottom-2"><strong class="govuk-tag govuk-tag--turquoise">Remote</strong></p>
            {% endif %}

            {% if opportunity.summary %}
              <p class="govuk-body">{{ opportunity.summary }}</p>
            {% endif %}

            <div class="nexus-alpha-actions">
              <a class="govuk-link" href="{{ urlFor('/volunteering/opportunities/' + (opportunity.id | string)) }}">View opportunity</a>
              <a class="govuk-link" href="{{ urlFor('/organisations/opportunities/' + (opportunity.id | string) + '/apply') }}">Apply to volunteer</a>
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  {% else %}
    <div class="govuk-inset-text">{{ t("org_depth.opportunities_empty") }}</div>
  {% endif %}

  <h2 class="govuk-heading-l">{{ t("org_depth.reviews_heading") }}</h2>
  {% if reviews and reviews.length %}
    <div class="nexus-alpha-card-list">
      {% for review in reviews %}
        {% set author = review.author or {} %}
        {% set authorName = author.name or "Someone" %}
        {% set rating = review.rating or 0 %}
        <article class="nexus-alpha-card">
          <div class="nexus-alpha-card-head">
            {% if author.avatar %}
              <img class="nexus-alpha-avatar" src="{{ author.avatar }}" alt="" width="48" height="48" loading="lazy" decoding="async">
            {% else %}
              <span class="nexus-alpha-avatar nexus-alpha-avatar--placeholder" aria-hidden="true">{{ authorName | first | upper }}</span>
            {% endif %}
            <span class="govuk-body govuk-!-margin-bottom-0 govuk-!-font-weight-bold">{{ authorName }}</span>
          </div>

          <p class="govuk-!-margin-bottom-2">
            <progress max="5" value="{{ rating }}" aria-label="{{ rating }} out of 5">{{ rating }} out of 5</progress>
            <span class="govuk-!-margin-left-2">{{ rating }} out of 5</span>
          </p>

          {% if review.comment %}
            <div class="govuk-body">{{ review.comment | nl2br | safe }}</div>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% else %}
    <div class="govuk-inset-text">{{ t("org_depth.reviews_empty") }}</div>
  {% endif %}
{% endblock %}
