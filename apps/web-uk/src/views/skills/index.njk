{% extends "layouts/base.njk" %}

{% macro categoryList(nodes) %}
  <ul class="govuk-list govuk-list--spaced">
    {% for node in nodes %}
      <li>
        {% if node.id %}
          <a class="govuk-link" href="{{ urlFor('/skills?category=' ~ node.id) }}">{{ node.name }}</a>
        {% else %}
          {{ node.name }}
        {% endif %}
        {% if node.children and node.children.length %}
          <div class="govuk-!-margin-left-3">
            {{ categoryList(node.children) }}
          </div>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
{% endmacro %}

{% block content %}
  <span class="govuk-caption-xl">{{ t("skills.caption", { community: tenantName }) }}</span>
  <h1 class="govuk-heading-xl">{{ t("skills.title") }}</h1>
  <p class="govuk-body-l">{{ t("skills.description") }}</p>

  {% if apiError %}
    <div class="govuk-inset-text">
      <p class="govuk-body">{{ apiError }}</p>
    </div>
  {% endif %}

  <form method="get" action="{{ urlFor('/skills') }}" class="govuk-!-margin-bottom-6">
    <div class="govuk-form-group">
      <label class="govuk-label" for="skill">{{ t("skills.search_label") }}</label>
      <div id="skill-hint" class="govuk-hint">{{ t("skills.search_hint") }}</div>
      <input class="govuk-input govuk-!-width-two-thirds" id="skill" name="skill" type="search" value="{{ skillQuery }}" aria-describedby="skill-hint" maxlength="100">
    </div>
    <button type="submit" class="govuk-button" data-module="govuk-button">{{ t("skills.search_button") }}</button>
  </form>

  {% if skillQuery %}
    <h2 class="govuk-heading-l">{{ t("skills.members_with", { skill: skillQuery }) }}</h2>
    {% if skillMembers and skillMembers.length %}
      <ul class="govuk-list">
        {% for member in skillMembers %}
          <li class="govuk-!-margin-bottom-2">
            {% if member.id %}
              <a class="govuk-link" href="{{ urlFor('/members/' ~ member.id) }}">{{ member.name }}</a>
            {% else %}
              {{ member.name }}
            {% endif %}
            {% if member.proficiencyLabel %}
              <strong class="govuk-tag govuk-tag--grey govuk-!-margin-left-1">{{ member.proficiencyLabel }}</strong>
            {% endif %}
            {% if member.isOffering %}
              <strong class="govuk-tag govuk-tag--green govuk-!-margin-left-1">{{ t("skills.offers") }}</strong>
            {% endif %}
            {% if member.isRequesting %}
              <strong class="govuk-tag govuk-tag--blue govuk-!-margin-left-1">{{ t("skills.wants") }}</strong>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <div class="govuk-inset-text">
        <p class="govuk-body">{{ t("skills.no_members") }}</p>
      </div>
    {% endif %}
    <hr class="govuk-section-break govuk-section-break--visible govuk-section-break--l">
  {% endif %}

  {% if selectedCategory %}
    <h2 class="govuk-heading-l">{{ t("skills.skills_in", { category: selectedCategory.name }) }}</h2>
    <p class="govuk-body"><a class="govuk-link" href="{{ urlFor('/skills') }}">{{ t("skills.back_to_categories") }}</a></p>
    {% if categorySkills and categorySkills.length %}
      <table class="govuk-table">
        <caption class="govuk-visually-hidden">{{ t("skills.skills_in", { category: selectedCategory.name }) }}</caption>
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">{{ t("skills.col_skill") }}</th>
            <th scope="col" class="govuk-table__header govuk-table__header--numeric">{{ t("skills.col_members") }}</th>
            <th scope="col" class="govuk-table__header govuk-table__header--numeric">{{ t("skills.col_offering") }}</th>
            <th scope="col" class="govuk-table__header govuk-table__header--numeric">{{ t("skills.col_requesting") }}</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          {% for skill in categorySkills %}
            <tr class="govuk-table__row">
              <th scope="row" class="govuk-table__header"><a class="govuk-link" href="{{ urlFor('/skills?skill=' ~ (skill.name | urlencode)) }}">{{ skill.name }}</a></th>
              <td class="govuk-table__cell govuk-table__cell--numeric">{{ skill.userCount }}</td>
              <td class="govuk-table__cell govuk-table__cell--numeric">{{ skill.offeringCount }}</td>
              <td class="govuk-table__cell govuk-table__cell--numeric">{{ skill.requestingCount }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    {% else %}
      <div class="govuk-inset-text">
        <p class="govuk-body">{{ t("skills.no_skills_in_category") }}</p>
      </div>
    {% endif %}
    <hr class="govuk-section-break govuk-section-break--visible govuk-section-break--l">
  {% endif %}

  <h2 class="govuk-heading-l">{{ t("skills.browse_by_category") }}</h2>
  {% if skillTree and skillTree.length %}
    {{ categoryList(skillTree) }}
  {% else %}
    <div class="govuk-inset-text">
      <p class="govuk-body">{{ t("skills.empty") }}</p>
    </div>
  {% endif %}
{% endblock %}
