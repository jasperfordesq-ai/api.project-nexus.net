{% extends "layouts/base.njk" %}

{% set organisationName = organisation.name or "Job openings" %}

{% block mainContent %}
  {% if organisation.id %}
    <a class="govuk-back-link" href="{{ urlFor('/organisations/' + (organisation.id | string)) }}">{{ organisationName }}</a>
  {% else %}
    <a class="govuk-back-link" href="{{ urlFor('/organisations/browse') }}">Back to organisations</a>
  {% endif %}

  <span class="govuk-caption-xl">Organisations in {{ tenantName }}</span>
  <h1 class="govuk-heading-xl">Job openings at {{ organisationName }}</h1>
  <p class="govuk-body-l">Open roles posted by this organisation.</p>

  {% if error %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            <li>We could not load the job openings. Please try again.</li>
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  {% if authRequired %}
    <div class="govuk-notification-banner" role="region" aria-labelledby="organisation-jobs-auth-title" data-module="govuk-notification-banner">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="organisation-jobs-auth-title">Sign in required</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-body">Sign in to load Laravel-backed job openings.</p>
      </div>
    </div>
  {% endif %}

  {% if jobs and jobs.length %}
    <p class="govuk-body">
      {% if jobs.length == 1 %}
        1 opening
      {% else %}
        {{ jobs.length }} openings
      {% endif %}
    </p>

    <div class="nexus-alpha-card-list">
      {% for job in jobs %}
        {% if job.id %}
          <article class="nexus-alpha-card">
            <h2 class="govuk-heading-m govuk-!-margin-bottom-2">
              <a class="govuk-link" href="{{ urlFor('/jobs/' + (job.id | string)) }}">{{ job.title or "Job openings" }}</a>
            </h2>

            <dl class="nexus-alpha-inline-list nexus-alpha-meta">
              {% if job.typeLabel %}
                <div>
                  <dt class="govuk-visually-hidden">Type of role</dt>
                  <dd><strong class="govuk-tag {{ job.typeTagClass }}">{{ job.typeLabel }}</strong></dd>
                </div>
              {% endif %}

              {% if job.is_remote %}
                <div>
                  <dt class="govuk-visually-hidden">Location</dt>
                  <dd>Remote</dd>
                </div>
              {% elseif job.location %}
                <div>
                  <dt class="govuk-visually-hidden">Location</dt>
                  <dd>{{ job.location }}</dd>
                </div>
              {% endif %}

              {% if job.deadline %}
                <div>
                  <dt class="govuk-visually-hidden">Application deadline</dt>
                  <dd>Closes {{ job.deadline | date }}</dd>
                </div>
              {% endif %}
            </dl>

            <div class="nexus-alpha-actions">
              <a class="govuk-link" href="{{ urlFor('/jobs/' + (job.id | string)) }}">View role</a>
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>
  {% else %}
    <div class="govuk-inset-text">This organisation has no open job openings at the moment.</div>
  {% endif %}
{% endblock %}
