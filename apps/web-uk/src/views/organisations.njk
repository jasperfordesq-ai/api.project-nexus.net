{% extends "layouts/base.njk" %}

{% block mainContent %}
  <span class="govuk-caption-xl">{{ tenantName }}</span>
  <h1 class="govuk-heading-xl">Organisations</h1>
  <p class="govuk-body-l">Community and partner organisations.</p>

  <nav class="govuk-!-margin-bottom-6" aria-label="Organisations">
    <ul class="govuk-list govuk-list--spaced">
      <li><a class="govuk-link" href="{{ urlFor('/organisations/browse') }}">Browse all organisations</a></li>
      <li><a class="govuk-link" href="{{ urlFor('/organisations/register') }}">Register an organisation</a></li>
      <li><a class="govuk-link" href="{{ urlFor('/organisations/manage') }}">Manage my organisations</a></li>
    </ul>
  </nav>

  {% if status == "org-submitted" %}
    <div class="govuk-notification-banner govuk-notification-banner--success" role="alert" aria-labelledby="organisations-success-title" data-module="govuk-notification-banner">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="organisations-success-title">Success</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">Thank you. Your organisation has been submitted for approval.</p>
      </div>
    </div>
  {% elseif status == "org-invalid" %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            <li><a href="#name">Check the organisation details and agree to the terms.</a></li>
          </ul>
        </div>
      </div>
    </div>
  {% elseif status == "org-failed" %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            <li><a href="#name">The organisation could not be submitted. Try again later.</a></li>
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  <form method="get" action="{{ urlFor('/organisations') }}" class="govuk-!-margin-bottom-7">
    <div class="govuk-form-group">
      <label class="govuk-label" for="q">Find an organisation</label>
      <div id="q-hint" class="govuk-hint">Search by name.</div>
      <input class="govuk-input govuk-!-width-two-thirds" id="q" name="q" type="search" value="{{ organisationsQuery }}" aria-describedby="q-hint">
    </div>
    <button class="govuk-button" data-module="govuk-button" type="submit">Search</button>
  </form>

  {% if organisationsLoadFailed %}
    <div class="govuk-warning-text">
      <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
      <strong class="govuk-warning-text__text">
        <span class="govuk-visually-hidden">Warning</span>
        Organisation listings are temporarily unavailable.
      </strong>
    </div>
  {% endif %}

  {% if organisations and organisations.length %}
    <div class="nexus-alpha-card-list govuk-!-margin-bottom-8">
      {% for organisation in organisations %}
        <article class="nexus-alpha-card">
          <h2 class="govuk-heading-m govuk-!-margin-bottom-2">
            <a class="govuk-link" href="{{ urlFor('/organisations/' + (organisation.id | string)) }}">{{ organisation.name }}</a>
          </h2>
          {% if organisation.description %}
            <p class="govuk-body govuk-!-margin-bottom-0">{{ organisation.description }}</p>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% else %}
    <div class="govuk-inset-text">There are no organisations listed yet.</div>
  {% endif %}

  <h2 class="govuk-heading-l govuk-!-margin-top-8">Register an organisation</h2>
  <p class="govuk-body">New organisations are reviewed before they appear.</p>
  <p class="govuk-body">
    Only registered organisations - charities, community groups, voluntary bodies
    and non-profits - should register here. Individual volunteers do not need to
    register: you can browse opportunities and log your hours using the
    timebanking tools without creating an organisation.
  </p>

  <form method="post" action="{{ urlFor('/organisations') }}" novalidate>
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    <div class="govuk-form-group">
      <label class="govuk-label" for="name">Organisation name</label>
      <input class="govuk-input govuk-!-width-two-thirds" id="name" name="name" type="text" autocomplete="organization" minlength="3" maxlength="255" required>
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label" for="description">Description</label>
      <div id="description-hint" class="govuk-hint">Describe what your organisation does. Enter at least 20 characters.</div>
      <textarea class="govuk-textarea" id="description" name="description" rows="5" maxlength="2000" aria-describedby="description-hint"></textarea>
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label" for="contact_email">Contact email</label>
      <input class="govuk-input govuk-!-width-two-thirds" id="contact_email" name="contact_email" type="email" autocomplete="email">
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label" for="website">Website (optional)</label>
      <input class="govuk-input govuk-!-width-two-thirds" id="website" name="website" type="url" autocomplete="url">
    </div>

    <div class="govuk-inset-text">
      <h3 class="govuk-heading-m">Organisation registration terms</h3>
      <ul class="govuk-list govuk-list--bullet">
        <li>You are authorised to register this organisation.</li>
        <li>The information you provide is accurate and can be reviewed by administrators.</li>
        <li>The organisation will follow the community guidelines and safeguarding rules.</li>
        <li>Volunteer opportunities must be lawful, respectful, and suitable for the community.</li>
        <li>Approval can be withdrawn if the organisation breaks these terms.</li>
      </ul>
    </div>

    <div class="govuk-form-group">
      <div class="govuk-checkboxes" data-module="govuk-checkboxes">
        <div class="govuk-checkboxes__item">
          <input class="govuk-checkboxes__input" id="agreed_terms" name="agreed_terms" type="checkbox" value="1" required>
          <label class="govuk-label govuk-checkboxes__label" for="agreed_terms">
            I have read and agree to the organisation registration terms above.
          </label>
        </div>
      </div>
    </div>

    <button class="govuk-button" data-module="govuk-button" type="submit">Submit for approval</button>
  </form>

  <div class="govuk-inset-text">
    Your organisation is pending admin approval. Once approved, it will appear
    publicly and you can post volunteer opportunities.
  </div>
{% endblock %}
