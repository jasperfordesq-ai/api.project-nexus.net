{% extends "layouts/base.njk" %}

{% macro reviewItem(review) %}
  <li class="nexus-alpha-card">
    <h3 class="govuk-heading-s govuk-!-margin-bottom-1">{{ review.otherLabel }} {{ review.otherName }}</h3>
    <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">Rating: {{ review.ratingLabel }}{% if review.createdAt %} - {{ review.createdAt | formatDate }}{% endif %}</p>
    {% if review.comment %}
      <p class="govuk-body govuk-!-margin-bottom-2">{{ review.comment }}</p>
    {% endif %}
    {% if review.id %}
      <p class="govuk-body-s govuk-!-margin-bottom-0"><a class="govuk-link" href="{{ urlFor('/reviews/' + (review.id | string) + '/comments') }}">Comment on this review</a></p>
    {% endif %}
    {% if review.id and review.canDelete %}
      <details class="govuk-details govuk-!-margin-top-3 govuk-!-margin-bottom-0" data-module="govuk-details">
        <summary class="govuk-details__summary">
          <span class="govuk-details__summary-text">{{ t("polish_members.review_delete_toggle") }}</span>
        </summary>
        <div class="govuk-details__text">
          <p class="govuk-body">{{ t("polish_members.review_delete_confirm") }}</p>
          <form method="post" action="{{ urlFor('/reviews/' + (review.id | string) + '/delete') }}">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button" type="submit">{{ t("polish_members.review_delete_button") }}</button>
          </form>
        </div>
      </details>
    {% endif %}
  </li>
{% endmacro %}

{% block mainContent %}
  {% if statusMessage %}
    {% if statusMessage.type == 'error' %}
      <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
        <div role="alert">
          <h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2>
          <div class="govuk-error-summary__body">
            <p class="govuk-body">{{ statusMessage.text }}</p>
          </div>
        </div>
      </div>
    {% else %}
      <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="reviews-status-title">
        <div class="govuk-notification-banner__header">
          <h2 class="govuk-notification-banner__title" id="reviews-status-title">{{ t("states.success_title") }}</h2>
        </div>
        <div class="govuk-notification-banner__content">
          <p class="govuk-notification-banner__heading">{{ statusMessage.text }}</p>
        </div>
      </div>
    {% endif %}
  {% endif %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <span class="govuk-caption-xl">Your reviews</span>
      <h1 class="govuk-heading-xl">Reviews</h1>
      <p class="govuk-body-l">Read the reviews you have received, check reviews you have given, and leave pending reviews after completed exchanges.</p>
      <p class="govuk-body"><a class="govuk-link" href="{{ urlFor('/reviews/list') }}">View all reviews</a></p>
    </div>
    <div class="govuk-grid-column-one-third">
      <div class="nexus-alpha-card">
        <h2 class="govuk-heading-m">Review score</h2>
        <p class="govuk-heading-l govuk-!-margin-bottom-1">{{ reviewStats.average or "Not rated" }}{% if reviewStats.average %} / 5{% endif %}</p>
        <p class="govuk-body govuk-!-margin-bottom-0">{{ reviewStats.total }} reviews</p>
      </div>
    </div>
  </div>

  <div class="govuk-grid-row govuk-!-margin-top-6">
    <div class="govuk-grid-column-one-half">
      <h2 class="govuk-heading-l">Received</h2>
      {% if reviewsReceived.length %}
        <ul class="nexus-alpha-card-list">
          {% for review in reviewsReceived %}
            {{ reviewItem(review) }}
          {% endfor %}
        </ul>
      {% else %}
        <p class="govuk-body">{{ t("reviews_page.received_empty") }}</p>
      {% endif %}
    </div>

    <div class="govuk-grid-column-one-half">
      <h2 class="govuk-heading-l">Given</h2>
      {% if reviewsGiven.length %}
        <ul class="nexus-alpha-card-list">
          {% for review in reviewsGiven %}
            {{ reviewItem(review) }}
          {% endfor %}
        </ul>
      {% else %}
        <p class="govuk-body">You have not given any reviews yet.</p>
      {% endif %}
    </div>
  </div>

  <div class="govuk-grid-row govuk-!-margin-top-6">
    <div class="govuk-grid-column-two-thirds">
      <h2 class="govuk-heading-l">Pending</h2>
      {% if reviewsPending.length %}
        <ul class="nexus-alpha-card-list">
          {% for pending in reviewsPending %}
            <li class="nexus-alpha-card">
              <h3 class="govuk-heading-s govuk-!-margin-bottom-1">{{ pending.receiverName }}</h3>
              <p class="govuk-body-s nexus-alpha-meta">{{ pending.title }}</p>
              <form method="post" action="{{ urlFor('/reviews') }}" novalidate>
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <input type="hidden" name="receiver_id" value="{{ pending.receiverId }}">
                <input type="hidden" name="transaction_id" value="{{ pending.transactionId }}">
                <div class="govuk-form-group">
                  <label class="govuk-label govuk-label--s" for="rating-{{ loop.index }}">Rating</label>
                  <select class="govuk-select" id="rating-{{ loop.index }}" name="rating">
                    <option value="5">5 - Excellent</option>
                    <option value="4">4 - Good</option>
                    <option value="3">3 - OK</option>
                    <option value="2">2 - Poor</option>
                    <option value="1">1 - Very poor</option>
                  </select>
                </div>
                <div class="govuk-form-group">
                  <label class="govuk-label govuk-label--s" for="comment-{{ loop.index }}">Your review</label>
                  <textarea class="govuk-textarea" id="comment-{{ loop.index }}" name="comment" rows="3" maxlength="2000"></textarea>
                </div>
                <button class="govuk-button" data-module="govuk-button" type="submit">Submit review</button>
              </form>
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <p class="govuk-body">There are no pending reviews.</p>
      {% endif %}
    </div>
  </div>
{% endblock %}
