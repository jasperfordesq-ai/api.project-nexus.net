{% extends "layouts/base.njk" %}

{% block mainContent %}
  <span class="govuk-caption-l">Exchanges</span>
  <h1 class="govuk-heading-xl">Exchanges</h1>
  <p class="govuk-body-l">Review exchange requests and track time-credit work.</p>

  {% if statusMessage or successMessage %}
    <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="exchange-success-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="exchange-success-title">Success</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ successMessage or statusMessage }}</p>
      </div>
    </div>
  {% endif %}

  {% if errorMessage %}
    <div class="govuk-notification-banner" data-module="govuk-notification-banner" role="region" aria-labelledby="exchange-error-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="exchange-error-title">Important</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ errorMessage }}</p>
      </div>
    </div>
  {% endif %}

  {% if not workflowEnabled %}
    <div class="govuk-notification-banner" data-module="govuk-notification-banner" role="region" aria-labelledby="exchange-disabled-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="exchange-disabled-title">Exchanges are unavailable</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-body">Exchange workflows are not enabled for this community.</p>
      </div>
    </div>
  {% endif %}

  <nav aria-label="Filter exchanges" class="govuk-!-margin-bottom-7">
    <ul class="nexus-alpha-filter-nav">
      <li><a class="govuk-link{% if activeTab == 'all' %} govuk-link--no-visited-state{% endif %}" href="{{ urlFor('/exchanges?tab=all') }}"{% if activeTab == 'all' %} aria-current="true"{% endif %}>All</a></li>
      <li><a class="govuk-link{% if activeTab == 'active' %} govuk-link--no-visited-state{% endif %}" href="{{ urlFor('/exchanges?tab=active') }}"{% if activeTab == 'active' %} aria-current="true"{% endif %}>Active</a></li>
      <li><a class="govuk-link{% if activeTab == 'needs_confirmation' %} govuk-link--no-visited-state{% endif %}" href="{{ urlFor('/exchanges?tab=needs_confirmation') }}"{% if activeTab == 'needs_confirmation' %} aria-current="true"{% endif %}>Needs confirmation</a></li>
      <li><a class="govuk-link{% if activeTab == 'completed' %} govuk-link--no-visited-state{% endif %}" href="{{ urlFor('/exchanges?tab=completed') }}"{% if activeTab == 'completed' %} aria-current="true"{% endif %}>Completed</a></li>
    </ul>
  </nav>

  <h2 class="govuk-heading-l">Results</h2>
  <p class="govuk-body nexus-alpha-result-count" aria-live="polite">
    {% if exchanges.length == 1 %}1 exchange shown{% else %}{{ exchanges.length }} exchanges shown{% endif %}
  </p>

  {% if not errorMessage and exchanges.length == 0 %}
    <div class="govuk-inset-text">
      <h2 class="govuk-heading-m">No results</h2>
      <p class="govuk-body">There are no exchanges to show for this filter.</p>
    </div>
  {% elif exchanges.length > 0 %}
    <div class="nexus-alpha-card-list">
      {% for exchange in exchanges %}
        <article class="nexus-alpha-card">
          <h3 class="govuk-heading-m govuk-!-margin-bottom-2">
            <a class="govuk-link" href="{{ urlFor('/exchanges/' + (exchange.id | string)) }}">{{ exchange.listingTitle }}</a>
          </h3>
          <strong class="govuk-tag {{ exchange.statusClass }}">{{ exchange.statusLabel }}</strong>
          {% if exchange.actionNeeded == 'respond' %}
            <strong class="govuk-tag govuk-tag--red">Respond</strong>
          {% elif exchange.actionNeeded == 'confirm' %}
            <strong class="govuk-tag govuk-tag--red">Confirm hours</strong>
          {% endif %}

          <dl class="nexus-alpha-inline-list govuk-!-margin-top-3">
            <div>
              <dt>Proposed hours</dt>
              <dd>{{ exchange.proposedHours }} hours</dd>
            </div>
            <div>
              <dt>Member</dt>
              <dd>{{ exchange.otherName }}</dd>
            </div>
            {% if exchange.createdAt %}
              <div>
                <dt>Created</dt>
                <dd>{{ exchange.createdAt | formatDate }}</dd>
              </div>
            {% endif %}
          </dl>

          <p class="govuk-body govuk-!-margin-bottom-0">
            <a class="govuk-link govuk-link--no-visited-state" href="{{ urlFor('/exchanges/' + (exchange.id | string)) }}">View exchange</a>
          </p>
        </article>
      {% endfor %}
    </div>

    {% if meta.has_more and meta.cursor %}
      <nav class="govuk-pagination govuk-pagination--block govuk-!-margin-top-6" aria-label="Exchange pagination">
        <div class="govuk-pagination__next">
          <a class="govuk-link govuk-pagination__link" href="{{ urlFor('/exchanges?tab=' + activeTab + '&cursor=' + meta.cursor) }}" rel="next">
            <span class="govuk-pagination__link-title">Load more</span>
            <span class="govuk-visually-hidden">:</span>
            <span class="govuk-pagination__link-label">more exchange results</span>
          </a>
        </div>
      </nav>
    {% endif %}
  {% endif %}
{% endblock %}
