{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a class="govuk-back-link" href="/listings/{{ listing.id }}">Back to listings</a>

  {% if errors and errors.length > 0 %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1" autofocus>
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            {% for error in errors %}
              <li><a href="{{ error.href or '#proposed_hours' }}">{{ error.text }}</a></li>
            {% endfor %}
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  {% if activeExchange %}
    <div class="govuk-notification-banner" data-module="govuk-notification-banner" role="region" aria-labelledby="active-exchange-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="active-exchange-title">Important</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">You already have an active exchange for this listing.</p>
        <p class="govuk-body"><a class="govuk-link" href="/exchanges/{{ activeExchange.id }}">View exchange</a></p>
      </div>
    </div>
  {% endif %}

  <span class="govuk-caption-l">Request exchange</span>
  <h1 class="govuk-heading-xl">{{ listing.title }}</h1>
  <p class="govuk-body-l">Ask the member to start an exchange for this listing.</p>

  <dl class="govuk-summary-list govuk-!-margin-bottom-7">
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Type</dt>
      <dd class="govuk-summary-list__value">{{ listing.typeLabel }}</dd>
    </div>
    {% if listing.categoryName %}
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Category</dt>
        <dd class="govuk-summary-list__value">{{ listing.categoryName }}</dd>
      </div>
    {% endif %}
    {% if listing.location %}
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Location</dt>
        <dd class="govuk-summary-list__value">{{ listing.location }}</dd>
      </div>
    {% endif %}
    {% if listing.hoursEstimate %}
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Hours</dt>
        <dd class="govuk-summary-list__value">{{ listing.hoursEstimate }}</dd>
      </div>
    {% endif %}
    {% if listing.authorName %}
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Posted by</dt>
        <dd class="govuk-summary-list__value">{{ listing.authorName }}</dd>
      </div>
    {% endif %}
  </dl>

  <form method="post" action="/exchanges/request/{{ listing.id }}">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    <div class="govuk-form-group{% if fieldErrors.proposed_hours %} govuk-form-group--error{% endif %}">
      <label class="govuk-label" for="proposed_hours">Proposed hours</label>
      <div id="proposed-hours-hint" class="govuk-hint">Enter the time you expect this exchange to take.</div>
      {% if fieldErrors.proposed_hours %}
        <p id="proposed-hours-error" class="govuk-error-message"><span class="govuk-visually-hidden">Error:</span> {{ fieldErrors.proposed_hours }}</p>
      {% endif %}
      <input class="govuk-input govuk-input--width-5{% if fieldErrors.proposed_hours %} govuk-input--error{% endif %}" id="proposed_hours" name="proposed_hours" type="number" min="0.25" max="24" step="0.25" value="{{ values.proposed_hours }}" aria-describedby="proposed-hours-hint{% if fieldErrors.proposed_hours %} proposed-hours-error{% endif %}" required>
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label" for="prep_time">Preparation time</label>
      <div id="prep-time-hint" class="govuk-hint">Optional time needed to prepare.</div>
      <input class="govuk-input govuk-input--width-5" id="prep_time" name="prep_time" type="number" min="0" max="24" step="0.25" value="{{ values.prep_time }}" aria-describedby="prep-time-hint">
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label" for="message">Message</label>
      <div id="message-hint" class="govuk-hint">Add anything the other member should know.</div>
      <textarea class="govuk-textarea" id="message" name="message" rows="6" aria-describedby="message-hint">{{ values.message }}</textarea>
    </div>

    <button class="govuk-button" data-module="govuk-button">Send request</button>
  </form>
{% endblock %}
