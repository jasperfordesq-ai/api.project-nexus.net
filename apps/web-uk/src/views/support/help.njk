{% extends "layouts/base.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <span class="govuk-caption-l">{{ communityName }}</span>
      <h1 class="govuk-heading-xl">Help centre</h1>
      <p class="govuk-body-l">Find answers to common questions about {{ communityName }}. If you cannot find what you need, contact us.</p>

      <form method="get" action="{{ urlFor('/help') }}" class="govuk-!-margin-bottom-6">
        <div class="govuk-form-group">
          <label class="govuk-label" for="q">Search help topics</label>
          <div id="q-hint" class="govuk-hint">Type a word or phrase to filter the questions below.</div>
          <input class="govuk-input govuk-!-width-two-thirds" id="q" name="q" type="search" value="{{ searchQuery }}" aria-describedby="q-hint">
        </div>
        <button class="govuk-button govuk-button--secondary" data-module="govuk-button" type="submit">Search</button>
      </form>

      {% if faqGroups.length == 0 %}
        <div class="govuk-inset-text">
          {% if searchQuery %}No help topics match your search. Try a different word, or contact us.{% else %}No help topics are available yet.{% endif %}
        </div>
      {% else %}
        {% for group in faqGroups %}
          <h2 class="govuk-heading-m">{{ group.category }}</h2>
          <div class="govuk-accordion" data-module="govuk-accordion" id="help-accordion-{{ loop.index0 }}">
            {% for faq in group.faqs %}
              <div class="govuk-accordion__section">
                <div class="govuk-accordion__section-header">
                  <h3 class="govuk-accordion__section-heading">
                    <span class="govuk-accordion__section-button" id="help-{{ loop.parent.index0 }}-{{ loop.index0 }}-heading">{{ faq.question }}</span>
                  </h3>
                </div>
                <div id="help-{{ loop.parent.index0 }}-{{ loop.index0 }}-content" class="govuk-accordion__section-content">
                  <div class="govuk-body">{{ faq.answer | safe }}</div>
                </div>
              </div>
            {% endfor %}
          </div>
        {% endfor %}
      {% endif %}

      <h2 class="govuk-heading-m">Still need help?</h2>
      <p class="govuk-body">If you cannot find the answer here, get in touch and we will help.</p>
      <a class="govuk-button" data-module="govuk-button" href="{{ urlFor('/contact') }}">Contact us</a>
    </div>
  </div>
{% endblock %}
