{% extends "layouts/base.njk" %}

{% block content %}
  {% set successStates = ["campaign-created", "campaign-updated", "campaign-deleted"] %}
  {% set errorStates = ["campaign-invalid", "campaign-failed"] %}
  {% set campaignStatusOptions = ["draft", "active", "completed", "archived"] %}
  {% set campaignStatusClasses = {
    active: "govuk-tag--green",
    completed: "govuk-tag--blue",
    archived: "govuk-tag--grey",
    draft: "govuk-tag--grey"
  } %}

  <span class="govuk-caption-xl">{{ t("govuk_alpha_ideation.campaigns.caption", { community: tenantName }) }}</span>
  <h1 class="govuk-heading-xl">{{ t("govuk_alpha_ideation.campaigns.title") }}</h1>
  <p class="govuk-body-l">{{ t("govuk_alpha_ideation.campaigns.intro") }}</p>

  {% set activeTab = "campaigns" %}
  {% include "ideation/_nav.njk" %}

  {% if status in successStates %}
    <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="campaign-status-banner">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="campaign-status-banner">{{ t("govuk_alpha_ideation.common.success_title") }}</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ t("govuk_alpha_ideation.states." ~ status) }}</p>
      </div>
    </div>
  {% elseif status in errorStates %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">{{ t("govuk_alpha_ideation.common.error_title") }}</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            <li>{% if status == "campaign-invalid" %}<a href="#campaign_title">{{ t("govuk_alpha_ideation.states." ~ status) }}</a>{% else %}{{ t("govuk_alpha_ideation.states." ~ status) }}{% endif %}</li>
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  {% if campaigns and campaigns.length %}
    <div class="nexus-alpha-card-list">
      {% for campaign in campaigns %}
        <article class="nexus-alpha-card">
          <div class="nexus-alpha-module-row">
            <h2 class="govuk-heading-s govuk-!-margin-bottom-1">
              <a class="govuk-link" href="{{ urlFor('/ideation/campaigns/' ~ campaign.id) }}">{{ campaign.title }}</a>
            </h2>
            <strong class="govuk-tag {{ campaignStatusClasses[campaign.status] }}">{{ t("govuk_alpha_ideation.campaigns.status_" ~ campaign.status) }}</strong>
          </div>
          {% if campaign.description %}
            <p class="govuk-body govuk-!-margin-bottom-1">{{ campaign.description }}</p>
          {% endif %}
          <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-0">
            {{ tc("govuk_alpha_ideation.campaigns.challenge_count", campaign.challengeCount, { count: campaign.challengeCount }) }}
            {% if campaign.creatorName %} &middot; {{ t("govuk_alpha_ideation.campaigns.by", { name: campaign.creatorName }) }}{% endif %}
          </p>
        </article>
      {% endfor %}
    </div>
  {% else %}
    <div class="govuk-inset-text">{{ t("govuk_alpha_ideation.campaigns.empty") }}</div>
  {% endif %}

  {% if ideationIsAdmin %}
    <h2 class="govuk-heading-l govuk-!-margin-top-6" id="create">{{ t("govuk_alpha_ideation.campaigns.create_heading") }}</h2>
    <p class="govuk-body">{{ t("govuk_alpha_ideation.campaigns.create_intro") }}</p>
    <form method="post" action="{{ urlFor('/ideation/campaigns') }}">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
      <div class="govuk-form-group{% if status == 'campaign-invalid' %} govuk-form-group--error{% endif %}">
        <label class="govuk-label" for="campaign_title">{{ t("govuk_alpha_ideation.campaigns.title_label") }}</label>
        {% if status == "campaign-invalid" %}
          <p id="campaign_title-error" class="govuk-error-message"><span class="govuk-visually-hidden">{{ t("govuk_alpha_ideation.common.error_prefix") }}</span> {{ t("govuk_alpha_ideation.campaigns.title_required") }}</p>
        {% endif %}
        <input class="govuk-input" id="campaign_title" name="title" type="text" maxlength="255"{% if status == "campaign-invalid" %} aria-describedby="campaign_title-error"{% endif %}>
      </div>
      <div class="govuk-form-group">
        <label class="govuk-label" for="campaign_description">{{ t("govuk_alpha_ideation.campaigns.description_label") }}</label>
        <textarea class="govuk-textarea" id="campaign_description" name="description" rows="4" maxlength="5000"></textarea>
      </div>
      <div class="govuk-form-group">
        <label class="govuk-label" for="campaign_cover_image">{{ t("govuk_alpha_ideation.campaigns.cover_image_label") }}</label>
        <input class="govuk-input" id="campaign_cover_image" name="cover_image" type="url" maxlength="500">
      </div>
      <div class="govuk-form-group">
        <label class="govuk-label" for="campaign_start_date">{{ t("govuk_alpha_ideation.campaigns.start_date_label") }}</label>
        <div id="campaign_start_date-hint" class="govuk-hint">{{ t("govuk_alpha_ideation.campaigns.date_hint") }}</div>
        <input class="govuk-input govuk-input--width-10" id="campaign_start_date" name="start_date" type="text" aria-describedby="campaign_start_date-hint">
      </div>
      <div class="govuk-form-group">
        <label class="govuk-label" for="campaign_end_date">{{ t("govuk_alpha_ideation.campaigns.end_date_label") }}</label>
        <div id="campaign_end_date-hint" class="govuk-hint">{{ t("govuk_alpha_ideation.campaigns.date_hint") }}</div>
        <input class="govuk-input govuk-input--width-10" id="campaign_end_date" name="end_date" type="text" aria-describedby="campaign_end_date-hint">
      </div>
      <div class="govuk-form-group">
        <fieldset class="govuk-fieldset">
          <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">{{ t("govuk_alpha_ideation.campaigns.status_label") }}</legend>
          <div class="govuk-radios govuk-radios--small govuk-radios--inline" data-module="govuk-radios">
            {% for option in campaignStatusOptions %}
              <div class="govuk-radios__item">
                <input class="govuk-radios__input" id="campaign-status-{{ option }}" name="campaign_status" type="radio" value="{{ option }}"{% if option == "draft" %} checked{% endif %}>
                <label class="govuk-label govuk-radios__label" for="campaign-status-{{ option }}">{{ t("govuk_alpha_ideation.campaigns.status_" ~ option) }}</label>
              </div>
            {% endfor %}
          </div>
        </fieldset>
      </div>
      <button type="submit" class="govuk-button" data-module="govuk-button">{{ t("govuk_alpha_ideation.campaigns.submit_create") }}</button>
    </form>
  {% endif %}
{% endblock %}
