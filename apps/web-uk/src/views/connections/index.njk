{% extends "layouts/base.njk" %}

{% block content %}
  <span class="govuk-caption-xl" id="connections-top">{{ t("connections.caption", { community: communityName }) }}</span>
  <h1 class="govuk-heading-xl">{{ t("connections.title") }}</h1>
  <p class="govuk-body-l">{{ t("connections.description") }}</p>

  <p class="govuk-body">
    <a class="govuk-link" href="{{ urlFor('/connections/network') }}">{{ t("govuk_alpha_connections.nav.network") }}</a>
  </p>

  <form method="get" action="{{ urlFor('/connections') }}" class="govuk-!-margin-bottom-5">
    <div class="govuk-form-group govuk-!-margin-bottom-2">
      <label class="govuk-label" for="conn-search">{{ t("polish_members.connections_search_label") }}</label>
      <div id="conn-search-hint" class="govuk-hint">{{ t("polish_members.connections_search_hint") }}</div>
      <input class="govuk-input govuk-!-width-two-thirds" id="conn-search" name="q" type="search" value="{{ connSearch }}" aria-describedby="conn-search-hint">
    </div>
    <div class="govuk-button-group">
      <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">{{ t("polish_members.connections_search_submit") }}</button>
      {% if connSearch %}
        <a class="govuk-link" href="{{ urlFor('/connections') }}">{{ t("polish_members.connections_search_clear") }}</a>
      {% endif %}
    </div>
  </form>

  {% if status == 'connection-accepted' or status == 'connection-declined' or status == 'connection-removed' %}
    <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="conn-status-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="conn-status-title">{{ t("states.success_title") }}</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">
          {% if status == 'connection-accepted' %}{{ t("connections.states.accepted") }}{% elif status == 'connection-declined' %}{{ t("connections.states.declined") }}{% else %}{{ t("connections.states.removed") }}{% endif %}
        </p>
      </div>
    </div>
  {% elif status == 'connection-failed' %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2>
        <div class="govuk-error-summary__body">
          <p class="govuk-body">{{ t("connections.states.failed") }}</p>
        </div>
      </div>
    </div>
  {% endif %}

  <p class="govuk-body">{{ t("connections.summary", { received: countLabels.received, sent: countLabels.sent, total: countLabels.accepted }) }}</p>

  <section aria-labelledby="received-heading">
    <h2 class="govuk-heading-l govuk-!-margin-top-6" id="received-heading">{{ t("connections.received_title") }}</h2>
    {% if receivedRequests.length %}
      {% for connection in receivedRequests %}
        <article class="nexus-alpha-card govuk-!-margin-bottom-4">
          <h3 class="govuk-heading-s govuk-!-margin-bottom-1">{{ connection.name }}</h3>
          {% if connection.location %}<p class="govuk-hint govuk-!-font-size-16 govuk-!-margin-bottom-2">{{ connection.location }}</p>{% endif %}
          {% if connection.bio %}<p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-2"><span class="govuk-visually-hidden">{{ t("govuk_alpha_connections.network.about", { name: connection.name }) }}: </span>{{ connection.bio }}</p>{% endif %}
          <p class="govuk-body-s govuk-!-margin-bottom-3">{{ t("connections.wants_to_connect") }}</p>
          <div class="govuk-button-group">
            {% if connection.acceptAction %}
              <form method="post" action="{{ urlFor(connection.acceptAction) }}">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <button class="govuk-button" data-module="govuk-button">{{ t("connections.accept_button") }}</button>
              </form>
              <form method="post" action="{{ urlFor(connection.declineAction) }}">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <button class="govuk-button govuk-button--secondary" data-module="govuk-button">{{ t("connections.decline_button") }}</button>
              </form>
            {% endif %}
            {% if connection.profileHref %}<a class="govuk-link govuk-link--no-visited-state" href="{{ urlFor(connection.profileHref) }}">{{ t("connections.view_profile") }}</a>{% endif %}
          </div>
        </article>
      {% endfor %}
    {% else %}
      <div class="govuk-inset-text"><p class="govuk-body">{{ t("connections.received_empty") }}</p></div>
    {% endif %}
  </section>

  <section aria-labelledby="accepted-heading">
    <h2 class="govuk-heading-l govuk-!-margin-top-6" id="accepted-heading">{{ t("connections.accepted_title") }}</h2>
    {% if acceptedConnections.length %}
      {% for connection in acceptedConnections %}
        <article class="nexus-alpha-card govuk-!-margin-bottom-4">
          <h3 class="govuk-heading-s govuk-!-margin-bottom-1">{{ connection.name }}</h3>
          {% if connection.location %}<p class="govuk-hint govuk-!-font-size-16 govuk-!-margin-bottom-2">{{ connection.location }}</p>{% endif %}
          {% if connection.bio %}<p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-2"><span class="govuk-visually-hidden">{{ t("govuk_alpha_connections.network.about", { name: connection.name }) }}: </span>{{ connection.bio }}</p>{% endif %}
          <div class="govuk-button-group">
            {% if connection.profileHref %}<a class="govuk-link govuk-link--no-visited-state" href="{{ urlFor(connection.profileHref) }}">{{ t("connections.view_profile") }}</a>{% endif %}
            {% if connection.removeAction %}
              <details class="govuk-details govuk-!-margin-bottom-0" data-module="govuk-details">
                <summary class="govuk-details__summary"><span class="govuk-details__summary-text">{{ t("connections.remove_button") }}</span></summary>
                <div class="govuk-details__text">
                  <div class="govuk-warning-text">
                    <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
                    <strong class="govuk-warning-text__text"><span class="govuk-visually-hidden">{{ t("states.warning_prefix") }}</span>{{ t("ux.confirm_irreversible") }}</strong>
                  </div>
                  <form method="post" action="{{ urlFor(connection.removeAction) }}">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                    <button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("connections.remove_button") }}</button>
                  </form>
                </div>
              </details>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    {% else %}
      <div class="govuk-inset-text"><p class="govuk-body">{{ t("connections.accepted_empty") }}</p></div>
    {% endif %}
  </section>

  <section aria-labelledby="sent-heading">
    <h2 class="govuk-heading-l govuk-!-margin-top-6" id="sent-heading">{{ t("connections.sent_title") }}</h2>
    {% if sentRequests.length %}
      {% for connection in sentRequests %}
        <article class="nexus-alpha-card govuk-!-margin-bottom-4">
          <h3 class="govuk-heading-s govuk-!-margin-bottom-1">{{ connection.name }}</h3>
          {% if connection.bio %}<p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-2"><span class="govuk-visually-hidden">{{ t("govuk_alpha_connections.network.about", { name: connection.name }) }}: </span>{{ connection.bio }}</p>{% endif %}
          <p class="govuk-body-s govuk-!-margin-bottom-3">{{ t("connections.awaiting_response") }}</p>
          <div class="govuk-button-group">
            {% if connection.profileHref %}<a class="govuk-link govuk-link--no-visited-state" href="{{ urlFor(connection.profileHref) }}">{{ t("connections.view_profile") }}</a>{% endif %}
            {% if connection.removeAction %}
              <details class="govuk-details govuk-!-margin-bottom-0" data-module="govuk-details">
                <summary class="govuk-details__summary"><span class="govuk-details__summary-text">{{ t("connections.cancel_button") }}</span></summary>
                <div class="govuk-details__text">
                  <div class="govuk-warning-text">
                    <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
                    <strong class="govuk-warning-text__text"><span class="govuk-visually-hidden">{{ t("states.warning_prefix") }}</span>{{ t("ux.confirm_irreversible") }}</strong>
                  </div>
                  <form method="post" action="{{ urlFor(connection.removeAction) }}">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                    <button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("connections.cancel_button") }}</button>
                  </form>
                </div>
              </details>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    {% else %}
      <div class="govuk-inset-text"><p class="govuk-body">{{ t("connections.sent_empty") }}</p></div>
    {% endif %}
  </section>
{% endblock %}
