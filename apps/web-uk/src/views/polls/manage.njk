{% extends "layouts/base.njk" %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <a class="govuk-back-link" href="{{ urlFor('/polls') }}">{{ t("govuk_alpha_gamification.common.back_to_polls") }}</a>

      <span class="govuk-caption-xl">{{ t("govuk_alpha_gamification.poll_manage.caption", { community: tenantName }) }}</span>
      <h1 class="govuk-heading-xl">{{ t("govuk_alpha_gamification.poll_manage.title") }}</h1>
      <p class="govuk-body-l">{{ t("govuk_alpha_gamification.poll_manage.description") }}</p>

      {% if statusBanner and statusBanner.type == "success" %}
        <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert">
          <div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">{{ t("govuk_alpha_gamification.states.success_title") }}</h2></div>
          <div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ statusBanner.message }}</p></div>
        </div>
      {% elif statusBanner and statusBanner.type == "error" %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
          <div role="alert"><h2 class="govuk-error-summary__title">{{ t("govuk_alpha_gamification.states.error_title") }}</h2><div class="govuk-error-summary__body"><p class="govuk-body">{{ statusBanner.message }}</p></div></div>
        </div>
      {% endif %}

      <p class="govuk-body"><a class="govuk-link" href="{{ urlFor('/polls/parity/create') }}">{{ t("govuk_alpha_gamification.poll_manage.create_link") }}</a></p>

      {% if not polls.length %}
        <div class="govuk-inset-text"><p class="govuk-body">{{ t("govuk_alpha_gamification.poll_manage.empty") }}</p></div>
      {% else %}
        {% for poll in polls %}
          <article class="nexus-alpha-card govuk-!-margin-bottom-6" id="poll-{{ poll.id }}">
            <div class="nexus-alpha-module-row">
              <h2 class="govuk-heading-m govuk-!-margin-bottom-1">{{ poll.question or t("govuk_alpha_gamification.poll_manage.title") }}</h2>
              {% if poll.status == "open" %}<strong class="govuk-tag govuk-tag--green">{{ t("govuk_alpha_gamification.poll_manage.open_tag") }}</strong>{% else %}<strong class="govuk-tag govuk-tag--grey">{{ t("govuk_alpha_gamification.poll_manage.closed_tag") }}</strong>{% endif %}
            </div>
            <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-3">
              {% if poll.pollType == "ranked" %}<strong class="govuk-tag govuk-tag--purple">{{ t("govuk_alpha_gamification.poll_manage.ranked_tag") }}</strong> {% endif %}
              {% if poll.isAnonymous %}<strong class="govuk-tag govuk-tag--blue">{{ t("govuk_alpha_gamification.poll_manage.anonymous_tag") }}</strong> {% endif %}
              {{ tc("govuk_alpha_gamification.poll_manage.votes_count", poll.totalVotes, { count: poll.totalVotes }) }}
              {% if poll.expiresAt %} - {{ poll.expiresAt | formatDate }}{% endif %}
            </p>
            <div class="nexus-alpha-actions govuk-button-group">
              {% if poll.pollType == "ranked" %}
                <a class="govuk-link" href="{{ urlFor('/polls/' + (poll.id | string) + '/rank') }}">{{ t("govuk_alpha_gamification.poll_manage.view_ranked") }}</a>
              {% endif %}
              <a class="govuk-link" href="{{ urlFor('/polls/' + (poll.id | string) + '/export') }}">{{ t("govuk_alpha_gamification.poll_manage.export_button") }}</a>
            </div>
            <details class="govuk-details govuk-!-margin-top-3" data-module="govuk-details">
              <summary class="govuk-details__summary"><span class="govuk-details__summary-text">{{ t("govuk_alpha_gamification.poll_manage.delete_button") }}</span></summary>
              <div class="govuk-details__text">
                <div class="govuk-warning-text">
                  <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
                  <strong class="govuk-warning-text__text">
                    <span class="govuk-visually-hidden">{{ t("govuk_alpha_gamification.states.error_title") }}</span>
                    {{ t("govuk_alpha_gamification.poll_manage.delete_warning") }}
                  </strong>
                </div>
                <form method="post" action="{{ urlFor('/polls/' + (poll.id | string) + '/delete') }}">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("govuk_alpha_gamification.poll_manage.delete_button") }}</button>
                </form>
              </div>
            </details>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
{% endblock %}
