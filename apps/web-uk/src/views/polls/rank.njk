{% extends "layouts/base.njk" %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <a class="govuk-back-link" href="{{ urlFor('/polls') }}">Back to polls</a>

      <span class="govuk-caption-xl">Polls at this community</span>
      <div class="nexus-alpha-module-row">
        <h1 class="govuk-heading-xl govuk-!-margin-bottom-1">{{ poll.question or "Ranked-choice poll" }}</h1>
        <strong class="govuk-tag govuk-tag--purple">Ranked</strong>
      </div>

      {% if poll.description %}<p class="govuk-body">{{ poll.description }}</p>{% endif %}

      {% if statusBanner and statusBanner.type == "success" %}
        <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert">
          <div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">{{ t("states.success_title") }}</h2></div>
          <div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ statusBanner.message }}</p></div>
        </div>
      {% elif statusBanner and statusBanner.type == "error" %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
          <div role="alert"><h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2><div class="govuk-error-summary__body"><p class="govuk-body">{{ statusBanner.message }}</p></div></div>
        </div>
      {% endif %}

      {% if not poll.options.length %}
        <div class="govuk-inset-text"><p class="govuk-body">This poll has no options to rank.</p></div>
      {% elif myRankings.length or poll.status != "open" %}
        {% if myRankings.length and poll.status == "open" %}
          <div class="govuk-inset-text">You have already submitted your ranking for this poll.</div>
        {% endif %}
        <h2 class="govuk-heading-l">{{ t("listings.results_title") }}</h2>
        <p class="govuk-body-s nexus-alpha-meta">
          {% if rankedResults.totalVoters == 0 %}no voters{% elif rankedResults.totalVoters == 1 %}1 voter{% else %}{{ rankedResults.totalVoters }} voters{% endif %}
        </p>
        {% if not rankedResults.rows.length %}
          <div class="govuk-inset-text"><p class="govuk-body">No rankings have been submitted yet.</p></div>
        {% else %}
          {% for row in rankedResults.rows %}
            {% set pct = ((row.votes / rankedResults.totalVoters) * 100) | round if rankedResults.totalVoters > 0 else 0 %}
            <div class="govuk-!-margin-bottom-3">
              <p class="govuk-body govuk-!-margin-bottom-1">{{ row.text }}{% if loop.first %} <strong class="govuk-tag govuk-tag--green">Leading</strong>{% endif %}</p>
              <progress max="100" value="{{ pct }}" aria-label="{{ row.text }}: {{ pct }}%">{{ pct }}%</progress>
              <span class="govuk-body-s">{{ pct }}% - {% if row.votes == 1 %}1 first-choice vote{% else %}{{ row.votes }} first-choice votes{% endif %}</span>
            </div>
          {% endfor %}
        {% endif %}
      {% else %}
        <div class="govuk-inset-text">Put the options in your order of preference, with your favourite first.</div>
        <form method="post" action="{{ urlFor('/polls/' + (poll.id | string) + '/rank') }}">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <fieldset class="govuk-fieldset">
            <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">Rank the options in order of preference</legend>
            {% for option in poll.options %}
              {% set defaultPosition = loop.index %}
              <div class="govuk-form-group">
                <label class="govuk-label" for="rank-{{ option.id }}">{{ option.text }}</label>
                <select class="govuk-select" id="rank-{{ option.id }}" name="rank[{{ option.id }}]">
                  {% for position in range(1, poll.options.length + 1) %}
                    <option value="{{ position }}"{% if position == defaultPosition %} selected{% endif %}>Position {{ position }}</option>
                  {% endfor %}
                </select>
              </div>
            {% endfor %}
          </fieldset>
          <button class="govuk-button" data-module="govuk-button">Submit ranking</button>
        </form>
      {% endif %}
    </div>
  </div>
{% endblock %}
