{% extends "layouts/base.njk" %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <a class="govuk-back-link" href="{{ urlFor('/polls') }}">{{ t("govuk_alpha_gamification.common.back_to_polls") }}</a>

      <span class="govuk-caption-xl">{{ t("govuk_alpha_gamification.ranked.caption", { community: tenantName }) }}</span>
      <div class="nexus-alpha-module-row">
        <h1 class="govuk-heading-xl govuk-!-margin-bottom-1">{{ poll.question or t("govuk_alpha_gamification.ranked.title") }}</h1>
        <strong class="govuk-tag govuk-tag--purple">{{ t("govuk_alpha_gamification.ranked.badge") }}</strong>
      </div>

      {% if poll.description %}<p class="govuk-body">{{ poll.description }}</p>{% endif %}

      {% if statusBanner and statusBanner.type == "success" %}
        <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert">
          <div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">{{ t("govuk_alpha_gamification.states.success_title") }}</h2></div>
          <div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ statusBanner.message }}</p></div>
        </div>
      {% elif statusBanner and statusBanner.type == "error" %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
          <div role="alert"><h2 class="govuk-error-summary__title">{{ t("govuk_alpha_gamification.states.error_title") }}</h2><div class="govuk-error-summary__body"><p class="govuk-body">{{ statusBanner.message }}</p></div></div>
        </div>
      {% endif %}

      {% if not poll.options.length %}
        <div class="govuk-inset-text"><p class="govuk-body">{{ t("govuk_alpha_gamification.ranked.no_options") }}</p></div>
      {% elif myRankings.length or poll.status != "open" %}
        {% if myRankings.length and poll.status == "open" %}
          <div class="govuk-inset-text">{{ t("govuk_alpha_gamification.ranked.already_ranked") }}</div>
        {% endif %}
        <h2 class="govuk-heading-l">{{ t("govuk_alpha_gamification.ranked.results_heading") }}</h2>
        <p class="govuk-body-s nexus-alpha-meta">
          {{ tc("govuk_alpha_gamification.ranked.total_voters", rankedResults.totalVoters, { count: rankedResults.totalVoters }) }}
        </p>
        {% if not rankedResults.rows.length %}
          <div class="govuk-inset-text"><p class="govuk-body">{{ t("govuk_alpha_gamification.ranked.no_results") }}</p></div>
        {% else %}
          {% for row in rankedResults.rows %}
            {% set pct = ((row.votes / rankedResults.totalVoters) * 100) | round if rankedResults.totalVoters > 0 else 0 %}
            <div class="govuk-!-margin-bottom-3">
              <p class="govuk-body govuk-!-margin-bottom-1">{{ row.text }}{% if rankedResults.totalVoters > 0 and row.votes == rankedResults.maxVotes and row.votes > 0 %} <strong class="govuk-tag govuk-tag--green">{{ t("govuk_alpha_gamification.ranked.winner") }}</strong>{% endif %}</p>
              <progress max="100" value="{{ pct }}" aria-label="{{ row.text }}: {{ pct }}%">{{ pct }}%</progress>
              <span class="govuk-body-s">{{ pct }}% - {{ tc("govuk_alpha_gamification.ranked.first_choice_votes", row.votes, { count: row.votes }) }}</span>
            </div>
          {% endfor %}
        {% endif %}
      {% else %}
        <div class="govuk-inset-text">{{ t("govuk_alpha_gamification.ranked.how_it_works") }}</div>
        <form method="post" action="{{ urlFor('/polls/' + (poll.id | string) + '/rank') }}">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <fieldset class="govuk-fieldset">
            <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">{{ t("govuk_alpha_gamification.ranked.legend") }}</legend>
            {% for option in poll.options %}
              {% set defaultPosition = loop.index %}
              <div class="govuk-form-group">
                <label class="govuk-label" for="rank-{{ option.id }}">{{ option.text }}</label>
                <select class="govuk-select" id="rank-{{ option.id }}" name="rank[{{ option.id }}]">
                  {% for position in range(1, poll.options.length + 1) %}
                    <option value="{{ position }}"{% if position == defaultPosition %} selected{% endif %}>{{ t("govuk_alpha_gamification.ranked.position_label", { num: position }) }}</option>
                  {% endfor %}
                </select>
              </div>
            {% endfor %}
          </fieldset>
          <button class="govuk-button" data-module="govuk-button">{{ t("govuk_alpha_gamification.ranked.submit_button") }}</button>
        </form>
      {% endif %}
    </div>
  </div>
{% endblock %}
