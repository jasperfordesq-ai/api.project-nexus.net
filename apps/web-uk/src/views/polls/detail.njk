{% extends "layouts/base.njk" %}

{% macro countText(count, singular, plural) %}
  {% if count == 0 %}no {{ plural }}{% elif count == 1 %}1 {{ singular }}{% else %}{{ count }} {{ plural }}{% endif %}
{% endmacro %}

{% macro renderComment(comment) %}
  <li id="comment-{{ comment.id }}" class="nexus-alpha-module-row">
    <p class="govuk-body govuk-!-margin-bottom-1">{{ comment.content }}</p>
    <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-2">
      {{ comment.user.name }}{% if comment.createdAt %} - Posted on {{ comment.createdAt | formatDate }}{% endif %}
    </p>
    {% if comment.replies.length %}
      <ul class="govuk-list govuk-!-margin-left-4">
        {% for reply in comment.replies %}
          {{ renderComment(reply) }}
        {% endfor %}
      </ul>
    {% endif %}
  </li>
{% endmacro %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <a class="govuk-back-link" href="{{ urlFor('/polls') }}">Back to polls</a>

      <span class="govuk-caption-xl">Polls at this community</span>
      <div class="nexus-alpha-module-row">
        <h1 class="govuk-heading-xl govuk-!-margin-bottom-1">{{ poll.question }}</h1>
        {% if poll.status == "open" %}<strong class="govuk-tag govuk-tag--green">Open</strong>{% else %}<strong class="govuk-tag govuk-tag--grey">Closed</strong>{% endif %}
        {% if poll.pollType == "ranked" %}<strong class="govuk-tag govuk-tag--purple">Ranked</strong>{% endif %}
      </div>

      <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-3">
        Posted by {{ poll.creator.name }}{% if poll.expiresAt %} - {% if poll.status == "open" %}Closes{% else %}Closed{% endif %} {{ poll.expiresAt | formatDate }}{% endif %} - {{ countText(poll.totalVotes, "vote", "votes") }}
      </p>

      {% if statusBanner and statusBanner.type == "success" %}
        <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert">
          <div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">{{ t("states.success_title") }}</h2></div>
          <div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ statusBanner.message }}</p></div>
        </div>
      {% elif statusBanner and statusBanner.type == "error" %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
          <div role="alert"><h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2><div class="govuk-error-summary__body"><p class="govuk-body">{{ statusBanner.message }}</p></div></div>
        </div>
      {% endif %}

      {% if poll.description %}<p class="govuk-body">{{ poll.description }}</p>{% endif %}

      {% if poll.pollType == "ranked" %}
        <a class="govuk-button" data-module="govuk-button" role="button" href="{{ urlFor('/polls/' + (poll.id | string) + '/rank') }}">{% if poll.hasVoted %}View ranked poll{% else %}Rank this poll{% endif %}</a>
      {% elif poll.status == "open" and not poll.hasVoted and poll.options.length %}
        <form method="post" action="{{ urlFor('/polls/' + (poll.id | string) + '/vote') }}">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <fieldset class="govuk-fieldset" aria-describedby="poll-detail-{{ poll.id }}-hint">
            <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Vote on this poll</legend>
            <div id="poll-detail-{{ poll.id }}-hint" class="govuk-hint">Results will be shown once voting closes or once you have voted.</div>
            <div class="govuk-radios govuk-radios--small" data-module="govuk-radios">
              {% for option in poll.options %}
                <div class="govuk-radios__item">
                  <input class="govuk-radios__input" id="poll-detail-{{ poll.id }}-opt-{{ option.id }}" name="option_id" type="radio" value="{{ option.id }}">
                  <label class="govuk-label govuk-radios__label" for="poll-detail-{{ poll.id }}-opt-{{ option.id }}">{{ option.text }}</label>
                </div>
              {% endfor %}
            </div>
          </fieldset>
          <button class="govuk-button govuk-!-margin-top-2" data-module="govuk-button">Vote on this poll</button>
        </form>
      {% elif poll.resultsVisible %}
        <h2 class="govuk-heading-l">{{ t("listings.results_title") }}</h2>
        {% for option in poll.options %}
          <div class="govuk-!-margin-bottom-3">
            <p class="govuk-body govuk-!-margin-bottom-1">
              {{ option.text }}
              {% if poll.votedOptionId and poll.votedOptionId == option.id %}<strong class="govuk-tag govuk-tag--blue">Your choice</strong>{% endif %}
            </p>
            <progress max="100" value="{{ option.percentage }}" aria-label="{{ option.text }}: {{ option.percentage }}%">{{ option.percentage }}%</progress>
            <span class="govuk-body-s">{{ option.percentage }}% - {{ countText(option.voteCount, "vote", "votes") }}</span>
          </div>
        {% endfor %}
      {% else %}
        <div class="govuk-inset-text">Results will be shown once voting closes or once you have voted.</div>
      {% endif %}

      <hr class="govuk-section-break govuk-section-break--visible govuk-section-break--l">
      <h2 class="govuk-heading-l" id="poll-social">Likes and comments</h2>

      <p class="govuk-body-s nexus-alpha-meta">
        {{ countText(poll.likeCount, "like", "likes") }} - {{ countText(commentsTotal, "comment", "comments") }}
      </p>

      <div class="nexus-alpha-actions govuk-!-margin-bottom-4">
        <form method="post" action="{{ urlFor('/polls/' + (poll.id | string) + '/like') }}">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button" aria-pressed="{% if poll.hasLiked %}true{% else %}false{% endif %}">
            {% if poll.hasLiked %}Unlike{% else %}Like{% endif %}
          </button>
        </form>
      </div>

      <h3 class="govuk-heading-m" id="poll-comments">Comments</h3>
      {% if comments.length %}
        <ul class="govuk-list nexus-alpha-comments-list">
          {% for comment in comments %}
            {{ renderComment(comment) }}
          {% endfor %}
        </ul>
      {% else %}
        <p class="govuk-body">{{ t("blog.comments_empty") }}</p>
      {% endif %}

      <form method="post" action="{{ urlFor('/polls/' + (poll.id | string) + '/comment') }}">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <div class="govuk-form-group">
          <label class="govuk-label" for="poll-comment-{{ poll.id }}">{{ t("blog.comment_body_label") }}</label>
          <div id="poll-comment-{{ poll.id }}-hint" class="govuk-hint">Be respectful and keep it on topic.</div>
          <textarea class="govuk-textarea" id="poll-comment-{{ poll.id }}" name="content" rows="3" aria-describedby="poll-comment-{{ poll.id }}-hint" maxlength="10000"></textarea>
        </div>
        <button class="govuk-button" data-module="govuk-button">{{ t("blog.comment_submit") }}</button>
      </form>
    </div>
  </div>
{% endblock %}
