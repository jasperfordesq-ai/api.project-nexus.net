{% extends "layouts/base.njk" %}

{% macro voteSummary(count) %}
  {% if count == 0 %}no votes{% elif count == 1 %}1 vote{% else %}{{ count }} votes{% endif %}
{% endmacro %}

{% macro renderResults(poll) %}
  {% for option in poll.options %}
    <div class="govuk-!-margin-bottom-3">
      <p class="govuk-body govuk-!-margin-bottom-1">
        {{ option.text }}
        {% if poll.votedOptionId and poll.votedOptionId == option.id %}
          <strong class="govuk-tag govuk-tag--blue">Your choice</strong>
        {% endif %}
      </p>
      <progress max="100" value="{{ option.percentage }}" aria-label="{{ option.text }}: {{ option.percentage }}%">{{ option.percentage }}%</progress>
      <span class="govuk-body-s">{{ option.percentage }}% - {{ voteSummary(option.voteCount) }}</span>
    </div>
  {% endfor %}
{% endmacro %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <span class="govuk-caption-xl">This community</span>
      <h1 class="govuk-heading-xl">Polls</h1>
      <p class="govuk-body-l">Have your say on questions put to the community.</p>

      {% if statusBanner and statusBanner.type == "success" %}
        <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert">
          <div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">Success</h2></div>
          <div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ statusBanner.message }}</p></div>
        </div>
      {% elif statusBanner and statusBanner.type == "error" %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
          <div role="alert"><h2 class="govuk-error-summary__title">There is a problem</h2><div class="govuk-error-summary__body"><p class="govuk-body">{{ statusBanner.message }}</p></div></div>
        </div>
      {% endif %}

      <div class="govuk-inset-text">You can vote once on each open poll. To keep things fair, the results stay hidden until a poll closes.</div>

      <form method="get" action="{{ urlFor('/polls') }}" class="govuk-!-margin-bottom-6">
        {% if categories.length %}
          <div class="govuk-form-group">
            <label class="govuk-label" for="category">Category</label>
            <select class="govuk-select" id="category" name="category">
              <option value="">All categories</option>
              {% for category in categories %}
                <option value="{{ category }}"{% if pollsCategory == category %} selected{% endif %}>{{ category | capitalize }}</option>
              {% endfor %}
            </select>
          </div>
        {% endif %}
        <div class="govuk-form-group">
          <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
            <div class="govuk-checkboxes__item">
              <input class="govuk-checkboxes__input" id="mine" name="mine" type="checkbox" value="1"{% if pollsMine %} checked{% endif %}>
              <label class="govuk-label govuk-checkboxes__label" for="mine">Show only polls I created</label>
            </div>
          </div>
        </div>
        <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">Search</button>
      </form>

      <div class="govuk-button-group">
        <a class="govuk-button govuk-button--secondary" data-module="govuk-button" role="button" href="{{ urlFor('/polls/parity/create') }}">Create a poll</a>
        <a class="govuk-button govuk-button--secondary" data-module="govuk-button" role="button" href="{{ urlFor('/polls/parity/manage') }}">Manage my polls</a>
      </div>

      <details class="govuk-details govuk-!-margin-bottom-6" data-module="govuk-details">
        <summary class="govuk-details__summary"><span class="govuk-details__summary-text">Create a poll</span></summary>
        <div class="govuk-details__text">
          <form method="post" action="{{ urlFor('/polls') }}" novalidate>
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <div class="govuk-form-group">
              <label class="govuk-label govuk-label--s" for="poll-question">Poll question</label>
              <div id="poll-question-hint" class="govuk-hint">Ask a clear, specific question</div>
              <input class="govuk-input" id="poll-question" name="question" type="text" aria-describedby="poll-question-hint" maxlength="500">
            </div>
            <fieldset class="govuk-fieldset govuk-!-margin-bottom-4">
              <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Poll options <span class="govuk-hint">Add at least 2 options. Leave extra fields blank.</span></legend>
              {% for number in [1, 2, 3, 4] %}
                <div class="govuk-form-group govuk-!-margin-bottom-2">
                  <label class="govuk-label" for="poll-option-{{ number }}">Option {{ number }}</label>
                  <input class="govuk-input govuk-input--width-30" id="poll-option-{{ number }}" name="options[]" type="text" maxlength="500">
                </div>
              {% endfor %}
            </fieldset>
            <button class="govuk-button" data-module="govuk-button">Create poll</button>
          </form>
        </div>
      </details>

      {% if not polls.length %}
        <div class="govuk-inset-text"><p class="govuk-body">There are no polls at the moment.</p></div>
      {% else %}
        <h2 class="govuk-heading-l">Open polls</h2>
        {% set anyOpen = false %}
        {% for poll in polls %}
          {% if poll.status == "open" %}
            {% set anyOpen = true %}
            <article class="nexus-alpha-card govuk-!-margin-bottom-6" id="poll-{{ poll.id }}">
              <div class="nexus-alpha-module-row">
                <h3 class="govuk-heading-m govuk-!-margin-bottom-1">{{ poll.question }}</h3>
                <strong class="govuk-tag govuk-tag--green">Open</strong>
                {% if poll.pollType == "ranked" %}<strong class="govuk-tag govuk-tag--purple">Ranked</strong>{% endif %}
              </div>
              <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-3">
                by {{ poll.creator.name }}{% if poll.expiresAt %} - Closes on {{ poll.expiresAt | formatDate }}{% endif %}
              </p>
              {% if poll.description %}<p class="govuk-body">{{ poll.description }}</p>{% endif %}

              {% if poll.pollType == "ranked" %}
                <a class="govuk-button" data-module="govuk-button" role="button" href="{{ urlFor('/polls/' + (poll.id | string) + '/rank') }}">{% if poll.hasVoted %}View ranked poll{% else %}Rank this poll{% endif %}</a>
              {% elif not poll.options.length %}
                <div class="govuk-inset-text"><p class="govuk-body">This poll has no options.</p></div>
              {% elif not poll.hasVoted %}
                <form method="post" action="{{ urlFor('/polls/' + (poll.id | string) + '/vote') }}">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <fieldset class="govuk-fieldset" aria-describedby="poll-{{ poll.id }}-hint">
                    <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Choose one option</legend>
                    <div id="poll-{{ poll.id }}-hint" class="govuk-hint">Choose one option. You cannot change your vote once it is submitted.</div>
                    <div class="govuk-radios govuk-radios--small" data-module="govuk-radios">
                      {% for option in poll.options %}
                        <div class="govuk-radios__item">
                          <input class="govuk-radios__input" id="poll-{{ poll.id }}-opt-{{ option.id }}" name="option_id" type="radio" value="{{ option.id }}">
                          <label class="govuk-label govuk-radios__label" for="poll-{{ poll.id }}-opt-{{ option.id }}">{{ option.text }}</label>
                        </div>
                      {% endfor %}
                    </div>
                  </fieldset>
                  <button class="govuk-button govuk-!-margin-top-2 govuk-!-margin-bottom-0" data-module="govuk-button">Vote</button>
                </form>
              {% else %}
                <div class="govuk-inset-text">You have voted. The results will be shown when this poll closes.</div>
              {% endif %}

              <p class="govuk-body govuk-!-margin-top-2 govuk-!-margin-bottom-0"><a class="govuk-link" href="{{ urlFor('/polls/' + (poll.id | string)) }}">View and discuss</a></p>
              {% if poll.isCreator %}
                <form method="post" action="{{ urlFor('/polls/' + (poll.id | string) + '/delete') }}" class="govuk-!-margin-top-3">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button">Delete poll</button>
                </form>
              {% endif %}
            </article>
          {% endif %}
        {% endfor %}
        {% if not anyOpen %}
          <div class="govuk-inset-text"><p class="govuk-body">There are no open polls right now.</p></div>
        {% endif %}

        <h2 class="govuk-heading-l govuk-!-margin-top-8">Closed polls</h2>
        {% for poll in polls %}
          {% if poll.status != "open" %}
            <article class="nexus-alpha-card govuk-!-margin-bottom-6" id="poll-{{ poll.id }}">
              <div class="nexus-alpha-module-row">
                <h3 class="govuk-heading-m govuk-!-margin-bottom-1">{{ poll.question }}</h3>
                <strong class="govuk-tag govuk-tag--grey">Closed</strong>
              </div>
              <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-3">
                by {{ poll.creator.name }}{% if poll.expiresAt %} - Closed on {{ poll.expiresAt | formatDate }}{% endif %} - {{ poll.totalVotes }} total votes
              </p>
              {% if poll.description %}<p class="govuk-body">{{ poll.description }}</p>{% endif %}
              {% if poll.resultsVisible %}
                {{ renderResults(poll) }}
              {% else %}
                <div class="govuk-inset-text">Results will be shown once voting closes or once you have voted.</div>
              {% endif %}
              <p class="govuk-body govuk-!-margin-top-2 govuk-!-margin-bottom-0"><a class="govuk-link" href="{{ urlFor('/polls/' + (poll.id | string)) }}">View and discuss</a></p>
            </article>
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
{% endblock %}
