{% extends "layouts/base.njk" %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <a class="govuk-back-link" href="{{ urlFor('/polls') }}">{{ t("govuk_alpha_gamification.common.back_to_polls") }}</a>

      <span class="govuk-caption-xl">{{ t("govuk_alpha_gamification.poll_create.caption", { community: tenantName }) }}</span>
      <h1 class="govuk-heading-xl">{{ t("govuk_alpha_gamification.poll_create.title") }}</h1>
      <p class="govuk-body-l">{{ t("govuk_alpha_gamification.poll_create.description") }}</p>

      {% if statusBanner and statusBanner.type == "success" %}
        <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert">
          <div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">{{ t("govuk_alpha_gamification.states.success_title") }}</h2></div>
          <div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ statusBanner.message }}</p></div>
        </div>
      {% elif statusBanner and statusBanner.type == "error" %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
          <div role="alert"><h2 class="govuk-error-summary__title">{{ t("govuk_alpha_gamification.states.error_title") }}</h2><div class="govuk-error-summary__body"><ul class="govuk-list govuk-error-summary__list"><li><a href="#poll-question">{{ statusBanner.message }}</a></li></ul></div></div>
        </div>
      {% endif %}

      <form method="post" action="{{ urlFor('/polls/parity/create') }}" novalidate>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <div class="govuk-form-group">
          <label class="govuk-label govuk-label--s" for="poll-question">{{ t("govuk_alpha_gamification.poll_create.question_label") }}</label>
          <div id="poll-question-hint" class="govuk-hint">{{ t("govuk_alpha_gamification.poll_create.question_hint") }}</div>
          <input class="govuk-input" id="poll-question" name="question" type="text" aria-describedby="poll-question-hint" required maxlength="255">
        </div>
        <div class="govuk-form-group">
          <label class="govuk-label govuk-label--s" for="poll-description">{{ t("govuk_alpha_gamification.poll_create.desc_label") }}</label>
          <div id="poll-desc-hint" class="govuk-hint">{{ t("govuk_alpha_gamification.poll_create.desc_hint") }}</div>
          <textarea class="govuk-textarea" id="poll-description" name="description" rows="3" aria-describedby="poll-desc-hint" maxlength="2000"></textarea>
        </div>
        {% if categories.length %}
          <div class="govuk-form-group">
            <label class="govuk-label govuk-label--s" for="poll-category">{{ t("govuk_alpha_gamification.poll_create.category_label") }}</label>
            <select class="govuk-select" id="poll-category" name="category">
              <option value="">{{ t("govuk_alpha_gamification.poll_create.category_none") }}</option>
              {% for category in categories %}
                <option value="{{ category }}">{{ category }}</option>
              {% endfor %}
            </select>
          </div>
        {% endif %}
        <fieldset class="govuk-fieldset govuk-!-margin-bottom-4">
          <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">{{ t("govuk_alpha_gamification.poll_create.options_legend") }} <span class="govuk-hint">{{ t("govuk_alpha_gamification.poll_create.options_hint") }}</span></legend>
          {% for number in [1, 2, 3, 4, 5, 6] %}
            <div class="govuk-form-group govuk-!-margin-bottom-2">
              <label class="govuk-label" for="poll-option-{{ number }}">{{ t("govuk_alpha_gamification.poll_create.option_label", { num: number }) }}</label>
              <input class="govuk-input govuk-input--width-30" id="poll-option-{{ number }}" name="options[]" type="text" maxlength="255"{% if number <= 2 %} required{% endif %}>
            </div>
          {% endfor %}
        </fieldset>
        <div class="govuk-form-group">
          <label class="govuk-label govuk-label--s" for="poll-expires">{{ t("govuk_alpha_gamification.poll_create.expires_label") }}</label>
          <input class="govuk-input govuk-input--width-10" id="poll-expires" name="expires_at" type="date" min="{{ minDate }}">
        </div>
        <div class="govuk-form-group">
          <fieldset class="govuk-fieldset">
            <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">{{ t("govuk_alpha_gamification.poll_create.type_legend") }}</legend>
            <div class="govuk-radios govuk-radios--small" data-module="govuk-radios">
              <div class="govuk-radios__item">
                <input class="govuk-radios__input" id="poll-type-standard" name="poll_type" type="radio" value="standard" checked>
                <label class="govuk-label govuk-radios__label" for="poll-type-standard">{{ t("govuk_alpha_gamification.poll_create.type_standard") }}</label>
              </div>
              <div class="govuk-radios__item">
                <input class="govuk-radios__input" id="poll-type-ranked" name="poll_type" type="radio" value="ranked">
                <label class="govuk-label govuk-radios__label" for="poll-type-ranked">{{ t("govuk_alpha_gamification.poll_create.type_ranked") }}</label>
              </div>
            </div>
          </fieldset>
        </div>
        <button class="govuk-button" data-module="govuk-button">{{ t("govuk_alpha_gamification.poll_create.submit_button") }}</button>
      </form>
    </div>
  </div>
{% endblock %}
