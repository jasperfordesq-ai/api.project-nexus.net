{% extends "layouts/base.njk" %}

{% block mainContent %}
  <span class="govuk-caption-xl">{{ tenantName }}</span>
  <h1 class="govuk-heading-xl">Federation</h1>
  <p class="govuk-body-l">
    {% if stats.optedIn %}
      Discover and collaborate with partner communities in the wider federation network.
    {% else %}
      Connect with trusted partner communities while keeping control of what you share.
    {% endif %}
  </p>

  <nav class="govuk-service-navigation govuk-!-margin-bottom-6" aria-label="Federation">
    <ul class="govuk-service-navigation__list">
      <li class="govuk-service-navigation__item govuk-service-navigation__item--active"><a class="govuk-service-navigation__link" href="/federation">Overview</a></li>
      <li class="govuk-service-navigation__item"><a class="govuk-service-navigation__link" href="/federation/partners">Partners</a></li>
      <li class="govuk-service-navigation__item"><a class="govuk-service-navigation__link" href="/federation/members">Members</a></li>
      <li class="govuk-service-navigation__item"><a class="govuk-service-navigation__link" href="/federation/groups">Groups</a></li>
      <li class="govuk-service-navigation__item"><a class="govuk-service-navigation__link" href="/federation/events">Events</a></li>
      <li class="govuk-service-navigation__item"><a class="govuk-service-navigation__link" href="/federation/connections">Connections</a></li>
      <li class="govuk-service-navigation__item"><a class="govuk-service-navigation__link" href="/federation/messages">Messages</a></li>
      <li class="govuk-service-navigation__item"><a class="govuk-service-navigation__link" href="/federation/settings">Settings</a></li>
    </ul>
  </nav>

  {% if statusBanner %}
    {% if statusBanner.type == "error" %}
      <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
        <div role="alert">
          <h2 class="govuk-error-summary__title">There is a problem</h2>
          <div class="govuk-error-summary__body">
            <ul class="govuk-list govuk-error-summary__list"><li>{{ statusBanner.message }}</li></ul>
          </div>
        </div>
      </div>
    {% else %}
      <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="federation-status-title">
        <div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title" id="federation-status-title">Success</h2></div>
        <div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ statusBanner.message }}</p></div>
      </div>
    {% endif %}
  {% endif %}

  {% if not stats.tenantEnabled %}
    <div class="govuk-inset-text">
      <h2 class="govuk-heading-m">Federation is not available for this community</h2>
      <p class="govuk-body">This community has not enabled cross-community federation yet.</p>
      <p class="govuk-body">Contact the community team if you expected to use federation here.</p>
    </div>
  {% else %}
    {% if not stats.optedIn %}
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
          <h2 class="govuk-heading-l">Join the federation network</h2>
          <p class="govuk-body">Choose what profile details, skills, messaging, and time-credit actions you want to make available across trusted partner communities.</p>
          <p class="govuk-body"><a class="govuk-button" data-module="govuk-button" href="/federation/opt-in">Turn on federation</a></p>
        </div>
      </div>

      <h2 class="govuk-heading-l">How federation works</h2>
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-one-third"><h3 class="govuk-heading-s">Discover</h3><p class="govuk-body">Find people, listings, events, and groups from partner communities.</p></div>
        <div class="govuk-grid-column-one-third"><h3 class="govuk-heading-s">Meet</h3><p class="govuk-body">Send connection requests and messages when both communities allow it.</p></div>
        <div class="govuk-grid-column-one-third"><h3 class="govuk-heading-s">Exchange</h3><p class="govuk-body">Use time-credit transfers only when federation settings permit them.</p></div>
      </div>
    {% endif %}

    <h2 class="govuk-heading-l">Network stats</h2>
    <dl class="govuk-summary-list">
      <div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">Partnerships</dt><dd class="govuk-summary-list__value">{{ stats.partnershipsCount }}</dd></div>
      <div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">Messages</dt><dd class="govuk-summary-list__value">{{ stats.messagesCount }}</dd></div>
      <div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">Transactions</dt><dd class="govuk-summary-list__value">{{ stats.transactionsCount }}</dd></div>
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Federation status</dt>
        <dd class="govuk-summary-list__value">
          {% if stats.optedIn %}
            <strong class="govuk-tag govuk-tag--green">Opted in</strong>
          {% else %}
            <strong class="govuk-tag govuk-tag--grey">Not opted in</strong>
          {% endif %}
        </dd>
      </div>
    </dl>

    {% if stats.optedIn %}
      <h2 class="govuk-heading-l">Recent activity</h2>
      {% if activity.length %}
        <div class="nexus-alpha-card-list">
          {% for item in activity %}
            <article class="nexus-alpha-card">
              <h3 class="govuk-heading-s govuk-!-margin-bottom-1">{{ item.title }}</h3>
              {% if item.description %}<p class="govuk-body govuk-!-margin-bottom-1">{{ item.description }}</p>{% endif %}
              {% if item.community %}<p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">From {{ item.community }}</p>{% endif %}
              {% if item.createdAt %}<p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-0">{{ item.createdAt | date }}</p>{% endif %}
            </article>
          {% endfor %}
        </div>
      {% else %}
        <div class="govuk-inset-text">
          <p class="govuk-body govuk-!-margin-bottom-1"><strong>No recent federation activity.</strong></p>
          <p class="govuk-body govuk-!-margin-bottom-0">Activity from partner communities will appear here.</p>
        </div>
      {% endif %}
    {% endif %}

    <h2 class="govuk-heading-l">Partner communities</h2>
    {% if partners.length %}
      <div class="nexus-alpha-card-list">
        {% for partner in partners %}
          <article class="nexus-alpha-card">
            <div class="nexus-alpha-module-row">
              <h3 class="govuk-heading-s govuk-!-margin-bottom-1"><a class="govuk-link" href="{{ partner.href }}">{{ partner.name }}</a></h3>
              {% if partner.isExternal %}
                <strong class="govuk-tag govuk-tag--grey">External</strong>
              {% elif partner.levelName %}
                <strong class="govuk-tag govuk-tag--purple">{{ partner.levelName }}</strong>
              {% endif %}
            </div>
            {% if partner.tagline %}<p class="govuk-body govuk-!-margin-bottom-2">{{ partner.tagline }}</p>{% endif %}
            <dl class="nexus-alpha-inline-list">
              {% if partner.location %}<div><dt>Location</dt><dd>{{ partner.location }}</dd></div>{% endif %}
              <div><dt>Members</dt><dd>{{ partner.memberCount }}</dd></div>
              <div><dt>Listings</dt><dd>{{ partner.listingCount }}</dd></div>
              {% if partner.partnershipSince %}<div><dt>Since</dt><dd>{{ partner.partnershipSince | date }}</dd></div>{% endif %}
            </dl>
            <p class="govuk-body-s govuk-!-margin-bottom-0"><a class="govuk-link" href="{{ partner.href }}">View community</a></p>
          </article>
        {% endfor %}
      </div>
      {% if partnerTotal > partners.length %}
        <p class="govuk-body govuk-!-margin-top-4"><a class="govuk-link" href="/federation/partners">View all {{ partnerTotal }} partner communities</a></p>
      {% endif %}
    {% else %}
      <div class="govuk-inset-text"><p class="govuk-body">No partner communities are available yet.</p></div>
    {% endif %}

    {% if stats.optedIn %}
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
          <h2 class="govuk-heading-l">Federation links</h2>
          <ul class="govuk-list">
            <li><a class="govuk-link" href="/federation/partners">Browse partner communities</a></li>
            <li><a class="govuk-link" href="/federation/members">Find federation members</a></li>
            <li><a class="govuk-link" href="/federation/connections">Manage federation connections</a></li>
            <li><a class="govuk-link" href="/federation/messages">Federation messages</a></li>
            <li><a class="govuk-link" href="/federation/listings">Federated listings</a></li>
            <li><a class="govuk-link" href="/federation/events">Federated events</a></li>
            <li><a class="govuk-link" href="/federation/groups">Federated groups</a></li>
            <li><a class="govuk-link" href="/federation/settings">Federation settings</a></li>
          </ul>
          <p class="govuk-body govuk-!-margin-top-4"><a class="govuk-link" href="/federation/opt-out">Turn off federation</a></p>
        </div>
      </div>
    {% endif %}
  {% endif %}
{% endblock %}
