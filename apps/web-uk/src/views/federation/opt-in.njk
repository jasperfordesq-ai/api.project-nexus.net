{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a href="/federation" class="govuk-back-link">Back to federation</a>

  <span class="govuk-caption-xl">This community</span>
  <h1 class="govuk-heading-xl">Opt in to federation</h1>
  <p class="govuk-body-l">Opting in lets you take part in the wider community network. You can change or turn off these settings at any time.</p>

  <nav class="govuk-service-navigation govuk-!-margin-bottom-6" aria-label="Federation">
    <ul class="govuk-service-navigation__list">
      <li class="govuk-service-navigation__item govuk-service-navigation__item--active"><a class="govuk-service-navigation__link" href="/federation">Overview</a></li>
      <li class="govuk-service-navigation__item"><a class="govuk-service-navigation__link" href="/federation/partners">Partners</a></li>
      <li class="govuk-service-navigation__item"><a class="govuk-service-navigation__link" href="/federation/members">Members</a></li>
      <li class="govuk-service-navigation__item"><a class="govuk-service-navigation__link" href="/federation/groups">Groups</a></li>
      <li class="govuk-service-navigation__item"><a class="govuk-service-navigation__link" href="/federation/events">Events</a></li>
      <li class="govuk-service-navigation__item"><a class="govuk-service-navigation__link" href="/federation/connections">Connections</a></li>
      <li class="govuk-service-navigation__item"><a class="govuk-service-navigation__link" href="/federation/messages">Messages</a></li>
      <li class="govuk-service-navigation__item"><a class="govuk-service-navigation__link" href="/federation/settings">Settings</a></li>
    </ul>
  </nav>

  {% if statusBanner %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            <li><a href="#profile_visible_federated">{{ statusBanner.message }}</a></li>
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  <h2 class="govuk-heading-m">What you can do</h2>
  <div class="govuk-grid-row govuk-!-margin-bottom-6">
    <div class="govuk-grid-column-one-third">
      <div class="nexus-alpha-card">
        <h3 class="govuk-heading-s govuk-!-margin-bottom-1">Discover</h3>
        <p class="govuk-body-s govuk-!-margin-bottom-0">Search members and listings across partner communities.</p>
      </div>
    </div>
    <div class="govuk-grid-column-one-third">
      <div class="nexus-alpha-card">
        <h3 class="govuk-heading-s govuk-!-margin-bottom-1">Connect</h3>
        <p class="govuk-body-s govuk-!-margin-bottom-0">Message and connect with members in other communities.</p>
      </div>
    </div>
    <div class="govuk-grid-column-one-third">
      <div class="nexus-alpha-card">
        <h3 class="govuk-heading-s govuk-!-margin-bottom-1">Exchange</h3>
        <p class="govuk-body-s govuk-!-margin-bottom-0">Offer help and send time credits across the network.</p>
      </div>
    </div>
  </div>

  <form method="post" action="/federation/opt-in">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    <input type="hidden" name="preferences_submitted" value="1">

    <fieldset class="govuk-fieldset govuk-!-margin-bottom-4">
      <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">Your visibility</legend>
      <div class="govuk-checkboxes" data-module="govuk-checkboxes">
        <div class="govuk-checkboxes__item">
          <input class="govuk-checkboxes__input" id="profile_visible_federated" name="profile_visible_federated" type="checkbox" value="1" checked>
          <label class="govuk-label govuk-checkboxes__label" for="profile_visible_federated">Show my profile to partner communities</label>
        </div>
        <div class="govuk-checkboxes__item">
          <input class="govuk-checkboxes__input" id="appear_in_federated_search" name="appear_in_federated_search" type="checkbox" value="1" checked>
          <label class="govuk-label govuk-checkboxes__label" for="appear_in_federated_search">Appear in federated member searches</label>
        </div>
        <div class="govuk-checkboxes__item">
          <input class="govuk-checkboxes__input" id="show_skills_federated" name="show_skills_federated" type="checkbox" value="1" checked>
          <label class="govuk-label govuk-checkboxes__label" for="show_skills_federated">Show my skills to partner communities</label>
        </div>
        <div class="govuk-checkboxes__item">
          <input class="govuk-checkboxes__input" id="show_location_federated" name="show_location_federated" type="checkbox" value="1" aria-describedby="show_location_federated-hint">
          <label class="govuk-label govuk-checkboxes__label" for="show_location_federated">Show my location to partner communities</label>
          <div id="show_location_federated-hint" class="govuk-hint govuk-checkboxes__hint">Your location is personal data. It stays hidden unless you turn this on.</div>
        </div>
        <div class="govuk-checkboxes__item">
          <input class="govuk-checkboxes__input" id="show_reviews_federated" name="show_reviews_federated" type="checkbox" value="1" checked>
          <label class="govuk-label govuk-checkboxes__label" for="show_reviews_federated">Show my reviews to partner communities</label>
        </div>
      </div>
    </fieldset>

    <fieldset class="govuk-fieldset govuk-!-margin-bottom-4">
      <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">Communication</legend>
      <div class="govuk-checkboxes" data-module="govuk-checkboxes">
        <div class="govuk-checkboxes__item">
          <input class="govuk-checkboxes__input" id="messaging_enabled_federated" name="messaging_enabled_federated" type="checkbox" value="1" checked>
          <label class="govuk-label govuk-checkboxes__label" for="messaging_enabled_federated">Allow federation messages</label>
        </div>
        <div class="govuk-checkboxes__item">
          <input class="govuk-checkboxes__input" id="transactions_enabled_federated" name="transactions_enabled_federated" type="checkbox" value="1" checked>
          <label class="govuk-label govuk-checkboxes__label" for="transactions_enabled_federated">Allow federation time-credit transfers</label>
        </div>
        <div class="govuk-checkboxes__item">
          <input class="govuk-checkboxes__input" id="email_notifications" name="email_notifications" type="checkbox" value="1" checked>
          <label class="govuk-label govuk-checkboxes__label" for="email_notifications">Email me about federated activity</label>
        </div>
      </div>
    </fieldset>

    <fieldset class="govuk-fieldset govuk-!-margin-bottom-2">
      <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">Service reach</legend>

      <div class="govuk-form-group">
        <label class="govuk-label" for="service_reach">Service reach</label>
        <select class="govuk-select" id="service_reach" name="service_reach">
          <option value="local_only" selected>Local only</option>
          <option value="remote_ok">Remote is fine</option>
          <option value="travel_ok">Willing to travel</option>
        </select>
      </div>

      <div class="govuk-form-group">
        <label class="govuk-label" for="travel_radius_km">Travel radius</label>
        <div id="travel_radius_km-hint" class="govuk-hint">The furthest distance you are willing to travel, in kilometres.</div>
        <div class="govuk-input__wrapper">
          <input class="govuk-input govuk-input--width-5" id="travel_radius_km" name="travel_radius_km" type="number" min="0" max="500" step="1" value="25" aria-describedby="travel_radius_km-hint" spellcheck="false">
          <div class="govuk-input__suffix" aria-hidden="true">km</div>
        </div>
      </div>
    </fieldset>

    <div class="govuk-button-group">
      <button type="submit" class="govuk-button" data-module="govuk-button">Opt in to federation</button>
      <a class="govuk-link" href="/federation">Do this later</a>
    </div>
  </form>

  <h2 class="govuk-heading-m govuk-!-margin-top-6">Communities you could connect with</h2>
  {% if partners.length %}
    <div class="nexus-alpha-card-list">
      {% for partner in partners %}
        <article class="nexus-alpha-card">
          <h3 class="govuk-heading-s govuk-!-margin-bottom-1">{{ partner.name }}</h3>
          {% if partner.location %}
            <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">Location: {{ partner.location }}</p>
          {% endif %}
          <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-0">Members: {{ partner.memberCount }}</p>
        </article>
      {% endfor %}
    </div>
  {% else %}
    <div class="govuk-inset-text"><p class="govuk-body">There are no partner communities yet.</p></div>
  {% endif %}
{% endblock %}
