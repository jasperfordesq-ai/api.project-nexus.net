{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a href="{{ urlFor('/federation') }}" class="govuk-back-link">{{ t("federation.events_browse.back") }}</a>

  <span class="govuk-caption-xl">{{ t("federation.events_browse.caption", { community: tenantName }) }}</span>
  <h1 class="govuk-heading-xl">{{ t("federation.events_browse.title") }}</h1>
  <p class="govuk-body-l">{{ t("federation.events_browse.description") }}</p>

  {% include "federation/_nav.njk" %}


  {% if not allowed %}
    <div class="govuk-inset-text"><p class="govuk-body">{{ t("federation.events_browse.not_available") }}</p></div>
  {% else %}
    <form method="get" action="{{ urlFor('/federation/events') }}" class="govuk-!-margin-bottom-6">
      <fieldset class="govuk-fieldset">
        <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">{{ t("federation.events_browse.filters_legend") }}</legend>

        <div class="govuk-form-group">
          <label class="govuk-label" for="q">{{ t("federation.events_browse.search_label") }}</label>
          <div id="q-hint" class="govuk-hint">{{ t("federation.events_browse.search_hint") }}</div>
          <input class="govuk-input govuk-!-width-two-thirds" id="q" name="q" type="search" value="{{ filters.q }}" aria-describedby="q-hint">
        </div>

        <div class="govuk-form-group">
          <label class="govuk-label" for="partner_id">{{ t("federation.events_browse.filter_by_community") }}</label>
          <select class="govuk-select" id="partner_id" name="partner_id">
            <option value=""{% if not filters.partnerId %} selected{% endif %}>{{ t("federation.events_browse.all_communities") }}</option>
            {% for partner in partnerOptions %}
              <option value="{{ partner.id }}"{% if filters.partnerId == partner.id %} selected{% endif %}>{{ partner.name }}</option>
            {% endfor %}
          </select>
        </div>

        <div class="govuk-form-group">
          <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
            <input type="hidden" name="upcoming" value="false">
            <div class="govuk-checkboxes__item">
              <input class="govuk-checkboxes__input" id="upcoming" name="upcoming" type="checkbox" value="1"{% if filters.upcoming %} checked{% endif %}>
              <label class="govuk-label govuk-checkboxes__label" for="upcoming">{{ t("federation.events_browse.upcoming_only") }}</label>
            </div>
          </div>
        </div>

        <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">{{ t("federation.events_browse.apply_filters") }}</button>
      </fieldset>
    </form>

    {% if loadError %}
      <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
        <div role="alert">
          <h2 class="govuk-error-summary__title">{{ t("federation.events_browse.unable_to_load") }}</h2>
          <div class="govuk-error-summary__body">
            <ul class="govuk-list govuk-error-summary__list">
              <li><a href="{{ urlFor('/federation/events') }}">{{ t("federation.events_browse.try_again") }}</a></li>
            </ul>
          </div>
        </div>
      </div>
    {% elif not events.length %}
      {% if filters.upcoming %}
        <div class="govuk-inset-text"><p class="govuk-body">{{ t("federation.events_browse.empty_upcoming") }}</p></div>
      {% else %}
        <div class="govuk-inset-text"><p class="govuk-body">{{ t("federation.events_browse.empty_general") }}</p></div>
      {% endif %}
    {% else %}
      <div class="nexus-alpha-card-list">
        {% for event in events %}
          <article class="nexus-alpha-card">
            {% if event.coverImage %}
              <img class="nexus-alpha-card-image govuk-!-margin-bottom-2" src="{{ event.coverImage }}" alt="">
            {% endif %}

            <div class="nexus-alpha-module-row">
              <h2 class="govuk-heading-s govuk-!-margin-bottom-1">{{ event.title }}</h2>
              {% if event.isPast %}
                <strong class="govuk-tag govuk-tag--grey">{{ t("federation.events_browse.past_label") }}</strong>
              {% endif %}
              {% if event.isOnline %}
                <strong class="govuk-tag govuk-tag--turquoise">{{ t("federation.events_browse.online_label") }}</strong>
              {% endif %}
            </div>

            {% if event.startDate %}
              <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">{{ event.startDateLabel }}</p>
            {% endif %}

            {% if event.organiserName %}
              <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">{{ t("federation.events_browse.organiser_label") }}: {{ event.organiserName }}</p>
            {% endif %}

            {% if event.tenantName %}
              <p class="govuk-body-s govuk-!-margin-bottom-1">
                <strong class="govuk-tag govuk-tag--grey">{{ event.tenantName }}</strong>
              </p>
            {% endif %}

            {% if event.description %}
              <p class="govuk-body govuk-!-margin-bottom-1">{{ event.description }}</p>
            {% endif %}

            <dl class="nexus-alpha-inline-list">
              {% if event.location and not event.isOnline %}
                <div>
                  <dt>{{ t("federation.location_label") }}</dt>
                  <dd>{{ event.location }}</dd>
                </div>
              {% endif %}
              <div>
                <dt>{{ t("federation.events_browse.attendees_label") }}</dt>
                <dd>{{ event.attendeesCountLabel }}</dd>
              </div>
            </dl>
          </article>
        {% endfor %}
      </div>

      {% if loadMoreHref %}
        <p class="govuk-body govuk-!-margin-top-4">
          <a class="govuk-link" href="{{ urlFor(loadMoreHref) }}">{{ t("federation.events_browse.load_more") }}</a>
        </p>
      {% endif %}
    {% endif %}
  {% endif %}
{% endblock %}
