{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a href="/federation" class="govuk-back-link">Back to federation</a>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <span class="govuk-caption-xl">Connecting this community</span>
      <h1 class="govuk-heading-xl">Welcome to the community network</h1>
      <p class="govuk-body-l">A few quick choices to connect with neighbouring communities.</p>

      <nav class="govuk-service-navigation govuk-!-margin-bottom-6" aria-label="Federation">
        <ul class="govuk-service-navigation__list">
          <li class="govuk-service-navigation__item govuk-service-navigation__item--active"><a class="govuk-service-navigation__link" href="/federation">Overview</a></li>
          <li class="govuk-service-navigation__item"><a class="govuk-service-navigation__link" href="/federation/partners">Partners</a></li>
          <li class="govuk-service-navigation__item"><a class="govuk-service-navigation__link" href="/federation/members">Members</a></li>
          <li class="govuk-service-navigation__item"><a class="govuk-service-navigation__link" href="/federation/listings">Listings</a></li>
          <li class="govuk-service-navigation__item"><a class="govuk-service-navigation__link" href="/federation/events">Events</a></li>
          <li class="govuk-service-navigation__item"><a class="govuk-service-navigation__link" href="/federation/groups">Groups</a></li>
          <li class="govuk-service-navigation__item"><a class="govuk-service-navigation__link" href="/federation/connections">Connections</a></li>
          <li class="govuk-service-navigation__item"><a class="govuk-service-navigation__link" href="/federation/messages">Messages</a></li>
          <li class="govuk-service-navigation__item"><a class="govuk-service-navigation__link" href="/federation/settings">Settings</a></li>
        </ul>
      </nav>

      {% if statusBanner %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
          <div role="alert">
            <h2 class="govuk-error-summary__title">There is a problem</h2>
            <div class="govuk-error-summary__body">
              <ul class="govuk-list govuk-error-summary__list">
                <li><a href="#fed-onboarding-form">{{ statusBanner.message }}</a></li>
              </ul>
            </div>
          </div>
        </div>
      {% endif %}

      <div class="govuk-!-margin-bottom-6">
        <p class="govuk-body-s govuk-!-margin-bottom-1">
          <strong>Step {{ stepNumber }} of {{ totalSteps }}</strong>
          {% if step == "welcome" %}
            <span class="nexus-alpha-meta">- Welcome</span>
          {% elif step == "privacy" %}
            <span class="nexus-alpha-meta">- Privacy</span>
          {% elif step == "communication" %}
            <span class="nexus-alpha-meta">- Communication</span>
          {% else %}
            <span class="nexus-alpha-meta">- Confirm</span>
          {% endif %}
        </p>
        <progress class="nexus-alpha-progress" value="{{ progressValue }}" max="100" aria-label="Onboarding progress: step {{ stepNumber }} of {{ totalSteps }}">{{ progressValue }}%</progress>
      </div>

      {% if step == "welcome" %}
        <h2 class="govuk-heading-l">Connect beyond your community</h2>
        <p class="govuk-body">Federation lets you discover members, listings, events and groups from neighbouring communities and exchange time credits across the network.</p>

        <div class="govuk-grid-row govuk-!-margin-top-4 govuk-!-margin-bottom-4">
          <div class="govuk-grid-column-one-third">
            <div class="nexus-alpha-card">
              <h3 class="govuk-heading-s govuk-!-margin-bottom-1">Discover more</h3>
              <p class="govuk-body-s govuk-!-margin-bottom-0">Find skills and offers that are not available in your own community.</p>
            </div>
          </div>
          <div class="govuk-grid-column-one-third">
            <div class="nexus-alpha-card">
              <h3 class="govuk-heading-s govuk-!-margin-bottom-1">Meet new people</h3>
              <p class="govuk-body-s govuk-!-margin-bottom-0">Connect with members from partner communities near you.</p>
            </div>
          </div>
          <div class="govuk-grid-column-one-third">
            <div class="nexus-alpha-card">
              <h3 class="govuk-heading-s govuk-!-margin-bottom-1">Exchange time</h3>
              <p class="govuk-body-s govuk-!-margin-bottom-0">Give and receive help across the wider timebanking network.</p>
            </div>
          </div>
        </div>

        <form id="fed-onboarding-form" method="post" action="/federation/onboarding">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <input type="hidden" name="step" value="welcome">
          <div class="govuk-button-group">
            <button type="submit" class="govuk-button" data-module="govuk-button">Get started</button>
            <a class="govuk-link" href="/federation">Do this later</a>
          </div>
        </form>
      {% elif step == "privacy" %}
        <form id="fed-onboarding-form" method="post" action="/federation/onboarding">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <input type="hidden" name="step" value="privacy">

          <fieldset class="govuk-fieldset govuk-!-margin-bottom-4" aria-describedby="privacy-hint">
            <legend class="govuk-fieldset__legend govuk-fieldset__legend--l">
              <h2 class="govuk-fieldset__heading">Profile visibility</h2>
            </legend>
            <div id="privacy-hint" class="govuk-hint">Choose what members of partner communities can see about you. You can change these at any time.</div>
            <div class="govuk-checkboxes" data-module="govuk-checkboxes">
              <div class="govuk-checkboxes__item">
                <input class="govuk-checkboxes__input" id="profile_visible_federated" name="profile_visible_federated" type="checkbox" value="1"{% if settings.profile_visible_federated %} checked{% endif %} aria-describedby="profile_visible_federated-hint">
                <label class="govuk-label govuk-checkboxes__label" for="profile_visible_federated">Show my profile to partner communities</label>
                <div id="profile_visible_federated-hint" class="govuk-hint govuk-checkboxes__hint">Let members of partner communities view your profile.</div>
              </div>
              <div class="govuk-checkboxes__item">
                <input class="govuk-checkboxes__input" id="appear_in_federated_search" name="appear_in_federated_search" type="checkbox" value="1"{% if settings.appear_in_federated_search %} checked{% endif %} aria-describedby="appear_in_federated_search-hint">
                <label class="govuk-label govuk-checkboxes__label" for="appear_in_federated_search">Appear in network search</label>
                <div id="appear_in_federated_search-hint" class="govuk-hint govuk-checkboxes__hint">Allow your profile to appear in searches across the network.</div>
              </div>
              <div class="govuk-checkboxes__item">
                <input class="govuk-checkboxes__input" id="show_skills_federated" name="show_skills_federated" type="checkbox" value="1"{% if settings.show_skills_federated %} checked{% endif %} aria-describedby="show_skills_federated-hint">
                <label class="govuk-label govuk-checkboxes__label" for="show_skills_federated">Share my skills</label>
                <div id="show_skills_federated-hint" class="govuk-hint govuk-checkboxes__hint">Show your skills to partner communities.</div>
              </div>
              <div class="govuk-checkboxes__item">
                <input class="govuk-checkboxes__input" id="show_location_federated" name="show_location_federated" type="checkbox" value="1"{% if settings.show_location_federated %} checked{% endif %} aria-describedby="show_location_federated-hint">
                <label class="govuk-label govuk-checkboxes__label" for="show_location_federated">Share my location</label>
                <div id="show_location_federated-hint" class="govuk-hint govuk-checkboxes__hint">Show your approximate location. This is off by default.</div>
              </div>
              <div class="govuk-checkboxes__item">
                <input class="govuk-checkboxes__input" id="show_reviews_federated" name="show_reviews_federated" type="checkbox" value="1"{% if settings.show_reviews_federated %} checked{% endif %} aria-describedby="show_reviews_federated-hint">
                <label class="govuk-label govuk-checkboxes__label" for="show_reviews_federated">Show my reviews</label>
                <div id="show_reviews_federated-hint" class="govuk-hint govuk-checkboxes__hint">Let partner communities see reviews you have received.</div>
              </div>
            </div>
          </fieldset>

          <div class="govuk-button-group">
            <a class="govuk-button govuk-button--secondary" data-module="govuk-button" href="/federation/onboarding?step=welcome">Back</a>
            <button type="submit" class="govuk-button" data-module="govuk-button">Continue</button>
          </div>
        </form>
      {% elif step == "communication" %}
        <form id="fed-onboarding-form" method="post" action="/federation/onboarding">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <input type="hidden" name="step" value="communication">

          <fieldset class="govuk-fieldset govuk-!-margin-bottom-4" aria-describedby="communication-hint">
            <legend class="govuk-fieldset__legend govuk-fieldset__legend--l">
              <h2 class="govuk-fieldset__heading">Communication preferences</h2>
            </legend>
            <div id="communication-hint" class="govuk-hint">Decide how you want to take part in the network.</div>
            <div class="govuk-checkboxes" data-module="govuk-checkboxes">
              <div class="govuk-checkboxes__item">
                <input class="govuk-checkboxes__input" id="messaging_enabled_federated" name="messaging_enabled_federated" type="checkbox" value="1"{% if settings.messaging_enabled_federated %} checked{% endif %} aria-describedby="messaging_enabled_federated-hint">
                <label class="govuk-label govuk-checkboxes__label" for="messaging_enabled_federated">Allow messages</label>
                <div id="messaging_enabled_federated-hint" class="govuk-hint govuk-checkboxes__hint">Let members of partner communities send you messages.</div>
              </div>
              <div class="govuk-checkboxes__item">
                <input class="govuk-checkboxes__input" id="transactions_enabled_federated" name="transactions_enabled_federated" type="checkbox" value="1"{% if settings.transactions_enabled_federated %} checked{% endif %} aria-describedby="transactions_enabled_federated-hint">
                <label class="govuk-label govuk-checkboxes__label" for="transactions_enabled_federated">Allow time exchanges</label>
                <div id="transactions_enabled_federated-hint" class="govuk-hint govuk-checkboxes__hint">Take part in time-credit exchanges across the network.</div>
              </div>
              <div class="govuk-checkboxes__item">
                <input class="govuk-checkboxes__input" id="email_notifications" name="email_notifications" type="checkbox" value="1"{% if settings.email_notifications %} checked{% endif %} aria-describedby="email_notifications-hint">
                <label class="govuk-label govuk-checkboxes__label" for="email_notifications">Email notifications</label>
                <div id="email_notifications-hint" class="govuk-hint govuk-checkboxes__hint">Get an email when something happens in the network.</div>
              </div>
            </div>
          </fieldset>

          <fieldset class="govuk-fieldset govuk-!-margin-bottom-4" aria-describedby="reach-hint">
            <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
              <h2 class="govuk-fieldset__heading">Service reach</h2>
            </legend>
            <div id="reach-hint" class="govuk-hint">Tell members how far you are willing to travel or work.</div>

            <div class="govuk-form-group">
              <label class="govuk-label" for="service_reach">Service availability</label>
              <select class="govuk-select" id="service_reach" name="service_reach">
                <option value="local_only"{% if settings.service_reach == "local_only" %} selected{% endif %}>Local only</option>
                <option value="remote_ok"{% if settings.service_reach == "remote_ok" %} selected{% endif %}>Remote is fine</option>
                <option value="travel_ok"{% if settings.service_reach == "travel_ok" %} selected{% endif %}>Happy to travel</option>
              </select>
            </div>

            <div class="govuk-form-group">
              <label class="govuk-label" for="travel_radius_km">How far will you travel?</label>
              <div id="travel_radius_km-hint" class="govuk-hint">Enter a distance in kilometres (up to 500).</div>
              <div class="govuk-input__wrapper">
                <input class="govuk-input govuk-input--width-5" id="travel_radius_km" name="travel_radius_km" type="number" min="0" max="500" step="1" value="{{ settings.travel_radius_km }}" aria-describedby="travel_radius_km-hint" spellcheck="false">
                <div class="govuk-input__suffix" aria-hidden="true">km</div>
              </div>
            </div>
          </fieldset>

          <div class="govuk-button-group">
            <a class="govuk-button govuk-button--secondary" data-module="govuk-button" href="/federation/onboarding?step=privacy">Back</a>
            <button type="submit" class="govuk-button" data-module="govuk-button">Continue</button>
          </div>
        </form>
      {% else %}
        <h2 class="govuk-heading-l">Review your settings</h2>
        <p class="govuk-body">Check your choices before enabling federation. You can change everything later in settings.</p>

        <h3 class="govuk-heading-s govuk-!-margin-bottom-2">Profile visibility</h3>
        <dl class="govuk-summary-list govuk-!-margin-bottom-6">
          {% set privacyRows = [
            ["Profile visible", settings.profile_visible_federated],
            ["In network search", settings.appear_in_federated_search],
            ["Skills shared", settings.show_skills_federated],
            ["Location shared", settings.show_location_federated],
            ["Reviews visible", settings.show_reviews_federated]
          ] %}
          {% for row in privacyRows %}
            <div class="govuk-summary-list__row">
              <dt class="govuk-summary-list__key">{{ row[0] }}</dt>
              <dd class="govuk-summary-list__value">
                {% if row[1] %}
                  <strong class="govuk-tag govuk-tag--green">On</strong>
                {% else %}
                  <strong class="govuk-tag govuk-tag--grey">Off</strong>
                {% endif %}
              </dd>
            </div>
          {% endfor %}
        </dl>

        <h3 class="govuk-heading-s govuk-!-margin-bottom-2">Communication</h3>
        <dl class="govuk-summary-list govuk-!-margin-bottom-6">
          {% set communicationRows = [
            ["Messaging", settings.messaging_enabled_federated],
            ["Time exchanges", settings.transactions_enabled_federated],
            ["Email alerts", settings.email_notifications]
          ] %}
          {% for row in communicationRows %}
            <div class="govuk-summary-list__row">
              <dt class="govuk-summary-list__key">{{ row[0] }}</dt>
              <dd class="govuk-summary-list__value">
                {% if row[1] %}
                  <strong class="govuk-tag govuk-tag--green">On</strong>
                {% else %}
                  <strong class="govuk-tag govuk-tag--grey">Off</strong>
                {% endif %}
              </dd>
            </div>
          {% endfor %}
        </dl>

        <h3 class="govuk-heading-s govuk-!-margin-bottom-2">Service reach</h3>
        <p class="govuk-body govuk-!-margin-bottom-6">{{ settings.reachSummary }}</p>

        <h3 class="govuk-heading-s govuk-!-margin-bottom-2">Partner communities</h3>
        {% if partners.length %}
          <p class="govuk-body">You will be able to connect with these communities.</p>
          <div class="nexus-alpha-card-list govuk-!-margin-bottom-4">
            {% for partner in partners %}
              <article class="nexus-alpha-card">
                <h4 class="govuk-heading-s govuk-!-margin-bottom-1">{{ partner.name }}</h4>
                {% if partner.location %}
                  <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">Location: {{ partner.location }}</p>
                {% endif %}
                <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-0">Members: {{ partner.memberCount }}</p>
              </article>
            {% endfor %}
          </div>
        {% else %}
          <div class="govuk-inset-text"><p class="govuk-body govuk-!-margin-bottom-0">There are no partner communities yet. You can still enable federation now and connect as the network grows.</p></div>
        {% endif %}

        <div class="govuk-warning-text">
          <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
          <strong class="govuk-warning-text__text">
            <span class="govuk-visually-hidden">Warning</span>
            Enabling federation shares the profile details you selected above with partner communities.
          </strong>
        </div>

        <form id="fed-onboarding-form" method="post" action="/federation/onboarding">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <input type="hidden" name="step" value="confirm">
          <div class="govuk-button-group">
            <a class="govuk-button govuk-button--secondary" data-module="govuk-button" href="/federation/onboarding?step=communication">Back</a>
            <button type="submit" class="govuk-button" data-module="govuk-button">Enable federation</button>
            <a class="govuk-link" href="/federation">Do this later</a>
          </div>
        </form>
      {% endif %}
    </div>
  </div>
{% endblock %}
