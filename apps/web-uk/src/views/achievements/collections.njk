{% extends "layouts/base.njk" %}

{% block content %}
  <a class="govuk-back-link" href="{{ urlFor('/achievements') }}">Back to achievements</a>

  <span class="govuk-caption-xl">Achievements at {{ communityName }}</span>
  <h1 class="govuk-heading-xl">Badge collections</h1>
  <p class="govuk-body-l">Complete a collection by earning every badge in it to unlock a bonus XP reward.</p>

  <nav class="govuk-tabs govuk-!-margin-top-2 govuk-!-margin-bottom-4" aria-label="Achievements and rewards">
    <h2 class="govuk-tabs__title">Achievements and rewards</h2>
    <ul class="govuk-tabs__list">
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="{{ urlFor('/achievements/shop') }}">XP shop</a>
      </li>
      <li class="govuk-tabs__list-item govuk-tabs__list-item--selected">
        <a class="govuk-tabs__tab" href="{{ urlFor('/achievements/collections') }}" aria-current="page">Collections</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="{{ urlFor('/achievements/showcase') }}">Showcase badges</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="{{ urlFor('/achievements/engagement') }}">Engagement history</a>
      </li>
    </ul>
  </nav>

  {% if collections.length %}
    <ul class="nexus-alpha-card-list govuk-list">
      {% for collection in collections %}
        <li class="nexus-alpha-card govuk-!-margin-bottom-4">
          <div class="nexus-alpha-module-row">
            <h2 class="govuk-heading-m govuk-!-margin-bottom-1">{{ collection.name }}</h2>
            {% if collection.completed %}
              <strong class="govuk-tag govuk-tag--green">Completed</strong>
            {% endif %}
          </div>
          {% if collection.description %}
            <p class="govuk-body">{{ collection.description }}</p>
          {% endif %}
          <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">
            {{ collection.earnedCount }} of {{ collection.totalCount }} badges
            {% if collection.rewardXp > 0 %}&middot; Reward: {{ collection.rewardLabel }}{% endif %}
            {% if collection.bonusClaimed %}&middot; <strong class="govuk-tag govuk-tag--blue">Bonus claimed</strong>{% endif %}
          </p>
          <progress max="100" value="{{ collection.progressPercent }}" aria-label="{{ collection.name }}: {{ collection.progressPercent }}%">{{ collection.progressPercent }}%</progress>

          {% if collection.badges.length %}
            <ul class="nexus-alpha-inline-list govuk-list govuk-!-margin-top-2">
              {% for badge in collection.badges %}
                <li>
                  {% if badge.href %}
                    <a class="govuk-link" href="{{ urlFor(badge.href) }}">{{ badge.name }}</a>
                  {% else %}
                    {{ badge.name }}
                  {% endif %}
                  <strong class="govuk-tag {% if badge.earned %}govuk-tag--green{% else %}govuk-tag--grey{% endif %}">{% if badge.earned %}Earned{% else %}Locked{% endif %}</strong>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <div class="govuk-inset-text">
      <p class="govuk-body">There are no badge collections yet.</p>
    </div>
  {% endif %}
{% endblock %}
