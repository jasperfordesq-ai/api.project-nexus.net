{% extends "layouts/base.njk" %}

{% block content %}
  <nav class="govuk-tabs govuk-!-margin-top-2 govuk-!-margin-bottom-4" aria-label="Achievements and rewards">
    <h2 class="govuk-tabs__title">Achievements and rewards</h2>
    <ul class="govuk-tabs__list">
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="/achievements/shop">XP shop</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="/achievements/collections">Collections</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="/achievements/showcase">Showcase badges</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="/achievements/engagement">Engagement history</a>
      </li>
    </ul>
  </nav>

  <span class="govuk-caption-xl">{{ communityName }}</span>
  <h1 class="govuk-heading-xl">Achievements</h1>
  <p class="govuk-body-l">Your level, experience and the badges you have earned in this community.</p>

  <dl class="govuk-summary-list govuk-!-margin-bottom-4">
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Level</dt>
      <dd class="govuk-summary-list__value">{{ achievements.profile.levelLabel }}</dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Experience points</dt>
      <dd class="govuk-summary-list__value">{{ achievements.profile.xpLabel }}</dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Badges earned</dt>
      <dd class="govuk-summary-list__value">{{ achievements.profile.badgesCountLabel }}</dd>
    </div>
  </dl>

  {% if achievements.profile.atMaxLevel %}
    <p class="govuk-body">You have reached the top level.</p>
  {% else %}
    <p class="govuk-body govuk-!-margin-bottom-1">{{ achievements.profile.progressPercent }}% of the way to the next level</p>
    <span class="govuk-body-s govuk-!-margin-right-2">{{ achievements.profile.progressPercent }}%</span>
    <progress max="100" value="{{ achievements.profile.progressPercent }}" aria-label="{{ achievements.profile.progressPercent }}%">{{ achievements.profile.progressPercent }}%</progress>
  {% endif %}

  <h2 class="govuk-heading-l govuk-!-margin-top-7">Daily reward</h2>
  <p class="govuk-body">Claim your daily login reward to build your streak and earn bonus XP.</p>

  {% if achievements.status.dailySuccessMessage %}
    <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="daily-reward-status">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="daily-reward-status">Success</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ achievements.status.dailySuccessMessage }}</p>
      </div>
    </div>
  {% endif %}

  {% if achievements.status.dailyError %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            <li>{{ achievements.status.dailyError }}</li>
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  <dl class="govuk-summary-list govuk-!-margin-bottom-4">
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Current streak: {{ achievements.dailyReward.streak }} day(s)</dt>
      <dd class="govuk-summary-list__value">Claim today to earn {{ achievements.dailyReward.nextXp }} XP</dd>
    </div>
  </dl>

  {% if achievements.dailyReward.canClaim %}
    <form method="post" action="/achievements/daily-reward">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
      <button class="govuk-button" data-module="govuk-button" type="submit">Claim daily reward</button>
    </form>
  {% else %}
    <p class="govuk-body"><strong class="govuk-tag govuk-tag--green">Daily reward already claimed today.</strong></p>
  {% endif %}

  <h2 class="govuk-heading-l govuk-!-margin-top-7">Active challenges</h2>
  <p class="govuk-body">Complete these challenges to earn XP rewards.</p>

  {% if achievements.status.challengeSuccess %}
    <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="challenge-status">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="challenge-status">Success</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ achievements.status.challengeSuccess }}</p>
      </div>
    </div>
  {% endif %}

  {% if achievements.status.challengeError %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            <li>{{ achievements.status.challengeError }}</li>
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  {% if achievements.challenges.length %}
    <div class="nexus-alpha-card-list govuk-!-margin-bottom-8">
      {% for challenge in achievements.challenges %}
        <article class="nexus-alpha-card">
          <div class="nexus-alpha-module-row">
            <h3 class="govuk-heading-s govuk-!-margin-bottom-1">{{ challenge.title }}</h3>
            {% if challenge.claimed %}
              <strong class="govuk-tag govuk-tag--green">Reward claimed</strong>
            {% elif challenge.completed %}
              <strong class="govuk-tag govuk-tag--blue">Completed</strong>
            {% endif %}
          </div>
          {% if challenge.description %}
            <p class="govuk-body-s govuk-!-margin-bottom-1">{{ challenge.description }}</p>
          {% endif %}
          <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">
            {{ challenge.current }} of {{ challenge.target }}
            &middot; Reward: {{ challenge.rewardXp }} XP
            {% if challenge.daysRemaining > 0 %}&middot; {{ challenge.daysRemaining }} day(s) left{% endif %}
          </p>
          <span class="govuk-body-s govuk-!-margin-right-2">{{ challenge.percent }}%</span>
          <progress max="100" value="{{ challenge.percent }}" aria-label="{{ challenge.percent }}%">{{ challenge.percent }}%</progress>
          {% if challenge.claimable %}
            <form method="post" action="/achievements/challenges/{{ challenge.id }}/claim" class="govuk-!-margin-top-2">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}">
              <button class="govuk-button govuk-!-margin-bottom-0" data-module="govuk-button" type="submit">Claim reward</button>
            </form>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% else %}
    <div class="govuk-inset-text">
      <p class="govuk-body">There are no active challenges right now.</p>
    </div>
  {% endif %}

  <h2 class="govuk-heading-l govuk-!-margin-top-7">Your badges</h2>
  {% if achievements.earnedBadges.length %}
    <div class="nexus-alpha-card-list">
      {% for badge in achievements.earnedBadges %}
        <article class="nexus-alpha-card">
          <h3 class="govuk-heading-s govuk-!-margin-bottom-1">{% if badge.icon %}{{ badge.icon }} {% endif %}{{ badge.name }}</h3>
          {% if badge.message %}
            <p class="govuk-body-s govuk-!-margin-bottom-0">{{ badge.message }}</p>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% else %}
    <div class="govuk-inset-text">
      <p class="govuk-body">You have not earned any badges yet. Take part in the community to start earning them.</p>
    </div>
  {% endif %}

  {% if achievements.badgeProgress.length %}
    <h2 class="govuk-heading-l govuk-!-margin-top-7">Almost there</h2>
    {% for badge in achievements.badgeProgress %}
      <div class="govuk-!-margin-bottom-3">
        <p class="govuk-body govuk-!-margin-bottom-1">{% if badge.icon %}{{ badge.icon }} {% endif %}{{ badge.name }} - {{ badge.remaining }} to go</p>
        <span class="govuk-body-s govuk-!-margin-right-2">{{ badge.percent }}%</span>
        <progress max="100" value="{{ badge.percent }}" aria-label="{{ badge.percent }}%">{{ badge.percent }}%</progress>
      </div>
    {% endfor %}
  {% endif %}
{% endblock %}
