{% extends "layouts/base.njk" %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">{{ errorTitle or t("error_pages.404_title") }}</h1>
      {% if errorMessage %}
        <p class="govuk-body">{{ errorMessage }}</p>
      {% else %}
        <p class="govuk-body">{{ t("error_pages.404_body") }}</p>
      {% endif %}
      <p class="govuk-body">
        <a href="{{ urlFor('/') }}" class="govuk-link">{{ t("error_pages.home_link") }}</a>
      </p>
    </div>
  </div>
{% endblock %}
