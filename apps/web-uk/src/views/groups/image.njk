{% extends "layouts/base.njk" %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% block mainContent %}
  <a class="govuk-back-link" href="{{ urlFor('/groups/' + (group.id | string)) }}">Back to group</a>

  <span class="govuk-caption-xl">Images for {{ group.name }}</span>
  <h1 class="govuk-heading-xl">Group images</h1>

  {% if statusBanner and statusBanner.type == "success" %}
    {{ govukNotificationBanner({
      type: "success",
      titleText: statusBanner.title,
      text: statusBanner.message
    }) }}
  {% elif statusBanner and statusBanner.type == "error" %}
    {{ govukErrorSummary({
      titleText: statusBanner.title,
      errorList: [
        {
          text: statusBanner.message,
          href: "#avatar-image"
        }
      ]
    }) }}
  {% endif %}

  <p class="govuk-body-l">Upload a group avatar and a cover image. Each upload replaces the current image.</p>

  <h2 class="govuk-heading-l">Group avatar</h2>
  <p class="govuk-body">A small square image shown next to the group name.</p>
  {% if group.imageUrl %}
    <p class="govuk-body">
      <img class="nexus-alpha-avatar" src="{{ group.imageUrl }}" alt="Current group avatar" width="96" height="96" loading="lazy" decoding="async">
    </p>
  {% else %}
    <div class="govuk-inset-text"><p class="govuk-body">No avatar has been set.</p></div>
  {% endif %}

  <form method="post" action="{{ urlFor('/groups/' + (group.id | string) + '/image') }}" enctype="multipart/form-data" class="govuk-!-margin-bottom-8" novalidate>
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    <input type="hidden" name="type" value="avatar">
    <div class="govuk-form-group">
      <label class="govuk-label" for="avatar-image">Upload a new avatar</label>
      <div id="avatar-image-hint" class="govuk-hint">Use a JPG, PNG, GIF or WEBP image.</div>
      <input class="govuk-file-upload" id="avatar-image" name="image" type="file" accept="image/jpeg,image/png,image/gif,image/webp" aria-describedby="avatar-image-hint" required>
    </div>
    <button class="govuk-button" data-module="govuk-button">Save avatar</button>
  </form>

  <h2 class="govuk-heading-l">Cover image</h2>
  <p class="govuk-body">A wide banner image shown at the top of the group page.</p>
  {% if group.coverImageUrl %}
    <p class="govuk-body">
      <img class="nexus-alpha-card-thumb" src="{{ group.coverImageUrl }}" alt="Current group cover image" width="320" height="180" loading="lazy" decoding="async">
    </p>
  {% else %}
    <div class="govuk-inset-text"><p class="govuk-body">No cover image has been set.</p></div>
  {% endif %}

  <form method="post" action="{{ urlFor('/groups/' + (group.id | string) + '/image') }}" enctype="multipart/form-data" novalidate>
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    <input type="hidden" name="type" value="cover">
    <div class="govuk-form-group">
      <label class="govuk-label" for="cover-image">Upload a new cover image</label>
      <div id="cover-image-hint" class="govuk-hint">Use a JPG, PNG, GIF or WEBP image.</div>
      <input class="govuk-file-upload" id="cover-image" name="image" type="file" accept="image/jpeg,image/png,image/gif,image/webp" aria-describedby="cover-image-hint" required>
    </div>
    <button class="govuk-button" data-module="govuk-button">Save cover image</button>
  </form>
{% endblock %}
