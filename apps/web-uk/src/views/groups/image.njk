{% extends "layouts/base.njk" %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% block mainContent %}
  <a class="govuk-back-link" href="{{ urlFor('/groups/' + (group.id | string)) }}">{{ t("govuk_alpha_groups.common.back_to_group") }}</a>

  <span class="govuk-caption-xl">{{ t("govuk_alpha_groups.image.caption", { group: group.name }) }}</span>
  <h1 class="govuk-heading-xl">{{ t("govuk_alpha_groups.image.title") }}</h1>

  {% if statusBanner and statusBanner.type == "success" %}
    {{ govukNotificationBanner({
      type: "success",
      titleText: statusBanner.title,
      text: statusBanner.message
    }) }}
  {% elif statusBanner and statusBanner.type == "error" %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">{{ statusBanner.title }}</h2>
        <div class="govuk-error-summary__body"><p class="govuk-body">{{ statusBanner.message }}</p></div>
      </div>
    </div>
  {% endif %}

  <p class="govuk-body-l">{{ t("govuk_alpha_groups.image.intro") }}</p>

  <h2 class="govuk-heading-l">{{ t("govuk_alpha_groups.image.avatar_heading") }}</h2>
  <p class="govuk-body">{{ t("govuk_alpha_groups.image.avatar_description") }}</p>
  {% if group.imageUrl %}
    <p class="govuk-body">
      <img class="nexus-alpha-avatar" src="{{ group.imageUrl }}" alt="{{ t('govuk_alpha_groups.image.avatar_current_alt') }}" width="96" height="96" loading="lazy" decoding="async">
    </p>
  {% else %}
    <div class="govuk-inset-text"><p class="govuk-body">{{ t("govuk_alpha_groups.image.avatar_none") }}</p></div>
  {% endif %}

  <form method="post" action="{{ urlFor('/groups/' + (group.id | string) + '/image') }}" enctype="multipart/form-data" class="govuk-!-margin-bottom-8" novalidate>
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    <input type="hidden" name="type" value="avatar">
    <div class="govuk-form-group">
      <label class="govuk-label" for="avatar-image">{{ t("govuk_alpha_groups.image.avatar_label") }}</label>
      <div id="avatar-image-hint" class="govuk-hint">{{ t("govuk_alpha_groups.image.avatar_hint") }}</div>
      <input class="govuk-file-upload" id="avatar-image" name="image" type="file" accept="image/jpeg,image/png,image/gif,image/webp" aria-describedby="avatar-image-hint" required>
    </div>
    <button class="govuk-button" data-module="govuk-button">{{ t("govuk_alpha_groups.image.avatar_submit") }}</button>
  </form>

  <h2 class="govuk-heading-l">{{ t("govuk_alpha_groups.image.cover_heading") }}</h2>
  <p class="govuk-body">{{ t("govuk_alpha_groups.image.cover_description") }}</p>
  {% if group.coverImageUrl %}
    <p class="govuk-body">
      <img class="nexus-alpha-card-thumb" src="{{ group.coverImageUrl }}" alt="{{ t('govuk_alpha_groups.image.cover_current_alt') }}" width="320" height="180" loading="lazy" decoding="async">
    </p>
  {% else %}
    <div class="govuk-inset-text"><p class="govuk-body">{{ t("govuk_alpha_groups.image.cover_none") }}</p></div>
  {% endif %}

  <form method="post" action="{{ urlFor('/groups/' + (group.id | string) + '/image') }}" enctype="multipart/form-data" novalidate>
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    <input type="hidden" name="type" value="cover">
    <div class="govuk-form-group">
      <label class="govuk-label" for="cover-image">{{ t("govuk_alpha_groups.image.cover_label") }}</label>
      <div id="cover-image-hint" class="govuk-hint">{{ t("govuk_alpha_groups.image.cover_hint") }}</div>
      <input class="govuk-file-upload" id="cover-image" name="image" type="file" accept="image/jpeg,image/png,image/gif,image/webp" aria-describedby="cover-image-hint" required>
    </div>
    <button class="govuk-button" data-module="govuk-button">{{ t("govuk_alpha_groups.image.cover_submit") }}</button>
  </form>
{% endblock %}
