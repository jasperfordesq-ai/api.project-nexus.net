{% extends "layouts/base.njk" %}
{% block mainContent %}
  <a class="govuk-back-link" href="{{ urlFor('/groups/' + (group.id | string) + '/announcements') }}">{{ t("govuk_alpha_groups.announcements.back_to_announcements") }}</a>

  <span class="govuk-caption-xl">{{ group.name }}</span>
  <h1 class="govuk-heading-xl">{{ t("govuk_alpha_groups.announcements.edit_heading") }}</h1>

  {% if statusBanner and statusBanner.type == "error" %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">{{ statusBanner.title }}</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list"><li>{{ statusBanner.message }}</li></ul>
        </div>
      </div>
    </div>
  {% endif %}

  <form method="post" action="{{ urlFor('/groups/' + (group.id | string) + '/announcements/' + (announcement.id | string) + '/edit') }}" novalidate>
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    <div class="govuk-form-group{% if statusBanner and statusBanner.href == '#ann-title' %} govuk-form-group--error{% endif %}">
      <label class="govuk-label govuk-label--s" for="edit-ann-title">{{ t("govuk_alpha_groups.announcements.title_label") }}</label>
      <div id="edit-ann-title-hint" class="govuk-hint">{{ t("govuk_alpha_groups.announcements.title_hint") }}</div>
      {% if statusBanner and statusBanner.href == '#ann-title' %}
        <p class="govuk-error-message" id="edit-ann-title-error"><span class="govuk-visually-hidden">{{ t("govuk_alpha.states.error_prefix") }}</span> {{ statusBanner.message }}</p>
      {% endif %}
      <input class="govuk-input{% if statusBanner and statusBanner.href == '#ann-title' %} govuk-input--error{% endif %}" id="edit-ann-title" name="title" type="text" maxlength="255" aria-describedby="edit-ann-title-hint{% if statusBanner and statusBanner.href == '#ann-title' %} edit-ann-title-error{% endif %}" value="{{ announcement.title }}">
    </div>

    <div class="govuk-form-group{% if statusBanner and statusBanner.href == '#ann-content' %} govuk-form-group--error{% endif %}">
      <label class="govuk-label govuk-label--s" for="edit-ann-content">{{ t("govuk_alpha_groups.announcements.content_label") }}</label>
      <div id="edit-ann-content-hint" class="govuk-hint">{{ t("govuk_alpha_groups.announcements.content_hint") }}</div>
      {% if statusBanner and statusBanner.href == '#ann-content' %}
        <p class="govuk-error-message" id="edit-ann-content-error"><span class="govuk-visually-hidden">{{ t("govuk_alpha.states.error_prefix") }}</span> {{ statusBanner.message }}</p>
      {% endif %}
      <textarea class="govuk-textarea{% if statusBanner and statusBanner.href == '#ann-content' %} govuk-textarea--error{% endif %}" id="edit-ann-content" name="content" rows="5" aria-describedby="edit-ann-content-hint{% if statusBanner and statusBanner.href == '#ann-content' %} edit-ann-content-error{% endif %}">{{ announcement.content }}</textarea>
    </div>

    <div class="govuk-form-group">
      <fieldset class="govuk-fieldset">
        <div class="govuk-checkboxes" data-module="govuk-checkboxes">
          <div class="govuk-checkboxes__item">
            <input class="govuk-checkboxes__input" id="edit-ann-is-pinned" name="is_pinned" type="checkbox" value="1"{% if announcement.isPinned %} checked{% endif %} aria-describedby="edit-ann-is-pinned-hint">
            <label class="govuk-label govuk-checkboxes__label" for="edit-ann-is-pinned">{{ t("govuk_alpha_groups.announcements.is_pinned_label") }}</label>
            <div id="edit-ann-is-pinned-hint" class="govuk-hint govuk-checkboxes__hint">{{ t("govuk_alpha_groups.announcements.is_pinned_hint") }}</div>
          </div>
        </div>
      </fieldset>
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--s" for="edit-ann-expires-at">{{ t("govuk_alpha_groups.announcements.expires_at_label") }}</label>
      <div id="edit-ann-expires-at-hint" class="govuk-hint">{{ t("govuk_alpha_groups.announcements.expires_at_hint") }}</div>
      <input class="govuk-input govuk-input--width-10" id="edit-ann-expires-at" name="expires_at" type="date" aria-describedby="edit-ann-expires-at-hint" value="{{ announcement.expiresAtInput }}">
    </div>

    <button type="submit" class="govuk-button" data-module="govuk-button">{{ t("govuk_alpha_groups.announcements.submit_edit") }}</button>

    <a class="govuk-button govuk-button--secondary govuk-!-margin-left-3" href="{{ urlFor('/groups/' + (group.id | string) + '/announcements') }}">{{ t("govuk_alpha_groups.announcements.back_to_announcements") }}</a>
  </form>
{% endblock %}
