{% extends "layouts/base.njk" %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block mainContent %}
  <a class="govuk-back-link" href="{{ urlFor('/groups/' + (group.id | string) + '/announcements') }}">Back to announcements</a>

  <span class="govuk-caption-xl">{{ group.name }}</span>
  <h1 class="govuk-heading-xl">Edit announcement</h1>

  {% if statusBanner and statusBanner.type == "error" %}
    {{ govukErrorSummary({
      titleText: statusBanner.title,
      errorList: [
        {
          text: statusBanner.message,
          href: statusBanner.href or "#edit-ann-title"
        }
      ]
    }) }}
  {% endif %}

  <form method="post" action="{{ urlFor('/groups/' + (group.id | string) + '/announcements/' + (announcement.id | string) + '/edit') }}" novalidate>
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    <div class="govuk-form-group{% if statusBanner and statusBanner.href == '#ann-title' %} govuk-form-group--error{% endif %}">
      <label class="govuk-label govuk-label--s" for="edit-ann-title">Title</label>
      <div id="edit-ann-title-hint" class="govuk-hint">A short summary of the announcement (max 255 characters).</div>
      {% if statusBanner and statusBanner.href == '#ann-title' %}
        <p class="govuk-error-message" id="edit-ann-title-error"><span class="govuk-visually-hidden">Error:</span> {{ statusBanner.message }}</p>
      {% endif %}
      <input class="govuk-input{% if statusBanner and statusBanner.href == '#ann-title' %} govuk-input--error{% endif %}" id="edit-ann-title" name="title" type="text" maxlength="255" aria-describedby="edit-ann-title-hint{% if statusBanner and statusBanner.href == '#ann-title' %} edit-ann-title-error{% endif %}" value="{{ announcement.title }}">
    </div>

    <div class="govuk-form-group{% if statusBanner and statusBanner.href == '#ann-content' %} govuk-form-group--error{% endif %}">
      <label class="govuk-label govuk-label--s" for="edit-ann-content">Content</label>
      <div id="edit-ann-content-hint" class="govuk-hint">The full text of the announcement.</div>
      {% if statusBanner and statusBanner.href == '#ann-content' %}
        <p class="govuk-error-message" id="edit-ann-content-error"><span class="govuk-visually-hidden">Error:</span> {{ statusBanner.message }}</p>
      {% endif %}
      <textarea class="govuk-textarea{% if statusBanner and statusBanner.href == '#ann-content' %} govuk-textarea--error{% endif %}" id="edit-ann-content" name="content" rows="5" aria-describedby="edit-ann-content-hint{% if statusBanner and statusBanner.href == '#ann-content' %} edit-ann-content-error{% endif %}">{{ announcement.content }}</textarea>
    </div>

    <div class="govuk-form-group">
      <fieldset class="govuk-fieldset">
        <div class="govuk-checkboxes" data-module="govuk-checkboxes">
          <div class="govuk-checkboxes__item">
            <input class="govuk-checkboxes__input" id="edit-ann-is-pinned" name="is_pinned" type="checkbox" value="1"{% if announcement.isPinned %} checked{% endif %} aria-describedby="edit-ann-is-pinned-hint">
            <label class="govuk-label govuk-checkboxes__label" for="edit-ann-is-pinned">Pin this announcement</label>
            <div id="edit-ann-is-pinned-hint" class="govuk-hint govuk-checkboxes__hint">Pinned announcements appear at the top of the list.</div>
          </div>
        </div>
      </fieldset>
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--s" for="edit-ann-expires-at">Expiry date (optional)</label>
      <div id="edit-ann-expires-at-hint" class="govuk-hint">Leave blank for no expiry. Format: YYYY-MM-DD.</div>
      <input class="govuk-input govuk-input--width-10" id="edit-ann-expires-at" name="expires_at" type="date" aria-describedby="edit-ann-expires-at-hint" value="{{ announcement.expiresAtInput }}">
    </div>

    <button type="submit" class="govuk-button" data-module="govuk-button">Save changes</button>

    <a class="govuk-button govuk-button--secondary govuk-!-margin-left-3" href="{{ urlFor('/groups/' + (group.id | string) + '/announcements') }}">Back to announcements</a>
  </form>
{% endblock %}
