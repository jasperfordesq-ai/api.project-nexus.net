{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a class="govuk-back-link" href="{{ urlFor('/groups/' + (group.id | string) + '/discussions') }}">{{ t("groups.discussions.back") }}</a>

  <span class="govuk-caption-l">{{ group.name }}</span>
  <h1 class="govuk-heading-xl">{{ t("groups.discussions.new_title") }}</h1>
  <p class="govuk-body-l">{{ t("groups.discussions.new_description") }}</p>

  {% if statusBanner and statusBanner.type == "error" %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">{{ statusBanner.title }}</h2>
        <div class="govuk-error-summary__body"><p class="govuk-body">{{ statusBanner.message }}</p></div>
      </div>
    </div>
  {% endif %}

  <form method="post" action="{{ urlFor('/groups/' + (group.id | string) + '/discussions/new') }}" novalidate>
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--m" for="title">{{ t("groups.discussions.title_label") }}</label>
      <div id="title-hint" class="govuk-hint">{{ t("groups.discussions.title_hint") }}</div>
      <input class="govuk-input" id="title" name="title" type="text" maxlength="255" aria-describedby="title-hint">
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--m" for="content">{{ t("groups.discussions.content_label") }}</label>
      <div id="content-hint" class="govuk-hint">{{ t("groups.discussions.content_hint") }}</div>
      <textarea class="govuk-textarea" id="content" name="content" rows="6" aria-describedby="content-hint"></textarea>
    </div>

    <button class="govuk-button" data-module="govuk-button">{{ t("groups.discussions.create_submit") }}</button>
  </form>
{% endblock %}
