{% extends "layouts/base.njk" %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block mainContent %}
  <a class="govuk-back-link" href="{{ urlFor('/groups/' + (group.id | string) + '/discussions') }}">{{ t("groups.discussions.back") }}</a>

  <span class="govuk-caption-l">{{ group.name }}</span>
  <h1 class="govuk-heading-xl">{{ t("groups.discussions.new_link") }}</h1>
  <p class="govuk-body-l">{{ t("groups.discussions.new_description") }}</p>

  {% if statusBanner and statusBanner.type == "error" %}
    {{ govukErrorSummary({
      titleText: statusBanner.title,
      errorList: [
        {
          text: statusBanner.message,
          href: "#content"
        }
      ]
    }) }}
  {% endif %}

  <form method="post" action="{{ urlFor('/groups/' + (group.id | string) + '/discussions/new') }}" novalidate>
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--m" for="title">{{ t("group_exchanges.form_title_label") }}</label>
      <div id="title-hint" class="govuk-hint">{{ t("groups.discussions.title_hint") }}</div>
      <input class="govuk-input" id="title" name="title" type="text" maxlength="255" aria-describedby="title-hint">
    </div>

    <div class="govuk-form-group{% if statusBanner and statusBanner.type == 'error' %} govuk-form-group--error{% endif %}">
      <label class="govuk-label govuk-label--m" for="content">Message</label>
      <div id="content-hint" class="govuk-hint">{{ t("groups.discussions.content_hint") }}</div>
      {% if statusBanner and statusBanner.type == "error" %}
        <p class="govuk-error-message" id="content-error"><span class="govuk-visually-hidden">{{ t("states.error_prefix") }}</span> {{ statusBanner.message }}</p>
      {% endif %}
      <textarea class="govuk-textarea{% if statusBanner and statusBanner.type == 'error' %} govuk-textarea--error{% endif %}" id="content" name="content" rows="6" aria-describedby="content-hint{% if statusBanner and statusBanner.type == 'error' %} content-error{% endif %}"></textarea>
    </div>

    <button class="govuk-button" data-module="govuk-button">{{ t("groups.discussions.create_submit") }}</button>
  </form>
{% endblock %}
