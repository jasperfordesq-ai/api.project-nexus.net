{% extends "layouts/base.njk" %}

{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/select/macro.njk" import govukSelect %}

{% block mainContent %}
  <span class="govuk-caption-xl">{{ t("groups.caption", { community: tenantName or serviceName }) }}</span>
  <h1 class="govuk-heading-xl">{{ t("groups.title") }}</h1>
  <p class="govuk-body-l">{{ t("groups.description") }}</p>

  {% if successMessage %}
    {% set notificationMessage = successMessage %}
    {% set notificationType = "success" %}
    {% include "partials/notification-banner.njk" %}
  {% endif %}

  {% if errorMessage %}
    {% set notificationMessage = errorMessage %}
    {% set notificationType = null %}
    {% include "partials/notification-banner.njk" %}
  {% endif %}

  <p class="govuk-body">
    <a href="{{ urlFor('/groups/new') }}" class="govuk-button" role="button" draggable="false" data-module="govuk-button">{{ t("polish_groups.create_group_cta") }}</a>
  </p>

  <form action="{{ urlFor('/groups') }}" method="get" class="govuk-!-margin-bottom-6">
    {{ govukInput({
      id: "q",
      name: "q",
      value: searchQuery,
      label: { text: t("groups.search_label") },
      hint: { text: t("groups.search_hint") },
      classes: "govuk-!-width-two-thirds"
    }) }}

    {{ govukSelect({
      id: "filter",
      name: "filter",
      label: { text: t("groups.filter_label") },
      items: [
        { value: "all", text: t("groups.filter_all"), selected: groupsFilter == "all" },
        { value: "joined", text: t("groups.filter_joined"), selected: groupsFilter == "joined" },
        { value: "public", text: t("groups.filter_public"), selected: groupsFilter == "public" },
        { value: "private", text: t("groups.filter_private"), selected: groupsFilter == "private" }
      ]
    }) }}

    <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">{{ t("actions.search") }}</button>
  </form>

  {% if groups.length == 0 %}
    <div class="govuk-inset-text"><p class="govuk-body">{{ t("groups.empty") }}</p></div>
  {% else %}
    <div class="nexus-alpha-card-list">
      {% for group in groups %}
        {% set isPrivate = group.visibility != "public" %}
        {% set memberCount = group.memberCount or group.member_count or 0 %}
        <article class="nexus-alpha-card">
          <div class="nexus-alpha-module-row">
            <h2 class="govuk-heading-s govuk-!-margin-bottom-1"><a class="govuk-link" href="{{ urlFor('/groups/' + (group.id | string)) }}">{{ group.name }}</a></h2>
            {{ govukTag({
              text: t("groups.visibility_private") if isPrivate else t("groups.visibility_public"),
              classes: "govuk-tag--grey" if isPrivate else "govuk-tag--green"
            }) }}
          </div>
          <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-2">{{ tc("groups.members_count", memberCount, { count: memberCount }) }}</p>
          {% if group.description %}
            <p class="govuk-body govuk-!-margin-bottom-0">{{ group.description | truncate(160) }}</p>
          {% endif %}
        </article>
      {% endfor %}
    </div>

    {% if pagination.hasMore and pagination.cursor %}
      <nav class="govuk-pagination govuk-!-margin-top-6" aria-label="{{ t('groups.pagination_label') }}">
        <div class="govuk-pagination__next">
          <a class="govuk-link govuk-pagination__link" href="{{ pagination.nextHref }}" rel="next">
            <span class="govuk-pagination__link-title">{{ t("polish_groups.pagination_next") }}</span>
            <svg class="govuk-pagination__icon govuk-pagination__icon--next" xmlns="http://www.w3.org/2000/svg" height="13" width="15" focusable="false" aria-hidden="true" viewBox="0 0 15 13">
              <path d="m8.107-0.0078125-1.4136 1.414 4.2926 4.293h-12.986v2h12.896l-4.1855 3.9766 1.377 1.4492 6.7441-6.4062-6.7246-6.7246z"/>
            </svg>
          </a>
        </div>
      </nav>
    {% endif %}
  {% endif %}
{% endblock %}
