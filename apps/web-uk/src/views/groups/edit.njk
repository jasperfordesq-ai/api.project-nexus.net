{% extends "layouts/base.njk" %}

{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% block beforeContent %}
  {{ super() }}
  {% set breadcrumbs = [
    { text: "Groups", href: urlFor("/groups") },
    { text: group.name, href: urlFor("/groups/" + (group.id | string)) },
    { text: t("jobs_t3.edit_button") }
  ] %}
  {% include "partials/breadcrumbs.njk" %}
{% endblock %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if errors and errors.length %}
        {{ govukErrorSummary({
          titleText: t("states.error_title"),
          errorList: errors
        }) }}
      {% endif %}

      <h1 class="govuk-heading-xl">{{ t("polish_groups.edit_link") }}</h1>

      <form method="post" action="{{ urlFor('/groups/' + (group.id | string) + '/edit') }}" novalidate data-validate-form>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        {{ govukInput({
          label: {
            text: t("groups.create.name_label"),
            classes: "govuk-label--m"
          },
          id: "name",
          name: "name",
          value: group.name,
          attributes: {
            "data-validate": "required maxLength:255",
            "data-label": "Group name"
          }
        }) }}

        {{ govukTextarea({
          label: {
            text: "Description",
            classes: "govuk-label--m"
          },
          hint: {
            text: "Describe what the group is about (optional)"
          },
          id: "description",
          name: "description",
          rows: 4,
          value: group.description if group.description else ""
        }) }}

        {{ govukRadios({
          name: "is_private",
          fieldset: {
            legend: {
              text: "Group visibility",
              classes: "govuk-fieldset__legend--m"
            }
          },
          items: [
            {
              value: "false",
              text: t("groups.visibility_public"),
              hint: { text: "Anyone can find and join this group" },
              checked: not (group.isPrivate or group.is_private)
            },
            {
              value: "true",
              text: "Private",
              hint: { text: "Only admins can add members" },
              checked: group.isPrivate or group.is_private
            }
          ]
        }) }}

        <div class="govuk-button-group">
          {{ govukButton({
            text: "Save changes"
          }) }}
          <a href="{{ urlFor('/groups/' + (group.id | string)) }}" class="govuk-link">{{ t("polish_federation.transfer_cancel") }}</a>
        </div>
      </form>

    </div>
  </div>
{% endblock %}
