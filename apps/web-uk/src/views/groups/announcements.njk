{% extends "layouts/base.njk" %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% block mainContent %}
  <a class="govuk-back-link" href="{{ urlFor('/groups/' + (group.id | string)) }}">{{ t("govuk_alpha_groups.announcements.back_to_group") }}</a>

  <span class="govuk-caption-xl">{{ t("govuk_alpha_groups.announcements.caption", { group: group.name }) }}</span>
  <h1 class="govuk-heading-xl">{{ t("govuk_alpha_groups.announcements.title") }}</h1>

  {% if statusBanner and statusBanner.type == "success" %}
    {{ govukNotificationBanner({
      type: "success",
      titleText: statusBanner.title,
      text: statusBanner.message
    }) }}
  {% elif statusBanner and statusBanner.type == "error" %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">{{ statusBanner.title }}</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list"><li>{{ statusBanner.message }}</li></ul>
        </div>
      </div>
    </div>
  {% endif %}

  {% if not announcements.length %}
    <p class="govuk-body">{{ t("govuk_alpha_groups.announcements.empty") }}</p>
  {% else %}
    {% for announcement in announcements %}
      <div class="govuk-summary-card">
        <div class="govuk-summary-card__title-wrapper">
          <h2 class="govuk-summary-card__title">
            {{ announcement.title }}
            {% if announcement.isPinned %}
              <strong class="govuk-tag govuk-tag--blue">{{ t("govuk_alpha_groups.announcements.pinned_tag") }}</strong>
            {% endif %}
            {% if announcement.isExpired %}
              <strong class="govuk-tag govuk-tag--grey">{{ t("govuk_alpha_groups.announcements.expired_tag") }}</strong>
            {% endif %}
          </h2>
          {% if isAdmin %}
            <ul class="govuk-summary-card__actions">
              <li class="govuk-summary-card__action">
                <a class="govuk-link" href="{{ urlFor('/groups/' + (group.id | string) + '/announcements/' + (announcement.id | string) + '/edit') }}" aria-label="{{ t('govuk_alpha_groups.announcements.edit_aria') }}">{{ t("govuk_alpha_groups.announcements.submit_edit") }}</a>
              </li>
              <li class="govuk-summary-card__action">
                <form method="post" action="{{ urlFor('/groups/' + (group.id | string) + '/announcements/' + (announcement.id | string) + '/pin') }}" style="display:inline">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <input type="hidden" name="is_pinned" value="{% if announcement.isPinned %}0{% else %}1{% endif %}">
                  <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button" aria-label="{% if announcement.isPinned %}{{ t('govuk_alpha_groups.announcements.unpin_aria') }}{% else %}{{ t('govuk_alpha_groups.announcements.pin_aria') }}{% endif %}">
                    {% if announcement.isPinned %}{{ t("govuk_alpha_groups.announcements.unpin_button") }}{% else %}{{ t("govuk_alpha_groups.announcements.pin_button") }}{% endif %}
                  </button>
                </form>
              </li>
              <li class="govuk-summary-card__action">
                <form method="post" action="{{ urlFor('/groups/' + (group.id | string) + '/announcements/' + (announcement.id | string) + '/delete') }}" style="display:inline">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <button type="submit" class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button" aria-label="{{ t('govuk_alpha_groups.announcements.delete_aria') }}">{{ t("govuk_alpha_groups.announcements.delete_confirm") }}</button>
                </form>
              </li>
            </ul>
          {% endif %}
        </div>
        <div class="govuk-summary-card__content">
          <p class="govuk-body">{{ announcement.content }}</p>
          {% if announcement.authorName or announcement.postedAtLabel %}
            <p class="govuk-body-s govuk-!-colour-secondary">{{ t("govuk_alpha_groups.announcements.by_line", { name: announcement.authorName, date: announcement.postedAtLabel }) }}</p>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  {% endif %}

  {% if isAdmin %}
    <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">
    <h2 class="govuk-heading-l">{{ t("govuk_alpha_groups.announcements.create_heading") }}</h2>

    <form method="post" action="{{ urlFor('/groups/' + (group.id | string) + '/announcements') }}" novalidate>
      <input type="hidden" name="_csrf" value="{{ csrfToken }}">

      <div class="govuk-form-group{% if statusBanner and statusBanner.href == '#ann-title' %} govuk-form-group--error{% endif %}">
        <label class="govuk-label govuk-label--s" for="ann-title">{{ t("govuk_alpha_groups.announcements.title_label") }}</label>
        <div id="ann-title-hint" class="govuk-hint">{{ t("govuk_alpha_groups.announcements.title_hint") }}</div>
        {% if statusBanner and statusBanner.href == '#ann-title' %}
          <p class="govuk-error-message" id="ann-title-error"><span class="govuk-visually-hidden">{{ t("states.error_prefix") }}</span> {{ statusBanner.message }}</p>
        {% endif %}
        <input class="govuk-input{% if statusBanner and statusBanner.href == '#ann-title' %} govuk-input--error{% endif %}" id="ann-title" name="title" type="text" maxlength="255" aria-describedby="ann-title-hint{% if statusBanner and statusBanner.href == '#ann-title' %} ann-title-error{% endif %}">
      </div>

      <div class="govuk-form-group{% if statusBanner and statusBanner.href == '#ann-content' %} govuk-form-group--error{% endif %}">
        <label class="govuk-label govuk-label--s" for="ann-content">{{ t("govuk_alpha_groups.announcements.content_label") }}</label>
        <div id="ann-content-hint" class="govuk-hint">{{ t("govuk_alpha_groups.announcements.content_hint") }}</div>
        {% if statusBanner and statusBanner.href == '#ann-content' %}
          <p class="govuk-error-message" id="ann-content-error"><span class="govuk-visually-hidden">{{ t("states.error_prefix") }}</span> {{ statusBanner.message }}</p>
        {% endif %}
        <textarea class="govuk-textarea{% if statusBanner and statusBanner.href == '#ann-content' %} govuk-textarea--error{% endif %}" id="ann-content" name="content" rows="5" aria-describedby="ann-content-hint{% if statusBanner and statusBanner.href == '#ann-content' %} ann-content-error{% endif %}"></textarea>
      </div>

      <div class="govuk-form-group">
        <fieldset class="govuk-fieldset">
          <div class="govuk-checkboxes" data-module="govuk-checkboxes">
            <div class="govuk-checkboxes__item">
              <input class="govuk-checkboxes__input" id="ann-is-pinned" name="is_pinned" type="checkbox" value="1" aria-describedby="ann-is-pinned-hint">
              <label class="govuk-label govuk-checkboxes__label" for="ann-is-pinned">{{ t("govuk_alpha_groups.announcements.is_pinned_label") }}</label>
              <div id="ann-is-pinned-hint" class="govuk-hint govuk-checkboxes__hint">{{ t("govuk_alpha_groups.announcements.is_pinned_hint") }}</div>
            </div>
          </div>
        </fieldset>
      </div>

      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--s" for="ann-expires-at">{{ t("govuk_alpha_groups.announcements.expires_at_label") }}</label>
        <div id="ann-expires-at-hint" class="govuk-hint">{{ t("govuk_alpha_groups.announcements.expires_at_hint") }}</div>
        <input class="govuk-input govuk-input--width-10" id="ann-expires-at" name="expires_at" type="date" aria-describedby="ann-expires-at-hint">
      </div>

      <button type="submit" class="govuk-button" data-module="govuk-button">{{ t("govuk_alpha_groups.announcements.submit_create") }}</button>
    </form>
  {% endif %}
{% endblock %}
