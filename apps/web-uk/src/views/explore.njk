{% extends "layouts/base.njk" %}

{% block mainContent %}
  <span class="govuk-caption-xl">{{ tenantName }}</span>
  <h1 class="govuk-heading-xl">Explore</h1>
  <p class="govuk-body-l">
    Find the main community spaces from one simpler accessible page.
  </p>

  <div class="nexus-alpha-card-list govuk-!-margin-top-6">
    {% for item in alphaExploreLinks %}
      <article class="nexus-alpha-card">
        <h2 class="govuk-heading-m govuk-!-margin-bottom-2">
          <a class="govuk-link" href="{{ item.href }}">{{ item.title }}</a>
        </h2>
        <p class="govuk-body govuk-!-margin-bottom-0">{{ item.description }}</p>
      </article>
    {% endfor %}
  </div>

  {% if recentListings and recentListings.length %}
    <h2 class="govuk-heading-l govuk-!-margin-top-8">Recent listings</h2>
    <ul class="govuk-list govuk-list--spaced govuk-!-margin-bottom-2">
      {% for listing in recentListings %}
        <li>
          {% if listing.href %}
            <a class="govuk-link" href="{{ listing.href }}">{{ listing.title }}</a>
          {% else %}
            {{ listing.title }}
          {% endif %}
          <strong class="govuk-tag {{ listing.tagClass }} govuk-!-margin-left-1">{{ listing.type }}</strong>
        </li>
      {% endfor %}
    </ul>
    <p class="govuk-body"><a class="govuk-link" href="/listings">View all listings</a></p>
  {% endif %}

  {% if upcomingEvents and upcomingEvents.length %}
    <h2 class="govuk-heading-l govuk-!-margin-top-6">Upcoming events</h2>
    <ul class="govuk-list govuk-list--spaced govuk-!-margin-bottom-2">
      {% for event in upcomingEvents %}
        <li>
          {% if event.href %}
            <a class="govuk-link" href="{{ event.href }}">{{ event.title }}</a>
          {% else %}
            {{ event.title }}
          {% endif %}
          {% if event.date %}<span class="govuk-body-s nexus-alpha-meta"> - {{ event.date | date }}</span>{% endif %}
        </li>
      {% endfor %}
    </ul>
    <p class="govuk-body"><a class="govuk-link" href="/events">View all events</a></p>
  {% endif %}
{% endblock %}
