{% extends "layouts/base.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <a class="govuk-back-link" href="{{ urlFor('/legal') }}">Back to legal</a>

      <span class="govuk-caption-l">{{ communityName }}</span>
      <h1 class="govuk-heading-xl">{% if document %}{{ document.title }}{% else %}{{ config.title }}{% endif %}</h1>

      {% if document %}
        {% if document.updatedLabel or document.versionNumber %}
          <p class="govuk-body-s nexus-alpha-meta">
            {% if document.updatedLabel %}Last updated: {{ document.updatedLabel }}{% endif %}
            {% if document.versionNumber %}{% if document.updatedLabel %} &middot; {% endif %}Version {{ document.versionNumber }}{% endif %}
          </p>
        {% endif %}
        <div class="legal-content govuk-body">
          {{ document.content | safe }}
        </div>
      {% else %}
        <div class="govuk-inset-text">A tailored version of this document has not been published for {{ communityName }} yet. The general policy below applies.</div>

        <p class="govuk-body">{{ config.fallbackIntro }}</p>

        {% if config.fallbackPoints %}
          {% if config.cookiesTypesTitle %}
            <h2 class="govuk-heading-m">{{ config.cookiesTypesTitle }}</h2>
          {% endif %}
          <ul class="govuk-list govuk-list--bullet">
            {% for point in config.fallbackPoints %}
              <li>{{ point }}</li>
            {% endfor %}
          </ul>
        {% endif %}

        {% if config.afterList %}
          <p class="govuk-body">{{ config.afterList }}</p>
        {% endif %}

        {% if config.sections %}
          {% for section in config.sections %}
            <h2 class="govuk-heading-m">{{ section.heading }}</h2>
            <p class="govuk-body">{{ section.body }}</p>
          {% endfor %}
        {% endif %}

        <p class="govuk-body">
          If you have a question about this document, please
          <a class="govuk-link" href="{{ urlFor('/contact') }}">contact us</a>.
        </p>
      {% endif %}
    </div>
  </div>
{% endblock %}
