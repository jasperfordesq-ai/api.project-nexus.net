{% extends "layouts/base.njk" %}

{% block content %}
  <span class="govuk-caption-xl">{{ tenant.name or tenant.slug or "Community" }}</span>
  <h1 class="govuk-heading-xl">{{ t("coupons.title") }}</h1>
  <p class="govuk-body-l">{{ t("coupons.description") }}</p>

  {% if coupons and coupons.length %}
    <div class="nexus-alpha-card-list">
      {% for coupon in coupons %}
        <article class="nexus-alpha-card">
          <div class="nexus-alpha-module-row">
            <h2 class="govuk-heading-s govuk-!-margin-bottom-1">
              <a class="govuk-link" href="{{ urlFor('/coupons/' + (coupon.id | string)) }}">{{ coupon.title }}</a>
            </h2>
            {% if coupon.discountLabel %}
              <strong class="govuk-tag govuk-tag--green">{{ coupon.discountLabel }}</strong>
            {% endif %}
          </div>

          {% if coupon.description %}
            <p class="govuk-body govuk-!-margin-bottom-2">{{ coupon.description | truncate(200) }}</p>
          {% endif %}

          {% if coupon.code %}
            <p class="govuk-body govuk-!-margin-bottom-1">Code: <strong>{{ coupon.code }}</strong></p>
          {% endif %}

          {% if coupon.validUntilText %}
            <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-0">Valid until {{ coupon.validUntilText }}</p>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% else %}
    <div class="govuk-inset-text">
      <p class="govuk-body">{{ t("coupons.empty") }}</p>
    </div>
  {% endif %}
{% endblock %}
