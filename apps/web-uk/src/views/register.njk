{% extends "layouts/base.njk" %}

{% block pageTitle %}{{ title }} - {{ serviceName }}{% endblock %}

{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if errors and errors.length %}
        {{ govukErrorSummary({
          titleText: t("states.error_title"),
          errorList: errors
        }) }}
      {% endif %}

      <h1 class="govuk-heading-xl">{{ title }}</h1>

      {% if registrationClosed %}
        <div class="govuk-notification-banner" data-module="govuk-notification-banner" role="region" aria-labelledby="registration-closed-title">
          <div class="govuk-notification-banner__header">
            <h2 class="govuk-notification-banner__title" id="registration-closed-title">{{ t("auth.registration_closed_title") }}</h2>
          </div>
          <div class="govuk-notification-banner__content">
            <p class="govuk-body">{{ t("auth.registration_closed_body") }}</p>
            <p class="govuk-body">
              <a class="govuk-link" href="{{ urlFor('/login') }}">{{ t("auth.registration_closed_login") }}</a>
            </p>
          </div>
        </div>
      {% else %}
        <p class="govuk-body-l">{{ t("auth.register_description", { community: tenantName or tenantSlug or serviceName }) }}</p>

        <form method="post" action="{{ urlFor('/register') }}" novalidate data-loading="{{ t('auth.register_action') }}">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">

          {# Laravel's single registration honeypot. Clipping avoids RTL overflow. #}
          <div aria-hidden="true" style="position:absolute;width:1px;height:1px;margin:-1px;padding:0;overflow:hidden;clip:rect(0 0 0 0);clip-path:inset(50%);white-space:nowrap;border:0;">
            <label for="website">{{ t("auth.honeypot_website_label") }}</label>
            <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" value="">
          </div>
          <input type="hidden" name="form_started_at" value="{{ formStartedAt }}">

          {{ govukRadios({
            idPrefix: "profile_type",
            name: "profile_type",
            fieldset: {
              legend: { text: t("auth.profile_type_label"), classes: "govuk-fieldset__legend--m" }
            },
            hint: { text: t("auth.profile_type_hint") },
            items: [
              {
                value: "individual",
                text: t("auth.profile_type_individual"),
                checked: (values.profile_type or "individual") == "individual"
              },
              {
                value: "organisation",
                text: t("auth.profile_type_organisation"),
                checked: values.profile_type == "organisation"
              }
            ],
            errorMessage: { text: fieldErrors.profile_type } if fieldErrors.profile_type else undefined
          }) }}

          {#
            Keep this field visible instead of using the GOV.UK conditional-radio
            macro. The macro adds aria-expanded to a radio during enhancement,
            which is not permitted for the radio role and fails the axe gate.
          #}
          {{ govukInput({
            label: { text: t("auth.organization_name_label") },
            id: "organization_name",
            name: "organization_name",
            autocomplete: "organization",
            value: values.organization_name,
            errorMessage: { text: fieldErrors.organization_name } if fieldErrors.organization_name else undefined,
            attributes: { maxlength: "255" }
          }) }}

          {% if requiresInviteCode %}
            {{ govukInput({
              label: { text: t("auth.invite_code_label"), classes: "govuk-label--m" },
              hint: { text: t("auth.invite_code_hint") },
              id: "invite_code",
              name: "invite_code",
              value: values.invite_code,
              errorMessage: { text: fieldErrors.invite_code } if fieldErrors.invite_code else undefined,
              attributes: { autocomplete: "off", required: "required" },
              classes: "govuk-input--width-10"
            }) }}
          {% endif %}

          {{ govukInput({
            label: { text: t("auth.first_name_label"), classes: "govuk-label--m" },
            id: "first_name",
            name: "first_name",
            autocomplete: "given-name",
            value: values.first_name,
            errorMessage: { text: fieldErrors.first_name } if fieldErrors.first_name else undefined,
            attributes: { required: "required", maxlength: "100" }
          }) }}

          {{ govukInput({
            label: { text: t("auth.last_name_label"), classes: "govuk-label--m" },
            id: "last_name",
            name: "last_name",
            autocomplete: "family-name",
            value: values.last_name,
            errorMessage: { text: fieldErrors.last_name } if fieldErrors.last_name else undefined,
            attributes: { required: "required", maxlength: "100" }
          }) }}

          {{ govukInput({
            label: { text: t("auth.phone_label"), classes: "govuk-label--m" },
            hint: { text: t("auth.phone_hint") },
            id: "phone",
            name: "phone",
            type: "tel",
            autocomplete: "tel",
            value: values.phone,
            errorMessage: { text: fieldErrors.phone } if fieldErrors.phone else undefined,
            attributes: { required: "required", maxlength: "30" }
          }) }}

          {{ govukInput({
            label: { text: t("auth.location_label"), classes: "govuk-label--m" },
            hint: { text: t("auth.location_hint") },
            id: "location",
            name: "location",
            autocomplete: "address-level2",
            value: values.location,
            errorMessage: { text: fieldErrors.location } if fieldErrors.location else undefined,
            attributes: { required: "required", maxlength: "255" }
          }) }}
          <input type="hidden" id="latitude" name="latitude" value="{{ values.latitude }}">
          <input type="hidden" id="longitude" name="longitude" value="{{ values.longitude }}">

          {{ govukInput({
            label: { text: t("auth.email_label"), classes: "govuk-label--m" },
            id: "email",
            name: "email",
            type: "email",
            autocomplete: "email",
            spellcheck: false,
            value: values.email,
            errorMessage: { text: fieldErrors.email } if fieldErrors.email else undefined,
            attributes: { required: "required", maxlength: "255" }
          }) }}

          {% if not tenantSlug %}
            {{ govukInput({
              label: { text: "Community code", classes: "govuk-label--m" },
              hint: { text: "Enter the code for your community" },
              id: "tenant_slug",
              name: "tenant_slug",
              value: values.tenant_slug,
              errorMessage: { text: fieldErrors.tenant_slug } if fieldErrors.tenant_slug else undefined,
              attributes: { required: "required" }
            }) }}
          {% else %}
            <input type="hidden" name="tenant_slug" value="{{ tenantSlug }}">
          {% endif %}

          {{ govukInput({
            label: { text: t("auth.password_label"), classes: "govuk-label--m" },
            hint: { text: t("auth.password_hint") },
            id: "password",
            name: "password",
            type: "password",
            autocomplete: "new-password",
            errorMessage: { text: fieldErrors.password } if fieldErrors.password else undefined,
            attributes: {
              required: "required",
              minlength: "12",
              "aria-describedby": "password-hint password-strength-msg"
            }
          }) }}
          <p id="password-strength-msg" class="govuk-body-s govuk-!-margin-top-2" aria-live="polite"></p>

          {{ govukInput({
            label: { text: t("auth.password_confirmation_label"), classes: "govuk-label--m" },
            id: "password_confirmation",
            name: "password_confirmation",
            type: "password",
            autocomplete: "new-password",
            errorMessage: { text: fieldErrors.password_confirmation } if fieldErrors.password_confirmation else undefined,
            attributes: { required: "required", minlength: "12" }
          }) }}

          <div class="govuk-form-group{% if fieldErrors.terms_accepted %} govuk-form-group--error{% endif %}">
            <fieldset class="govuk-fieldset"{% if fieldErrors.terms_accepted %} aria-describedby="terms_accepted-error"{% endif %}>
              <legend class="govuk-fieldset__legend govuk-visually-hidden">{{ t("auth.consents_legend") }}</legend>
              {% if fieldErrors.terms_accepted %}
                <p id="terms_accepted-error" class="govuk-error-message">
                  <span class="govuk-visually-hidden">{{ t("states.error_prefix") }}</span>
                  {{ fieldErrors.terms_accepted }}
                </p>
              {% endif %}
              <div class="govuk-checkboxes" data-module="govuk-checkboxes">
                <div class="govuk-checkboxes__item">
                  <input class="govuk-checkboxes__input" id="terms_accepted" name="terms_accepted" type="checkbox" value="1" required{% if values.terms_accepted %} checked{% endif %}>
                  <label class="govuk-label govuk-checkboxes__label" for="terms_accepted">
                    {% set termsLink %}<a class="govuk-link" href="{{ urlFor('/legal/terms') }}">{{ t("auth.terms_link_text") }}</a>{% endset %}
                    {% set privacyLink %}<a class="govuk-link" href="{{ urlFor('/legal/privacy') }}">{{ t("auth.privacy_link_text") }}</a>{% endset %}
                    {{ t("auth.terms_label", { terms: termsLink, privacy: privacyLink }) | safe }}
                  </label>
                </div>
                <div class="govuk-checkboxes__item">
                  <input class="govuk-checkboxes__input" id="newsletter_opt_in" name="newsletter_opt_in" type="checkbox" value="1"{% if values.newsletter_opt_in %} checked{% endif %}>
                  <label class="govuk-label govuk-checkboxes__label" for="newsletter_opt_in">{{ t("auth.newsletter_label") }}</label>
                </div>
              </div>
            </fieldset>
          </div>

          <p class="govuk-body-s">{{ t("auth.data_protection_notice") }}</p>

          {{ govukButton({ text: t("auth.register_action") }) }}
        </form>
      {% endif %}

      <p class="govuk-body govuk-!-margin-top-6">
        <a href="{{ urlFor('/login') }}" class="govuk-link">{{ t("auth.have_account") }}</a>
      </p>
    </div>
  </div>

  {% if not registrationClosed %}
    <script src="/js/password-strength.js" defer></script>
  {% endif %}
{% endblock %}
