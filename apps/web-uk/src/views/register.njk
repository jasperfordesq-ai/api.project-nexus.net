{% extends "layouts/base.njk" %}

{% block pageTitle %}{{ t("auth.register_title") }} - {{ serviceName }}{% endblock %}

{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if errors and errors.length %}
        {{ govukErrorSummary({
          titleText: t("states.error_title"),
          errorList: errors
        }) }}
      {% endif %}

      <h1 class="govuk-heading-xl">{{ t("auth.register_title") }}</h1>
      <p class="govuk-body-l">{{ t("auth.register_description", { community: tenantName or serviceName }) }}</p>

      <form method="post" action="{{ urlFor('/register') }}" novalidate data-validate-form data-loading="{{ t('auth.register_action') }}">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        {# Honeypot — hidden from real users (off-screen + aria-hidden + tabindex=-1)
           but auto-filled by form-spam bots. The Express route should drop submissions
           where `website` is non-empty and return the success page anyway so the bot
           can't tell it was rejected. Use clipping instead of a physical off-screen
           position so the hidden field cannot create horizontal overflow in RTL. #}
        <div aria-hidden="true" style="position:absolute;width:1px;height:1px;margin:-1px;padding:0;overflow:hidden;clip:rect(0 0 0 0);clip-path:inset(50%);white-space:nowrap;border:0;">
          <label for="website">{{ t("auth.honeypot_website_label") }}</label>
          <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" value="">
        </div>

        {# Cloudflare Turnstile — only rendered when TURNSTILE_SITE_KEY is configured.
           Without it the widget is omitted and the Express route's verifier short-
           circuits to true (dev mode). The widget emits a hidden cf-turnstile-response
           input that posts back with the form. #}
        {% if turnstileSiteKey %}
        <div class="govuk-form-group">
          <div class="cf-turnstile" data-sitekey="{{ turnstileSiteKey }}" data-theme="auto"></div>
        </div>
        <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
        {% endif %}

        {{ govukInput({
          label: {
            text: t("auth.first_name_label"),
            classes: "govuk-label--m"
          },
          id: "first_name",
          name: "first_name",
          autocomplete: "given-name",
          value: values.first_name if values else "",
          errorMessage: { text: fieldErrors.first_name } if fieldErrors.first_name else undefined,
          attributes: {
            "data-validate": "required",
            "data-label": t("auth.first_name_label")
          }
        }) }}

        {{ govukInput({
          label: {
            text: t("auth.last_name_label"),
            classes: "govuk-label--m"
          },
          id: "last_name",
          name: "last_name",
          autocomplete: "family-name",
          value: values.last_name if values else "",
          errorMessage: { text: fieldErrors.last_name } if fieldErrors.last_name else undefined,
          attributes: {
            "data-validate": "required",
            "data-label": t("auth.last_name_label")
          }
        }) }}

        {{ govukInput({
          label: {
            text: t("auth.email_label"),
            classes: "govuk-label--m"
          },
          id: "email",
          name: "email",
          type: "email",
          autocomplete: "email",
          spellcheck: false,
          value: values.email if values else "",
          errorMessage: { text: fieldErrors.email } if fieldErrors.email else undefined,
          attributes: {
            "data-validate": "required email",
            "data-label": t("auth.email_label")
          }
        }) }}

        {% if tenantSlug %}
          <input type="hidden" name="tenant_slug" value="{{ tenantSlug }}">
        {% else %}
          {{ govukInput({
            label: {
              text: "Community code",
              classes: "govuk-label--m"
            },
            hint: {
              text: "Enter the code for your community (e.g. 'acme')"
            },
            id: "tenant_slug",
            name: "tenant_slug",
            value: values.tenant_slug if values else "",
            errorMessage: { text: fieldErrors.tenant_slug } if fieldErrors.tenant_slug else undefined,
            attributes: {
              "data-validate": "required",
              "data-label": "Community code"
            }
          }) }}
        {% endif %}

        {{ govukInput({
          label: {
            text: t("auth.password_label"),
            classes: "govuk-label--m"
          },
          hint: {
            text: t("auth.password_hint")
          },
          id: "password",
          name: "password",
          type: "password",
          autocomplete: "new-password",
          errorMessage: { text: fieldErrors.password } if fieldErrors.password else undefined,
          attributes: {
            "data-validate": "required minLength:12",
            "data-label": t("auth.password_label"),
            "minlength": "12",
            "aria-describedby": "password-hint password-strength-msg"
          }
        }) }}
        <p id="password-strength-msg" class="govuk-body-s govuk-!-margin-top-2" aria-live="polite"></p>
        <script src="/js/password-strength.js" defer></script>

        {{ govukInput({
          label: {
            text: t("auth.password_confirmation_label"),
            classes: "govuk-label--m"
          },
          id: "confirm_password",
          name: "confirm_password",
          type: "password",
          autocomplete: "new-password",
          errorMessage: { text: fieldErrors.confirm_password } if fieldErrors.confirm_password else undefined,
          attributes: {
            "data-validate": "required matches:password",
            "data-label": t("auth.password_confirmation_label")
          }
        }) }}

        {{ govukButton({
          text: t("auth.register_action")
        }) }}
      </form>

      <p class="govuk-body govuk-!-margin-top-6">
        <a href="{{ urlFor('/login') }}" class="govuk-link">{{ t("auth.have_account") }}</a>
      </p>

    </div>
  </div>
{% endblock %}
