{% extends "layouts/base.njk" %}

{% block content %}
  <a class="govuk-back-link" href="{{ urlFor('/leaderboard') }}">Back to leaderboard</a>

  <span class="govuk-caption-xl">Leaderboard at {{ communityName }}</span>
  <h1 class="govuk-heading-xl">Competitive leaderboard</h1>
  <p class="govuk-body-l">See how members rank across experience points, volunteer hours, credits earned and NEXUS score.</p>

  <nav class="govuk-tabs govuk-!-margin-top-2 govuk-!-margin-bottom-4" aria-label="{{ t("leaderboard.title") }}">
    <h2 class="govuk-tabs__title">{{ t("leaderboard.title") }}</h2>
    <ul class="govuk-tabs__list">
      <li class="govuk-tabs__list-item govuk-tabs__list-item--selected">
        <a class="govuk-tabs__tab" href="{{ urlFor('/leaderboard/competitive') }}" aria-current="page">Competitive</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="{{ urlFor('/leaderboard/seasons') }}">Seasons</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="{{ urlFor('/leaderboard/journey') }}">My journey</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="{{ urlFor('/leaderboard/spotlight') }}">Member spotlight</a>
      </li>
    </ul>
  </nav>

  {% if competitive.season.hasSeason %}
    <div class="nexus-alpha-card govuk-!-margin-bottom-6">
      <h2 class="govuk-heading-m govuk-!-margin-bottom-1">Active season{% if competitive.season.seasonName %}: {{ competitive.season.seasonName }}{% endif %}</h2>
      <p class="govuk-body-s nexus-alpha-meta">
        {{ competitive.season.daysRemainingLabel }} &middot; {{ competitive.season.participantsLabel }}
      </p>
      {% if competitive.season.hasUserData %}
        <p class="govuk-body">Your season XP: {{ competitive.season.xpLabel }}</p>
      {% endif %}
      <a class="govuk-link" href="{{ urlFor('/leaderboard/seasons') }}">View all seasons</a>
    </div>
  {% endif %}

  <form method="get" action="{{ urlFor('/leaderboard/competitive') }}" data-alpha-auto-submit class="govuk-!-margin-bottom-6">
    <fieldset class="govuk-fieldset">
      <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
        <h2 class="govuk-fieldset__heading">Filter the leaderboard</h2>
      </legend>
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-one-half">
          <div class="govuk-form-group">
            <label class="govuk-label" for="type">Metric</label>
            <select class="govuk-select" id="type" name="type">
              {% for type in competitive.types %}
                <option value="{{ type.value }}"{% if type.value == competitive.type %} selected{% endif %}>{{ type.label }}</option>
              {% endfor %}
            </select>
          </div>
        </div>
        <div class="govuk-grid-column-one-half">
          <div class="govuk-form-group">
            <label class="govuk-label" for="period">{{ t("leaderboard.period_label") }}</label>
            <select class="govuk-select" id="period" name="period">
              {% for period in competitive.periods %}
                <option value="{{ period.value }}"{% if period.value == competitive.period %} selected{% endif %}>{{ period.label }}</option>
              {% endfor %}
            </select>
          </div>
        </div>
      </div>
      <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">Update leaderboard</button>
    </fieldset>
  </form>

  <div class="govuk-inset-text">
    {% if competitive.hasYourRank %}
      Your rank: {{ competitive.yourRank }}
    {% else %}
      You are not yet ranked for this metric.
    {% endif %}
  </div>

  {% if competitive.rows.length %}
    <p class="govuk-body-s nexus-alpha-meta">{{ competitive.countLabel }}</p>
    <table class="govuk-table">
      <caption class="govuk-table__caption govuk-table__caption--s govuk-visually-hidden">{{ competitive.type }}</caption>
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header govuk-table__header--numeric">{{ t("leaderboard.rank_column") }}</th>
          <th scope="col" class="govuk-table__header">Member</th>
          <th scope="col" class="govuk-table__header govuk-table__header--numeric">Score</th>
        </tr>
      </thead>
      <tbody class="govuk-table__body">
        {% for row in competitive.rows %}
          <tr class="govuk-table__row {% if row.isCurrentUser %}nexus-alpha-row--active{% endif %}">
            <td class="govuk-table__cell govuk-table__cell--numeric">{{ row.rank }}</td>
            <td class="govuk-table__cell">
              {% if row.href %}
                <a class="govuk-link" href="{{ urlFor(row.href) }}">{{ row.name }}</a>
              {% else %}
                {{ row.name }}
              {% endif %}
              {% if row.isCurrentUser %}<strong class="govuk-tag govuk-tag--blue">You</strong>{% endif %}
            </td>
            <td class="govuk-table__cell govuk-table__cell--numeric">{{ row.scoreLabel }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>

    {% if competitive.hasMore %}
      <a class="govuk-button govuk-button--secondary" data-module="govuk-button" role="button" href="{{ urlFor('/leaderboard/competitive?type=' + competitive.type + '&period=' + competitive.period + '&limit=' + (competitive.nextLimit | string) + '#leaderboard-end') }}">{{ t("federation.members_browse.load_more") }}</a>
    {% endif %}
    <span id="leaderboard-end" tabindex="-1"></span>
  {% else %}
    <div class="govuk-inset-text">
      <p class="govuk-body">There are no ranked members for this metric yet.</p>
    </div>
  {% endif %}
{% endblock %}
