{% extends "layouts/base.njk" %}

{% block mainContent %}
  <span class="govuk-caption-xl">{{ tenantName }}</span>
  <h1 class="govuk-heading-xl">Volunteering</h1>
  <p class="govuk-body-l">{{ t("volunteering.description") }}</p>

  <p class="govuk-body govuk-!-margin-bottom-6">
    <a class="govuk-link govuk-link--no-visited-state" href="{{ urlFor('/organisations') }}">{{ t("vol_org.browse_link") }}</a>
  </p>

  <div class="govuk-inset-text" role="note" aria-labelledby="how-it-works-heading">
    <h2 class="govuk-heading-s govuk-!-margin-bottom-2" id="how-it-works-heading">How volunteering works</h2>
    <ol class="govuk-list govuk-list--number govuk-!-margin-bottom-0">
      <li>Find an opportunity that suits you.</li>
      <li>Apply, and tell the organiser about yourself.</li>
      <li>Once you are accepted, log the hours you give.</li>
      <li>The organisation reviews and approves your hours.</li>
      <li>You receive 1 time credit for every hour - added straight to your wallet.</li>
    </ol>
  </div>

  {% if authRequired %}
    <div class="govuk-notification-banner" data-module="govuk-notification-banner" role="region" aria-labelledby="volunteering-auth-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="volunteering-auth-title">Sign in required</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-body">{{ t("volunteering.auth_required_detail") }}</p>
      </div>
    </div>
  {% else %}
    <nav class="govuk-!-margin-top-6 govuk-!-margin-bottom-4" aria-label="{{ t('volunteering.tabs_title') }}">
      <ul class="govuk-list govuk-list--inline">
        <li><a class="govuk-link" href="{{ urlFor('/volunteering') }}"{% if selectedTab == 'opportunities' %} aria-current="page"{% endif %}>{{ t("volunteering.tabs.opportunities") }}</a></li>
        <li><a class="govuk-link" href="{{ urlFor('/volunteering?tab=applications') }}"{% if selectedTab == 'applications' %} aria-current="page"{% endif %}>{{ t("volunteering.tabs.applications") }}</a></li>
        <li><a class="govuk-link" href="{{ urlFor('/volunteering/recommended-shifts') }}">{{ t("volunteering.tabs.recommended") }}</a></li>
        <li><a class="govuk-link" href="{{ urlFor('/volunteering/hours') }}">{{ t("volunteering.tabs.hours") }}</a></li>
      </ul>
    </nav>
  {% endif %}

  {% if not authRequired and selectedTab == 'applications' %}
    {% if status == 'application-withdrawn' %}
      <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="application-status-title">
        <div class="govuk-notification-banner__header">
          <h2 class="govuk-notification-banner__title" id="application-status-title">{{ t("states.success_title") }}</h2>
        </div>
        <div class="govuk-notification-banner__content">
          <p class="govuk-notification-banner__heading">{{ t("volunteering.application_withdrawn") }}</p>
        </div>
      </div>
    {% endif %}

    <h2 class="govuk-heading-l">{{ t("volunteering.applications_title") }}</h2>
    <form method="get" action="{{ urlFor('/volunteering') }}" class="govuk-!-margin-bottom-6">
      <input type="hidden" name="tab" value="applications">
      <div class="govuk-form-group">
        <label class="govuk-label" for="app_status">{{ t("volunteering.application_status_label") }}</label>
        <select class="govuk-select" id="app_status" name="app_status">
          <option value="">{{ t("volunteering.application_status_all") }}</option>
          {% for value in ["pending", "approved", "declined", "withdrawn"] %}
            <option value="{{ value }}"{% if applicationStatus == value %} selected{% endif %}>{{ t("volunteering.status_values." ~ value) }}</option>
          {% endfor %}
        </select>
      </div>
      <div class="govuk-button-group">
        <button class="govuk-button govuk-button--secondary" data-module="govuk-button">{{ t("actions.apply_filters") }}</button>
        {% if applicationStatus %}<a class="govuk-link" href="{{ urlFor('/volunteering?tab=applications') }}">{{ t("actions.clear_filters") }}</a>{% endif %}
      </div>
    </form>

    {% if applications.length %}
      <div class="nexus-alpha-card-list">
        {% for application in applications %}
          {% set opportunity = application.opportunity or {} %}
          {% set organization = application.organization or {} %}
          {% set applicationState = application.status or "pending" %}
          <article class="nexus-alpha-card">
            <h3 class="govuk-heading-m govuk-!-margin-bottom-2">
              {% if opportunity.id %}<a class="govuk-link" href="{{ urlFor('/volunteering/opportunities/' ~ opportunity.id) }}">{{ opportunity.title or t("volunteering.detail_title") }}</a>{% else %}{{ opportunity.title or t("volunteering.detail_title") }}{% endif %}
            </h3>
            <strong class="govuk-tag{% if applicationState == 'approved' %} govuk-tag--green{% elseif applicationState == 'pending' %} govuk-tag--yellow{% elseif applicationState == 'declined' %} govuk-tag--red{% else %} govuk-tag--grey{% endif %}">{{ t("volunteering.status_values." ~ applicationState) }}</strong>
            <dl class="govuk-summary-list govuk-!-margin-top-4 govuk-!-margin-bottom-0">
              {% if organization.name %}<div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("volunteering.organization") }}</dt><dd class="govuk-summary-list__value">{{ organization.name }}</dd></div>{% endif %}
              {% if opportunity.location %}<div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("volunteering.location") }}</dt><dd class="govuk-summary-list__value">{{ opportunity.location }}</dd></div>{% endif %}
              {% if application.appliedOnLabel %}<div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("volunteering.applied_on") }}</dt><dd class="govuk-summary-list__value">{{ application.appliedOnLabel }}</dd></div>{% endif %}
            </dl>
            {% if applicationState == 'pending' and application.id %}
              <form method="post" action="{{ urlFor('/volunteering/applications/' ~ application.id ~ '/withdraw') }}" class="govuk-!-margin-top-3">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("volunteering.withdraw_application") }}<span class="govuk-visually-hidden"> {{ t("volunteering.withdraw_application_for", { title: opportunity.title or '' }) }}</span></button>
              </form>
            {% endif %}
          </article>
        {% endfor %}
      </div>
      {% if applicationsMeta.has_more and applicationsMeta.cursor %}
        <nav class="govuk-pagination govuk-pagination--block govuk-!-margin-top-6" aria-label="{{ t('volunteering.applications_pagination_label') }}">
          <div class="govuk-pagination__next"><a class="govuk-link govuk-pagination__link" href="{{ urlFor(applicationsLoadMoreHref) }}" rel="next"><span class="govuk-pagination__link-title">{{ t("actions.load_more") }}</span><span class="govuk-visually-hidden">:</span> <span class="govuk-pagination__link-label">{{ t("volunteering.applications_more_label") }}</span></a></div>
        </nav>
      {% endif %}
    {% else %}
      <div class="govuk-inset-text">
        <p class="govuk-body">{{ t("volunteering.empty_applications") }}</p>
        <p class="govuk-body govuk-!-margin-bottom-0">{{ t("vol_clarity.empty_applications_cta") }}</p>
        <a class="govuk-button govuk-button--secondary govuk-!-margin-top-2 govuk-!-margin-bottom-0" href="{{ urlFor('/volunteering') }}">{{ t("vol_clarity.browse_opportunities") }}</a>
      </div>
    {% endif %}
  {% else %}
  <form method="get" action="{{ urlFor('/volunteering') }}" class="govuk-!-margin-bottom-7">
    <fieldset class="govuk-fieldset" aria-describedby="volunteering-filter-hint">
      <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
        <h2 class="govuk-fieldset__heading">{{ t("volunteering.filters_title") }}</h2>
      </legend>
      <div id="volunteering-filter-hint" class="govuk-hint">{{ t("volunteering.filters_hint") }}</div>

      <div class="govuk-form-group">
        <label class="govuk-label" for="q">{{ t("volunteering.search_label") }}</label>
        <div id="q-hint" class="govuk-hint">{{ t("volunteering.search_hint") }}</div>
        <input class="govuk-input govuk-!-width-two-thirds" id="q" name="q" type="search" value="{{ volunteeringQuery }}" aria-describedby="q-hint">
      </div>

      <div class="govuk-form-group">
        <label class="govuk-label" for="category_id">Category</label>
        <input class="govuk-input govuk-input--width-10" id="category_id" name="category_id" inputmode="numeric" value="{{ categoryId }}">
      </div>

      <div class="govuk-form-group">
        <div class="govuk-checkboxes" data-module="govuk-checkboxes">
          <div class="govuk-checkboxes__item">
            <input class="govuk-checkboxes__input" id="is_remote" name="is_remote" type="checkbox" value="1" {% if isRemote %}checked{% endif %}>
            <label class="govuk-label govuk-checkboxes__label" for="is_remote">{{ t("volunteering.remote_label") }}</label>
          </div>
        </div>
      </div>

      <div class="govuk-button-group">
        <button class="govuk-button" data-module="govuk-button" type="submit">Search</button>
        {% if volunteeringQuery or categoryId or isRemote %}
          <a class="govuk-link" href="{{ urlFor('/volunteering') }}">Clear filters</a>
        {% endif %}
      </div>
    </fieldset>
  </form>

  <h2 class="govuk-heading-l">Opportunities</h2>
  <p class="govuk-body nexus-alpha-result-count" aria-live="polite">
    {% if opportunities.length == 0 %}
      No opportunities shown
    {% elseif opportunities.length == 1 %}
      1 opportunity shown
    {% else %}
      {{ opportunities.length }} opportunities shown
    {% endif %}
  </p>

  {% if error %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2>
        <div class="govuk-error-summary__body">
          <p>{{ t("volunteering.error_detail") }}</p>
        </div>
      </div>
    </div>
  {% endif %}

  {% if opportunities and opportunities.length %}
    <div class="nexus-alpha-card-list">
      {% for opportunity in opportunities %}
        <article class="nexus-alpha-card">
          <h3 class="govuk-heading-m govuk-!-margin-bottom-2">
            <a class="govuk-link" href="{{ urlFor('/volunteering/opportunities/' ~ opportunity.id) }}">{{ opportunity.title or "Volunteering opportunity" }}</a>
          </h3>

          {% if opportunity.is_remote %}
            <strong class="govuk-tag govuk-tag--turquoise">Remote</strong>
          {% endif %}

          <dl class="nexus-alpha-inline-list govuk-!-margin-top-2">
            {% if opportunity.organizationName %}
              <div>
                <dt>{{ t("auth.profile_type_organisation") }}</dt>
                <dd>{{ opportunity.organizationName }}</dd>
              </div>
            {% endif %}
            {% if opportunity.location %}
              <div>
                <dt>Location</dt>
                <dd>{{ opportunity.location }}</dd>
              </div>
            {% endif %}
            {% if opportunity.categoryName %}
              <div>
                <dt>Category</dt>
                <dd>{{ opportunity.categoryName }}</dd>
              </div>
            {% endif %}
          </dl>

          {% if opportunity.summary %}
            <p class="govuk-body govuk-!-margin-top-3">{{ opportunity.summary }}</p>
          {% endif %}

          <ul class="govuk-list govuk-list--inline govuk-!-margin-bottom-0">
            <li><a class="govuk-link govuk-link--no-visited-state" href="{{ urlFor('/volunteering/opportunities/' ~ opportunity.id) }}">{{ t("actions.view_details") }}</a></li>
            <li><a class="govuk-link govuk-link--no-visited-state" href="{{ urlFor('/organisations/opportunities/' ~ opportunity.id ~ '/apply') }}">Apply to volunteer</a></li>
          </ul>
        </article>
      {% endfor %}
    </div>

    {% if hasMore and loadMoreHref %}
      <nav class="govuk-pagination govuk-pagination--block govuk-!-margin-top-6" aria-label="{{ t("volunteering.pagination_label") }}">
        <div class="govuk-pagination__next">
          <a class="govuk-link govuk-pagination__link" href="{{ urlFor(loadMoreHref) }}" rel="next">
            <span class="govuk-pagination__link-title">{{ t("actions.load_more") }}</span>
            <span class="govuk-visually-hidden">:</span>
            <span class="govuk-pagination__link-label">{{ t("volunteering.more_results_label") }}</span>
          </a>
        </div>
      </nav>
    {% endif %}
  {% else %}
    <div class="govuk-inset-text">
      <h2 class="govuk-heading-m">No opportunities found</h2>
      <p class="govuk-body">{{ t("volunteering.empty") }}</p>
      <p class="govuk-body govuk-!-margin-bottom-0">
        {% if volunteeringQuery or categoryId or isRemote %}
          No opportunities match your filters. Try widening your search or <a class="govuk-link" href="{{ urlFor('/volunteering') }}">clear filters</a>.
        {% else %}
          There are no opportunities listed right now. Check back soon, or follow the community feed for new openings.
        {% endif %}
      </p>
    </div>
  {% endif %}
  {% endif %}
{% endblock %}
