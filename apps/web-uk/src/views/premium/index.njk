{% extends "layouts/base.njk" %}

{% block mainContent %}
  {% if status %}
    {% if status.type == 'error' %}
      <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
        <div role="alert">
          <h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2>
          <div class="govuk-error-summary__body">
            <ul class="govuk-list govuk-error-summary__list"><li>{{ status.message }}</li></ul>
          </div>
        </div>
      </div>
    {% else %}
      <div class="govuk-inset-text"><p class="govuk-body">{{ status.message }}</p></div>
    {% endif %}
  {% endif %}

  <span class="govuk-caption-xl">{{ t("premium.caption", { community: tenantName }) }}</span>
  <h1 class="govuk-heading-xl">{{ t("premium.title") }}</h1>
  <p class="govuk-body-l">{{ t("premium.description") }}</p>

  {% if currentTierName %}
    <div class="govuk-inset-text">
      <h2 class="govuk-heading-s govuk-!-margin-bottom-1">{{ t("premium.current_plan_title") }}</h2>
      <p class="govuk-body govuk-!-margin-bottom-0">{{ t("premium.current_plan_notice", { name: currentTierName }) }}</p>
    </div>
  {% endif %}

  {% if not tiers or not tiers.length %}
    <div class="govuk-inset-text"><p class="govuk-body">{{ t("premium.empty") }}</p></div>
  {% else %}
    <div class="nexus-alpha-card-list">
      {% for tier in tiers %}
        <article class="nexus-alpha-card">
          <h2 class="govuk-heading-m govuk-!-margin-bottom-2">{{ tier.name }}</h2>
          {% if tier.description %}
            <p class="govuk-body">{{ tier.description }}</p>
          {% endif %}
          <p class="govuk-body govuk-!-margin-bottom-2">
            {% if tier.monthlyPrice %}<strong>{{ tier.monthlyPrice }}</strong> {{ t("premium.per_month") }}{% endif %}
            {% if tier.monthlyPrice and tier.yearlyPrice %} · {% endif %}
            {% if tier.yearlyPrice %}<strong>{{ tier.yearlyPrice }}</strong> {{ t("premium.per_year") }}{% endif %}
          </p>
          {% if tier.features and tier.features.length %}
            <ul class="govuk-list govuk-list--bullet">
              {% for feature in tier.features %}
                <li>{{ feature }}</li>
              {% endfor %}
            </ul>
          {% endif %}
          <form method="post" action="{{ urlFor('/premium/subscribe') }}">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <input type="hidden" name="tier_id" value="{{ tier.id }}">
            {% if tier.monthlyPrice and tier.yearlyPrice %}
              <div class="govuk-form-group">
                <fieldset class="govuk-fieldset">
                  <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">{{ t("polish_commerce.premium_interval_heading") }}</legend>
                  <div class="govuk-radios govuk-radios--small" data-module="govuk-radios">
                    <div class="govuk-radios__item">
                      <input class="govuk-radios__input" id="interval-{{ tier.id }}-monthly" name="interval" type="radio" value="monthly" checked>
                      <label class="govuk-label govuk-radios__label" for="interval-{{ tier.id }}-monthly">{{ t("polish_commerce.premium_interval_monthly") }} — {{ tier.monthlyPrice }}</label>
                    </div>
                    <div class="govuk-radios__item">
                      <input class="govuk-radios__input" id="interval-{{ tier.id }}-yearly" name="interval" type="radio" value="yearly">
                      <label class="govuk-label govuk-radios__label" for="interval-{{ tier.id }}-yearly">{{ t("polish_commerce.premium_interval_yearly") }} — {{ tier.yearlyPrice }}</label>
                    </div>
                  </div>
                </fieldset>
              </div>
            {% else %}
              <input type="hidden" name="interval" value="{{ tier.defaultInterval }}">
            {% endif %}
            <button class="govuk-button govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("premium.subscribe_button") }}</button>
          </form>
        </article>
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
