{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a href="{{ urlFor('/courses') }}" class="govuk-back-link">{{ t("courses.back") }}</a>

  <span class="govuk-caption-xl">Your courses at {{ tenantName }}</span>
  <h1 class="govuk-heading-xl">My learning</h1>
  <p class="govuk-body-l">Pick up where you left off with the courses you are enrolled in.</p>

  {% set activeTab = 'learning' %}
  {% include "courses/_nav.njk" %}

  {% if not enrollments or not enrollments.length %}
    <div class="govuk-inset-text">
      <p class="govuk-body">You are not enrolled in any courses yet. Browse the course library to get started.</p>
    </div>
    <p class="govuk-body">
      <a class="govuk-button" href="{{ urlFor('/courses') }}" role="button" draggable="false" data-module="govuk-button">Browse courses</a>
    </p>
  {% else %}
    <div class="nexus-alpha-card-list">
      {% for enrollment in enrollments %}
        <article class="nexus-alpha-card">
          <div class="nexus-alpha-listing-row">
            {% if enrollment.course.cover_image %}
              <div class="nexus-alpha-listing-row__media">
                <img class="nexus-alpha-card-thumb" src="{{ enrollment.course.cover_image }}" alt="{{ enrollment.course.title }}" width="120" height="90" loading="lazy" decoding="async">
              </div>
            {% endif %}
            <div class="nexus-alpha-listing-row__body">
              <div class="nexus-alpha-module-row">
                <h2 class="govuk-heading-s govuk-!-margin-bottom-1">{{ enrollment.course.title }}</h2>
                <strong class="govuk-tag {% if enrollment.completed %}govuk-tag--green{% else %}govuk-tag--blue{% endif %}">{{ enrollment.statusLabel }}</strong>
              </div>
              <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">{{ enrollment.percent }}% complete</p>
              <progress value="{{ enrollment.percent }}" max="100" aria-label="{{ enrollment.percent }}% complete">{{ enrollment.percent }}%</progress>
              <div class="nexus-alpha-actions govuk-!-margin-top-2">
                <a class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" href="{{ urlFor('/courses/' + (enrollment.course.id | string) + '/learn') }}" role="button" draggable="false" data-module="govuk-button">{% if enrollment.percent > 0 %}Resume{% else %}Start learning{% endif %}</a>
              </div>
            </div>
          </div>
        </article>
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
