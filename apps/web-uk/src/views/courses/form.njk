{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a class="govuk-back-link" href="{{ urlFor('/courses/instructor') }}">Back to courses you teach</a>

  {% set activeTab = 'teaching' %}
  {% include "courses/_nav.njk" %}

  {% if status %}
    {% if status.type == 'success' %}
      <div class="govuk-notification-banner govuk-notification-banner--success" role="alert" aria-labelledby="course-form-status" data-module="govuk-notification-banner">
        <div class="govuk-notification-banner__header">
          <h2 class="govuk-notification-banner__title" id="course-form-status">Success</h2>
        </div>
        <div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ status.message }}</p></div>
      </div>
    {% else %}
      <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
        <div role="alert">
          <h2 class="govuk-error-summary__title">There is a problem</h2>
          <div class="govuk-error-summary__body"><ul class="govuk-list govuk-error-summary__list"><li>{{ status.message }}</li></ul></div>
        </div>
      </div>
    {% endif %}
  {% endif %}

  <span class="govuk-caption-l">Teaching at {{ tenantName }}</span>
  <h1 class="govuk-heading-xl">{% if mode == 'edit' %}Edit your course{% else %}Create a course{% endif %}</h1>

  {% if mode == 'edit' and course.status != 'published' %}
    <p class="govuk-body">Your course is a draft. Publish it when you are ready for learners to enrol.</p>
  {% endif %}

  <form method="post" action="{{ urlFor(formAction) }}" novalidate>
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    <fieldset class="govuk-fieldset">
      <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
        <h2 class="govuk-fieldset__heading">About the course</h2>
      </legend>

      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--s" for="title">Course title</label>
        <div id="title-hint" class="govuk-hint">A clear, descriptive name for your course.</div>
        <input class="govuk-input" id="title" name="title" type="text" maxlength="200" value="{{ course.title if course.id else '' }}" aria-describedby="title-hint">
      </div>

      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--s" for="summary">Short summary <span class="govuk-hint govuk-!-display-inline">(optional)</span></label>
        <div id="summary-hint" class="govuk-hint">A one-line summary shown in the course catalogue.</div>
        <input class="govuk-input" id="summary" name="summary" type="text" maxlength="500" value="{{ course.summary }}" aria-describedby="summary-hint">
      </div>

      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--s" for="description">Description <span class="govuk-hint govuk-!-display-inline">(optional)</span></label>
        <div id="description-hint" class="govuk-hint">Explain what the course covers and who it is for.</div>
        <textarea class="govuk-textarea" id="description" name="description" rows="6" aria-describedby="description-hint">{{ course.description }}</textarea>
      </div>
    </fieldset>

    <fieldset class="govuk-fieldset govuk-!-margin-top-4">
      <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
        <h2 class="govuk-fieldset__heading">Settings</h2>
      </legend>

      <div class="govuk-form-group">
        <fieldset class="govuk-fieldset">
          <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Level</legend>
          <div class="govuk-radios govuk-radios--small" data-module="govuk-radios">
            {% for level in levels %}
              <div class="govuk-radios__item">
                <input class="govuk-radios__input" id="{% if loop.first %}level{% else %}level-{{ level.value }}{% endif %}" name="level" type="radio" value="{{ level.value }}"{% if course.level == level.value or (not course.level and level.value == 'beginner') %} checked{% endif %}>
                <label class="govuk-label govuk-radios__label" for="{% if loop.first %}level{% else %}level-{{ level.value }}{% endif %}">{{ level.label }}</label>
              </div>
            {% endfor %}
          </div>
        </fieldset>
      </div>

      <div class="govuk-form-group">
        <fieldset class="govuk-fieldset">
          <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Who can see this course?</legend>
          <div class="govuk-radios govuk-radios--small" data-module="govuk-radios">
            {% for visibility in visibilities %}
              <div class="govuk-radios__item">
                <input class="govuk-radios__input" id="{% if loop.first %}visibility{% else %}visibility-{{ visibility.value }}{% endif %}" name="visibility" type="radio" value="{{ visibility.value }}"{% if course.visibility == visibility.value %} checked{% endif %}>
                <label class="govuk-label govuk-radios__label" for="{% if loop.first %}visibility{% else %}visibility-{{ visibility.value }}{% endif %}">{{ visibility.label }}</label>
              </div>
            {% endfor %}
          </div>
        </fieldset>
      </div>

      <div class="govuk-form-group">
        <fieldset class="govuk-fieldset">
          <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">How do learners join?</legend>
          <div class="govuk-radios govuk-radios--small" data-module="govuk-radios">
            {% for enrollment in enrollmentTypes %}
              <div class="govuk-radios__item">
                <input class="govuk-radios__input" id="{% if loop.first %}enrollment_type{% else %}enrollment_type-{{ enrollment.value }}{% endif %}" name="enrollment_type" type="radio" value="{{ enrollment.value }}"{% if course.enrollmentType == enrollment.value %} checked{% endif %}>
                <label class="govuk-label govuk-radios__label" for="{% if loop.first %}enrollment_type{% else %}enrollment_type-{{ enrollment.value }}{% endif %}">{{ enrollment.label }}</label>
              </div>
            {% endfor %}
          </div>
        </fieldset>
      </div>

      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--s" for="credit_cost">Time credit cost</label>
        <div id="credit_cost-hint" class="govuk-hint">The number of time credits a learner pays to enrol. Leave as zero for a free course.</div>
        <input class="govuk-input govuk-input--width-5" id="credit_cost" name="credit_cost" type="text" inputmode="decimal" value="{{ course.creditCost or 0 }}" aria-describedby="credit_cost-hint">
      </div>

      {% if categories and categories.length %}
        <div class="govuk-form-group">
          <label class="govuk-label govuk-label--s" for="category_id">Category</label>
          <select class="govuk-select" id="category_id" name="category_id">
            <option value="">No category</option>
            {% for category in categories %}
              <option value="{{ category.id }}"{% if course.categoryId == category.id %} selected{% endif %}>{{ category.name }}</option>
            {% endfor %}
          </select>
        </div>
      {% endif %}
    </fieldset>

    <div class="govuk-button-group govuk-!-margin-top-4">
      <button class="govuk-button" data-module="govuk-button">{% if mode == 'edit' %}Save changes{% else %}Create course{% endif %}</button>
      <a class="govuk-link" href="{{ urlFor('/courses/instructor') }}">Cancel</a>
    </div>
  </form>

  {% if mode == 'edit' and course.id > 0 %}
    <h2 class="govuk-heading-m govuk-!-margin-top-8">Add your lessons</h2>
    <p class="govuk-body">Group your lessons into sections, then add lessons to each section. Learners work through them in order.</p>

    {% if (not builderSections or not builderSections.length) and (not builderUnsectioned or not builderUnsectioned.length) %}
      <p class="govuk-inset-text">You have not added any sections yet. Add a section to start building your course.</p>
    {% else %}
      {% for section in builderSections %}
        <div class="nexus-alpha-card govuk-!-margin-bottom-4">
          <h3 class="govuk-heading-s govuk-!-margin-bottom-2">{{ section.title }}</h3>
          {% if not section.lessons or not section.lessons.length %}
            <p class="govuk-body-s nexus-alpha-meta">No lessons in this section yet.</p>
          {% else %}
            <ul class="govuk-list">
              {% for lesson in section.lessons %}
                <li class="nexus-alpha-module-row">
                  <span>{{ lesson.title }} <span class="govuk-tag govuk-tag--grey">{{ lesson.contentTypeLabel }}</span></span>
                  <form method="post" action="{{ urlFor('/courses/instructor/' + (course.id | string) + '/lessons/' + (lesson.id | string) + '/delete') }}" class="govuk-!-display-inline">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                    <button class="govuk-button govuk-button--warning govuk-button--small" data-module="govuk-button">Delete lesson</button>
                  </form>
                </li>
              {% endfor %}
            </ul>
          {% endif %}

          <details class="govuk-details" data-module="govuk-details">
            <summary class="govuk-details__summary"><span class="govuk-details__summary-text">Rename / Delete section</span></summary>
            <div class="govuk-details__text">
              <form method="post" action="{{ urlFor('/courses/instructor/' + (course.id | string) + '/sections/' + (section.id | string) + '/update') }}" class="govuk-!-margin-bottom-3">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <div class="govuk-form-group">
                  <label class="govuk-label govuk-label--s" for="rename-section-{{ section.id }}">Section title</label>
                  <input class="govuk-input" id="rename-section-{{ section.id }}" name="section_title" type="text" maxlength="200" value="{{ section.title }}">
                </div>
                <button class="govuk-button govuk-button--secondary" data-module="govuk-button">Rename</button>
              </form>
              <div class="govuk-warning-text">
                <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
                <strong class="govuk-warning-text__text"><span class="govuk-visually-hidden">Notice</span>Deleting a section keeps its lessons but moves them out of any section.</strong>
              </div>
              <form method="post" action="{{ urlFor('/courses/instructor/' + (course.id | string) + '/sections/' + (section.id | string) + '/delete') }}">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <button class="govuk-button govuk-button--warning" data-module="govuk-button">Delete section</button>
              </form>
            </div>
          </details>
        </div>
      {% endfor %}
    {% endif %}

    <h3 class="govuk-heading-s govuk-!-margin-top-4">Add a section</h3>
    <form method="post" action="{{ urlFor('/courses/instructor/' + (course.id | string) + '/sections') }}" class="govuk-!-margin-bottom-6">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--s" for="section_title">Section title</label>
        <div id="section_title-hint" class="govuk-hint">For example, Getting started or Week 1.</div>
        <input class="govuk-input" id="section_title" name="section_title" type="text" maxlength="200" aria-describedby="section_title-hint">
      </div>
      <button class="govuk-button govuk-button--secondary" data-module="govuk-button">Add section</button>
    </form>

    <h3 class="govuk-heading-s govuk-!-margin-top-4">Add a lesson</h3>
    <form method="post" action="{{ urlFor('/courses/instructor/' + (course.id | string) + '/lessons') }}" class="govuk-!-margin-bottom-6">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--s" for="lesson_title">Lesson title</label>
        <div id="lesson_title-hint" class="govuk-hint">A short, clear name for this lesson.</div>
        <input class="govuk-input" id="lesson_title" name="lesson_title" type="text" maxlength="200" aria-describedby="lesson_title-hint">
      </div>

      {% if builderSections and builderSections.length %}
        <div class="govuk-form-group">
          <label class="govuk-label govuk-label--s" for="section_id">Section</label>
          <select class="govuk-select" id="section_id" name="section_id">
            <option value="">No section</option>
            {% for section in builderSections %}
              <option value="{{ section.id }}">{{ section.title }}</option>
            {% endfor %}
          </select>
        </div>
      {% endif %}

      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--s" for="content_type">Lesson type</label>
        <select class="govuk-select" id="content_type" name="content_type">
          {% for contentType in contentTypes %}
            <option value="{{ contentType.value }}">{{ contentType.label }}</option>
          {% endfor %}
        </select>
      </div>

      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--s" for="body">Lesson content <span class="govuk-hint govuk-!-display-inline">(optional)</span></label>
        <div id="body-hint" class="govuk-hint">The text learners read, or notes about the video or document.</div>
        <textarea class="govuk-textarea" id="body" name="body" rows="4" aria-describedby="body-hint"></textarea>
      </div>

      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--s" for="media_url">Media link <span class="govuk-hint govuk-!-display-inline">(optional)</span></label>
        <div id="media_url-hint" class="govuk-hint">The web address of the video, document or interactive content.</div>
        <input class="govuk-input" id="media_url" name="media_url" type="url" inputmode="url" aria-describedby="media_url-hint">
      </div>

      <button class="govuk-button govuk-button--secondary" data-module="govuk-button">Add lesson</button>
    </form>

    <h2 class="govuk-heading-m govuk-!-margin-top-6">{% if course.status == 'published' %}Unpublish{% else %}Publish{% endif %}</h2>
    <form method="post" action="{{ urlFor('/courses/instructor/' + (course.id | string) + '/' + ('unpublish' if course.status == 'published' else 'publish')) }}">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
      <button class="govuk-button govuk-button--secondary" data-module="govuk-button">{% if course.status == 'published' %}Unpublish{% else %}Publish{% endif %}</button>
    </form>

    <div class="govuk-!-margin-top-2">
      <a class="govuk-link" href="{{ urlFor('/courses/instructor/' + (course.id | string) + '/analytics') }}">View analytics</a>
    </div>
    <div class="govuk-!-margin-top-2">
      <a class="govuk-link" href="{{ urlFor('/courses/instructor/' + (course.id | string) + '/grading') }}">Grading queue</a>
    </div>

    <h2 class="govuk-heading-m govuk-!-margin-top-6">Delete this course</h2>
    <div class="govuk-warning-text">
      <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
      <strong class="govuk-warning-text__text">
        <span class="govuk-visually-hidden">Notice</span>
        Deleting a course removes it permanently, along with its lessons and learner progress. This cannot be undone.
      </strong>
    </div>
    <form method="post" action="{{ urlFor('/courses/instructor/' + (course.id | string) + '/delete') }}">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
      <button class="govuk-button govuk-button--warning" data-module="govuk-button">Delete</button>
    </form>
  {% endif %}
{% endblock %}
