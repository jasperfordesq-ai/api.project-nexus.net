{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a href="{{ urlFor('/courses') }}" class="govuk-back-link">Back to courses</a>

  {% set activeTab = 'teaching' %}
  {% include "courses/_nav.njk" %}

  {% if status %}
    {% if status.type == 'success' %}
      <div class="govuk-notification-banner govuk-notification-banner--success" role="alert" aria-labelledby="course-instructor-status" data-module="govuk-notification-banner">
        <div class="govuk-notification-banner__header">
          <h2 class="govuk-notification-banner__title" id="course-instructor-status">Success</h2>
        </div>
        <div class="govuk-notification-banner__content">
          <p class="govuk-notification-banner__heading">{{ status.message }}</p>
        </div>
      </div>
    {% else %}
      <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
        <div role="alert">
          <h2 class="govuk-error-summary__title">There is a problem</h2>
          <div class="govuk-error-summary__body"><ul class="govuk-list govuk-error-summary__list"><li>{{ status.message }}</li></ul></div>
        </div>
      </div>
    {% endif %}
  {% endif %}

  <span class="govuk-caption-xl">Teaching at {{ tenantName }}</span>
  <h1 class="govuk-heading-xl">Courses you teach</h1>
  <p class="govuk-body-l">Create and manage the courses you teach, track enrolments and publish when you are ready.</p>

  {% if canAuthor %}
    <p class="govuk-body">
      <a class="govuk-button" href="{{ urlFor('/courses/instructor/new') }}" role="button" draggable="false" data-module="govuk-button">Create a course</a>
    </p>
  {% else %}
    <div class="govuk-inset-text"><p class="govuk-body">Course creation is limited to approved instructors at this community.</p></div>
  {% endif %}

  {% if not courses or not courses.length %}
    <div class="govuk-inset-text"><p class="govuk-body">You have not created any courses yet. Create your first course to start teaching.</p></div>
  {% else %}
    <div class="nexus-alpha-card-list">
      {% for course in courses %}
        <article class="nexus-alpha-card">
          <div class="nexus-alpha-module-row">
            <h2 class="govuk-heading-s govuk-!-margin-bottom-1">{{ course.title }}</h2>
            <strong class="govuk-tag {{ course.instructorStatusClass }}">{{ course.instructorStatusLabel }}</strong>
          </div>
          <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-2">
            Enrolments: {{ course.enrollmentCount }}
            &middot;
            Completions: {{ course.completionCount }}
          </p>
          <div class="nexus-alpha-actions">
            <a class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" href="{{ urlFor('/courses/instructor/' + (course.id | string) + '/edit') }}" role="button" draggable="false" data-module="govuk-button">Edit course</a>
            <a class="govuk-link govuk-!-margin-left-3" href="{{ urlFor('/courses/instructor/' + (course.id | string) + '/analytics') }}">View analytics</a>
          </div>
        </article>
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
