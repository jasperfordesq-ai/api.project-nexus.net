{% extends "layouts/base.njk" %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <a class="govuk-back-link" href="/members">Member directory</a>

      <span class="govuk-caption-l">Community members at {{ communityName }}</span>
      <h1 class="govuk-heading-xl">Recommended members</h1>
      <p class="govuk-body-l">Recommended members are ordered using community signals such as activity, reputation and shared interests.</p>

      <nav class="nexus-alpha-actions govuk-!-margin-bottom-6" aria-label="Member directory filters">
        <a class="govuk-link" href="/members">All members</a>
        <a class="govuk-link" href="/members?sort=joined&amp;order=DESC">New members</a>
        <a class="govuk-link" href="/members?sort=hours_given&amp;order=DESC">Active members</a>
        <strong class="govuk-tag govuk-tag--blue">Recommended</strong>
        <a class="govuk-link" href="/members/nearby">Near me</a>
      </nav>

      <p class="govuk-hint">Recommendations are recalculated from signals available in this community.</p>

      <form method="get" action="/members/discover" class="govuk-!-margin-bottom-6">
        <div class="govuk-form-group">
          <label class="govuk-label" for="q">Search recommended members</label>
          <div id="discover-q-hint" class="govuk-hint">Search by name, interest, skill or location.</div>
          <input class="govuk-input govuk-input--width-20" id="q" name="q" type="search" value="{{ search }}" aria-describedby="discover-q-hint">
        </div>
        <div class="nexus-alpha-actions">
          <button class="govuk-button" data-module="govuk-button">Search</button>
          {% if search %}
            <a class="govuk-link" href="/members/discover">Clear filters</a>
          {% endif %}
        </div>
      </form>

      <h2 class="govuk-heading-l">Recommended for you</h2>
      <p class="govuk-body nexus-alpha-result-count" aria-live="polite">{{ totalItemsLabel }}</p>

      {% if errorMessage %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
          <div role="alert">
            <h2 class="govuk-error-summary__title">There is a problem</h2>
            <div class="govuk-error-summary__body">
              <p>{{ errorMessage }}</p>
            </div>
          </div>
        </div>
      {% elif not members or not members.length %}
        <div class="govuk-inset-text">
          <h2 class="govuk-heading-m">No results found</h2>
          <p class="govuk-body">No recommended members match the current filters.</p>
        </div>
      {% else %}
        <div class="nexus-alpha-card-list">
          {% for member in members %}
            <article class="nexus-alpha-card">
              <div class="nexus-alpha-member-row">
                <div class="nexus-alpha-member-row__media">
                  {% if member.avatar %}
                    <img class="nexus-alpha-avatar nexus-alpha-avatar--large" src="{{ member.avatar }}" alt="Avatar for {{ member.name }}">
                  {% else %}
                    <span class="nexus-alpha-avatar nexus-alpha-avatar--large nexus-alpha-avatar--placeholder" aria-hidden="true">{{ member.initial }}</span>
                  {% endif %}
                </div>
                <div class="nexus-alpha-member-row__content">
                  <div class="nexus-alpha-member-row__heading">
                    <h3 class="govuk-heading-m govuk-!-margin-bottom-2">
                      <a class="govuk-link" href="/members/{{ member.id }}">{{ member.name }}</a>
                    </h3>
                    {% if member.isVerified %}
                      <strong class="govuk-tag govuk-tag--green">Verified</strong>
                    {% endif %}
                    {% if member.levelLabel %}
                      <strong class="govuk-tag govuk-tag--turquoise">{{ member.levelLabel }}</strong>
                    {% endif %}
                    {% if member.connectionLabel %}
                      <strong class="govuk-tag govuk-tag--blue">{{ member.connectionLabel }}</strong>
                    {% endif %}
                  </div>

                  {% if member.tagline %}
                    <p class="govuk-body">{{ member.tagline }}</p>
                  {% endif %}

                  {% if member.rankPercent !== null %}
                    <p class="govuk-body govuk-!-margin-bottom-1">
                      <strong>Recommendation score:</strong> {{ member.rankPercent }}%
                    </p>
                    <progress class="nexus-alpha-progress" value="{{ member.rankPercent }}" max="100" aria-label="Recommendation score {{ member.rankPercent }} percent">{{ member.rankPercent }}%</progress>
                  {% endif %}

                  <dl class="nexus-alpha-inline-list">
                    {% if member.location %}
                      <div>
                        <dt>Location</dt>
                        <dd>{{ member.location }}</dd>
                      </div>
                    {% endif %}
                    <div>
                      <dt>Hours given</dt>
                      <dd>{{ member.hoursGivenLabel }}</dd>
                    </div>
                    <div>
                      <dt>Hours received</dt>
                      <dd>{{ member.hoursReceivedLabel }}</dd>
                    </div>
                    {% if member.ratingLabel %}
                      <div>
                        <dt>Rating</dt>
                        <dd>{{ member.ratingLabel }}</dd>
                      </div>
                    {% endif %}
                  </dl>
                </div>
                <div class="nexus-alpha-member-row__action">
                  <a class="govuk-link govuk-link--no-visited-state" href="/members/{{ member.id }}">
                    View profile
                    <span class="govuk-visually-hidden"> for {{ member.name }}</span>
                  </a>
                </div>
              </div>
            </article>
          {% endfor %}
        </div>

        {% if nextHref %}
          <nav class="govuk-pagination govuk-pagination--block govuk-!-margin-top-6" aria-label="Member pagination">
            <div class="govuk-pagination__next">
              <a class="govuk-link govuk-pagination__link" href="{{ nextHref }}" rel="next">
                <svg class="govuk-pagination__icon govuk-pagination__icon--next" xmlns="http://www.w3.org/2000/svg" height="13" width="15" aria-hidden="true" focusable="false" viewBox="0 0 15 13">
                  <path d="m8.107-0.0078125-1.4136 1.414 4.2926 4.293h-12.986v2h12.896l-4.1855 3.9766 1.377 1.4492 6.7441-6.4062-6.7246-6.7266z"></path>
                </svg>
                <span class="govuk-pagination__link-title">Load more</span>
                <span class="govuk-visually-hidden">:</span>
                <span class="govuk-pagination__link-label">Recommended members</span>
              </a>
            </div>
          </nav>
        {% endif %}
      {% endif %}
    </div>
  </div>
{% endblock %}
