{% extends "layouts/base.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/input/macro.njk" import govukInput %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">

      {% if successMessage %}
        {% set notificationMessage = successMessage %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      {% if errorMessage %}
        {% set notificationMessage = errorMessage %}
        {% set notificationType = null %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      <h1 class="govuk-heading-xl">Community members</h1>

      <p class="govuk-body">Browse members of your community and send connection requests.</p>

      <form action="/members" method="get" class="govuk-!-margin-bottom-6">
        <div class="app-search-form">
          {{ govukInput({
            id: "search",
            name: "search",
            value: searchQuery,
            label: {
              text: "Search members",
              classes: "govuk-visually-hidden"
            },
            classes: "app-search-form__input",
            attributes: {
              placeholder: "Search by name or email..."
            }
          }) }}
          <button type="submit" class="govuk-button app-search-form__button govuk-!-margin-bottom-0">
            Search
          </button>
          {% if searchQuery %}
            <a href="/members" class="govuk-link govuk-!-margin-left-3">Clear</a>
          {% endif %}
        </div>
      </form>

      {% if searchQuery and users.length == 0 %}
        {% set emptyState = {
          icon: "🔍",
          heading: "No results found",
          message: "No members match \"" + searchQuery + "\". Try a different search term.",
          action: {
            text: "Clear search",
            href: "/members"
          }
        } %}
        {% include "partials/empty-state.njk" %}
      {% elif users.length > 0 %}
        <table class="govuk-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">Name</th>
              <th scope="col" class="govuk-table__header">Email</th>
              <th scope="col" class="govuk-table__header">Status</th>
              <th scope="col" class="govuk-table__header">Actions</th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for user in users %}
              {% set conn = connectionMap[user.id] %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">
                  <div class="app-member-cell">
                    {% include "partials/avatar.njk" %}
                    <a href="/members/{{ user.id }}" class="govuk-link">
                      {{ user.first_name or user.firstName }} {{ user.last_name or user.lastName }}
                    </a>
                  </div>
                </td>
                <td class="govuk-table__cell">
                  {{ user.email }}
                </td>
                <td class="govuk-table__cell">
                  {% if conn %}
                    {% if conn.status == 'accepted' %}
                      {{ govukTag({ text: "Connected", classes: "govuk-tag--green" }) }}
                    {% elif conn.status == 'pending' %}
                      {% if conn.is_requester %}
                        {{ govukTag({ text: "Request sent", classes: "govuk-tag--yellow" }) }}
                      {% else %}
                        {{ govukTag({ text: "Wants to connect", classes: "govuk-tag--blue" }) }}
                      {% endif %}
                    {% endif %}
                  {% else %}
                    {{ govukTag({ text: "Not connected", classes: "govuk-tag--grey" }) }}
                  {% endif %}
                </td>
                <td class="govuk-table__cell">
                  <a href="/members/{{ user.id }}" class="govuk-link govuk-!-margin-right-3">View profile</a>
                  {% if not conn %}
                    <form action="/members/{{ user.id }}/connect" method="post" style="display: inline;">
                      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                      <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0">
                        Connect
                      </button>
                    </form>
                  {% elif conn.status == 'pending' and not conn.is_requester %}
                    <a href="/connections/pending" class="govuk-link">Respond</a>
                  {% endif %}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        {% set emptyState = {
          icon: "👥",
          heading: "No members found",
          message: "There are no other members in your community yet."
        } %}
        {% include "partials/empty-state.njk" %}
      {% endif %}

      {# Pagination #}
      {% if pagination and (pagination.totalPages or pagination.total_pages) > 1 %}
        {% set paginationConfig = {
          baseUrl: "/members",
          page: pagination.page,
          totalPages: pagination.totalPages or pagination.total_pages,
          queryParams: { search: searchQuery }
        } %}
        {% include "partials/pagination.njk" %}
      {% endif %}

    </div>
  </div>
{% endblock %}
