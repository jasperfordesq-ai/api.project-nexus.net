{% extends "layouts/base.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/input/macro.njk" import govukInput %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">

      {% if successMessage %}
        {% set notificationMessage = successMessage %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      {% if errorMessage %}
        {% set notificationMessage = errorMessage %}
        {% set notificationType = null %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      <span class="govuk-caption-l">{{ t("members.caption", { community: communityName }) }}</span>
      <h1 class="govuk-heading-xl">{{ t("members.title") }}</h1>
      <p class="govuk-body-l">{{ t("members.description") }}</p>

      {% if requiresAuth %}
        <div class="govuk-notification-banner" data-module="govuk-notification-banner" role="region" aria-labelledby="members-auth-required-title">
          <div class="govuk-notification-banner__header">
            <h2 class="govuk-notification-banner__title" id="members-auth-required-title">{{ t("states.error_title") }}</h2>
          </div>
          <div class="govuk-notification-banner__content">
            <p class="govuk-notification-banner__heading">{{ t("states.auth_required") }}</p>
            <p class="govuk-body">{{ t("members.auth_required_detail", { community: communityName }) }}</p>
            <div class="govuk-button-group">
              {{ govukButton({ text: t("nav.login"), href: urlFor('/login') }) }}
              {{ govukButton({ text: t("nav.register"), href: urlFor('/register'), classes: "govuk-button--secondary" }) }}
            </div>
          </div>
        </div>
      {% else %}

      <form action="{{ urlFor('/members') }}" method="get" class="govuk-!-margin-bottom-6">
        {% if sort != 'name' %}<input type="hidden" name="sort" value="{{ sort }}">{% endif %}
        {% if order != 'ASC' %}<input type="hidden" name="order" value="{{ order }}">{% endif %}
        <div class="app-search-form">
          {{ govukInput({
            id: "search",
            name: "search",
            value: searchQuery,
            label: {
              text: t("members.search_label"),
              classes: "govuk-visually-hidden"
            },
            classes: "app-search-form__input",
            attributes: {
              placeholder: "Search by name or email..."
            }
          }) }}
          <button type="submit" class="govuk-button app-search-form__button govuk-!-margin-bottom-0">
            Search
          </button>
          {% if searchQuery %}
            <a href="{{ urlFor('/members') }}" class="govuk-link govuk-!-margin-left-3">Clear</a>
          {% endif %}
        </div>
      </form>

      {% if searchQuery and users.length == 0 %}
        {% set emptyState = {
          icon: "🔍",
          heading: "No results found",
          message: "No members match \"" + searchQuery + "\". Try a different search term.",
          action: {
            text: t("polish_members.connections_search_clear"),
            href: urlFor("/members")
          }
        } %}
        {% include "partials/empty-state.njk" %}
      {% elif users.length > 0 %}
        <table class="govuk-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">Name</th>
              <th scope="col" class="govuk-table__header">Location</th>
              <th scope="col" class="govuk-table__header">Status</th>
              <th scope="col" class="govuk-table__header">Actions</th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for user in users %}
              {% set conn = connectionMap[user.id] %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">
                  <div class="app-member-cell">
                    {% include "partials/avatar.njk" %}
                    <a href="{{ urlFor('/members/' + (user.id | string)) }}" class="govuk-link">
                      {% if user.name %}{{ user.name }}{% else %}{{ user.first_name or user.firstName }} {{ user.last_name or user.lastName }}{% endif %}
                    </a>
                  </div>
                </td>
                <td class="govuk-table__cell">
                  {{ user.location or "Not provided" }}
                </td>
                <td class="govuk-table__cell">
                  {% if conn %}
                    {% if conn.status == 'accepted' %}
                      {{ govukTag({ text: "Connected", classes: "govuk-tag--green" }) }}
                    {% elif conn.status == 'pending' %}
                      {% if conn.is_requester %}
                        {{ govukTag({ text: "Request sent", classes: "govuk-tag--yellow" }) }}
                      {% else %}
                        {{ govukTag({ text: t("members.connection_request_received"), classes: "govuk-tag--blue" }) }}
                      {% endif %}
                    {% endif %}
                  {% else %}
                    {{ govukTag({ text: "Not connected", classes: "govuk-tag--grey" }) }}
                  {% endif %}
                </td>
                <td class="govuk-table__cell">
                  <a href="{{ urlFor('/members/' + (user.id | string)) }}" class="govuk-link govuk-!-margin-right-3">View profile</a>
                  {% if not conn %}
                    <form action="{{ urlFor('/members/' + (user.id | string) + '/connection') }}" method="post" style="display: inline;">
                      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                      <input type="hidden" name="action" value="connect">
                      <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0">
                        Connect
                      </button>
                    </form>
                  {% elif conn.status == 'pending' and not conn.is_requester %}
                    <a href="{{ urlFor('/connections/network?tab=pending_received') }}" class="govuk-link">Respond</a>
                  {% endif %}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        {% set emptyState = {
          icon: "👥",
          heading: "No members found",
          message: "There are no other members in your community yet."
        } %}
        {% include "partials/empty-state.njk" %}
      {% endif %}

      {# Pagination #}
      {% if pagination and (pagination.totalPages or pagination.total_pages) > 1 %}
        {% set paginationConfig = {
          baseUrl: urlFor("/members"),
          page: pagination.page,
          totalPages: pagination.totalPages or pagination.total_pages,
          queryParams: { search: searchQuery, sort: sort if sort != 'name' else '', order: order if order != 'ASC' else '' }
        } %}
        {% include "partials/pagination.njk" %}
      {% endif %}

      {% endif %}

    </div>
  </div>
{% endblock %}
