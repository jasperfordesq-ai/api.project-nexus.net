{% extends "layouts/base.njk" %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block beforeContent %}
  <a class="govuk-back-link" href="{{ urlFor('/explore') }}">Back</a>
{% endblock %}

{% block mainContent %}
  <span class="govuk-caption-xl">{{ tenantName }}</span>
  <h1 class="govuk-heading-xl">AI assistant</h1>
  <p class="govuk-body-l">Ask questions about your community, platform features, listings, events, groups, and next steps.</p>

  <div class="govuk-warning-text">
    <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
    <strong class="govuk-warning-text__text">
      <span class="govuk-visually-hidden">Warning</span>
      AI can make mistakes. Check important information before acting on it.
    </strong>
  </div>

  {% if status == "empty" %}
    {{ govukErrorSummary({
      titleText: "There is a problem",
      errorList: [
        {
          text: "Enter a message before sending.",
          href: "#message"
        }
      ]
    }) }}
  {% endif %}

  {% if status == "sent" %}
    {{ govukNotificationBanner({
      type: "success",
      text: "Message sent."
    }) }}
  {% endif %}

  {% if status == "failed" or apiError %}
    {{ govukNotificationBanner({
      titleText: "AI assistant unavailable",
      text: apiError or "The AI assistant could not respond. Try again later."
    }) }}
  {% endif %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-one-third">
      <h2 class="govuk-heading-m">Conversations</h2>
      <p class="govuk-body">
        <a class="govuk-link" href="{{ urlFor('/chat') }}">New conversation</a>
      </p>

      {% if conversations and conversations.length %}
        <ul class="govuk-list govuk-list--spaced">
          {% for conversation in conversations %}
            <li>
              {% if selectedId and conversation.id == selectedId %}
                <strong>{{ conversation.title }}</strong>
              {% else %}
                <a class="govuk-link" href="{{ urlFor('/chat?c=' + (conversation.id | string)) }}">{{ conversation.title }}</a>
              {% endif %}
              {% if conversation.updated_at %}
                <br><span class="govuk-hint govuk-!-font-size-16">{{ conversation.updated_at | formatDate }}</span>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <p class="govuk-hint">No conversations yet.</p>
      {% endif %}
    </div>

    <div class="govuk-grid-column-two-thirds">
      <h2 class="govuk-heading-m">Thread</h2>

      {% if messages and messages.length %}
        <ol class="govuk-list govuk-list--spaced">
          {% for message in messages %}
            <li class="nexus-alpha-card">
              <p class="govuk-!-margin-bottom-1">
                {% if message.role == "user" %}
                  <strong class="govuk-tag govuk-tag--blue">You</strong>
                {% else %}
                  <strong class="govuk-tag govuk-tag--green">Assistant</strong>
                {% endif %}
              </p>
              <div class="govuk-body govuk-!-margin-bottom-0">{{ message.content | nl2br | safe }}</div>
            </li>
          {% endfor %}
        </ol>
      {% else %}
        <p class="govuk-inset-text">Start a conversation, or choose an existing conversation from the list.</p>
      {% endif %}

      <form method="post" action="{{ urlFor('/chat') }}" class="govuk-!-margin-top-4">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        {% if selectedId %}
          <input type="hidden" name="conversation_id" value="{{ selectedId }}">
        {% endif %}
        <div class="govuk-form-group">
          <label class="govuk-label govuk-label--m" for="message">Message</label>
          <div id="message-hint" class="govuk-hint">Ask up to 4,000 characters. Do not include sensitive personal information.</div>
          <textarea class="govuk-textarea" id="message" name="message" rows="4" maxlength="4000" aria-describedby="message-hint" required></textarea>
        </div>
        {{ govukButton({
          text: "Send"
        }) }}
      </form>
    </div>
  </div>
{% endblock %}
