{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a class="govuk-back-link" href="/explore">Back</a>

  <span class="govuk-caption-xl">Community help</span>
  <h1 class="govuk-heading-xl">AI assistant</h1>
  <p class="govuk-body-l">Ask a question and the community assistant will reply. It can help you find your way around the platform.</p>

  <div class="govuk-warning-text">
    <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
    <strong class="govuk-warning-text__text">
      <span class="govuk-visually-hidden">Warning</span>
      Replies are generated by AI and may be inaccurate. Do not share sensitive personal information.
    </strong>
  </div>

  {% if validationMessage %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            <li><a href="#message">{{ validationMessage }}</a></li>
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  {% if statusMessage %}
    <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="ai-success-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="ai-success-title">Success</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ statusMessage }}</p>
      </div>
    </div>
  {% endif %}

  {% if errorMessage or loadError %}
    <div class="govuk-notification-banner" data-module="govuk-notification-banner" role="region" aria-labelledby="ai-error-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="ai-error-title">Important</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ errorMessage or 'AI assistant information could not be loaded. Try again.' }}</p>
      </div>
    </div>
  {% endif %}

  {% if not aiEnabled %}
    <div class="govuk-notification-banner" data-module="govuk-notification-banner" role="region" aria-labelledby="ai-disabled-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="ai-disabled-title">There is a problem</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-body">The AI assistant is not available at the moment.</p>
      </div>
    </div>
  {% endif %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-one-third">
      <h2 class="govuk-heading-m">Your conversations</h2>
      <p class="govuk-body"><a class="govuk-link" href="/chat">Start a new conversation</a></p>

      {% if conversations.length == 0 %}
        <p class="govuk-hint">You have no conversations yet. Ask a question below to start one.</p>
      {% else %}
        <ul class="govuk-list govuk-list--spaced">
          {% for conversation in conversations %}
            <li>
              {% if selectedId and conversation.id == selectedId %}
                <strong>{{ conversation.title }}</strong>
              {% else %}
                <a class="govuk-link" href="/chat?c={{ conversation.id }}">{{ conversation.title }}</a>
              {% endif %}
              {% if conversation.updatedAt %}
                <br><span class="govuk-hint govuk-!-font-size-16">{{ conversation.updatedAt | formatDate }}</span>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      {% endif %}

      {% if starters.length > 0 %}
        <h2 class="govuk-heading-m">Suggested questions</h2>
        <ul class="govuk-list govuk-list--spaced">
          {% for starter in starters %}
            <li>{{ starter }}</li>
          {% endfor %}
        </ul>
      {% endif %}

      {% if limits and limits.remaining is defined %}
        <p class="govuk-hint">Requests remaining: {{ limits.remaining }}</p>
      {% endif %}
    </div>

    <div class="govuk-grid-column-two-thirds">
      <h2 class="govuk-heading-m">Conversation</h2>
      {% if messages.length == 0 %}
        <p class="govuk-inset-text">No messages yet. Ask a question to begin.</p>
      {% else %}
        <ol class="govuk-list govuk-list--spaced">
          {% for message in messages %}
            <li class="nexus-alpha-card">
              <p class="govuk-!-margin-bottom-1">
                <strong class="govuk-tag {{ message.tagClass }}">{{ message.roleLabel }}</strong>
              </p>
              <div class="govuk-body govuk-!-margin-bottom-0">{{ message.content | nl2br | safe }}</div>
            </li>
          {% endfor %}
        </ol>
      {% endif %}

      <form method="post" action="/chat" class="govuk-!-margin-top-4">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        {% if selectedId %}
          <input type="hidden" name="conversation_id" value="{{ selectedId }}">
        {% endif %}
        <div class="govuk-form-group{% if validationMessage %} govuk-form-group--error{% endif %}">
          <label class="govuk-label govuk-label--m" for="message">Your message</label>
          <div id="message-hint" class="govuk-hint">Type your question, then select Send to get a reply.</div>
          {% if validationMessage %}
            <p id="message-error" class="govuk-error-message">
              <span class="govuk-visually-hidden">Error:</span> {{ validationMessage }}
            </p>
          {% endif %}
          <textarea class="govuk-textarea{% if validationMessage %} govuk-textarea--error{% endif %}" id="message" name="message" rows="4" maxlength="4000" aria-describedby="message-hint{% if validationMessage %} message-error{% endif %}" required></textarea>
        </div>
        <button class="govuk-button" data-module="govuk-button">Send</button>
      </form>
    </div>
  </div>
{% endblock %}
