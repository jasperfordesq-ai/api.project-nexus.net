{#
  Pagination partial

  Usage:
  {% set paginationConfig = {
    baseUrl: "/members",
    page: pagination.page,
    totalPages: pagination.total_pages,
    queryParams: { search: searchQuery }
  } %}
  {% include "partials/pagination.njk" %}
#}
{% if paginationConfig.totalPages > 1 %}
  <nav class="govuk-pagination app-pagination" aria-label="Pagination">
    {% if paginationConfig.page > 1 %}
      <div class="govuk-pagination__prev">
        <a class="govuk-link govuk-pagination__link" href="{{ paginationConfig.baseUrl }}?page={{ paginationConfig.page - 1 }}{% for key, value in paginationConfig.queryParams %}{% if value %}&{{ key }}={{ value | urlencode }}{% endif %}{% endfor %}" rel="prev">
          <svg class="govuk-pagination__icon govuk-pagination__icon--prev" xmlns="http://www.w3.org/2000/svg" height="13" width="15" aria-hidden="true" focusable="false" viewBox="0 0 15 13">
            <path d="m6.5938-0.0078125-6.7266 6.7266 6.7441 6.4062 1.377-1.449-4.1856-3.9768h12.896v-2h-12.984l4.2931-4.293-1.414-1.414z"></path>
          </svg>
          <span class="govuk-pagination__link-title">Previous</span>
        </a>
      </div>
    {% endif %}

    <ul class="govuk-pagination__list">
      {# Show first page if not near start #}
      {% if paginationConfig.page > 3 %}
        <li class="govuk-pagination__item">
          <a class="govuk-link govuk-pagination__link" href="{{ paginationConfig.baseUrl }}?page=1{% for key, value in paginationConfig.queryParams %}{% if value %}&{{ key }}={{ value | urlencode }}{% endif %}{% endfor %}" aria-label="Page 1">
            1
          </a>
        </li>
        {% if paginationConfig.page > 4 %}
          <li class="govuk-pagination__item govuk-pagination__item--ellipses">&ctdot;</li>
        {% endif %}
      {% endif %}

      {# Show pages around current #}
      {% for i in range(1, paginationConfig.totalPages + 1) %}
        {% if i >= paginationConfig.page - 2 and i <= paginationConfig.page + 2 %}
          <li class="govuk-pagination__item{% if i == paginationConfig.page %} govuk-pagination__item--current{% endif %}">
            <a class="govuk-link govuk-pagination__link" href="{{ paginationConfig.baseUrl }}?page={{ i }}{% for key, value in paginationConfig.queryParams %}{% if value %}&{{ key }}={{ value | urlencode }}{% endif %}{% endfor %}" aria-label="Page {{ i }}"{% if i == paginationConfig.page %} aria-current="page"{% endif %}>
              {{ i }}
            </a>
          </li>
        {% endif %}
      {% endfor %}

      {# Show last page if not near end #}
      {% if paginationConfig.page < paginationConfig.totalPages - 2 %}
        {% if paginationConfig.page < paginationConfig.totalPages - 3 %}
          <li class="govuk-pagination__item govuk-pagination__item--ellipses">&ctdot;</li>
        {% endif %}
        <li class="govuk-pagination__item">
          <a class="govuk-link govuk-pagination__link" href="{{ paginationConfig.baseUrl }}?page={{ paginationConfig.totalPages }}{% for key, value in paginationConfig.queryParams %}{% if value %}&{{ key }}={{ value | urlencode }}{% endif %}{% endfor %}" aria-label="Page {{ paginationConfig.totalPages }}">
            {{ paginationConfig.totalPages }}
          </a>
        </li>
      {% endif %}
    </ul>

    {% if paginationConfig.page < paginationConfig.totalPages %}
      <div class="govuk-pagination__next">
        <a class="govuk-link govuk-pagination__link" href="{{ paginationConfig.baseUrl }}?page={{ paginationConfig.page + 1 }}{% for key, value in paginationConfig.queryParams %}{% if value %}&{{ key }}={{ value | urlencode }}{% endif %}{% endfor %}" rel="next">
          <span class="govuk-pagination__link-title">Next</span>
          <svg class="govuk-pagination__icon govuk-pagination__icon--next" xmlns="http://www.w3.org/2000/svg" height="13" width="15" aria-hidden="true" focusable="false" viewBox="0 0 15 13">
            <path d="m8.107-0.0078125-1.4136 1.414 4.2926 4.293h-12.986v2h12.896l-4.1855 3.9766 1.377 1.4492 6.7441-6.4062-6.7246-6.7266z"></path>
          </svg>
        </a>
      </div>
    {% endif %}
  </nav>
{% endif %}
