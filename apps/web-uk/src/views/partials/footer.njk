{#
  Custom Project NEXUS footer using GOV.UK typography and spacing only.
  No crown, no GOV.UK logotype, and no official government identity claim.
#}
<footer class="govuk-footer" role="contentinfo">
  <div class="govuk-width-container">
    {% if alphaFooterColumns and alphaFooterColumns.length %}
      <div class="govuk-footer__navigation">
        {% for column in alphaFooterColumns %}
          <div class="govuk-footer__section govuk-grid-column-one-third">
            <h2 class="govuk-footer__heading govuk-heading-m">{{ column.heading }}</h2>
            <ul class="govuk-footer__list">
              {% for link in column.links %}
                <li class="govuk-footer__list-item">
                  <a class="govuk-footer__link" href="{{ link.href }}">{{ link.label }}</a>
                </li>
              {% endfor %}
            </ul>
          </div>
        {% endfor %}
      </div>
      <hr class="govuk-footer__section-break">
    {% endif %}

    <div class="govuk-footer__meta">
      <div class="govuk-footer__meta-item govuk-footer__meta-item--grow">
        <h2 class="govuk-visually-hidden">Support and licence information</h2>

        <ul class="govuk-footer__inline-list">
          <li class="govuk-footer__inline-list-item">
            <a class="govuk-footer__link" href="/contact">Report a problem with this page</a>
          </li>
          <li class="govuk-footer__inline-list-item">
            <a class="govuk-footer__link" href="/privacy">Privacy</a>
          </li>
          <li class="govuk-footer__inline-list-item">
            <a class="govuk-footer__link" href="/terms">Terms</a>
          </li>
        </ul>

        {% if isAuthenticated %}
          <ul class="govuk-footer__inline-list">
            <li class="govuk-footer__inline-list-item">
              <form method="post" action="/logout" class="nexus-alpha-linkform">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <button type="submit" class="govuk-footer__link nexus-alpha-linkbutton">Sign out</button>
              </form>
            </li>
          </ul>
        {% endif %}

        <div class="govuk-footer__meta-custom">
          <p class="govuk-!-margin-bottom-2">Licensed under GNU AGPL v3.</p>
          <p class="govuk-!-margin-bottom-2">Created by Jasper Ford. Co-founded with Mary Casey.</p>
          <p class="govuk-!-margin-bottom-0">
            <a class="govuk-footer__link" href="https://github.com/jasperfordesq-ai/api.project-nexus.net" rel="noopener noreferrer">Source code</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</footer>
