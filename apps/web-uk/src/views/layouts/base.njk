{#
  Base layout for Project NEXUS Community

  Standard GOV.UK Frontend header/footer pattern with crown/GOV.UK identity removed.
  LEGAL: We are NOT a government service.
#}
{% extends "govuk/template.njk" %}

{% from "govuk/components/phase-banner/macro.njk" import govukPhaseBanner %}

{% set assetPath = "/assets" %}

{% block pageTitle %}{{ title }} - Project NEXUS Community{% endblock %}

{% block skipLink %}
  <a href="#main-content" class="govuk-skip-link" data-module="govuk-skip-link">Skip to main content</a>
{% endblock %}

{% block headIcons %}
  {# Custom favicon - no GOV.UK crown branding #}
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🔗</text></svg>">
{% endblock %}

{% block head %}
  <link rel="stylesheet" href="/css/main.css">
{% endblock %}

{% block header %}
  <header class="govuk-header app-header" data-module="govuk-header">
    <div class="govuk-header__container govuk-width-container">
      <div class="govuk-header__logo">
        <a href="/" class="govuk-header__link govuk-header__link--homepage">
          <span class="govuk-header__logotype-text">Project NEXUS Community</span>
          <span class="govuk-header__logotype-text app-header__disclaimer" style="font-size: 14px; font-weight: normal; display: block;">Not affiliated with GOV.UK</span>
        </a>
      </div>
      <div class="govuk-header__content">
        {% if isAuthenticated %}
          <button type="button" class="app-header__menu-button js-header-toggle" aria-controls="navigation" aria-label="Show or hide navigation menu" aria-expanded="false">
            Menu
          </button>
          <nav id="navigation" aria-label="Account menu" class="govuk-header__navigation app-header__navigation js-header-navigation" aria-hidden="true">
            <ul class="govuk-header__navigation-list">
              <li class="govuk-header__navigation-item">
                <a class="govuk-header__link" href="/dashboard">Dashboard</a>
              </li>
              <li class="govuk-header__navigation-item">
                <a class="govuk-header__link" href="/feed">Feed</a>
              </li>
              <li class="govuk-header__navigation-item">
                <a class="govuk-header__link" href="/listings">Listings</a>
              </li>
              <li class="govuk-header__navigation-item">
                <a class="govuk-header__link" href="/wallet">Wallet</a>
              </li>
              <li class="govuk-header__navigation-item app-header__notification-item">
                <a class="govuk-header__link app-header__notification-link" href="/messages" aria-label="Messages{% if unreadMessageCount > 0 %} ({{ unreadMessageCount }} unread){% endif %}">
                  <span class="app-header__notification-icon" aria-hidden="true">💬</span>
                  <span class="app-header__notification-text">Messages</span>
                  {% if unreadMessageCount > 0 %}
                    <span class="app-header__notification-badge" aria-hidden="true">{{ unreadMessageCount if unreadMessageCount < 100 else '99+' }}</span>
                  {% endif %}
                </a>
              </li>
              <li class="govuk-header__navigation-item">
                <a class="govuk-header__link" href="/connections">Connections</a>
              </li>
              <li class="govuk-header__navigation-item">
                <a class="govuk-header__link" href="/members">Members</a>
              </li>
              <li class="govuk-header__navigation-item">
                <a class="govuk-header__link" href="/groups">Groups</a>
              </li>
              <li class="govuk-header__navigation-item">
                <a class="govuk-header__link" href="/events">Events</a>
              </li>
              <li class="govuk-header__navigation-item">
                <a class="govuk-header__link" href="/search">Search</a>
              </li>
              <li class="govuk-header__navigation-item">
                <a class="govuk-header__link" href="/progress">Progress</a>
              </li>
              <li class="govuk-header__navigation-item app-header__notification-item">
                <a class="govuk-header__link app-header__notification-link" href="/notifications" aria-label="Notifications{% if notificationCount > 0 %} ({{ notificationCount }} unread){% endif %}">
                  <span class="app-header__notification-icon" aria-hidden="true">🔔</span>
                  <span class="app-header__notification-text">Notifications</span>
                  {% if notificationCount > 0 %}
                    <span class="app-header__notification-badge" aria-hidden="true">{{ notificationCount if notificationCount < 100 else '99+' }}</span>
                  {% endif %}
                </a>
              </li>
              <li class="govuk-header__navigation-item">
                <a class="govuk-header__link" href="/profile">Profile</a>
              </li>
              <li class="govuk-header__navigation-item">
                <form method="post" action="/logout" style="display:inline">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <button type="submit" class="govuk-header__link app-header__logout-button">Sign out</button>
                </form>
              </li>
            </ul>
          </nav>
        {% else %}
          <nav aria-label="Sign in" class="govuk-header__navigation">
            <ul class="govuk-header__navigation-list">
              <li class="govuk-header__navigation-item">
                <a class="govuk-header__link" href="/login">Sign in</a>
              </li>
              <li class="govuk-header__navigation-item">
                <a class="govuk-header__link" href="/register">Register</a>
              </li>
            </ul>
          </nav>
        {% endif %}
      </div>
    </div>
  </header>
{% endblock %}

{% block beforeContent %}
  {{ govukPhaseBanner({
    tag: {
      text: "Alpha"
    },
    html: 'This is a new community service – your <a class="govuk-link" href="/contact">feedback</a> will help us improve it.'
  }) }}
{% endblock %}

{% block content %}
  {% if isAuthenticated %}
    <div data-authenticated="true" data-csrf-token="{{ csrfToken }}" hidden></div>
  {% endif %}
  <main id="main-content" class="govuk-main-wrapper" role="main">
    {% block mainContent %}{% endblock %}
  </main>
{% endblock %}

{% block footer %}
  {% include "partials/footer.njk" %}
{% endblock %}

{% block bodyEnd %}
  <script type="module" src="/js/govuk-frontend.min.js"></script>
  <script type="module" src="/js/init.js"></script>
  <script src="/js/validation.js"></script>
  <script src="/js/loading-states.js"></script>
  <script src="/js/timeout-warning.js"></script>
  <script src="/js/mobile-nav.js"></script>
{% endblock %}
