{#
  Shared accessible frontend shell for Project NEXUS.

  This intentionally uses a custom Project NEXUS header and service-navigation
  navigation component pattern, not the GOV.UK header identity.
#}
{% extends "govuk/template.njk" %}

{% from "govuk/components/phase-banner/macro.njk" import govukPhaseBanner %}

{% set assetPath = "/assets" %}

{% block pageTitle %}{{ title }} - {{ serviceName }}{% endblock %}

{% block skipLink %}
  <a href="#main-content" class="govuk-skip-link" data-module="govuk-skip-link">Skip to main content</a>
{% endblock %}

{% block bodyStart %}
  {% include "partials/cookie-banner.njk" %}
{% endblock %}

{% block headIcons %}
  <link rel="icon" href="/assets/favicon.ico">
{% endblock %}

{% block head %}
  <link rel="stylesheet" href="/css/main.css">
{% endblock %}

{% block header %}
  <header class="nexus-alpha-header" role="banner">
    <div class="govuk-width-container nexus-alpha-header__container">
      <a class="nexus-alpha-header__brand govuk-!-font-size-24" href="{{ homeUrl or '/' }}">
        {{ tenantName or serviceName }}
      </a>

      <nav class="nexus-alpha-header__links" aria-label="Service links">
        {% if alphaLocaleOptions and alphaLocaleOptions.length > 1 %}
          <form method="get" action="{{ currentPath or '/' }}" class="nexus-alpha-lang" aria-label="Choose a language">
            {% for queryParam in alphaLocaleQueryParams %}
              <input type="hidden" name="{{ queryParam.key }}" value="{{ queryParam.value }}">
            {% endfor %}
            <label class="govuk-visually-hidden" for="alpha-locale-select">Choose a language</label>
            <select class="govuk-select nexus-alpha-lang__select" id="alpha-locale-select" name="locale">
              {% for locale in alphaLocaleOptions %}
                <option value="{{ locale[0] }}" {% if locale[0] == alphaCurrentLocale %}selected{% endif %}>{{ locale[1] }}</option>
              {% endfor %}
            </select>
            <button type="submit" class="govuk-button govuk-button--secondary nexus-alpha-lang__submit govuk-!-margin-bottom-0" data-module="govuk-button">Change</button>
          </form>
        {% endif %}

        {% if isAuthenticated %}
          <a class="nexus-alpha-header__link" href="{{ accountUrl or '/account' }}" {% if (activeNav or alphaActiveNav) == 'account' %}aria-current="page"{% endif %}>
            My account
            {% if unreadMessageCount > 0 %}
              <span class="nexus-alpha-nav-badge" aria-hidden="true">{{ unreadMessageCount if unreadMessageCount < 100 else '99+' }}</span>
              <span class="govuk-visually-hidden">{{ unreadMessageCount }} unread messages</span>
            {% endif %}
          </a>
        {% endif %}
      </nav>
    </div>
  </header>

  <section class="govuk-service-navigation" data-module="govuk-service-navigation" aria-label="Community service information">
    <div class="govuk-width-container">
      <div class="govuk-service-navigation__container">
        <nav class="govuk-service-navigation__wrapper" aria-label="Community navigation">
          <button type="button" class="govuk-service-navigation__toggle govuk-js-service-navigation-toggle" aria-controls="alpha-navigation" hidden aria-hidden="true">
            Menu
          </button>
          <ul class="govuk-service-navigation__list" id="alpha-navigation">
            {% for item in alphaNavItems %}
              <li class="govuk-service-navigation__item {% if (activeNav or alphaActiveNav) == item.key %}govuk-service-navigation__item--active{% endif %}">
                <a class="govuk-service-navigation__link" href="{{ item.href }}" {% if (activeNav or alphaActiveNav) == item.key %}aria-current="page"{% endif %}>
                  {% if (activeNav or alphaActiveNav) == item.key %}
                    <strong class="govuk-service-navigation__active-fallback">{{ item.label }}</strong>
                  {% else %}
                    {{ item.label }}
                  {% endif %}
                </a>
              </li>
            {% endfor %}
            {% if not isAuthenticated %}
              <li class="govuk-service-navigation__item {% if (activeNav or alphaActiveNav) == 'login' %}govuk-service-navigation__item--active{% endif %}">
                <a class="govuk-service-navigation__link" href="{{ loginUrl or '/login' }}" {% if (activeNav or alphaActiveNav) == 'login' %}aria-current="page"{% endif %}>Sign in</a>
              </li>
              <li class="govuk-service-navigation__item {% if (activeNav or alphaActiveNav) == 'register' %}govuk-service-navigation__item--active{% endif %}">
                <a class="govuk-service-navigation__link" href="{{ registerUrl or '/register' }}" {% if (activeNav or alphaActiveNav) == 'register' %}aria-current="page"{% endif %}>Register</a>
              </li>
            {% endif %}
          </ul>
        </nav>
      </div>
    </div>
  </section>
{% endblock %}

{% block beforeContent %}
  {{ govukPhaseBanner({
    tag: {
      text: phaseText or "Beta"
    },
    html: '<a class="govuk-link" href="' ~ feedbackUrl ~ '">Give feedback</a>'
  }) }}
{% endblock %}

{% block content %}
  {% if isAuthenticated %}
    <div data-authenticated="true" data-csrf-token="{{ csrfToken }}" hidden></div>
  {% endif %}
  <main id="main-content" class="govuk-main-wrapper" role="main">
    {% block mainContent %}{% endblock %}
  </main>
{% endblock %}

{% block footer %}
  {% include "partials/footer.njk" %}
{% endblock %}

{% block bodyEnd %}
  <script type="module" src="/js/govuk-frontend.min.js"></script>
  <script type="module" src="/js/init.js"></script>
  <script src="/js/validation.js"></script>
  <script src="/js/loading-states.js"></script>
  <script src="/js/timeout-warning.js"></script>
  <script src="/js/mobile-nav.js"></script>
{% endblock %}
