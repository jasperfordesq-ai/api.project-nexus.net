{% extends "layouts/base.njk" %}

{% block content %}
  <a class="govuk-back-link" href="{{ urlFor('/volunteering') }}">{{ t("actions.back_to_volunteering") }}</a>

  {% if status %}
    {% if status.type == "success" %}
      <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="swap-success-title">
        <div class="govuk-notification-banner__header">
          <h2 class="govuk-notification-banner__title" id="swap-success-title">{{ t("govuk_alpha.states.success_title") }}</h2>
        </div>
        <div class="govuk-notification-banner__content">
          <p class="govuk-notification-banner__heading">{{ status.message }}</p>
        </div>
      </div>
    {% else %}
      <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
        <div role="alert">
          <h2 class="govuk-error-summary__title">{{ t("govuk_alpha.states.error_title") }}</h2>
          <div class="govuk-error-summary__body">
            <p>{{ status.message }}</p>
          </div>
        </div>
      </div>
    {% endif %}
  {% endif %}

  <span class="govuk-caption-l">{{ t("volunteering.title") }}</span>
  <h1 class="govuk-heading-xl">{{ t("govuk_alpha.vol_depth.swaps_title") }}</h1>
  <p class="govuk-body-l">{{ t("vol_depth.swaps_description") }}</p>

  <h2 class="govuk-heading-l">{{ t("vol_depth.swap_request_title") }}</h2>
  {% if not myShifts.length %}
    <div class="govuk-inset-text">{{ t("vol_depth.swap_no_shifts") }}</div>
  {% else %}
    <form method="post" action="{{ urlFor('/volunteering/swaps') }}" class="govuk-!-margin-bottom-8">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
      <div class="govuk-form-group">
        <label class="govuk-label" for="from_shift_id">{{ t("vol_depth.swap_from_shift_label") }}</label>
        <div id="from_shift_id-hint" class="govuk-hint">{{ t("vol_depth.swap_from_shift_hint") }}</div>
        <select class="govuk-select" id="from_shift_id" name="from_shift_id" aria-describedby="from_shift_id-hint" required>
          <option value="">{{ t("vol_depth.swap_select_shift") }}</option>
          {% for shift in myShifts %}
            <option value="{{ shift.id }}">{{ shift.label }}</option>
          {% endfor %}
        </select>
      </div>
      <div class="govuk-form-group">
        <label class="govuk-label" for="to_shift_id">{{ t("vol_depth.swap_to_shift_label") }}</label>
        <div id="to_shift_id-hint" class="govuk-hint">{{ t("vol_depth.swap_to_shift_hint") }}</div>
        <input class="govuk-input govuk-input--width-10" id="to_shift_id" name="to_shift_id" type="text" inputmode="numeric" pattern="[0-9]*" aria-describedby="to_shift_id-hint" required>
      </div>
      <div class="govuk-form-group">
        <label class="govuk-label" for="to_user_id">{{ t("vol_depth.swap_to_user_label") }}</label>
        <div id="to_user_id-hint" class="govuk-hint">{{ t("vol_depth.swap_to_user_hint") }}</div>
        <input class="govuk-input govuk-input--width-10" id="to_user_id" name="to_user_id" type="text" inputmode="numeric" pattern="[0-9]*" aria-describedby="to_user_id-hint" required>
      </div>
      <div class="govuk-form-group">
        <label class="govuk-label" for="message">{{ t("vol_depth.swap_message_label") }}</label>
        <div id="message-hint" class="govuk-hint">{{ t("vol_depth.swap_message_hint") }}</div>
        <textarea class="govuk-textarea" id="message" name="message" rows="3" aria-describedby="message-hint" maxlength="500"></textarea>
      </div>
      <button class="govuk-button" data-module="govuk-button">{{ t("vol_depth.swap_request_submit") }}</button>
    </form>
  {% endif %}

  <h2 class="govuk-heading-l">{{ t("vol_depth.swaps_list_title") }}</h2>
  {% if loadError %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">{{ t("govuk_alpha.states.error_title") }}</h2>
        <div class="govuk-error-summary__body">
          <p>{{ loadError }}</p>
        </div>
      </div>
    </div>
  {% elif not swaps.length %}
    <div class="govuk-inset-text">{{ t("vol_depth.swaps_empty") }}</div>
  {% else %}
    <div class="nexus-alpha-card-list">
      {% for swap in swaps %}
        <article class="nexus-alpha-card">
          <p class="govuk-!-margin-bottom-2">
            <strong class="govuk-tag {{ swap.directionClassName }}">{{ swap.directionLabel }}</strong>
            <strong class="govuk-tag {{ swap.status.className }}">{{ swap.status.label }}</strong>
          </p>
          {% if swap.direction == "sent" and swap.recipientName %}
            <p class="govuk-body-s govuk-!-margin-bottom-3">{{ t("vol_depth.swap_to", { name: swap.recipientName }) }}</p>
          {% elif swap.direction == "received" and swap.requesterName %}
            <p class="govuk-body-s govuk-!-margin-bottom-3">{{ t("vol_depth.swap_from", { name: swap.requesterName }) }}</p>
          {% endif %}

          <div class="govuk-grid-row">
            <div class="govuk-grid-column-one-half">
              <h3 class="govuk-heading-s govuk-!-margin-bottom-1">{{ t("vol_depth.swap_original_shift") }}</h3>
              <p class="govuk-body govuk-!-margin-bottom-1">{{ swap.originalShift.title }}</p>
              {% if swap.originalShift.organizationName %}
                <p class="govuk-body-s govuk-!-margin-bottom-1">{{ swap.originalShift.organizationName }}</p>
              {% endif %}
              {% if swap.originalShift.startLabel %}
                <p class="govuk-body-s govuk-!-margin-bottom-0">{{ swap.originalShift.startLabel }}</p>
              {% endif %}
            </div>
            <div class="govuk-grid-column-one-half">
              <h3 class="govuk-heading-s govuk-!-margin-bottom-1">{{ t("vol_depth.swap_proposed_shift") }}</h3>
              <p class="govuk-body govuk-!-margin-bottom-1">{{ swap.proposedShift.title }}</p>
              {% if swap.proposedShift.organizationName %}
                <p class="govuk-body-s govuk-!-margin-bottom-1">{{ swap.proposedShift.organizationName }}</p>
              {% endif %}
              {% if swap.proposedShift.startLabel %}
                <p class="govuk-body-s govuk-!-margin-bottom-0">{{ swap.proposedShift.startLabel }}</p>
              {% endif %}
            </div>
          </div>

          {% if swap.message %}
            <p class="govuk-body govuk-!-margin-top-3 govuk-!-margin-bottom-3"><span class="govuk-!-font-weight-bold">{{ t("vol_depth.swap_message_from") }}</span> {{ swap.message }}</p>
          {% endif %}

          {% if swap.direction == "received" and swap.status.value == "pending" %}
            <form method="post" action="{{ urlFor('/volunteering/swaps/' ~ swap.id ~ '/respond') }}">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}">
              <div class="govuk-button-group">
                <button class="govuk-button govuk-!-margin-bottom-0" name="action" value="accept" data-module="govuk-button">{{ t("vol_depth.swap_accept") }}</button>
                <button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" name="action" value="reject" data-module="govuk-button">{{ t("vol_depth.swap_reject") }}</button>
              </div>
            </form>
          {% elif swap.direction == "sent" and (swap.status.value == "pending" or swap.status.value == "admin_pending") %}
            <form method="post" action="{{ urlFor('/volunteering/swaps/' ~ swap.id ~ '/cancel') }}">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}">
              <button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("vol_depth.swap_cancel") }}</button>
            </form>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
