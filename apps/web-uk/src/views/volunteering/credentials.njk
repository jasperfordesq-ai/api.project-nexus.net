{% extends "layouts/base.njk" %}

{% block content %}
  <a class="govuk-back-link" href="{{ urlFor('/volunteering') }}">{{ t("actions.back_to_volunteering") }}</a>

  {% if status %}
    {% if status.type == "success" %}
      <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="credential-success-title">
        <div class="govuk-notification-banner__header">
          <h2 class="govuk-notification-banner__title" id="credential-success-title">{{ t("states.success_title") }}</h2>
        </div>
        <div class="govuk-notification-banner__content">
          <p class="govuk-notification-banner__heading">{{ status.message }}</p>
        </div>
      </div>
    {% else %}
      <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
        <div role="alert">
          <h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2>
          <div class="govuk-error-summary__body">
            {% if status.field %}
              <ul class="govuk-list govuk-error-summary__list">
                <li><a href="#{{ status.field }}">{{ status.linkText or status.message }}</a></li>
              </ul>
            {% else %}
              <p>{{ status.message }}</p>
            {% endif %}
          </div>
        </div>
      </div>
    {% endif %}
  {% endif %}

  <span class="govuk-caption-l">{{ t("govuk_alpha.volunteering.title") }}</span>
  <h1 class="govuk-heading-xl">{{ t("govuk_alpha_volunteering.credentials.title") }}</h1>
  <p class="govuk-body-l">{{ t("govuk_alpha_volunteering.credentials.description") }}</p>

  <div class="govuk-warning-text">
    <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
    <strong class="govuk-warning-text__text">
      <span class="govuk-visually-hidden">{{ t("govuk_alpha_volunteering.shared.warning") }}:</span>
      {{ t("govuk_alpha_volunteering.credentials.vetting_documents_notice") }}
    </strong>
  </div>

  <form method="post" action="{{ urlFor('/volunteering/credentials') }}" enctype="multipart/form-data" class="govuk-!-margin-bottom-7">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    <h2 class="govuk-heading-l">{{ t("govuk_alpha_volunteering.credentials.upload_title") }}</h2>

    <div class="govuk-form-group{% if status and status.field == 'credential_type' %} govuk-form-group--error{% endif %}">
      <label class="govuk-label" for="credential_type">{{ t("govuk_alpha_volunteering.credentials.type_label") }}</label>
      <div id="credential-type-hint" class="govuk-hint">{{ t("govuk_alpha_volunteering.credentials.type_hint") }}</div>
      {% if status and status.field == 'credential_type' %}
        <p id="credential-type-error" class="govuk-error-message"><span class="govuk-visually-hidden">{{ t("states.error_prefix") }}</span> {{ status.message }}</p>
      {% endif %}
      <select class="govuk-select" id="credential_type" name="credential_type" aria-describedby="credential-type-hint{% if status and status.field == 'credential_type' %} credential-type-error{% endif %}">
        <option value="">{{ t("govuk_alpha_volunteering.credentials.type_select") }}</option>
        {% for credentialType in credentialTypes %}
          <option value="{{ credentialType.value }}">{{ credentialType.label }}</option>
        {% endfor %}
      </select>
    </div>

    <div class="govuk-form-group{% if status and status.field == 'document' %} govuk-form-group--error{% endif %}">
      <label class="govuk-label" for="document">{{ t("govuk_alpha_volunteering.credentials.file_label") }}</label>
      <div id="document-hint" class="govuk-hint">{{ t("govuk_alpha_volunteering.credentials.file_hint") }}</div>
      {% if status and status.field == 'document' %}
        <p id="document-error" class="govuk-error-message"><span class="govuk-visually-hidden">{{ t("states.error_prefix") }}</span> {{ status.message }}</p>
      {% endif %}
      <input class="govuk-file-upload" id="document" name="document" type="file" accept=".pdf,.jpg,.jpeg,.png,.webp" aria-describedby="document-hint{% if status and status.field == 'document' %} document-error{% endif %}">
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label" for="expiry_date">{{ t("govuk_alpha_volunteering.credentials.expiry_label") }} {{ t("govuk_alpha_volunteering.shared.optional") }}</label>
      <div id="expiry-date-hint" class="govuk-hint">{{ t("govuk_alpha_volunteering.credentials.expiry_hint") }}</div>
      <input class="govuk-input govuk-input--width-10" id="expiry_date" name="expiry_date" type="date" aria-describedby="expiry-date-hint">
    </div>

    <button class="govuk-button" data-module="govuk-button">{{ t("govuk_alpha_volunteering.credentials.upload_button") }}</button>
  </form>

  {% if loadError %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2>
        <div class="govuk-error-summary__body">
          <p>{{ loadError }}</p>
        </div>
      </div>
    </div>
  {% endif %}

  <h2 class="govuk-heading-l">{{ t("govuk_alpha_volunteering.credentials.list_title") }}</h2>
  {% if not credentials.length %}
    <div class="govuk-inset-text">{{ t("govuk_alpha_volunteering.credentials.empty") }}</div>
  {% else %}
    <div class="nexus-alpha-table-scroll" role="region" aria-label="{{ t('govuk_alpha_volunteering.credentials.list_title') }}" tabindex="0">
    <table class="govuk-table govuk-!-margin-bottom-0">
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header">{{ t("govuk_alpha_volunteering.credentials.col_type") }}</th>
          <th scope="col" class="govuk-table__header">{{ t("govuk_alpha_volunteering.credentials.col_status") }}</th>
          <th scope="col" class="govuk-table__header">{{ t("govuk_alpha_volunteering.credentials.col_expiry") }}</th>
          <th scope="col" class="govuk-table__header">{{ t("govuk_alpha_volunteering.credentials.col_uploaded") }}</th>
          <th scope="col" class="govuk-table__header"><span class="govuk-visually-hidden">{{ t("govuk_alpha_volunteering.credentials.delete_button") }}</span></th>
        </tr>
      </thead>
      <tbody class="govuk-table__body">
        {% for credential in credentials %}
          <tr class="govuk-table__row">
            <th scope="row" class="govuk-table__header">
              {{ credential.typeLabel }}
              {% if credential.warning %}
                <p class="govuk-body-s govuk-!-margin-top-2 govuk-!-margin-bottom-0">{{ credential.warning }}</p>
              {% endif %}
              {% if credential.fileName %}
                <span class="govuk-hint govuk-!-margin-bottom-0">{{ credential.fileName }}</span>
              {% endif %}
            </th>
            <td class="govuk-table__cell">
              <strong class="govuk-tag {{ credential.status.className }}">{{ credential.status.label }}</strong>
            </td>
            <td class="govuk-table__cell">{{ credential.expiryLabel }}</td>
            <td class="govuk-table__cell">{{ credential.uploadedLabel }}</td>
            <td class="govuk-table__cell">
              {% if credential.id %}
                <form method="post" action="{{ urlFor('/volunteering/credentials/' ~ credential.id ~ '/delete') }}">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button">
                    {{ credential.deleteLabel }}<span class="govuk-visually-hidden"> {{ credential.deleteAriaLabel }}</span>
                  </button>
                </form>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
    </div>
  {% endif %}
{% endblock %}
