{% extends "layouts/base.njk" %}

{% block content %}
  <a class="govuk-back-link" href="{{ urlFor('/volunteering') }}">{{ t("actions.back_to_volunteering") }}</a>

  {% if status %}
    {% if status.type == "success" %}
      <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="credential-success-title">
        <div class="govuk-notification-banner__header">
          <h2 class="govuk-notification-banner__title" id="credential-success-title">{{ t("states.success_title") }}</h2>
        </div>
        <div class="govuk-notification-banner__content">
          <p class="govuk-notification-banner__heading">{{ status.message }}</p>
        </div>
      </div>
    {% else %}
      <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
        <div role="alert">
          <h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2>
          <div class="govuk-error-summary__body">
            {% if status.field %}
              <ul class="govuk-list govuk-error-summary__list">
                <li><a href="#{{ status.field }}">{{ status.linkText or status.message }}</a></li>
              </ul>
            {% else %}
              <p>{{ status.message }}</p>
            {% endif %}
          </div>
        </div>
      </div>
    {% endif %}
  {% endif %}

  <span class="govuk-caption-l">Volunteering</span>
  <h1 class="govuk-heading-xl">My credentials</h1>
  <p class="govuk-body-l">Upload checks and certificates so organisations can verify you. Files are private and only shared with administrators.</p>

  <form method="post" action="{{ urlFor('/volunteering/credentials') }}" enctype="multipart/form-data" class="govuk-!-margin-bottom-7">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    <h2 class="govuk-heading-m">Upload a credential</h2>

    <div class="govuk-form-group{% if status and status.field == 'credential_type' %} govuk-form-group--error{% endif %}">
      <label class="govuk-label govuk-label--m" for="credential_type">Credential type</label>
      <div id="credential-type-hint" class="govuk-hint">For example: police check, first aid, safeguarding.</div>
      {% if status and status.field == 'credential_type' %}
        <p id="credential-type-error" class="govuk-error-message"><span class="govuk-visually-hidden">{{ t("states.error_prefix") }}</span> {{ status.message }}</p>
      {% endif %}
      <select class="govuk-select" id="credential_type" name="credential_type" aria-describedby="credential-type-hint{% if status and status.field == 'credential_type' %} credential-type-error{% endif %}">
        <option value="">Select a credential type</option>
        {% for credentialType in credentialTypes %}
          <option value="{{ credentialType.value }}">{{ credentialType.label }}</option>
        {% endfor %}
      </select>
    </div>

    <div class="govuk-form-group{% if status and status.field == 'document' %} govuk-form-group--error{% endif %}">
      <label class="govuk-label govuk-label--m" for="document">Upload a file</label>
      <div id="document-hint" class="govuk-hint">PDF, JPG, PNG or WEBP. Maximum size 10MB.</div>
      {% if status and status.field == 'document' %}
        <p id="document-error" class="govuk-error-message"><span class="govuk-visually-hidden">{{ t("states.error_prefix") }}</span> {{ status.message }}</p>
      {% endif %}
      <input class="govuk-file-upload" id="document" name="document" type="file" accept=".pdf,.jpg,.jpeg,.png,.webp" aria-describedby="document-hint{% if status and status.field == 'document' %} document-error{% endif %}">
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--m" for="expiry_date">Expiry date</label>
      <div id="expiry-date-hint" class="govuk-hint">Leave blank if the credential does not expire. For example, 2027-01-31.</div>
      <input class="govuk-input govuk-input--width-10" id="expiry_date" name="expiry_date" type="date" aria-describedby="expiry-date-hint">
    </div>

    <button class="govuk-button" data-module="govuk-button">Upload credential</button>
  </form>

  {% if loadError %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2>
        <div class="govuk-error-summary__body">
          <p>{{ loadError }}</p>
        </div>
      </div>
    </div>
  {% endif %}

  <h2 class="govuk-heading-l">Your credentials</h2>
  {% if not credentials.length %}
    <p class="govuk-body">You have not uploaded any credentials yet.</p>
  {% else %}
    <table class="govuk-table">
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header">Type</th>
          <th scope="col" class="govuk-table__header">Status</th>
          <th scope="col" class="govuk-table__header">Expires</th>
          <th scope="col" class="govuk-table__header">Uploaded</th>
          <th scope="col" class="govuk-table__header"><span class="govuk-visually-hidden">Action</span></th>
        </tr>
      </thead>
      <tbody class="govuk-table__body">
        {% for credential in credentials %}
          <tr class="govuk-table__row">
            <th scope="row" class="govuk-table__header">
              {{ credential.typeLabel }}
              {% if credential.fileName %}
                <span class="govuk-hint govuk-!-margin-bottom-0">{{ credential.fileName }}</span>
              {% endif %}
            </th>
            <td class="govuk-table__cell">
              <strong class="govuk-tag {{ credential.status.className }}">{{ credential.status.label }}</strong>
            </td>
            <td class="govuk-table__cell">{{ credential.expiryLabel }}</td>
            <td class="govuk-table__cell">{{ credential.uploadedLabel }}</td>
            <td class="govuk-table__cell">
              {% if credential.id %}
                <form method="post" action="{{ urlFor('/volunteering/credentials/' ~ credential.id ~ '/delete') }}">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button" aria-label="Delete the {{ credential.typeLabel }} credential">
                    {{ t("jobs_t3.delete_button") }}<span class="govuk-visually-hidden"> the {{ credential.typeLabel }} credential</span>
                  </button>
                </form>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% endif %}
{% endblock %}
