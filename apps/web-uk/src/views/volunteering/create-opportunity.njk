{% extends "layouts/base.njk" %}

{% block content %}
  <a class="govuk-back-link" href="{{ urlFor('/volunteering/my-organisations') }}">Back to my organisations</a>

  {% if status %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          {% if status.type == "validation" %}
            <ul class="govuk-list govuk-error-summary__list">
              {% for error in status.errors %}
                <li><a href="{{ error.href }}">{{ error.text }}</a></li>
              {% endfor %}
            </ul>
          {% else %}
            <p>{{ status.message }}</p>
          {% endif %}
        </div>
      </div>
    </div>
  {% endif %}

  {% if loadError %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <p>{{ loadError }}</p>
        </div>
      </div>
    </div>
  {% endif %}

  <h1 class="govuk-heading-xl">Post a volunteer opportunity</h1>
  <p class="govuk-body-l">Create a new opportunity for one of your organisations. Volunteers can then apply and log hours.</p>

  {% if not organizations.length %}
    <div class="govuk-inset-text">
      <p class="govuk-body">You need an approved organisation where you are an owner or admin before you can create opportunities.</p>
      <p class="govuk-body govuk-!-margin-bottom-0">Go back to my organisations to register one or wait for approval.</p>
    </div>
  {% else %}
    <form method="post" action="{{ urlFor('/volunteering/opportunities/create') }}">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}">

      <div class="govuk-form-group">
        <label class="govuk-label" for="organization_id">Organisation</label>
        <div id="organization_id-hint" class="govuk-hint">Choose an approved organisation where you are an owner or admin.</div>
        <select class="govuk-select" id="organization_id" name="organization_id" aria-describedby="organization_id-hint" required>
          <option value="">Select an organisation</option>
          {% for organization in organizations %}
            <option value="{{ organization.id }}">{{ organization.name }}</option>
          {% endfor %}
        </select>
      </div>

      <div class="govuk-form-group">
        <label class="govuk-label" for="title">Opportunity title</label>
        <div id="title-hint" class="govuk-hint">Use a short title people can recognise.</div>
        <input class="govuk-input" id="title" name="title" type="text" maxlength="200" aria-describedby="title-hint" required>
      </div>

      <div class="govuk-form-group">
        <label class="govuk-label" for="description">Description</label>
        <div id="description-hint" class="govuk-hint">Explain what volunteers will do and who they will support.</div>
        <textarea class="govuk-textarea" id="description" name="description" rows="6" aria-describedby="description-hint" required></textarea>
      </div>

      <div class="govuk-form-group">
        <label class="govuk-label" for="location">Location</label>
        <div id="location-hint" class="govuk-hint">Add a place or area if the role is not fully remote.</div>
        <input class="govuk-input" id="location" name="location" type="text" maxlength="255" aria-describedby="location-hint">
      </div>

      <div class="govuk-form-group">
        <label class="govuk-label" for="skills_needed">Skills needed</label>
        <div id="skills_needed-hint" class="govuk-hint">List any useful skills, checks, or experience.</div>
        <input class="govuk-input" id="skills_needed" name="skills_needed" type="text" maxlength="255" aria-describedby="skills_needed-hint">
      </div>

      <div class="govuk-form-group">
        <label class="govuk-label" for="category_id">Category</label>
        <select class="govuk-select" id="category_id" name="category_id">
          <option value="">Select a category</option>
          {% for category in categories %}
            <option value="{{ category.id }}">{{ category.name }}</option>
          {% endfor %}
        </select>
      </div>

      <div class="govuk-grid-row">
        <div class="govuk-grid-column-one-half">
          <div class="govuk-form-group">
            <label class="govuk-label" for="start_date">Start date</label>
            <div id="start_date-hint" class="govuk-hint">Use this if the role starts on a specific date.</div>
            <input class="govuk-input govuk-input--width-10" id="start_date" name="start_date" type="date" aria-describedby="start_date-hint">
          </div>
        </div>
        <div class="govuk-grid-column-one-half">
          <div class="govuk-form-group">
            <label class="govuk-label" for="end_date">End date</label>
            <input class="govuk-input govuk-input--width-10" id="end_date" name="end_date" type="date">
          </div>
        </div>
      </div>

      <fieldset class="govuk-fieldset govuk-!-margin-bottom-4">
        <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Visibility</legend>
        <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
          <div class="govuk-checkboxes__item">
            <input class="govuk-checkboxes__input" id="is_remote" name="is_remote" type="checkbox" value="1">
            <label class="govuk-label govuk-checkboxes__label" for="is_remote">This opportunity can be done remotely</label>
          </div>
          <div class="govuk-checkboxes__item">
            <input class="govuk-checkboxes__input" id="federated_visibility" name="federated_visibility" type="checkbox" value="1" aria-describedby="federated-hint">
            <label class="govuk-label govuk-checkboxes__label" for="federated_visibility">Share this opportunity across the network</label>
            <div id="federated-hint" class="govuk-hint govuk-checkboxes__hint">Network visibility lets partner communities discover the role where federation is enabled.</div>
          </div>
        </div>
      </fieldset>

      <button class="govuk-button" data-module="govuk-button">Post opportunity</button>
    </form>
  {% endif %}
{% endblock %}
