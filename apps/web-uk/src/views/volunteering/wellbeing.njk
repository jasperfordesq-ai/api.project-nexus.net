{% extends "layouts/base.njk" %}

{% block content %}
  <a class="govuk-back-link" href="{{ urlFor('/volunteering') }}">{{ t("actions.back_to_volunteering") }}</a>

  {% if status %}
    {% if status.type == "success" %}
      <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="wellbeing-success-title">
        <div class="govuk-notification-banner__header">
          <h2 class="govuk-notification-banner__title" id="wellbeing-success-title">{{ t("states.success_title") }}</h2>
        </div>
        <div class="govuk-notification-banner__content">
          <p class="govuk-notification-banner__heading">{{ status.message }}</p>
        </div>
      </div>
    {% else %}
      <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
        <div role="alert">
          <h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2>
          <div class="govuk-error-summary__body">
            <p>{{ status.message }}</p>
          </div>
        </div>
      </div>
    {% endif %}
  {% endif %}

  <span class="govuk-caption-l">Volunteering</span>
  <h1 class="govuk-heading-xl">My wellbeing</h1>
  <p class="govuk-body-l">A private summary of your volunteering balance, to help you avoid burnout. Only you can see this.</p>

  {% if loadError %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2>
        <div class="govuk-error-summary__body">
          <p>{{ loadError }}</p>
        </div>
      </div>
    </div>
  {% endif %}

  <div class="govuk-form-group">
    <label class="govuk-label govuk-label--m" for="wellbeing-score">Wellbeing score</label>
    <p class="govuk-body govuk-!-margin-bottom-1">{{ wellbeing.score }} out of 100</p>
    <progress id="wellbeing-score" max="100" value="{{ wellbeing.score }}" aria-label="Wellbeing score">{{ wellbeing.score }}%</progress>
  </div>

  <p class="govuk-body">
    Burnout risk:
    <strong class="govuk-tag {{ wellbeing.risk.className }}">{{ wellbeing.risk.label }}</strong>
  </p>

  <dl class="nexus-alpha-stat-grid">
    <div class="nexus-alpha-stat">
      <dt>Hours this week</dt>
      <dd>{{ wellbeing.hoursThisWeekLabel }}</dd>
    </div>
    <div class="nexus-alpha-stat">
      <dt>Hours this month</dt>
      <dd>{{ wellbeing.hoursThisMonthLabel }}</dd>
    </div>
    <div class="nexus-alpha-stat">
      <dt>Day streak</dt>
      <dd>{{ wellbeing.streakDays }}</dd>
    </div>
  </dl>

  <h2 class="govuk-heading-l">Things to be aware of</h2>
  {% if wellbeing.warnings.length %}
    <ul class="govuk-list govuk-list--bullet">
      {% for warning in wellbeing.warnings %}
        <li>{{ warning }}</li>
      {% endfor %}
    </ul>
  {% else %}
    <div class="govuk-inset-text">No wellbeing warnings right now. Keep up the good balance.</div>
  {% endif %}

  <h2 class="govuk-heading-l">How are you feeling?</h2>
  <p class="govuk-body">Record a quick mood check-in. This helps you track how volunteering is going.</p>
  <form method="post" action="{{ urlFor('/volunteering/wellbeing/checkin') }}" class="govuk-!-margin-bottom-8">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    <fieldset class="govuk-fieldset">
      <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Your mood</legend>
      <div class="govuk-radios govuk-radios--small" data-module="govuk-radios">
        {% for mood in wellbeing.moodOptions %}
          <div class="govuk-radios__item">
            <input class="govuk-radios__input" id="mood-{{ mood.value }}" name="mood" type="radio" value="{{ mood.value }}"{% if mood.checked %} checked{% endif %}>
            <label class="govuk-label govuk-radios__label" for="mood-{{ mood.value }}">{{ mood.label }}</label>
          </div>
        {% endfor %}
      </div>
    </fieldset>
    <div class="govuk-form-group govuk-!-margin-top-4">
      <label class="govuk-label" for="note">Note optional</label>
      <div id="note-hint" class="govuk-hint">Anything you want to remember about today.</div>
      <textarea class="govuk-textarea" id="note" name="note" rows="3" maxlength="500" aria-describedby="note-hint"></textarea>
    </div>
    <button class="govuk-button" data-module="govuk-button">Save check-in</button>
  </form>

  <h2 class="govuk-heading-l">Recent check-ins</h2>
  {% if wellbeing.recentCheckins.length %}
    <table class="govuk-table">
      <caption class="govuk-visually-hidden">Recent check-ins</caption>
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header">Date</th>
          <th scope="col" class="govuk-table__header">Mood</th>
          <th scope="col" class="govuk-table__header">Note</th>
        </tr>
      </thead>
      <tbody class="govuk-table__body">
        {% for checkin in wellbeing.recentCheckins %}
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">{{ checkin.createdAtLabel or "-" }}</td>
            <td class="govuk-table__cell">{{ checkin.moodLabel }}</td>
            <td class="govuk-table__cell">{{ checkin.note }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% else %}
    <div class="govuk-inset-text">No check-ins yet.</div>
  {% endif %}
{% endblock %}
