{% extends "layouts/base.njk" %}

{% block content %}
  <a class="govuk-back-link" href="{{ urlFor('/volunteering/organisations/' ~ orgId ~ '/dashboard') }}">Back to dashboard</a>

  {% if status and status.type == "success" %}
    <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="org-wallet-success-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="org-wallet-success-title">Success</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ status.message }}</p>
      </div>
    </div>
  {% elif status and status.type == "error" %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body"><p>{{ status.message }}</p></div>
      </div>
    </div>
  {% endif %}

  <span class="govuk-caption-l">{{ orgName }}</span>
  <h1 class="govuk-heading-xl">Organisation wallet</h1>
  <p class="govuk-body-l">Manage the time-credit float used for volunteer hours and organisation payouts.</p>

  {% if loadError %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body"><p>{{ loadError }}</p></div>
      </div>
    </div>
  {% endif %}

  <dl class="nexus-alpha-stat-grid">
    <div class="nexus-alpha-stat">
      <dt>Balance</dt>
      <dd>{{ summary.balanceLabel }}</dd>
    </div>
    <div class="nexus-alpha-stat">
      <dt>Total deposited</dt>
      <dd>{{ summary.totalDepositedLabel }}</dd>
    </div>
    <div class="nexus-alpha-stat">
      <dt>Total paid out</dt>
      <dd>{{ summary.totalPaidOutLabel }}</dd>
    </div>
    <div class="nexus-alpha-stat">
      <dt>Pending hours value</dt>
      <dd>{{ summary.pendingHoursValueLabel }}</dd>
    </div>
  </dl>

  <h2 class="govuk-heading-l">Auto-pay</h2>
  <p class="govuk-body">Automatically credit approved volunteer hours from this organisation's wallet when possible.</p>
  <p class="govuk-body">
    <strong class="govuk-tag {% if autoPayEnabled %}govuk-tag--green{% else %}govuk-tag--grey{% endif %}">
      {% if autoPayEnabled %}Auto-pay is on{% else %}Auto-pay is off{% endif %}
    </strong>
  </p>
  <form method="post" action="{{ urlFor('/volunteering/organisations/' ~ orgId ~ '/wallet/auto-pay') }}" class="govuk-!-margin-bottom-8">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    <input type="hidden" name="enabled" value="{% if autoPayEnabled %}0{% else %}1{% endif %}">
    <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">
      {% if autoPayEnabled %}Disable auto-pay{% else %}Enable auto-pay{% endif %}
    </button>
  </form>

  <h2 class="govuk-heading-l">Add credits</h2>
  <div class="govuk-warning-text">
    <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
    <strong class="govuk-warning-text__text">
      <span class="govuk-visually-hidden">Warning</span>
      Deposits move credits from your wallet into this organisation's wallet.
    </strong>
  </div>
  <form method="post" action="{{ urlFor('/volunteering/organisations/' ~ orgId ~ '/wallet/deposit') }}" class="govuk-!-margin-bottom-8">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    <div class="govuk-form-group{% if status and status.field == 'amount' %} govuk-form-group--error{% endif %}">
      <label class="govuk-label" for="amount">Amount</label>
      <div id="amount-hint" class="govuk-hint">Enter the number of time credits to add.</div>
      {% if status and status.field == 'amount' %}
        <p id="amount-error" class="govuk-error-message"><span class="govuk-visually-hidden">Error:</span> {{ status.message }}</p>
      {% endif %}
      <input class="govuk-input govuk-input--width-5" id="amount" name="amount" type="text" inputmode="decimal" aria-describedby="amount-hint{% if status and status.field == 'amount' %} amount-error{% endif %}" required>
    </div>
    <div class="govuk-form-group">
      <label class="govuk-label" for="note">Note <span class="govuk-hint govuk-!-display-inline">optional</span></label>
      <input class="govuk-input" id="note" name="note" type="text" maxlength="255">
    </div>
    <button class="govuk-button" data-module="govuk-button">Add credits</button>
  </form>

  <h2 class="govuk-heading-l">Transactions</h2>
  {% if not transactions.length %}
    <div class="govuk-inset-text">There are no wallet transactions for this organisation yet.</div>
  {% else %}
    <table class="govuk-table">
      <caption class="govuk-visually-hidden">Organisation wallet transactions</caption>
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header">When</th>
          <th scope="col" class="govuk-table__header">Type</th>
          <th scope="col" class="govuk-table__header govuk-table__header--numeric">Amount</th>
          <th scope="col" class="govuk-table__header govuk-table__header--numeric">Balance after</th>
          <th scope="col" class="govuk-table__header">Description</th>
        </tr>
      </thead>
      <tbody class="govuk-table__body">
        {% for transaction in transactions %}
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">{{ transaction.createdAtLabel }}</td>
            <td class="govuk-table__cell">{{ transaction.typeLabel }}</td>
            <td class="govuk-table__cell govuk-table__cell--numeric">{{ transaction.amountLabel }}</td>
            <td class="govuk-table__cell govuk-table__cell--numeric">{{ transaction.balanceAfterLabel }}</td>
            <td class="govuk-table__cell">{{ transaction.description }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% endif %}
{% endblock %}
