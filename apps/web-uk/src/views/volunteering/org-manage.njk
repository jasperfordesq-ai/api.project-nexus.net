{% extends "layouts/base.njk" %}

{% block content %}
  <a class="govuk-back-link" href="/volunteering?tab=organisations">Back to volunteering</a>

  <span class="govuk-caption-l">{{ orgName }}</span>
  <h1 class="govuk-heading-xl">Manage your organisation</h1>
  <p class="govuk-body-l">Approve volunteer applications and approve the hours volunteers have logged.</p>

  {% if status and status.type == "success" %}
    <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="org-manage-success-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="org-manage-success-title">Success</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ status.message }}</p>
      </div>
    </div>
  {% elif status and status.type == "error" %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body"><p>{{ status.message }}</p></div>
      </div>
    </div>
  {% endif %}

  {% if loadError %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body"><p>{{ loadError }}</p></div>
      </div>
    </div>
  {% endif %}

  <h2 class="govuk-heading-l">Applications awaiting a decision</h2>
  {% if not applications.length %}
    <div class="govuk-inset-text">
      <p class="govuk-body">There are no pending applications for this organisation.</p>
      <p class="govuk-body govuk-!-margin-bottom-0">New applications appear here when members apply for your opportunities.</p>
    </div>
  {% else %}
    <div class="nexus-alpha-card-list">
      {% for application in applications %}
        <article class="nexus-alpha-card">
          <h3 class="govuk-heading-m govuk-!-margin-bottom-2">
            {% if application.applicant.id %}
              <a class="govuk-link" href="/members/{{ application.applicant.id }}">{{ application.applicant.name }}</a>
            {% else %}
              {{ application.applicant.name }}
            {% endif %}
          </h3>
          <dl class="govuk-summary-list govuk-!-margin-bottom-0">
            <div class="govuk-summary-list__row">
              <dt class="govuk-summary-list__key">Opportunity</dt>
              <dd class="govuk-summary-list__value">
                {% if application.opportunity.id %}
                  <a class="govuk-link" href="/volunteering/opportunities/{{ application.opportunity.id }}">{{ application.opportunity.title }}</a>
                {% else %}
                  {{ application.opportunity.title }}
                {% endif %}
              </dd>
            </div>
            {% if application.shiftLabel %}
              <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">Shift</dt>
                <dd class="govuk-summary-list__value">{{ application.shiftLabel }}</dd>
              </div>
            {% endif %}
            {% if application.createdAtLabel %}
              <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">Applied on</dt>
                <dd class="govuk-summary-list__value">{{ application.createdAtLabel }}</dd>
              </div>
            {% endif %}
          </dl>
          {% if application.message %}
            <p class="govuk-body govuk-!-margin-top-3 govuk-!-margin-bottom-1"><strong>Applicant message</strong></p>
            <div class="govuk-inset-text govuk-!-margin-top-0">{{ application.message }}</div>
          {% endif %}
          <form method="post" action="/volunteering/organisations/{{ orgId }}/applications/{{ application.id }}">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <div class="govuk-button-group">
              <button class="govuk-button govuk-!-margin-bottom-0" name="action" value="approve" data-module="govuk-button">Approve application</button>
              <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" name="action" value="decline" data-module="govuk-button">Decline application</button>
            </div>
          </form>
        </article>
      {% endfor %}
    </div>
  {% endif %}

  <h2 class="govuk-heading-l govuk-!-margin-top-8">Hours awaiting approval</h2>
  <div class="govuk-inset-text">Approving hours confirms the volunteer's time record and lets the platform credit their wallet.</div>
  {% if not hours.length %}
    <div class="govuk-inset-text">
      <p class="govuk-body">There are no pending hours for this organisation.</p>
      <p class="govuk-body govuk-!-margin-bottom-0">Submitted hours appear here when volunteers log time against your opportunities.</p>
    </div>
  {% else %}
    <div class="nexus-alpha-card-list">
      {% for log in hours %}
        <article class="nexus-alpha-card">
          <h3 class="govuk-heading-m govuk-!-margin-bottom-2">
            {% if log.volunteer.id %}
              <a class="govuk-link" href="/members/{{ log.volunteer.id }}">{{ log.volunteer.name }}</a>
            {% else %}
              {{ log.volunteer.name }}
            {% endif %}
          </h3>
          <dl class="govuk-summary-list govuk-!-margin-bottom-0">
            <div class="govuk-summary-list__row">
              <dt class="govuk-summary-list__key">Hours</dt>
              <dd class="govuk-summary-list__value">{{ log.hoursLabel }}</dd>
            </div>
            {% if log.dateLabel %}
              <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">Date</dt>
                <dd class="govuk-summary-list__value">{{ log.dateLabel }}</dd>
              </div>
            {% endif %}
            {% if log.opportunity.title %}
              <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">Opportunity</dt>
                <dd class="govuk-summary-list__value">{{ log.opportunity.title }}</dd>
              </div>
            {% endif %}
          </dl>
          {% if log.description %}
            <p class="govuk-body govuk-!-margin-top-3">{{ log.description }}</p>
          {% endif %}
          <form method="post" action="/volunteering/organisations/{{ orgId }}/hours/{{ log.id }}">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <div class="govuk-button-group">
              <button class="govuk-button govuk-!-margin-bottom-0" name="action" value="approve" data-module="govuk-button">Approve hours</button>
              <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" name="action" value="decline" data-module="govuk-button">Decline hours</button>
            </div>
          </form>
        </article>
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
