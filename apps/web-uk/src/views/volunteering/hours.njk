{% extends "layouts/base.njk" %}

{% block content %}
  <a class="govuk-back-link" href="/volunteering">Back to volunteering</a>

  {% if status %}
    {% if status.type == "success" %}
      <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="hours-success-title">
        <div class="govuk-notification-banner__header">
          <h2 class="govuk-notification-banner__title" id="hours-success-title">Success</h2>
        </div>
        <div class="govuk-notification-banner__content">
          <p class="govuk-notification-banner__heading">{{ status.message }}</p>
        </div>
      </div>
    {% else %}
      <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
        <div role="alert">
          <h2 class="govuk-error-summary__title">There is a problem</h2>
          <div class="govuk-error-summary__body">
            <p>{{ status.message }}</p>
          </div>
        </div>
      </div>
    {% endif %}
  {% endif %}

  <span class="govuk-caption-l">Volunteering</span>
  <h1 class="govuk-heading-xl">Volunteering hours</h1>

  <div class="govuk-inset-text" role="note">
    <p class="govuk-body govuk-!-margin-bottom-0">When an organisation approves your hours, the time credits are added to your wallet automatically - 1 time credit for every hour you give.</p>
  </div>

  {% if loadError %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <p>{{ loadError }}</p>
        </div>
      </div>
    </div>
  {% endif %}

  <dl class="nexus-alpha-stat-grid">
    <div class="nexus-alpha-stat">
      <dt>Approved hours</dt>
      <dd>{{ summary.approvedHoursLabel }}</dd>
    </div>
    <div class="nexus-alpha-stat">
      <dt>Pending hours</dt>
      <dd>{{ summary.pendingHoursLabel }}</dd>
    </div>
    <div class="nexus-alpha-stat">
      <dt>This month</dt>
      <dd>{{ summary.thisMonthHoursLabel }}</dd>
    </div>
  </dl>

  {% if nextGoal %}
    <div class="govuk-!-margin-bottom-6">
      <label class="govuk-visually-hidden" for="hours-goal-progress">{{ summary.approvedHoursLabel }} of {{ nextGoal }} hours</label>
      <progress id="hours-goal-progress" max="{{ nextGoal }}" value="{{ summary.approvedTotal }}">{{ summary.approvedHoursLabel }} / {{ nextGoal }}</progress>
      <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-top-1">{{ summary.approvedHoursLabel }} of {{ nextGoal }} hours</p>
    </div>
  {% endif %}

  {% if summary.byOrganization.length %}
    <h2 class="govuk-heading-m govuk-!-margin-top-7">Hours by organisation</h2>
    <table class="govuk-table">
      <caption class="govuk-table__caption govuk-table__caption--s govuk-visually-hidden">Hours by organisation</caption>
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header">Organisation</th>
          <th scope="col" class="govuk-table__header govuk-table__header--numeric">Approved hours</th>
        </tr>
      </thead>
      <tbody class="govuk-table__body">
        {% for row in summary.byOrganization %}
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">{{ row.name }}</td>
            <td class="govuk-table__cell govuk-table__cell--numeric">{{ row.hoursLabel }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% endif %}

  {% if summary.byMonth.length %}
    <h2 class="govuk-heading-m">Hours by month</h2>
    <table class="govuk-table">
      <caption class="govuk-table__caption govuk-table__caption--s govuk-visually-hidden">Hours by month</caption>
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header">Month</th>
          <th scope="col" class="govuk-table__header govuk-table__header--numeric">Approved hours</th>
        </tr>
      </thead>
      <tbody class="govuk-table__body">
        {% for row in summary.byMonth %}
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">{{ row.monthLabel }}</td>
            <td class="govuk-table__cell govuk-table__cell--numeric">{{ row.hoursLabel }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% endif %}

  <form method="post" action="/volunteering/hours" class="govuk-!-margin-top-7">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    <fieldset class="govuk-fieldset">
      <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">
        <h2 class="govuk-fieldset__heading">Log volunteering hours</h2>
      </legend>
      <div class="govuk-hint">Record the time you have already volunteered. The organisation reviews each entry, and approved hours become time credits in your wallet automatically.</div>
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-one-half">
          <div class="govuk-form-group">
            <label class="govuk-label" for="organization_id">Organisation</label>
            <div id="organization-id-hint" class="govuk-hint">Choose the organisation you volunteered for. They will review and approve the hours.</div>
            <select class="govuk-select" id="organization_id" name="organization_id" aria-describedby="organization-id-hint" required>
              {% for organization in organizations %}
                <option value="{{ organization.id }}">{{ organization.name }}</option>
              {% endfor %}
            </select>
          </div>
        </div>
        <div class="govuk-grid-column-one-half">
          <div class="govuk-form-group">
            <label class="govuk-label" for="opportunity_id">Related opportunity</label>
            <select class="govuk-select" id="opportunity_id" name="opportunity_id">
              <option value="">No related opportunity</option>
              {% for application in applications %}
                {% if application.opportunity.id %}
                  <option value="{{ application.opportunity.id }}">{{ application.opportunity.title }}</option>
                {% endif %}
              {% endfor %}
            </select>
          </div>
        </div>
      </div>
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-one-half">
          <div class="govuk-form-group">
            <label class="govuk-label" for="date">Date</label>
            <div id="date-hint" class="govuk-hint">The day you did the volunteering, not today's date.</div>
            <input class="govuk-input govuk-input--width-10" id="date" name="date" type="date" value="{{ today }}" aria-describedby="date-hint" required>
          </div>
        </div>
        <div class="govuk-grid-column-one-half">
          <div class="govuk-form-group">
            <label class="govuk-label" for="hours">Hours</label>
            <div id="log-hours-hint" class="govuk-hint">Enter the hours you volunteered, between 0.25 and 24, in quarter-hour steps.</div>
            <input class="govuk-input govuk-input--width-5" id="hours" name="hours" type="number" min="0.25" max="24" step="0.25" aria-describedby="log-hours-hint" required>
          </div>
        </div>
      </div>
      <div class="govuk-form-group">
        <label class="govuk-label" for="description">What did you do?</label>
        <div id="description-hint" class="govuk-hint">Briefly describe what you did. This helps the organisation recognise and approve your hours.</div>
        <textarea class="govuk-textarea" id="description" name="description" rows="5" aria-describedby="description-hint"></textarea>
      </div>
    </fieldset>
    <button class="govuk-button" data-module="govuk-button"{% if not organizations.length %} disabled{% endif %}>Log hours</button>
  </form>

  <h2 class="govuk-heading-l govuk-!-margin-top-8">Recent hour logs</h2>
  {% if not logs.length %}
    <div class="govuk-inset-text">
      <p class="govuk-body">No volunteering hours have been logged yet.</p>
      <p class="govuk-body govuk-!-margin-bottom-0">When you have given some time, use the form above to log your hours. Once an organisation approves them, the time credits are added to your wallet automatically.</p>
    </div>
  {% else %}
    <p class="govuk-body">Each entry shows where your logged hours are: submitted for review, then approved. Approved hours are credited to your wallet automatically - 1 time credit for every hour.</p>
    <div class="nexus-alpha-card-list">
      {% for log in logs %}
        <article class="nexus-alpha-card">
          <h3 class="govuk-heading-m govuk-!-margin-bottom-2">{{ log.dateLabel }}</h3>
          <p class="govuk-!-margin-bottom-2">
            <strong class="govuk-tag {{ log.status.className }}">{{ log.status.label }}</strong>
          </p>
          {% if log.status.note %}
            <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-2">{{ log.status.note }}</p>
          {% endif %}
          <dl class="nexus-alpha-inline-list">
            <div>
              <dt>Hours</dt>
              <dd>{{ log.hoursLabel }}</dd>
            </div>
            {% if log.organizationName %}
              <div>
                <dt>Organisation</dt>
                <dd>{{ log.organizationName }}</dd>
              </div>
            {% endif %}
          </dl>
          {% if log.description %}
            <p class="govuk-body govuk-!-margin-top-3">{{ log.description }}</p>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
