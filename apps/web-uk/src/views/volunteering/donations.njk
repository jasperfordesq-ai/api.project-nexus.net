{% extends "layouts/base.njk" %}

{% block content %}
  <a class="govuk-back-link" href="{{ urlFor('/volunteering') }}">Back to volunteering</a>

  {% if status %}
    {% if status.type == "success" %}
      <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="donations-success-title">
        <div class="govuk-notification-banner__header">
          <h2 class="govuk-notification-banner__title" id="donations-success-title">Success</h2>
        </div>
        <div class="govuk-notification-banner__content">
          <p class="govuk-notification-banner__heading">{{ status.message }}</p>
        </div>
      </div>
    {% else %}
      <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
        <div role="alert">
          <h2 class="govuk-error-summary__title">There is a problem</h2>
          <div class="govuk-error-summary__body">
            <ul class="govuk-list govuk-error-summary__list">
              <li><a href="#{{ status.field or 'donate-amount' }}">{{ status.message }}</a></li>
            </ul>
          </div>
        </div>
      </div>
    {% endif %}
  {% endif %}

  <span class="govuk-caption-l">Volunteering</span>
  <h1 class="govuk-heading-xl">Donations and giving</h1>
  <p class="govuk-body-l">Support your community with a money donation, and follow how active fundraising campaigns are doing.</p>

  <div class="govuk-inset-text" role="note" aria-labelledby="donations-intro-heading">
    <h2 class="govuk-heading-s govuk-!-margin-bottom-2" id="donations-intro-heading">About donations</h2>
    <p class="govuk-body govuk-!-margin-bottom-0">Donations are money gifts to support the community. They are not time credits. Time credits are still earned only by logging approved volunteer hours.</p>
  </div>

  {% if loadError %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <p>{{ loadError }}</p>
        </div>
      </div>
    </div>
  {% endif %}

  <h2 class="govuk-heading-l">Fundraising so far</h2>
  <dl class="nexus-alpha-stat-grid">
    <div class="nexus-alpha-stat">
      <dt>Total raised</dt>
      <dd>{{ dashboard.stats.totalRaisedLabel }}</dd>
    </div>
    <div class="nexus-alpha-stat">
      <dt>Donors</dt>
      <dd>{{ dashboard.stats.totalDonors }}</dd>
    </div>
    <div class="nexus-alpha-stat">
      <dt>Active campaigns</dt>
      <dd>{{ dashboard.stats.activeCampaigns }}</dd>
    </div>
  </dl>

  <h2 class="govuk-heading-l">Active giving days</h2>
  {% if dashboard.givingDays.length %}
    <ul class="nexus-alpha-card-list govuk-list">
      {% for day in dashboard.givingDays %}
        <li class="nexus-alpha-card">
          <h3 class="govuk-heading-m govuk-!-margin-bottom-1">
            {{ day.title }}
            <strong class="govuk-tag {{ day.status.className }}">{{ day.status.label }}</strong>
          </h3>
          {% if day.description %}
            <p class="govuk-body">{{ day.description }}</p>
          {% endif %}
          <p class="govuk-body govuk-!-margin-bottom-1">Raised {{ day.raisedLabel }} of {{ day.goalLabel }}</p>
          <progress max="100" value="{{ day.percent }}" aria-label="Fundraising progress: {{ day.percent }} percent of the goal">{{ day.percent }}%</progress>
          <p class="nexus-alpha-meta govuk-!-margin-top-1">
            <span>{{ day.donorsLabel }}</span>
            {% if day.endDateLabel %}
              <span>Campaign ends: {{ day.endDateLabel }}</span>
            {% endif %}
          </p>
          {% if day.id %}
            <a class="govuk-link" href="#donate-form" data-vol-giving-day="{{ day.id }}">Donate to this campaign</a>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <div class="govuk-inset-text">There are no active fundraising campaigns right now.</div>
  {% endif %}

  <h2 class="govuk-heading-l">My donations</h2>
  {% if dashboard.donations.length %}
    <table class="govuk-table">
      <caption class="govuk-visually-hidden">My donations</caption>
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header">Amount</th>
          <th scope="col" class="govuk-table__header">Status</th>
          <th scope="col" class="govuk-table__header">Method</th>
          <th scope="col" class="govuk-table__header">Date</th>
          <th scope="col" class="govuk-table__header">Message</th>
        </tr>
      </thead>
      <tbody class="govuk-table__body">
        {% for donation in dashboard.donations %}
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">{{ donation.amountLabel }} {{ donation.currency }}</td>
            <td class="govuk-table__cell">
              <strong class="govuk-tag {{ donation.status.className }}">{{ donation.status.label }}</strong>
              {% if donation.isAnonymous %}
                <strong class="govuk-tag govuk-tag--grey">Anonymous</strong>
              {% endif %}
            </td>
            <td class="govuk-table__cell">{{ donation.methodLabel }}</td>
            <td class="govuk-table__cell">{{ donation.createdAtLabel or "-" }}</td>
            <td class="govuk-table__cell">{{ donation.message }}</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% else %}
    <div class="govuk-inset-text">You have not made any donations yet.</div>
  {% endif %}

  <h2 class="govuk-heading-l" id="donate-form">Make a donation</h2>
  <p class="govuk-body">Record a donation by bank transfer or PayPal. An administrator will confirm it once the payment has arrived.</p>
  <form id="donate" method="post" action="{{ urlFor('/volunteering/donations#donate') }}" class="govuk-!-margin-bottom-8">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    <div class="govuk-form-group{% if status and status.type == 'error' %} govuk-form-group--error{% endif %}">
      <label class="govuk-label govuk-label--s" for="donate-amount">Amount</label>
      <div id="donate-amount-hint" class="govuk-hint">A whole or decimal amount, for example 25 or 25.50.</div>
      {% if status and status.type == 'error' %}
        <p id="donate-amount-error" class="govuk-error-message">
          <span class="govuk-visually-hidden">There is a problem:</span>
          {{ status.message }}
        </p>
      {% endif %}
      <div class="govuk-input__wrapper">
        <div class="govuk-input__prefix">{{ tenantCurrency }}</div>
        <input class="govuk-input govuk-input--width-10{% if status and status.type == 'error' %} govuk-input--error{% endif %}" id="donate-amount" name="amount" type="text" inputmode="decimal" spellcheck="false" aria-describedby="donate-amount-hint{% if status and status.type == 'error' %} donate-amount-error{% endif %}">
      </div>
    </div>

    {% if dashboard.givingDays.length %}
      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--s" for="donate-giving-day">Campaign</label>
        <div id="donate-giving-day-hint" class="govuk-hint">Choose a fundraising campaign, or leave as a general community donation.</div>
        <select class="govuk-select" id="donate-giving-day" name="giving_day_id" aria-describedby="donate-giving-day-hint">
          <option value="0">General community donation</option>
          {% for day in dashboard.givingDays %}
            {% if day.id %}
              <option value="{{ day.id }}">{{ day.title }}</option>
            {% endif %}
          {% endfor %}
        </select>
      </div>
    {% endif %}

    <div class="govuk-form-group">
      <fieldset class="govuk-fieldset" aria-describedby="donate-method-hint">
        <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Payment method</legend>
        <div id="donate-method-hint" class="govuk-hint">How you will send the donation.</div>
        <div class="govuk-radios govuk-radios--small" data-module="govuk-radios">
          {% for method in dashboard.paymentMethods %}
            <div class="govuk-radios__item">
              <input class="govuk-radios__input" id="donate-method-{{ method.value }}" name="payment_method" type="radio" value="{{ method.value }}"{% if method.checked %} checked{% endif %}>
              <label class="govuk-label govuk-radios__label" for="donate-method-{{ method.value }}">{{ method.label }}</label>
            </div>
          {% endfor %}
        </div>
      </fieldset>
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--s" for="donate-message">Message optional</label>
      <div id="donate-message-hint" class="govuk-hint">An optional note shown with your donation.</div>
      <textarea class="govuk-textarea" id="donate-message" name="message" rows="3" maxlength="500" aria-describedby="donate-message-hint"></textarea>
    </div>

    <div class="govuk-form-group">
      <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
        <div class="govuk-checkboxes__item">
          <input class="govuk-checkboxes__input" id="donate-anonymous" name="is_anonymous" type="checkbox" value="1" aria-describedby="donate-anonymous-hint">
          <label class="govuk-label govuk-checkboxes__label" for="donate-anonymous">Donate anonymously</label>
          <div id="donate-anonymous-hint" class="govuk-hint govuk-checkboxes__hint">Hide your name from public donor lists.</div>
        </div>
      </div>
    </div>

    <button class="govuk-button" data-module="govuk-button">Record donation</button>
  </form>
{% endblock %}
