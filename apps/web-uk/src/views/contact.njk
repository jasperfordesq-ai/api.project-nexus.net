{% extends "layouts/base.njk" %}

{% block mainContent %}
  {% set hasErrors = errors and (errors.name or errors.email or errors.message) %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <span class="govuk-caption-l">{{ tenantName }}</span>
      <h1 class="govuk-heading-xl">{{ t("contact.title") if t else title }}</h1>
      <p class="govuk-body-l">Have a question about {{ tenantName }}? We'd love to hear from you.</p>

      {% if status == 'contact-sent' %}
        <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="contact-success-title">
          <div class="govuk-notification-banner__header">
            <h2 class="govuk-notification-banner__title" id="contact-success-title">{{ t("states.success_title") }}</h2>
          </div>
          <div class="govuk-notification-banner__content">
            <p class="govuk-notification-banner__heading">{{ t("contact.success_title") }}</p>
            <p class="govuk-body">{{ t("contact.success_message") }}</p>
            <p class="govuk-body govuk-!-margin-bottom-0">
              <a class="govuk-link" href="{{ urlFor('/') }}">{{ t("contact.back_to_home") }}</a>
            </p>
          </div>
        </div>
      {% else %}
        {% if hasErrors %}
          <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
            <div role="alert">
              <h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2>
              <div class="govuk-error-summary__body">
                <ul class="govuk-list govuk-error-summary__list">
                  {% if errors.name %}<li><a href="#name">{{ errors.name }}</a></li>{% endif %}
                  {% if errors.email %}<li><a href="#email">{{ errors.email }}</a></li>{% endif %}
                  {% if errors.message %}<li><a href="#message">{{ errors.message }}</a></li>{% endif %}
                </ul>
              </div>
            </div>
          </div>
        {% elif statusMessage %}
          <div class="govuk-notification-banner" data-module="govuk-notification-banner" role="region" aria-labelledby="contact-error-title">
            <div class="govuk-notification-banner__header">
              <h2 class="govuk-notification-banner__title" id="contact-error-title">Error</h2>
            </div>
            <div class="govuk-notification-banner__content">
              <p class="govuk-notification-banner__heading">{{ statusMessage }}</p>
            </div>
          </div>
        {% endif %}

        <form method="post" action="{{ urlFor('/contact') }}" novalidate>
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">

          <fieldset class="govuk-fieldset">
            <legend class="govuk-fieldset__legend govuk-visually-hidden">{{ t("contact.form.fieldset_legend") }}</legend>

            <div class="govuk-form-group{% if errors.name %} govuk-form-group--error{% endif %}">
              <label class="govuk-label" for="name">Name</label>
              {% if errors.name %}
                <p id="name-error" class="govuk-error-message"><span class="govuk-visually-hidden">{{ t("states.error_prefix") }}</span> {{ errors.name }}</p>
              {% endif %}
              <input class="govuk-input{% if errors.name %} govuk-input--error{% endif %}" id="name" name="name" type="text" autocomplete="name" value="{{ values.name or '' }}" {% if errors.name %}aria-describedby="name-error"{% endif %}>
            </div>

            <div class="govuk-form-group{% if errors.email %} govuk-form-group--error{% endif %}">
              <label class="govuk-label" for="email">Email address</label>
              {% if errors.email %}
                <p id="email-error" class="govuk-error-message"><span class="govuk-visually-hidden">{{ t("states.error_prefix") }}</span> {{ errors.email }}</p>
              {% endif %}
              <input class="govuk-input govuk-!-width-two-thirds{% if errors.email %} govuk-input--error{% endif %}" id="email" name="email" type="email" autocomplete="email" value="{{ values.email or '' }}" {% if errors.email %}aria-describedby="email-error"{% endif %}>
            </div>

            <div class="govuk-form-group">
              <label class="govuk-label" for="subject">{{ t("contact.form.subject_label") }}</label>
              <select class="govuk-select" id="subject" name="subject">
                <option value="">{{ t("contact.form.subject_placeholder") }}</option>
                <option value="general" {% if values.subject == 'general' %}selected{% endif %}>{{ t("contact.form.subjects.general") }}</option>
                <option value="account" {% if values.subject == 'account' %}selected{% endif %}>{{ t("contact.form.subjects.account") }}</option>
                <option value="technical" {% if values.subject == 'technical' %}selected{% endif %}>{{ t("contact.form.subjects.technical") }}</option>
                <option value="feedback" {% if values.subject == 'feedback' %}selected{% endif %}>{{ t("contact.form.subjects.feedback") }}</option>
                <option value="other" {% if values.subject == 'other' %}selected{% endif %}>Other</option>
              </select>
            </div>

            <div class="govuk-form-group{% if errors.message %} govuk-form-group--error{% endif %}">
              <label class="govuk-label" for="message">Message</label>
              {% if errors.message %}
                <p id="message-error" class="govuk-error-message"><span class="govuk-visually-hidden">{{ t("states.error_prefix") }}</span> {{ errors.message }}</p>
              {% endif %}
              <textarea class="govuk-textarea{% if errors.message %} govuk-textarea--error{% endif %}" id="message" name="message" rows="5" {% if errors.message %}aria-describedby="message-error"{% endif %}>{{ values.message or '' }}</textarea>
            </div>
          </fieldset>

          <button class="govuk-button" data-module="govuk-button" type="submit">{{ t("contact.form.submit") }}</button>

          {% if not isAuthenticated %}
            <p class="govuk-body-s">
              {{ t("contact.form.login_prompt_before") }} <a class="govuk-link" href="{{ urlFor('/login') }}">{{ t("contact.form.login_link") }}</a> {{ t("contact.form.login_prompt_after") }}
            </p>
          {% endif %}
        </form>
      {% endif %}
    </div>
  </div>
{% endblock %}
