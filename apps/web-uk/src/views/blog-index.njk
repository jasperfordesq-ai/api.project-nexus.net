{% extends "layouts/base.njk" %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <span class="govuk-caption-l">{{ tenantName }}</span>
      <h1 class="govuk-heading-xl">Blog</h1>
      <p class="govuk-body-l">News, stories and updates from {{ tenantName }}.</p>

      <form method="get" action="{{ alphaRoutePrefix }}/blog" class="govuk-!-margin-bottom-6">
        <div class="govuk-form-group">
          <label class="govuk-label" for="q">Search the blog</label>
          <div id="q-hint" class="govuk-hint">Search by title or content.</div>
          <input class="govuk-input govuk-!-width-two-thirds" id="q" name="q" type="search" value="{{ searchQuery }}" aria-describedby="q-hint">
        </div>
        <button class="govuk-button govuk-button--secondary" data-module="govuk-button" type="submit">Search</button>
      </form>

      <h2 class="govuk-heading-m">Posts</h2>

      <div class="govuk-inset-text">
        {% if searchQuery %}
          No posts match your search.
        {% else %}
          No blog posts have been published yet.
        {% endif %}
      </div>
    </div>
  </div>
{% endblock %}
