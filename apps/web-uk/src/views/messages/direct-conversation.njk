{% extends "layouts/base.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <a href="{{ urlFor('/messages') }}" class="govuk-back-link">{{ t("govuk_alpha.actions.back_to_messages") }}</a>

      {% if directStatus and directStatus.type == "success" %}
        {% set notificationMessage = directStatus.message %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      {% if directStatus and directStatus.type == "error" %}
        {{ govukErrorSummary({
          titleText: t("govuk_alpha.states.error_title"),
          errorList: [{ text: directStatus.message, href: "#body" }]
        }) }}
      {% endif %}

      <span class="govuk-caption-xl">{{ t("govuk_alpha.messages.title") }}</span>
      <h1 class="govuk-heading-xl">{{ t("govuk_alpha.messages.conversation_title", { name: conversation.otherUser.name }) }}</h1>

      {% if listing %}
        <div class="govuk-inset-text">
          <a class="govuk-link" href="{{ urlFor('/listings/' + (listing.id | string)) }}">
            {{ t("govuk_alpha.messages.listing_context", { title: listing.title or listing.name }) }}
          </a>
        </div>
      {% endif %}

      {% if not directMessagingEnabled %}
        <div class="govuk-warning-text">
          <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
          <strong class="govuk-warning-text__text">
            <span class="govuk-visually-hidden">{{ t("govuk_alpha.states.warning") }}</span>
            {{ t("govuk_alpha.messages.disabled_detail") }}
          </strong>
        </div>
      {% elseif restricted %}
        <div class="govuk-warning-text">
          <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
          <strong class="govuk-warning-text__text">
            <span class="govuk-visually-hidden">{{ t("govuk_alpha.states.warning") }}</span>
            {{ t("govuk_alpha.messages.restricted_detail") }}
          </strong>
        </div>
      {% endif %}

      <form method="get" action="{{ urlFor('/messages/' + (conversation.id | string)) }}" class="govuk-!-margin-bottom-6">
        {% if listingId %}
          <input type="hidden" name="listing" value="{{ listingId }}">
        {% endif %}
        {{ govukInput({
          label: { text: t("polish_members.conversation_filter_label"), classes: "govuk-label--s" },
          hint: { text: t("polish_members.conversation_filter_hint") },
          id: "q",
          name: "q",
          value: query
        }) }}
        {{ govukButton({ text: t("govuk_alpha.actions.search"), classes: "govuk-button--secondary" }) }}
      </form>

      {% if meta.hasMore and olderHref %}
        <nav class="govuk-pagination govuk-pagination--block govuk-!-margin-bottom-4" aria-label="{{ t('govuk_alpha.messages.older_pagination_label') }}">
          <div class="govuk-pagination__prev">
            <a class="govuk-link govuk-pagination__link" href="{{ urlFor(olderHref) }}" rel="prev">
              <span class="govuk-pagination__link-title">{{ t("govuk_alpha.messages.show_older") }}</span>
            </a>
          </div>
        </nav>
      {% endif %}

      {% if messages and messages.length %}
        <ol class="app-messages-container govuk-list" role="log" aria-label="{{ t('govuk_alpha.messages.older_pagination_label') }}">
          {% for message in messages %}
            <li id="m-{{ message.id }}" class="app-message{% if message.isOwn %} app-message--own{% endif %}">
              <div class="app-message-header">
                <strong class="govuk-body-s govuk-!-font-weight-bold">{{ message.displaySenderName }}</strong>
                {% if message.created_at or message.createdAt %}
                  <span class="govuk-body-s">
                    {{ t("govuk_alpha.messages.sent_label") }} {{ (message.created_at or message.createdAt) | formatDate }}
                    {% if message.is_edited or message.isEdited %} · {{ t("govuk_alpha.messages.edited") }}{% endif %}
                  </span>
                {% endif %}
              </div>

              <div class="app-message-body">
                {% if message.isDeleted %}
                  <p class="govuk-body govuk-hint">{{ t("govuk_alpha.messages.deleted_placeholder") }}</p>
                {% else %}
                  {% if message.body %}
                    <p class="govuk-body">{{ message.body }}</p>
                  {% endif %}

                  {% if (message.is_voice or message.isVoice) and (message.audio_url or message.audioUrl) %}
                    <audio controls preload="none" src="{{ message.audio_url or message.audioUrl }}">
                      {{ t("govuk_alpha_messages.voice.no_audio_support") }}
                    </audio>
                    {% if message.transcript %}
                      <details class="govuk-details govuk-!-margin-top-2">
                        <summary class="govuk-details__summary">
                          <span class="govuk-details__summary-text">{{ t("govuk_alpha_messages.voice.transcript_toggle") }}</span>
                        </summary>
                        <div class="govuk-details__text">{{ message.transcript }}</div>
                      </details>
                    {% endif %}
                  {% endif %}

                  {% set attachments = message.attachments or [] %}
                  {% if attachments.length %}
                    <ul class="govuk-list govuk-list--bullet">
                      {% for attachment in attachments %}
                        {% set attachmentHref = attachment.url or attachment.file_url or attachment.download_url or attachment.path %}
                        {% set attachmentName = attachment.name or attachment.file_name or attachment.filename or t("govuk_alpha_messages.attachments.default_name") %}
                        <li>
                          {% if attachmentHref %}
                            <a class="govuk-link" href="{{ attachmentHref }}">{{ attachmentName }}</a>
                          {% else %}
                            {{ attachmentName }}
                          {% endif %}
                        </li>
                      {% endfor %}
                    </ul>
                  {% endif %}

                  {% if translation and translation.id == message.id and translation.text %}
                    <div class="govuk-inset-text govuk-!-margin-top-2">
                      <p class="govuk-body govuk-!-font-weight-bold govuk-!-margin-bottom-1">{{ t("govuk_alpha_messages.translate.translated_label") }}</p>
                      <p class="govuk-body govuk-!-margin-bottom-0">{{ translation.text }}</p>
                    </div>
                  {% elseif translationEnabled and message.id and (message.body or message.transcript) %}
                    <form method="post" action="{{ urlFor('/messages/' + (conversation.id | string) + '/m/' + (message.id | string) + '/translate') }}" class="govuk-!-margin-top-2">
                      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                      <input type="hidden" name="target_language" value="{{ locale }}">
                      {{ govukButton({ text: t("govuk_alpha_messages.translate.button"), classes: "govuk-button--secondary govuk-!-margin-bottom-0" }) }}
                    </form>
                  {% endif %}
                {% endif %}

                {% if message.canManage %}
                  <details class="govuk-details govuk-!-margin-top-2">
                    <summary class="govuk-details__summary">
                      <span class="govuk-details__summary-text">{{ t("govuk_alpha.messages.edit_delete_toggle") }}</span>
                    </summary>
                    <div class="govuk-details__text">
                      {% if message.canEdit %}
                        <form method="post" action="{{ urlFor('/messages/' + (conversation.id | string) + '/m/' + (message.id | string) + '/edit') }}" class="govuk-!-margin-bottom-3">
                          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                          {{ govukTextarea({
                            label: { text: t("govuk_alpha.messages.edit_label"), classes: "govuk-label--s" },
                            hint: { text: t("govuk_alpha.messages.edit_window_hint") },
                            id: "edit-body-" + (message.id | string),
                            name: "body",
                            rows: 3,
                            value: message.body
                          }) }}
                          {{ govukButton({ text: t("govuk_alpha.messages.edit_button"), classes: "govuk-button--secondary" }) }}
                        </form>
                      {% else %}
                        <p class="govuk-hint">{{ t("govuk_alpha.messages.edit_expired_notice") }}</p>
                      {% endif %}

                      <form method="post" action="{{ urlFor('/messages/' + (conversation.id | string) + '/m/' + (message.id | string) + '/delete') }}">
                        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                        <fieldset class="govuk-fieldset govuk-!-margin-bottom-3">
                          <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">{{ t("govuk_alpha.messages.delete_legend") }}</legend>
                          <div class="govuk-radios govuk-radios--small">
                            <div class="govuk-radios__item">
                              <input class="govuk-radios__input" id="delete-scope-self-{{ message.id }}" name="scope" type="radio" value="self" aria-describedby="delete-scope-self-hint-{{ message.id }}">
                              <label class="govuk-label govuk-radios__label" for="delete-scope-self-{{ message.id }}">{{ t("govuk_alpha.messages.delete_scope_self") }}</label>
                              <div id="delete-scope-self-hint-{{ message.id }}" class="govuk-hint govuk-radios__hint">{{ t("govuk_alpha.messages.delete_scope_self_hint") }}</div>
                            </div>
                            <div class="govuk-radios__item">
                              <input class="govuk-radios__input" id="delete-scope-everyone-{{ message.id }}" name="scope" type="radio" value="everyone" checked aria-describedby="delete-scope-everyone-hint-{{ message.id }}">
                              <label class="govuk-label govuk-radios__label" for="delete-scope-everyone-{{ message.id }}">{{ t("govuk_alpha.messages.delete_scope_everyone") }}</label>
                              <div id="delete-scope-everyone-hint-{{ message.id }}" class="govuk-hint govuk-radios__hint">{{ t("govuk_alpha.messages.delete_scope_everyone_hint") }}</div>
                            </div>
                          </div>
                        </fieldset>
                        {{ govukButton({ text: t("govuk_alpha.messages.delete_button"), classes: "govuk-button--warning" }) }}
                      </form>
                    </div>
                  </details>
                {% endif %}
              </div>
            </li>
          {% endfor %}
        </ol>
      {% else %}
        <div class="govuk-inset-text"><p class="govuk-body">{{ t("govuk_alpha.messages.empty") }}</p></div>
      {% endif %}

      {% if canSend %}
        <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">
        <h2 class="govuk-heading-m">{{ t("govuk_alpha.actions.reply") }}</h2>
        <form method="post" action="{{ urlFor('/messages/' + (conversation.id | string)) }}" enctype="multipart/form-data" novalidate>
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          {% if listingId %}
            <input type="hidden" name="context_type" value="listing">
            <input type="hidden" name="context_id" value="{{ listingId }}">
          {% endif %}
          {{ govukTextarea({
            label: { text: t("govuk_alpha.messages.message_label"), classes: "govuk-label--m" },
            hint: { text: t("govuk_alpha.messages.message_hint") },
            id: "body",
            name: "body",
            rows: 5
          }) }}
          <div class="govuk-form-group">
            <label class="govuk-label govuk-label--s" for="attachments">{{ t("govuk_alpha_messages.attachments.label") }}</label>
            <div id="attachments-hint" class="govuk-hint">{{ t("govuk_alpha_messages.attachments.hint") }}</div>
            <input class="govuk-file-upload" id="attachments" name="attachments[]" type="file" multiple aria-describedby="attachments-hint" accept=".jpg,.jpeg,.png,.gif,.webp,.pdf,.txt,.csv,.doc,.docx,.xls,.xlsx">
          </div>
          {{ govukButton({ text: t("govuk_alpha.actions.reply") }) }}
        </form>

        <form method="post" action="{{ urlFor('/messages/' + (conversation.id | string) + '/voice') }}" enctype="multipart/form-data" class="govuk-!-margin-top-4">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <div class="govuk-form-group govuk-!-margin-bottom-2">
            <label class="govuk-label govuk-label--s" for="voice">{{ t("govuk_alpha_messages.voice.label") }}</label>
            <div id="voice-hint" class="govuk-hint">{{ t("govuk_alpha_messages.voice.hint") }}</div>
            <input class="govuk-file-upload" id="voice" name="voice" type="file" accept="audio/*" capture aria-describedby="voice-hint">
          </div>
          {{ govukButton({ text: t("govuk_alpha_messages.voice.submit"), classes: "govuk-button--secondary" }) }}
        </form>
      {% endif %}

      <form method="post" action="{{ urlFor('/messages/' + (conversation.id | string) + '/archive') }}" class="govuk-!-margin-top-6">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        {{ govukButton({ text: t("govuk_alpha.actions.archive_conversation"), classes: "govuk-button--secondary" }) }}
      </form>
    </div>
  </div>
{% endblock %}
