{% extends "layouts/base.njk" %}

{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block beforeContent %}
  {{ super() }}
  <a class="govuk-back-link" href="{{ urlFor('/messages') }}">{{ t("actions.back_to_messages") }}</a>
{% endblock %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if successMessage %}
        {% set notificationMessage = successMessage %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      {% if error %}
        {{ govukErrorSummary({
          titleText: t("states.error_title"),
          errorList: [{ text: error, href: "#content" }],
          attributes: { tabindex: "-1" }
        }) }}
      {% endif %}

      <div class="govuk-!-margin-bottom-6" style="display: flex; align-items: center; gap: 20px;">
        {% set otherUserName = conversation.otherUser.name or conversation.other_user_name or conversation.otherUserName or "Unknown" %}
        {% set nameParts = otherUserName.split(' ') %}
        {% set user = { firstName: nameParts[0] or '', lastName: nameParts[1] or '' } %}
        {% set size = 'large' %}
        {% include "partials/avatar.njk" %}
        <h1 class="govuk-heading-xl govuk-!-margin-bottom-0">
          {{ otherUserName }}
        </h1>
      </div>

      {% if listing %}
        <p class="govuk-body-s govuk-!-margin-bottom-6">
          Regarding: <a href="{{ urlFor('/listings/' + (listing.id | string)) }}" class="govuk-link">{{ listing.title or listing.name or "Listing" }}</a>
        </p>
      {% endif %}

      <div class="app-messages-container" role="log" aria-live="polite" aria-label="Conversation messages">
        {% if messages and messages.length > 0 %}
          {% for message in messages %}
            <div class="app-message{% if message.is_own %} app-message--own{% endif %}">
              <div class="app-message-header">
                <div class="app-member-cell">
                  {% if message.is_own %}
                    {% set user = currentUser %}
                  {% else %}
                    {% set senderName = message.sender_name or message.senderName or "User" %}
                    {% set nameParts = senderName.split(' ') %}
                    {% set user = { firstName: nameParts[0] or '', lastName: nameParts[1] or '' } %}
                  {% endif %}
                  {% set size = 'small' %}
                  {% include "partials/avatar.njk" %}
                  <strong class="govuk-!-font-weight-bold govuk-body-s">
                    {% if message.is_own %}
                      You
                    {% else %}
                      {{ message.sender_name or message.senderName or "User" }}
                    {% endif %}
                  </strong>
                </div>
                <span class="govuk-body-s">
                  {{ (message.created_at or message.createdAt) | formatBladeDateTime if (message.created_at or message.createdAt) else "" }}
                </span>
              </div>
              <div class="app-message-body">
                <p class="govuk-body">{{ message.content or message.body or "" }}</p>

                {% set attachments = message.attachments or [] %}
                {% if attachments.length %}
                  <ul class="govuk-list govuk-list--bullet">
                    {% for attachment in attachments %}
                      {% set attachmentHref = attachment.url or attachment.file_url or attachment.download_url or attachment.path %}
                      {% set attachmentName = attachment.name or attachment.file_name or attachment.filename or "Attachment" %}
                      <li>
                        {% if attachmentHref %}
                          <a class="govuk-link" href="{{ attachmentHref }}">{{ attachmentName }}</a>
                        {% else %}
                          {{ attachmentName }}
                        {% endif %}
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}

                {% if message.isOwn or message.is_own %}
                  <details class="govuk-details govuk-!-margin-top-2" data-module="govuk-details">
                    <summary class="govuk-details__summary">
                      <span class="govuk-details__summary-text">{{ t("messages.edit_delete_toggle") }}</span>
                    </summary>
                    <div class="govuk-details__text">
                      <form method="post" action="{{ urlFor('/messages/' + (conversation.id | string) + '/m/' + (message.id | string) + '/edit') }}" class="govuk-!-margin-bottom-3">
                        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                        {{ govukTextarea({
                          label: { text: t("messages.edit_label"), classes: "govuk-label--s" },
                          id: "edit-body-" + (message.id | string),
                          name: "body",
                          rows: 3,
                          value: message.body or message.content
                        }) }}
                        {{ govukButton({ text: t("messages.edit_button"), classes: "govuk-button--secondary" }) }}
                      </form>
                      <form method="post" action="{{ urlFor('/messages/' + (conversation.id | string) + '/m/' + (message.id | string) + '/delete') }}">
                        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                        <fieldset class="govuk-fieldset govuk-!-margin-bottom-3">
                          <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">{{ t("messages.delete_legend") }}</legend>
                          <div class="govuk-radios govuk-radios--small">
                            <div class="govuk-radios__item">
                              <input class="govuk-radios__input" id="delete-scope-self-{{ message.id }}" name="scope" type="radio" value="self" checked>
                              <label class="govuk-label govuk-radios__label" for="delete-scope-self-{{ message.id }}">{{ t("messages.delete_scope_self") }}</label>
                              <div class="govuk-hint govuk-radios__hint">{{ t("messages.delete_scope_self_hint") }}</div>
                            </div>
                            <div class="govuk-radios__item">
                              <input class="govuk-radios__input" id="delete-scope-everyone-{{ message.id }}" name="scope" type="radio" value="everyone">
                              <label class="govuk-label govuk-radios__label" for="delete-scope-everyone-{{ message.id }}">{{ t("messages.delete_scope_everyone") }}</label>
                              <div class="govuk-hint govuk-radios__hint">{{ t("messages.delete_scope_everyone_hint") }}</div>
                            </div>
                          </div>
                        </fieldset>
                        {{ govukButton({ text: t("messages.delete_button"), classes: "govuk-button--warning" }) }}
                      </form>
                    </div>
                  </details>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        {% else %}
          <p class="govuk-body">No messages in this conversation yet.</p>
        {% endif %}
      </div>

      <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

      <h2 class="govuk-heading-m">Send a message</h2>

      <form method="post" action="{{ urlFor('/messages/' + (conversation.id | string)) }}" enctype="multipart/form-data" novalidate>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        {% if listingId %}
          <input type="hidden" name="context_type" value="listing">
          <input type="hidden" name="context_id" value="{{ listingId }}">
        {% endif %}
        {{ govukTextarea({
          label: {
            text: "Your message",
            classes: "govuk-visually-hidden"
          },
          id: "content",
          name: "content",
          rows: 4,
          errorMessage: { text: error } if error else undefined
        }) }}

        <div class="govuk-form-group">
          <label class="govuk-label govuk-label--s" for="attachments">
            Attachments
          </label>
          <div id="attachments-hint" class="govuk-hint">
            Upload images or documents. You can send a message with only attachments.
          </div>
          <input class="govuk-file-upload" id="attachments" name="attachments[]" type="file" multiple aria-describedby="attachments-hint" accept=".jpg,.jpeg,.png,.gif,.webp,.pdf,.txt,.csv,.doc,.docx,.xls,.xlsx">
        </div>

        {{ govukButton({
          text: t("actions.send_message")
        }) }}
      </form>

      <p class="govuk-body govuk-!-margin-top-6">
        <a href="{{ urlFor('/messages') }}" class="govuk-link">{{ t("actions.back_to_messages") }}</a>
      </p>

    </div>
  </div>
{% endblock %}
