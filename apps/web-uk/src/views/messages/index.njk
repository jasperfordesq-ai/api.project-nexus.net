{% extends "layouts/base.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/input/macro.njk" import govukInput %}

{% block mainContent %}
      <span class="govuk-caption-l">{{ t("nav.messages") }}</span>
      <h1 class="govuk-heading-xl">{{ t("messages.title") }}</h1>
      <p class="govuk-body-l">{{ t("messages.description") }}</p>
      {% if unreadCount > 0 %}
        <p class="govuk-body"><strong class="govuk-tag govuk-tag--blue">{{ tc("polish_members.messages_unread_summary", unreadCount, { count: unreadCount }) }}</strong></p>
      {% endif %}

      {% set messagesActive = "direct" %}
      {% include "messages/_subnav.njk" %}

      {% if canStart %}
        <div class="nexus-alpha-card govuk-!-margin-bottom-6">
          <h2 class="govuk-heading-m">{{ t("govuk_alpha.messages.start_new") }}</h2>
          <form method="get" action="{{ urlFor('/messages') }}">
            <div class="govuk-form-group govuk-!-margin-bottom-2">
              <label class="govuk-label" for="message-user-search">{{ t("govuk_alpha.messages.search_label") }}</label>
              <div id="message-user-search-hint" class="govuk-hint">{{ t("govuk_alpha.messages.search_hint") }}</div>
              <input class="govuk-input govuk-!-width-two-thirds" id="message-user-search" name="q" type="search" value="{{ searchQuery }}" aria-describedby="message-user-search-hint">
            </div>
            <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("govuk_alpha.actions.search") }}</button>
          </form>
          {% if searchQuery %}
            {% if searchResults and searchResults.length %}
              <ul class="govuk-list govuk-!-margin-top-3 govuk-!-margin-bottom-0">
                {% for result in searchResults %}
                  <li class="govuk-!-margin-bottom-2"><a class="govuk-link" href="{{ urlFor('/messages/new/' + (result.id | string)) }}">{{ result.displayName }}</a></li>
                {% endfor %}
              </ul>
            {% else %}
              <p class="govuk-body govuk-!-margin-top-3 govuk-!-margin-bottom-0">{{ t("govuk_alpha.messages.search_empty") }}</p>
            {% endif %}
          {% endif %}
          <p class="govuk-body govuk-!-margin-top-3 govuk-!-margin-bottom-0"><a class="govuk-link" href="{{ urlFor('/members') }}">{{ t("govuk_alpha.messages.browse_directory") }}</a></p>
        </div>
      {% endif %}

      {% if successMessage %}
        {% set notificationMessage = successMessage %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      {% if not directMessagingEnabled %}
        <div class="govuk-notification-banner" data-module="govuk-notification-banner" role="region" aria-labelledby="messages-disabled-title">
          <div class="govuk-notification-banner__header">
            <h2 class="govuk-notification-banner__title" id="messages-disabled-title">{{ t("govuk_alpha.messages.disabled_title") }}</h2>
          </div>
          <div class="govuk-notification-banner__content"><p class="govuk-body">{{ t("govuk_alpha.messages.disabled_detail") }}</p></div>
        </div>
      {% elseif restricted %}
        <div class="govuk-notification-banner" data-module="govuk-notification-banner" role="region" aria-labelledby="messages-restricted-title">
          <div class="govuk-notification-banner__header">
            <h2 class="govuk-notification-banner__title" id="messages-restricted-title">{{ t("govuk_alpha.messages.disabled_title") }}</h2>
          </div>
          <div class="govuk-notification-banner__content"><p class="govuk-body">{{ t("govuk_alpha.messages.restricted_detail") }}</p></div>
        </div>
      {% endif %}

      <nav class="govuk-!-margin-bottom-4" aria-label="{{ t('messages.tabs_title') }}">
        <ul class="govuk-list" style="display:flex;gap:1rem;list-style:none;padding:0;margin:0 0 1rem">
          <li><a class="govuk-link{% if not showArchived %} govuk-link--no-visited-state{% endif %}" href="{{ urlFor('/messages') }}"{% if not showArchived %} aria-current="page"{% endif %}>{{ t("messages.inbox") }}</a></li>
          <li><a class="govuk-link{% if showArchived %} govuk-link--no-visited-state{% endif %}" href="{{ urlFor('/messages?archived=1') }}"{% if showArchived %} aria-current="page"{% endif %}>{{ t("messages.archived") }}</a></li>
        </ul>
      </nav>

      {% if conversations and conversations.length %}
        <form method="get" action="{{ urlFor('/messages') }}" class="govuk-!-margin-bottom-5">
          {% if showArchived %}<input type="hidden" name="archived" value="1">{% endif %}
          {{ govukInput({
            id: "conv-filter",
            name: "filter",
            value: filter,
            label: { text: t("polish_members.messages_filter_label") },
            hint: { text: t("polish_members.messages_filter_hint") },
            classes: "govuk-!-width-two-thirds",
            formGroup: { classes: "govuk-!-margin-bottom-2" }
          }) }}
          <div class="govuk-button-group">
            {{ govukButton({ text: t("polish_members.messages_filter_submit"), classes: "govuk-button--secondary" }) }}
            {% if filter %}
              <a class="govuk-link" href="{{ urlFor('/messages' + ('?archived=1' if showArchived else '')) }}">{{ t("polish_members.messages_filter_clear") }}</a>
            {% endif %}
          </div>
        </form>
      {% endif %}

      {% if conversations and conversations.length > 0 %}
        <div class="nexus-alpha-card-list">
          {% for conversation in conversations %}
            {% set otherUser = conversation.otherUser %}
            {% set otherUserName = conversation.displayName %}
            {% set conversationUnread = conversation.unreadCount %}
            <article class="nexus-alpha-card">
              <div class="nexus-alpha-card-head">
                {% if otherUser.avatarAssetUrl %}
                  <img class="nexus-alpha-avatar" src="{{ otherUser.avatarAssetUrl }}" alt="" loading="lazy" decoding="async" width="48" height="48">
                {% else %}
                  <span class="nexus-alpha-avatar nexus-alpha-avatar--placeholder" aria-hidden="true">{{ otherUserName | first | upper }}</span>
                {% endif %}
                <h2 class="govuk-heading-m govuk-!-margin-bottom-0">
                  <a class="govuk-link" href="{{ urlFor('/messages/' + (conversation.id | string)) }}">{{ t("govuk_alpha.messages.conversation_title", { name: otherUserName }) }}</a>
                </h2>
              </div>
              {% if conversationUnread > 0 %}
                <strong class="govuk-tag govuk-tag--blue">{{ tc("messages.unread_count", conversationUnread, { count: conversationUnread }) }}</strong>
              {% endif %}
              <p class="govuk-body govuk-!-margin-top-3">
                <strong>{{ t("govuk_alpha.messages.last_message_label") }}:</strong>
                {{ conversation.lastMessageSenderLabel }}:
                {{ conversation.lastMessageText }}
              </p>
              {% if conversation.lastMessageAt %}
                <p class="govuk-hint">{{ t("govuk_alpha.messages.sent_label") }} {{ conversation.lastMessageAt | formatBladeDateTime }}</p>
              {% endif %}
              {% if showArchived %}
                <form method="post" action="{{ urlFor('/messages/' + (conversation.id | string) + '/restore') }}">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  {{ govukButton({ text: t("actions.restore_conversation"), classes: "govuk-button--secondary" }) }}
                </form>
              {% endif %}
            </article>
          {% endfor %}
        </div>
        {% if meta.hasMore and meta.cursor %}
          <nav class="govuk-pagination govuk-pagination--block govuk-!-margin-top-6" aria-label="{{ t('messages.pagination_label') }}">
            <div class="govuk-pagination__next">
              <a class="govuk-link govuk-pagination__link" href="{{ urlFor('/messages?' + ('archived=1&' if showArchived else '') + ('filter=' + (filter | urlencode) + '&' if filter else '') + 'cursor=' + (meta.cursor | urlencode)) }}" rel="next">
                <svg class="govuk-pagination__icon govuk-pagination__icon--next" xmlns="http://www.w3.org/2000/svg" height="13" width="15" aria-hidden="true" focusable="false" viewBox="0 0 15 13"><path d="m8.107-0.0078125-1.4136 1.414 4.2926 4.293h-12.986v2h12.896l-4.1855 3.9766 1.377 1.4492 6.7441-6.4062-6.7246-6.7266z"></path></svg>
                <span class="govuk-pagination__link-title">{{ t("govuk_alpha.actions.load_more") }}</span>
                <span class="govuk-visually-hidden">:</span>
                <span class="govuk-pagination__link-label">{{ t("messages.more_results_label") }}</span>
              </a>
            </div>
          </nav>
        {% endif %}
      {% else %}
        <div class="govuk-inset-text">
          <h2 class="govuk-heading-m">{{ t("states.empty_title") }}</h2>
          <p class="govuk-body">{{ t("messages.empty") }}</p>
          {% if canStart %}<a class="govuk-link" href="{{ urlFor('/members') }}">{{ t("messages.start_new") }}</a>{% endif %}
        </div>
      {% endif %}

{% endblock %}
