{% extends "layouts/base.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/pagination/macro.njk" import govukPagination %}

{% block beforeContent %}
  {{ super() }}
  {{ govukBreadcrumbs({
    items: [
      { text: t("nav.home"), href: urlFor("/") },
      { text: t("messages.title") }
    ]
  }) }}
{% endblock %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if successMessage %}
        {% set notificationMessage = successMessage %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      <span class="govuk-caption-l">{{ t("nav.messages") }}</span>
      <h1 class="govuk-heading-xl">
        {{ t("messages.title") }}
        {% if unreadCount > 0 %}
          <span class="govuk-tag govuk-tag--blue govuk-!-margin-left-2">{{ tc("polish_members.messages_unread_summary", unreadCount, { count: unreadCount }) }}</span>
        {% endif %}
      </h1>
      <p class="govuk-body-l">{{ t("messages.description") }}</p>

      <nav class="govuk-!-margin-bottom-4" aria-label="{{ t('messages.tabs_title') }}">
        <ul class="govuk-list" style="display:flex;gap:1rem;list-style:none;padding:0;margin:0 0 1rem">
          <li><a class="govuk-link govuk-link--no-visited-state" href="{{ urlFor('/messages') }}" aria-current="page">{{ t("govuk_alpha_messages.groups.tab_direct") }}</a></li>
          <li><a class="govuk-link" href="{{ urlFor('/messages/groups') }}">{{ t("govuk_alpha_messages.groups.tab_groups") }}</a></li>
        </ul>
      </nav>

      <nav class="govuk-!-margin-bottom-4" aria-label="{{ t('messages.tabs_title') }}">
        <ul class="govuk-list" style="display:flex;gap:1rem;list-style:none;padding:0">
          <li><a class="govuk-link" href="{{ urlFor('/messages') }}"{% if not showArchived %} aria-current="page"{% endif %}>{{ t("messages.inbox") }}</a></li>
          <li><a class="govuk-link" href="{{ urlFor('/messages?archived=1') }}"{% if showArchived %} aria-current="page"{% endif %}>{{ t("messages.archived") }}</a></li>
        </ul>
      </nav>

      {% if conversations and conversations.length %}
        <form method="get" action="{{ urlFor('/messages') }}" class="govuk-!-margin-bottom-5">
          {% if showArchived %}<input type="hidden" name="archived" value="1">{% endif %}
          {{ govukInput({
            id: "filter",
            name: "filter",
            value: filter,
            label: { text: t("polish_members.messages_filter_label") },
            hint: { text: t("polish_members.messages_filter_hint") }
          }) }}
          {{ govukButton({ text: t("polish_members.messages_filter_submit"), classes: "govuk-button--secondary" }) }}
          {% if filter %}
            <a class="govuk-link" href="{{ urlFor('/messages' + ('?archived=1' if showArchived else '')) }}">{{ t("polish_members.messages_filter_clear") }}</a>
          {% endif %}
        </form>
      {% endif %}

      {% if conversations and conversations.length > 0 %}
        <ul class="govuk-list app-conversation-list">
          {% for conversation in conversations %}
            {% set otherUser = conversation.otherUser %}
            {% set otherUserName = conversation.displayName %}
            {% set conversationUnread = conversation.unreadCount %}
            <li class="app-conversation-item{% if conversationUnread > 0 %} app-conversation-item--unread{% endif %}">
              <a href="{{ urlFor('/messages/' + (conversation.id | string)) }}" class="govuk-link app-conversation-link">
                <div class="app-conversation-header">
                  <div class="app-member-cell">
                    {% if otherUser.avatar_url %}
                      <img class="app-avatar" src="{{ otherUser.avatar_url }}" alt="" width="48" height="48" loading="lazy" decoding="async">
                    {% else %}
                      {% set user = otherUser %}
                      {% include "partials/avatar.njk" %}
                    {% endif %}
                    <strong class="govuk-!-font-weight-bold">
                      {{ otherUserName }}
                    </strong>
                  </div>
                  <span class="govuk-body-s govuk-!-margin-bottom-0">
                    {{ conversation.lastMessageAt | formatDate if conversation.lastMessageAt else "" }}
                  </span>
                </div>
                <p class="govuk-body-s govuk-!-margin-bottom-0 govuk-!-margin-top-1">
                  {{ conversation.lastMessageText }}
                </p>
                {% if conversationUnread > 0 %}
                  <span class="govuk-tag govuk-tag--blue app-conversation-badge">
                    {{ tc("messages.unread_count", conversationUnread, { count: conversationUnread }) }}
                  </span>
                {% endif %}
              </a>
              {% if showArchived %}
                <form method="post" action="{{ urlFor('/messages/' + (conversation.id | string) + '/restore') }}" class="govuk-!-margin-top-2">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  {{ govukButton({ text: t("actions.restore_conversation"), classes: "govuk-button--secondary" }) }}
                </form>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
        {% if meta.hasMore and meta.cursor %}
          {{ govukPagination({
            next: {
              labelText: t("messages.more_results_label"),
              href: urlFor("/messages?" + ("archived=1&" if showArchived else "") + ("filter=" + (filter | urlencode) + "&" if filter else "") + "cursor=" + (meta.cursor | urlencode))
            },
            landmarkLabel: t("messages.pagination_label")
          }) }}
        {% endif %}
      {% else %}
        <div class="govuk-inset-text">
          <h2 class="govuk-heading-m">{{ t("states.empty_title") }}</h2>
          <p class="govuk-body">{{ t("messages.empty") }}</p>
          <a class="govuk-link" href="{{ urlFor('/members') }}">{{ t("messages.start_new") }}</a>
        </div>
      {% endif %}

    </div>
  </div>
{% endblock %}
