{% extends "layouts/base.njk" %}

{% block beforeContent %}
  {{ super() }}
  <a class="govuk-back-link" href="{{ urlFor('/messages/groups') }}">Back to group conversations</a>
{% endblock %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if statusMessage %}
        <div class="govuk-notification-banner govuk-notification-banner--success" role="alert" aria-labelledby="messages-group-status-title">
          <div class="govuk-notification-banner__header">
            <h2 class="govuk-notification-banner__title" id="messages-group-status-title">{{ t("states.success_title") }}</h2>
          </div>
          <div class="govuk-notification-banner__content">
            <p class="govuk-body">{{ statusMessage }}</p>
          </div>
        </div>
      {% endif %}

      <span class="govuk-caption-l">Group conversation</span>
      <h1 class="govuk-heading-xl">{{ conversation.displayName }}</h1>

      <h2 class="govuk-heading-m">Members</h2>
      <ul class="govuk-list">
        {% for participant in participants %}
          <li class="govuk-!-margin-bottom-2">
            <span>{{ participant.displayName }}</span>
            {% if participant.id == currentUserId %}
              <strong class="govuk-tag govuk-tag--green">You</strong>
            {% endif %}
            {% if participant.role == "admin" %}
              <strong class="govuk-tag govuk-tag--blue">Administrator</strong>
            {% endif %}
            {% if participant.is_online %}
              <strong class="govuk-tag govuk-tag--turquoise">Online</strong>
            {% endif %}
            {% if isAdmin and participant.id != currentUserId %}
              <form method="post" action="{{ urlFor('/messages/groups/' + (conversation.id | string) + '/members/' + (participant.id | string) + '/remove') }}" class="govuk-!-display-inline">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <button type="submit" class="govuk-link app-link-button">{{ t("groups.manage.remove") }}<span class="govuk-visually-hidden"> {{ participant.displayName }}</span></button>
              </form>
            {% endif %}
          </li>
        {% endfor %}
      </ul>

      <div class="nexus-alpha-card govuk-!-margin-bottom-4">
        <form method="get" action="{{ urlFor('/messages/groups/' + (conversation.id | string)) }}">
          <div class="govuk-form-group govuk-!-margin-bottom-2">
            <label class="govuk-label" for="group-conv-search">Search this conversation</label>
            <div id="group-conv-search-hint" class="govuk-hint">Show only messages that contain these words.</div>
            <input class="govuk-input govuk-!-width-two-thirds" id="group-conv-search" name="q" type="search" value="{{ searchQuery }}" aria-describedby="group-conv-search-hint">
          </div>
          <div class="govuk-button-group">
            <button type="submit" class="govuk-button govuk-button--secondary">{{ t("polish_members.conversation_filter_label") }}</button>
            {% if searchQuery %}
              <a class="govuk-link" href="{{ urlFor('/messages/groups/' + (conversation.id | string)) }}">{{ t("polish_members.connections_search_clear") }}</a>
            {% endif %}
          </div>
        </form>
        {% if searchQuery %}
          <p class="govuk-body govuk-!-margin-top-2 govuk-!-margin-bottom-0">{{ messages.length }} messages match {{ searchQuery }}</p>
        {% endif %}
      </div>

      {% if not searchQuery and meta.hasMore and meta.cursor %}
        <nav class="govuk-pagination govuk-pagination--block govuk-!-margin-bottom-4" aria-label="Older messages">
          <div class="govuk-pagination__prev">
            <a class="govuk-link govuk-pagination__link" href="{{ urlFor('/messages/groups/' + (conversation.id | string) + '?cursor=' + (meta.cursor | string)) }}" rel="prev">
              <span class="govuk-pagination__link-title">{{ t("messages.show_older") }}</span>
            </a>
          </div>
        </nav>
      {% endif %}

      {% if messages and messages.length %}
        <ol class="govuk-list govuk-list--spaced">
          {% for message in messages %}
            <li class="nexus-alpha-card" id="m-{{ message.id }}">
              <p class="govuk-body govuk-!-font-weight-bold govuk-!-margin-bottom-1">{{ message.displaySenderName }}</p>
              {% if message.created_at %}
                <p class="govuk-hint govuk-!-margin-bottom-2">Sent {{ message.created_at | formatDate }}</p>
              {% endif %}
              {% if message.is_deleted %}
                <p class="govuk-body govuk-hint">This message was deleted</p>
              {% else %}
                <p class="govuk-body">{{ message.body or message.content }}</p>
              {% endif %}

              {% if canSend and not message.is_deleted %}
                <details class="govuk-details">
                  <summary class="govuk-details__summary">
                    <span class="govuk-details__summary-text">React to this message</span>
                  </summary>
                  <div class="govuk-details__text">
                    <div class="govuk-button-group">
                      {% for emoji in reactionEmojis %}
                        <form method="post" action="{{ urlFor('/messages/groups/' + (conversation.id | string) + '/m/' + (message.id | string) + '/react') }}" class="govuk-!-display-inline">
                          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                          <input type="hidden" name="emoji" value="{{ emoji }}">
                          <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0">
                            <span aria-hidden="true">{{ emoji }}</span>
                            <span class="govuk-visually-hidden">React with {{ emoji }}</span>
                          </button>
                        </form>
                      {% endfor %}
                    </div>
                  </div>
                </details>
              {% endif %}
            </li>
          {% endfor %}
        </ol>
      {% else %}
        <div class="govuk-inset-text">
          <p class="govuk-body">No messages in this group yet. Be the first to say hello.</p>
        </div>
      {% endif %}

      {% if canSend %}
        <form method="post" action="{{ urlFor('/messages/groups/' + (conversation.id | string)) }}" class="govuk-!-margin-top-6">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <div class="govuk-form-group">
            <label class="govuk-label govuk-label--m" for="group-body">Write a message</label>
            <div id="group-body-hint" class="govuk-hint">Everyone in the group will see your message.</div>
            <textarea class="govuk-textarea" id="group-body" name="body" rows="5" aria-describedby="group-body-hint" required></textarea>
          </div>
          <button class="govuk-button">{{ t("actions.send_message") }}</button>
        </form>
      {% endif %}

      {% if isAdmin and canSend %}
        <div class="nexus-alpha-card govuk-!-margin-top-6">
          <h2 class="govuk-heading-m">Manage members</h2>
          <form method="post" action="{{ urlFor('/messages/groups/' + (conversation.id | string) + '/members') }}">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <fieldset class="govuk-fieldset">
              <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Add a member</legend>
              <div class="govuk-form-group">
                <label class="govuk-label" for="add-user-id">Member ID to add</label>
                <div id="add-user-hint" class="govuk-hint">Search the directory first, then add a member by their profile.</div>
                <input class="govuk-input govuk-input--width-10" id="add-user-id" name="user_id" type="number" min="1" inputmode="numeric" aria-describedby="add-user-hint" required>
              </div>
              <p class="govuk-body govuk-!-margin-bottom-2">
                <a class="govuk-link" href="{{ urlFor('/members') }}">Find a member to add</a>
              </p>
              <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0">Add member</button>
            </fieldset>
          </form>
        </div>
      {% else %}
        <p class="govuk-hint govuk-!-margin-top-4">Only group administrators can add or remove members.</p>
      {% endif %}

      <div class="govuk-!-margin-top-6">
        <h2 class="govuk-heading-m">Leave this group</h2>
        <div class="govuk-warning-text">
          <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
          <strong class="govuk-warning-text__text">
            <span class="govuk-visually-hidden">Warning</span>
            If you leave, you will no longer receive messages from this group.
          </strong>
        </div>
        <form method="post" action="{{ urlFor('/messages/groups/' + (conversation.id | string) + '/members/' + (currentUserId | string) + '/remove') }}">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <input type="hidden" name="self_leave" value="1">
          <button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0">{{ t("groups.leave") }}</button>
        </form>
      </div>
    </div>
  </div>
{% endblock %}
