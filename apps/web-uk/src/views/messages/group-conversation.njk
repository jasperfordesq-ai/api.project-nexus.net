{% extends "layouts/base.njk" %}

{% block beforeContent %}
  {{ super() }}
  <a class="govuk-back-link" href="{{ urlFor('/messages/groups') }}">{{ t("govuk_alpha_messages.conversation.back") }}</a>
{% endblock %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if groupStatus and groupStatus.type == "success" %}
        <div class="govuk-notification-banner govuk-notification-banner--success" role="alert" aria-labelledby="messages-group-status-title">
          <div class="govuk-notification-banner__header">
            <h2 class="govuk-notification-banner__title" id="messages-group-status-title">{{ t("govuk_alpha.states.success_title") }}</h2>
          </div>
          <div class="govuk-notification-banner__content">
            <p class="govuk-notification-banner__heading">{{ groupStatus.message }}</p>
          </div>
        </div>
      {% elif groupStatus %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
          <div role="alert">
            <h2 class="govuk-error-summary__title">{{ t("govuk_alpha.states.error_title") }}</h2>
            <div class="govuk-error-summary__body"><ul class="govuk-list govuk-error-summary__list"><li>{{ groupStatus.message }}</li></ul></div>
          </div>
        </div>
      {% endif %}

      <span class="govuk-caption-l">{{ t("govuk_alpha_messages.conversation.caption") }}</span>
      <h1 class="govuk-heading-xl">{{ conversation.displayName }}</h1>

      {% if not directMessagingEnabled or restricted %}
        <div class="govuk-notification-banner" role="region" aria-labelledby="group-conv-disabled-title">
          <div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title" id="group-conv-disabled-title">{{ t("govuk_alpha.messages.disabled_title") }}</h2></div>
          <div class="govuk-notification-banner__content"><p class="govuk-body">{% if restricted %}{{ t("govuk_alpha.messages.restricted_detail") }}{% else %}{{ t("govuk_alpha.messages.disabled_detail") }}{% endif %}</p></div>
        </div>
      {% elseif safeguarding and safeguarding.restricted %}
        <div id="safeguarding-notice" class="govuk-notification-banner" data-module="govuk-notification-banner" role="region" aria-labelledby="group-conv-safeguarding-title">
          <div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title" id="group-conv-safeguarding-title">{{ safeguarding.title or t("safeguarding.errors.contact_restricted_title") }}</h2></div>
          <div class="govuk-notification-banner__content"><p class="govuk-body">{{ safeguarding.detail or safeguarding.message or t("safeguarding.errors.contact_restricted") }}</p></div>
        </div>
      {% endif %}

      <h2 class="govuk-heading-m">{{ t("govuk_alpha_messages.conversation.members_heading") }}</h2>
      <ul class="govuk-list">
        {% for participant in participants %}
          <li class="govuk-!-margin-bottom-2">
            <span>{{ participant.displayName }}</span>
            {% if participant.id == currentUserId %}
              <strong class="govuk-tag govuk-tag--green">{{ t("govuk_alpha_messages.conversation.you_badge") }}</strong>
            {% endif %}
            {% if participant.role == "admin" %}
              <strong class="govuk-tag govuk-tag--blue">{{ t("govuk_alpha_messages.conversation.admin_badge") }}</strong>
            {% endif %}
            {% if participant.is_online %}
              <strong class="govuk-tag govuk-tag--turquoise">{{ t("govuk_alpha_messages.conversation.online_badge") }}</strong>
            {% endif %}
            {% if isAdmin and participant.id != currentUserId %}
              <details class="govuk-details govuk-!-margin-bottom-0" data-module="govuk-details">
                <summary class="govuk-details__summary"><span class="govuk-details__summary-text">{{ t("govuk_alpha_messages.manage.remove_button") }}<span class="govuk-visually-hidden"> {{ t("govuk_alpha_messages.manage.remove_hidden", { name: participant.displayName }) }}</span></span></summary>
                <div class="govuk-details__text">
                  <div class="govuk-warning-text">
                    <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
                    <strong class="govuk-warning-text__text"><span class="govuk-visually-hidden">{{ t("govuk_alpha.states.warning_prefix") }}</span>{{ t("govuk_alpha.ux.confirm_irreversible") }}</strong>
                  </div>
                  <form method="post" action="{{ urlFor('/messages/groups/' + (conversation.id | string) + '/members/' + (participant.id | string) + '/remove') }}">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                    <button type="submit" class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("govuk_alpha_messages.manage.remove_button") }}<span class="govuk-visually-hidden"> {{ t("govuk_alpha_messages.manage.remove_hidden", { name: participant.displayName }) }}</span></button>
                  </form>
                </div>
              </details>
            {% endif %}
          </li>
        {% endfor %}
      </ul>

      <div class="nexus-alpha-card govuk-!-margin-bottom-4">
        <form method="get" action="{{ urlFor('/messages/groups/' + (conversation.id | string)) }}">
          <div class="govuk-form-group govuk-!-margin-bottom-2">
            <label class="govuk-label" for="group-conv-search">{{ t("govuk_alpha_messages.conversation.search_label") }}</label>
            <div id="group-conv-search-hint" class="govuk-hint">{{ t("govuk_alpha_messages.conversation.search_hint") }}</div>
            <input class="govuk-input govuk-!-width-two-thirds" id="group-conv-search" name="q" type="search" value="{{ searchQuery }}" aria-describedby="group-conv-search-hint">
          </div>
          <div class="govuk-button-group">
            <button type="submit" class="govuk-button govuk-button--secondary">{{ t("govuk_alpha_messages.conversation.search_button") }}</button>
            {% if searchQuery %}
              <a class="govuk-link" href="{{ urlFor('/messages/groups/' + (conversation.id | string)) }}">{{ t("govuk_alpha_messages.conversation.search_clear") }}</a>
            {% endif %}
          </div>
        </form>
        {% if searchQuery %}
          <p class="govuk-body govuk-!-margin-top-2 govuk-!-margin-bottom-0">{{ tc("govuk_alpha_messages.conversation.search_results", messages.length, { count: messages.length, query: searchQuery }) }}</p>
        {% endif %}
      </div>

      {% if not searchQuery and meta.hasMore and meta.cursor %}
        <nav class="govuk-pagination govuk-pagination--block govuk-!-margin-bottom-4" aria-label="{{ t('govuk_alpha_messages.conversation.older_pagination_label') }}">
          <div class="govuk-pagination__prev">
            <a class="govuk-link govuk-pagination__link" href="{{ urlFor('/messages/groups/' + (conversation.id | string) + '?cursor=' + (meta.cursor | string)) }}" rel="prev">
              <span class="govuk-pagination__link-title">{{ t("govuk_alpha_messages.conversation.show_older") }}</span>
            </a>
          </div>
        </nav>
      {% endif %}

      {% if messages and messages.length %}
        <ol class="govuk-list govuk-list--spaced">
          {% for message in messages %}
            <li class="nexus-alpha-card" id="m-{{ message.id }}">
              <div class="nexus-alpha-card-head">
                {% if message.sender and message.sender.avatar_url %}
                  <img class="nexus-alpha-avatar" src="{{ message.sender.avatar_url }}" alt="" loading="lazy" decoding="async" width="48" height="48">
                {% else %}
                  <span class="nexus-alpha-avatar nexus-alpha-avatar--placeholder" aria-hidden="true">{{ message.displaySenderName | first | upper }}</span>
                {% endif %}
                <p class="govuk-body govuk-!-font-weight-bold govuk-!-margin-bottom-0">{{ message.displaySenderName }}</p>
              </div>
              {% if message.created_at %}
                <p class="govuk-hint govuk-!-margin-bottom-2">{{ t("govuk_alpha_messages.conversation.sent_label") }} {{ message.created_at | formatBladeDateTime }}</p>
              {% endif %}
              {% if message.is_deleted %}
                <p class="govuk-body govuk-hint">{{ t("govuk_alpha_messages.conversation.deleted_placeholder") }}</p>
              {% elif searchQuery %}
                <div class="govuk-body">{% for segment in message.searchSegments %}{% if segment.match %}<mark class="nexus-alpha-search-match">{{ segment.text | nl2br | safe }}</mark>{% else %}{{ segment.text | nl2br | safe }}{% endif %}{% endfor %}</div>
              {% else %}
                <div class="govuk-body">{{ (message.body or message.content) | nl2br | safe }}</div>
              {% endif %}

              {% if canSend and not message.is_deleted %}
                <details class="govuk-details">
                  <summary class="govuk-details__summary">
                    <span class="govuk-details__summary-text">{{ t("govuk_alpha_messages.reactions.heading") }}</span>
                  </summary>
                  <div class="govuk-details__text">
                    <div class="govuk-button-group">
                      {% for emoji in reactionEmojis %}
                        <form method="post" action="{{ urlFor('/messages/groups/' + (conversation.id | string) + '/m/' + (message.id | string) + '/react') }}" class="govuk-!-display-inline">
                          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                          <input type="hidden" name="emoji" value="{{ emoji }}">
                          <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0">
                            <span aria-hidden="true">{{ emoji }}</span>
                            <span class="govuk-visually-hidden">{{ t("govuk_alpha_messages.reactions.react_with", { emoji: emoji }) }}</span>
                          </button>
                        </form>
                      {% endfor %}
                    </div>
                  </div>
                </details>
              {% endif %}
            </li>
          {% endfor %}
        </ol>
      {% else %}
        <div class="govuk-inset-text">
          <p class="govuk-body">{{ t("govuk_alpha_messages.conversation.empty") }}</p>
        </div>
      {% endif %}

      {% if canSend %}
        <form method="post" action="{{ urlFor('/messages/groups/' + (conversation.id | string)) }}" class="govuk-!-margin-top-6">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <div class="govuk-form-group">
            <label class="govuk-label govuk-label--m" for="group-body">{{ t("govuk_alpha_messages.conversation.reply_label") }}</label>
            <div id="group-body-hint" class="govuk-hint">{{ t("govuk_alpha_messages.conversation.reply_hint") }}</div>
            <textarea class="govuk-textarea" id="group-body" name="body" rows="5" aria-describedby="group-body-hint" required></textarea>
          </div>
          <button class="govuk-button">{{ t("govuk_alpha_messages.conversation.send_button") }}</button>
        </form>
      {% endif %}

      {% if isAdmin and canSend %}
        <div class="nexus-alpha-card govuk-!-margin-top-6">
          <h2 class="govuk-heading-m">{{ t("govuk_alpha_messages.manage.heading") }}</h2>
          <form method="post" action="{{ urlFor('/messages/groups/' + (conversation.id | string) + '/members') }}">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <fieldset class="govuk-fieldset">
              <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">{{ t("govuk_alpha_messages.manage.add_legend") }}</legend>
              <div class="govuk-form-group">
                <label class="govuk-label" for="add-user-id">{{ t("govuk_alpha_messages.manage.add_user_label") }}</label>
                <div id="add-user-hint" class="govuk-hint">{{ t("govuk_alpha_messages.manage.add_hint") }}</div>
                <input class="govuk-input govuk-input--width-10" id="add-user-id" name="user_id" type="number" min="1" inputmode="numeric" aria-describedby="add-user-hint" required>
              </div>
              <p class="govuk-body govuk-!-margin-bottom-2">
                <a class="govuk-link" href="{{ urlFor('/members') }}">{{ t("govuk_alpha_messages.manage.add_via_directory") }}</a>
              </p>
              <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0">{{ t("govuk_alpha_messages.manage.add_button") }}</button>
            </fieldset>
          </form>
        </div>
      {% else %}
        <p class="govuk-hint govuk-!-margin-top-4">{{ t("govuk_alpha_messages.manage.admin_only_notice") }}</p>
      {% endif %}

      <div class="govuk-!-margin-top-6">
        <h2 class="govuk-heading-m">{{ t("govuk_alpha_messages.manage.leave_heading") }}</h2>
        <div class="govuk-warning-text">
          <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
          <strong class="govuk-warning-text__text">
            <span class="govuk-visually-hidden">{{ t("govuk_alpha.states.warning_prefix") }}</span>
            {{ t("govuk_alpha_messages.manage.leave_warning") }}
          </strong>
        </div>
        <form method="post" action="{{ urlFor('/messages/groups/' + (conversation.id | string) + '/members/' + (currentUserId | string) + '/remove') }}">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <input type="hidden" name="self_leave" value="1">
          <button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0">{{ t("govuk_alpha_messages.manage.leave_button") }}</button>
        </form>
      </div>
    </div>
  </div>
{% endblock %}
