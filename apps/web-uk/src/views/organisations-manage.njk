{% extends "layouts/base.njk" %}

{% macro roleLabel(role) %}
  {% if role == "owner" %}
    {{ t("govuk_alpha_organisations.manage.role_owner") }}
  {% elseif role == "admin" %}
    {{ t("govuk_alpha_organisations.manage.role_admin") }}
  {% else %}
    {{ t("govuk_alpha_organisations.manage.role_member") }}
  {% endif %}
{% endmacro %}

{% block mainContent %}
  <a class="govuk-back-link" href="{{ urlFor('/organisations/browse') }}">{{ t("govuk_alpha_organisations.common.back_to_organisations") }}</a>

  <span class="govuk-caption-xl">{{ t("govuk_alpha_organisations.common.caption", { community: tenantName }) }}</span>
  <h1 class="govuk-heading-xl">{{ t("govuk_alpha_organisations.manage.title") }}</h1>

  {% if error %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">{{ t("govuk_alpha_organisations.common.error_title") }}</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            <li>{{ t("govuk_alpha_organisations.common.load_error") }}</li>
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  <p class="govuk-body-l">{{ t("govuk_alpha_organisations.manage.description") }}</p>

  {% if (not manageableOrganisations or manageableOrganisations.length == 0) and (not pendingOrganisations or pendingOrganisations.length == 0) %}
    <div class="govuk-inset-text">
      <h2 class="govuk-heading-m govuk-!-margin-bottom-2">{{ t("govuk_alpha_organisations.manage.empty_title") }}</h2>
      <p class="govuk-body">{{ t("govuk_alpha_organisations.manage.empty_body") }}</p>
      <a class="govuk-button" data-module="govuk-button" href="{{ urlFor('/organisations/register') }}">{{ t("govuk_alpha_organisations.manage.register_cta") }}</a>
    </div>
  {% else %}
    {% if manageableOrganisations and manageableOrganisations.length %}
      <div class="nexus-alpha-card-list">
        {% for organisation in manageableOrganisations %}
          <article class="nexus-alpha-card">
            <h2 class="govuk-heading-s govuk-!-margin-bottom-1">{{ organisation.name }}</h2>
            <dl class="nexus-alpha-inline-list nexus-alpha-meta">
              <div>
                <dt>{{ t("govuk_alpha_organisations.manage.role_label") }}</dt>
                <dd>{{ roleLabel(organisation.member_role) }}</dd>
              </div>
            </dl>
            <div class="nexus-alpha-actions">
              <a class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button" href="{{ urlFor('/volunteering/organisations/' + (organisation.id | string) + '/manage') }}">{{ t("govuk_alpha_organisations.manage.manage_button") }}</a>
              <a class="govuk-link" href="{{ urlFor('/organisations/' + (organisation.id | string)) }}">{{ t("govuk_alpha_organisations.common.view_organisation") }}</a>
            </div>
          </article>
        {% endfor %}
      </div>
    {% endif %}

    {% if pendingOrganisations and pendingOrganisations.length %}
      <h2 class="govuk-heading-l govuk-!-margin-top-6">{{ t("govuk_alpha_organisations.manage.status_pending") }}</h2>
      <div class="nexus-alpha-card-list">
        {% for organisation in pendingOrganisations %}
          <article class="nexus-alpha-card">
            <h3 class="govuk-heading-s govuk-!-margin-bottom-1">{{ organisation.name }}</h3>
            <p class="govuk-body govuk-!-margin-bottom-0">
              <strong class="govuk-tag govuk-tag--yellow">{{ t("govuk_alpha_organisations.manage.status_pending") }}</strong>
            </p>
            <p class="govuk-body govuk-!-margin-top-2 govuk-!-margin-bottom-0">{{ t("govuk_alpha_organisations.manage.status_pending_note") }}</p>
          </article>
        {% endfor %}
      </div>
    {% endif %}
  {% endif %}
{% endblock %}
