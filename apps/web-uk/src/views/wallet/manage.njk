{% extends "layouts/base.njk" %}

{% block content %}
  <a class="govuk-back-link" href="/wallet">Back to wallet</a>

  {% if status %}
    {% if status.type == "success" %}
      <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="wallet-manage-success-title">
        <div class="govuk-notification-banner__header">
          <h2 class="govuk-notification-banner__title" id="wallet-manage-success-title">Success</h2>
        </div>
        <div class="govuk-notification-banner__content">
          <p class="govuk-notification-banner__heading">{{ status.message }}</p>
        </div>
      </div>
    {% else %}
      <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
        <div role="alert">
          <h2 class="govuk-error-summary__title">There is a problem</h2>
          <div class="govuk-error-summary__body">
            <ul class="govuk-list govuk-error-summary__list">
              <li><a href="{{ status.href }}">{{ status.message }}</a></li>
            </ul>
          </div>
        </div>
      </div>
    {% endif %}
  {% endif %}

  <span class="govuk-caption-l">Wallet</span>
  <h1 class="govuk-heading-xl">Manage credits</h1>
  <p class="govuk-body-l">Use this page to send time credits, donate credits, and review wallet status.</p>

  <section aria-labelledby="wallet-balance-heading" id="balance">
    <h2 class="govuk-heading-l" id="wallet-balance-heading">Your balance</h2>
    <div class="nexus-alpha-card">
      <p class="govuk-heading-l govuk-!-margin-bottom-2">{{ creditsLabel(wallet.balance) }}</p>
      {% if wallet.pendingIn > 0 %}
        <strong class="govuk-tag govuk-tag--yellow">{{ wallet.pendingIn | round }} pending in</strong>
      {% else %}
        <strong class="govuk-tag govuk-tag--grey">No pending credits</strong>
      {% endif %}
    </div>
  </section>

  <section aria-labelledby="wallet-stats-heading" id="stats">
    <h2 class="govuk-heading-l govuk-!-margin-top-7" id="wallet-stats-heading">Wallet summary</h2>
    <dl class="nexus-alpha-stat-grid">
      <div class="nexus-alpha-stat">
        <dt>Total earned</dt>
        <dd>{{ creditsLabel(wallet.earned) }}</dd>
      </div>
      <div class="nexus-alpha-stat">
        <dt>Total spent</dt>
        <dd>{{ creditsLabel(wallet.spent) }}</dd>
      </div>
      <div class="nexus-alpha-stat">
        <dt>Pending</dt>
        <dd>{{ creditsLabel(wallet.pendingTotal) }}</dd>
      </div>
    </dl>
    <p class="govuk-hint">Pending combines incoming and outgoing time-credit activity awaiting completion.</p>
  </section>

  <section aria-labelledby="transfer-heading" id="transfer">
    <h2 class="govuk-heading-l govuk-!-margin-top-7" id="transfer-heading">Send credits to a member</h2>
    <p class="govuk-body">Search for a member, then send a no-JS transfer request through the wallet transfer route.</p>

    <form method="get" action="/wallet/manage" class="govuk-!-margin-bottom-4">
      <div class="govuk-form-group">
        <label class="govuk-label" for="recipient_q">Search for a member</label>
        <div id="recipient-q-hint" class="govuk-hint">Enter at least 2 characters.</div>
        <input class="govuk-input govuk-!-width-two-thirds" id="recipient_q" name="recipient_q" type="search" value="{{ recipientQuery }}" aria-describedby="recipient-q-hint">
      </div>
      <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">Search</button>
    </form>

    {% if recipientQuery and not recipients.length %}
      <p class="govuk-body">No members matched your search.</p>
    {% endif %}

    {% for recipient in recipients %}
      <div class="nexus-alpha-card govuk-!-margin-bottom-4">
        <h3 class="govuk-heading-m govuk-!-margin-bottom-1">{{ recipient.name }}</h3>
        <p class="govuk-hint govuk-!-font-size-16">
          {% if recipient.location %}{{ recipient.location }}{% endif %}
          {% if recipient.location and recipient.memberSince %} - {% endif %}
          {% if recipient.memberSince %}Member since {{ recipient.memberSince }}{% endif %}
        </p>
        <form method="post" action="/wallet/transfer">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <input type="hidden" name="receiver_id" value="{{ recipient.id }}">
          <input type="hidden" name="recipient_id" value="{{ recipient.id }}">
          <div class="govuk-form-group govuk-!-margin-bottom-3">
            <label class="govuk-label" for="amount-{{ recipient.id }}">Amount</label>
            <div id="amount-hint-{{ recipient.id }}" class="govuk-hint">Enter the time credits to send.</div>
            <input class="govuk-input govuk-input--width-5" id="amount-{{ recipient.id }}" name="amount" type="number" min="0.25" max="1000" step="0.25" inputmode="decimal" aria-describedby="amount-hint-{{ recipient.id }}" required>
          </div>
          <div class="govuk-form-group govuk-!-margin-bottom-3">
            <label class="govuk-label" for="description-{{ recipient.id }}">Note</label>
            <input class="govuk-input" id="description-{{ recipient.id }}" name="description" type="text" maxlength="255">
          </div>
          <button class="govuk-button govuk-!-margin-bottom-0" data-module="govuk-button">Send credits to {{ recipient.name }}</button>
        </form>
      </div>
    {% endfor %}
  </section>

  <section aria-labelledby="donate-heading" id="donate">
    <h2 class="govuk-heading-l govuk-!-margin-top-7" id="donate-heading">Donate credits</h2>
    <p class="govuk-body">Donate whole credits to the community fund or to a searched member.</p>

    <dl class="govuk-summary-list">
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Community fund balance</dt>
        <dd class="govuk-summary-list__value">{{ creditsLabel(fund.balance) }}</dd>
      </div>
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Total donated to the fund</dt>
        <dd class="govuk-summary-list__value">{{ creditsLabel(fund.donated) }}</dd>
      </div>
    </dl>

    <form method="post" action="/wallet/donate">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}">

      <div class="govuk-form-group">
        <fieldset class="govuk-fieldset">
          <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">Donate to</legend>
          <div class="govuk-radios" data-module="govuk-radios">
            <div class="govuk-radios__item">
              <input class="govuk-radios__input" id="donate-target-fund" name="target" type="radio" value="community_fund"{% if donateTarget != "user" %} checked{% endif %}>
              <label class="govuk-label govuk-radios__label" for="donate-target-fund">Community fund</label>
            </div>
            <div class="govuk-radios__item">
              <input class="govuk-radios__input" id="donate-target-member" name="target" type="radio" value="user"{% if donateTarget == "user" %} checked{% endif %}{% if not recipients.length %} disabled{% endif %}>
              <label class="govuk-label govuk-radios__label" for="donate-target-member">Searched member</label>
            </div>
          </div>
        </fieldset>
      </div>

      {% if recipients.length %}
        <input type="hidden" name="recipient_id" value="{{ recipients[0].id }}">
        <p class="govuk-body">Selected member: {{ recipients[0].name }}</p>
      {% else %}
        <p class="govuk-hint">Search for a member above before donating directly to a member.</p>
      {% endif %}

      <div class="govuk-form-group">
        <label class="govuk-label" for="donate-amount">Amount</label>
        <div id="donate-amount-hint" class="govuk-hint">Enter whole time credits.</div>
        <input class="govuk-input govuk-input--width-5" id="donate-amount" name="amount" type="number" min="1" max="1000" step="1" inputmode="numeric" aria-describedby="donate-amount-hint" required>
      </div>
      <div class="govuk-form-group">
        <label class="govuk-label" for="donate-message">Message (optional)</label>
        <input class="govuk-input" id="donate-message" name="message" type="text" maxlength="255">
      </div>
      <button class="govuk-button" data-module="govuk-button">Donate credits</button>
    </form>
  </section>
{% endblock %}
