{% extends "layouts/base.njk" %}

{% block content %}
  <a class="govuk-back-link" href="{{ urlFor('/wallet') }}">{{ t("govuk_alpha_wallet.manage.back_to_wallet") }}</a>

  {% if status %}
    {% if status.type == "success" %}
      <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="wallet-manage-success-title">
        <div class="govuk-notification-banner__header">
          <h2 class="govuk-notification-banner__title" id="wallet-manage-success-title">{{ t("govuk_alpha_wallet.states.success_title") }}</h2>
        </div>
        <div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ status.message }}</p></div>
      </div>
    {% else %}
      <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
        <div role="alert">
          <h2 class="govuk-error-summary__title">{{ t("govuk_alpha_wallet.states.error_title") }}</h2>
          <div class="govuk-error-summary__body"><ul class="govuk-list govuk-error-summary__list"><li><a href="{{ status.href }}">{{ status.message }}</a></li></ul></div>
        </div>
      </div>
    {% endif %}
  {% endif %}

  <span class="govuk-caption-l">{{ t("govuk_alpha_wallet.manage.caption") }}</span>
  <h1 class="govuk-heading-xl">{{ t("govuk_alpha_wallet.manage.title") }}</h1>
  <p class="govuk-body-l">{{ t("govuk_alpha_wallet.manage.description") }}</p>

  <section aria-labelledby="wallet-balance-heading" id="balance">
    <h2 class="govuk-heading-l" id="wallet-balance-heading">{{ t("govuk_alpha_wallet.balance.heading") }}</h2>
    <div class="nexus-alpha-card">
      <dl class="govuk-summary-list govuk-!-margin-bottom-2">
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">{{ t("govuk_alpha_wallet.balance.label") }}</dt>
          <dd class="govuk-summary-list__value">{{ t("govuk_alpha_wallet.hours_value", { value: hoursValue(wallet.balance) }) }}</dd>
        </div>
      </dl>
      <p class="govuk-body govuk-!-margin-bottom-0">
        {% if wallet.pendingIn > 0 %}
          <strong class="govuk-tag govuk-tag--yellow">{{ tc("govuk_alpha_wallet.balance.pending_badge_in", wallet.pendingIn | round, { count: wallet.pendingIn | round }) }}</strong>
        {% else %}
          <strong class="govuk-tag govuk-tag--grey">{{ t("govuk_alpha_wallet.balance.no_pending") }}</strong>
        {% endif %}
      </p>
    </div>
  </section>

  <section aria-labelledby="wallet-stats-heading" id="stats">
    <h2 class="govuk-heading-l govuk-!-margin-top-7" id="wallet-stats-heading">{{ t("govuk_alpha_wallet.stats.heading") }}</h2>
    <dl class="nexus-alpha-stat-grid">
      <div class="nexus-alpha-stat"><dt>{{ t("govuk_alpha_wallet.stats.earned") }}</dt><dd>{{ t("govuk_alpha_wallet.stats.earned_value", { value: hoursValue(wallet.earned) }) }}</dd></div>
      <div class="nexus-alpha-stat"><dt>{{ t("govuk_alpha_wallet.stats.spent") }}</dt><dd>{{ t("govuk_alpha_wallet.stats.spent_value", { value: hoursValue(wallet.spent) }) }}</dd></div>
      <div class="nexus-alpha-stat"><dt>{{ t("govuk_alpha_wallet.stats.pending") }}</dt><dd>{{ t("govuk_alpha_wallet.stats.pending_value", { value: hoursValue(wallet.pendingTotal) }) }}</dd></div>
    </dl>
    <p class="govuk-hint">{{ t("govuk_alpha_wallet.stats.pending_hint") }}</p>
  </section>

  <section aria-labelledby="transfer-heading" id="transfer">
    <h2 class="govuk-heading-l govuk-!-margin-top-7" id="transfer-heading">{{ t("govuk_alpha_wallet.transfer.heading") }}</h2>
    <p class="govuk-body">{{ t("govuk_alpha_wallet.transfer.description") }}</p>

    <form method="get" action="{{ urlFor('/wallet/manage') }}" class="govuk-!-margin-bottom-4">
      <div class="govuk-form-group">
        <label class="govuk-label" for="recipient_q">{{ t("govuk_alpha_wallet.transfer.search_label") }}</label>
        <div id="recipient-q-hint" class="govuk-hint">{{ t("govuk_alpha_wallet.transfer.search_hint") }}</div>
        <input class="govuk-input govuk-!-width-two-thirds" id="recipient_q" name="recipient_q" type="search" value="{{ recipientQuery }}" aria-describedby="recipient-q-hint">
      </div>
      <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">{{ t("govuk_alpha_wallet.transfer.search_button") }}</button>
    </form>

    {% if recipientQuery and not recipients.length %}<p class="govuk-body">{{ t("govuk_alpha_wallet.transfer.search_empty") }}</p>{% endif %}
    {% if recipients.length %}<h3 class="govuk-heading-m">{{ t("govuk_alpha_wallet.transfer.recipient_heading") }}</h3>{% endif %}

    {% for recipient in recipients %}
      <div class="nexus-alpha-card govuk-!-margin-bottom-4">
        <h4 class="govuk-heading-s govuk-!-margin-bottom-1">{{ recipient.name }}</h4>
        {% if recipient.location or recipient.memberSince %}
          <p class="govuk-hint govuk-!-font-size-16 govuk-!-margin-bottom-3">{% if recipient.location %}{{ recipient.location }}{% endif %}{% if recipient.location and recipient.memberSince %} · {% endif %}{% if recipient.memberSince %}{{ t("govuk_alpha_wallet.member_since", { date: recipient.memberSince }) }}{% endif %}</p>
        {% endif %}
        <form method="post" action="{{ urlFor('/wallet/transfer') }}">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <input type="hidden" name="recipient_id" value="{{ recipient.id }}">
          <input type="hidden" name="idempotency_key" value="{{ recipient.idempotencyKey }}">
          <div class="govuk-form-group govuk-!-margin-bottom-3">
            <label class="govuk-label" for="amount-{{ recipient.id }}">{{ t("govuk_alpha_wallet.transfer.amount_label") }}</label>
            <div id="amount-hint-{{ recipient.id }}" class="govuk-hint">{{ t("govuk_alpha_wallet.transfer.amount_hint") }}</div>
            <input class="govuk-input govuk-input--width-5" id="amount-{{ recipient.id }}" name="amount" type="number" min="0.25" max="1000" step="0.25" inputmode="decimal" aria-describedby="amount-hint-{{ recipient.id }}" required>
          </div>
          <div class="govuk-form-group govuk-!-margin-bottom-3">
            <label class="govuk-label" for="note-{{ recipient.id }}">{{ t("govuk_alpha_wallet.transfer.note_label") }}</label>
            <div id="note-hint-{{ recipient.id }}" class="govuk-hint">{{ t("govuk_alpha_wallet.transfer.note_hint") }}</div>
            <input class="govuk-input" id="note-{{ recipient.id }}" name="note" type="text" maxlength="255" aria-describedby="note-hint-{{ recipient.id }}">
          </div>
          <button class="govuk-button govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("govuk_alpha_wallet.transfer.send_button", { name: recipient.name }) }}</button>
        </form>
      </div>
    {% endfor %}
  </section>

  <section aria-labelledby="donate-heading" id="donate">
    <h2 class="govuk-heading-l govuk-!-margin-top-7" id="donate-heading">{{ t("govuk_alpha_wallet.donate.heading") }}</h2>
    <p class="govuk-body">{{ t("govuk_alpha_wallet.donate.description") }}</p>
    <div class="govuk-inset-text" role="note"><p class="govuk-body govuk-!-margin-bottom-0">{{ t("govuk_alpha_wallet.donate.credits_not_money") }}</p></div>

    <dl class="govuk-summary-list">
      <div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_wallet.donate.fund_balance_label") }}</dt><dd class="govuk-summary-list__value">{{ t("govuk_alpha_wallet.hours_value", { value: hoursValue(fund.balance) }) }}</dd></div>
      <div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_wallet.donate.fund_donated_label") }}</dt><dd class="govuk-summary-list__value">{{ t("govuk_alpha_wallet.hours_value", { value: hoursValue(fund.donated) }) }}</dd></div>
    </dl>

    <div class="govuk-warning-text"><span class="govuk-warning-text__icon" aria-hidden="true">!</span><strong class="govuk-warning-text__text"><span class="govuk-visually-hidden">{{ t("govuk_alpha_wallet.states.warning") }}</span>{{ t("govuk_alpha_wallet.donate.warning") }}</strong></div>

    <form method="post" action="{{ urlFor('/wallet/donate') }}">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
      <div class="govuk-form-group">
        <fieldset class="govuk-fieldset" aria-describedby="donate-target-hint">
          <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">{{ t("govuk_alpha_wallet.donate.target_legend") }}</legend>
          <div id="donate-target-hint" class="govuk-hint">{{ t("govuk_alpha_wallet.donate.target_fund_hint") }}</div>
          <div class="govuk-radios" data-module="govuk-radios">
            <div class="govuk-radios__item"><input class="govuk-radios__input" id="donate-target-fund" name="target" type="radio" value="community_fund"{% if donateTarget != "user" %} checked{% endif %}><label class="govuk-label govuk-radios__label" for="donate-target-fund">{{ t("govuk_alpha_wallet.donate.target_fund") }}</label></div>
            <div class="govuk-radios__item"><input class="govuk-radios__input" id="donate-target-member" name="target" type="radio" value="user"{% if donateTarget == "user" %} checked{% endif %}{% if not recipients.length %} disabled{% endif %}><label class="govuk-label govuk-radios__label" for="donate-target-member">{{ t("govuk_alpha_wallet.donate.target_member") }}</label><div class="govuk-hint govuk-radios__hint">{{ t("govuk_alpha_wallet.donate.target_member_hint") }}</div></div>
          </div>
        </fieldset>
      </div>

      {% if recipients.length %}<input type="hidden" name="recipient_id" value="{{ recipients[0].id }}"><p class="govuk-body">{{ recipients[0].name }}</p>{% else %}<p class="govuk-hint">{{ t("govuk_alpha_wallet.donate.recipient_required") }}</p>{% endif %}
      <div class="govuk-form-group"><label class="govuk-label" for="donate-amount">{{ t("govuk_alpha_wallet.donate.amount_label") }}</label><div id="donate-amount-hint" class="govuk-hint">{{ t("govuk_alpha_wallet.donate.amount_hint") }}</div><input class="govuk-input govuk-input--width-5" id="donate-amount" name="amount" type="number" min="1" max="1000" step="1" inputmode="numeric" aria-describedby="donate-amount-hint" required></div>
      <div class="govuk-form-group"><label class="govuk-label" for="donate-message">{{ t("govuk_alpha_wallet.donate.message_label") }}</label><div id="donate-message-hint" class="govuk-hint">{{ t("govuk_alpha_wallet.donate.message_hint") }}</div><input class="govuk-input" id="donate-message" name="message" type="text" maxlength="255" aria-describedby="donate-message-hint"></div>
      <button class="govuk-button" data-module="govuk-button">{% if recipients.length and donateTarget == "user" %}{{ t("govuk_alpha_wallet.donate.button_member", { name: recipients[0].name }) }}{% else %}{{ t("govuk_alpha_wallet.donate.button_fund") }}{% endif %}</button>
    </form>
  </section>

  <p class="govuk-body govuk-!-margin-top-7"><a class="govuk-link" href="{{ urlFor('/wallet') }}">{{ t("govuk_alpha_wallet.footer.wallet_link") }}</a></p>
{% endblock %}
