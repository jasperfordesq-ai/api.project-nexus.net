{% extends "layouts/base.njk" %}

{% block content %}
  {% if status == "transfer-sent" %}
    <div class="govuk-panel govuk-panel--confirmation"><h2 class="govuk-panel__title">{{ t("states.success_title") }}</h2><div class="govuk-panel__body">{{ t("wallet.sent") }}</div></div>
  {% elseif status == "transfer-failed" %}
    {% set transferMessage = t("wallet.errors.failed") %}
    {% if transferError == "invalid" %}{% set transferMessage = t("wallet.errors.invalid") %}{% elseif transferError == "insufficient" %}{% set transferMessage = t("wallet.errors.insufficient") %}{% elseif transferError == "not-found" %}{% set transferMessage = t("wallet.errors.not_found") %}{% elseif transferError == "self" %}{% set transferMessage = t("wallet.errors.self") %}{% elseif transferError == "inactive" %}{% set transferMessage = t("wallet.errors.inactive") %}{% elseif transferError == "too-large" %}{% set transferMessage = t("wallet.errors.too_large") %}{% elseif transferError == "decimals" %}{% set transferMessage = t("wallet.errors.decimals") %}{% endif %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1"><div role="alert"><h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2><div class="govuk-error-summary__body"><ul class="govuk-list govuk-error-summary__list"><li><a href="#transfer">{{ transferMessage }}</a></li></ul></div></div></div>
  {% elseif status == "donate-sent" %}
    <div class="govuk-notification-banner govuk-notification-banner--success" role="alert" aria-labelledby="wallet-donate-success-title" data-module="govuk-notification-banner"><div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title" id="wallet-donate-success-title">{{ t("states.success_title") }}</h2></div><div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ t("wallet_t1.donate_success") }}</p></div></div>
  {% elseif status == "donate-failed" %}
    {% set donateMessage = t("wallet_t1.errors.failed") %}
    {% if donateError == "invalid" %}{% set donateMessage = t("wallet_t1.errors.invalid") %}{% elseif donateError == "insufficient" %}{% set donateMessage = t("wallet_t1.errors.insufficient") %}{% elseif donateError == "not-found" %}{% set donateMessage = t("wallet_t1.errors.not_found") %}{% elseif donateError == "self" %}{% set donateMessage = t("wallet_t1.errors.self") %}{% elseif donateError == "too-large" %}{% set donateMessage = t("wallet_t1.errors.too_large") %}{% elseif donateError == "decimals" %}{% set donateMessage = t("wallet_t1.errors.decimals") %}{% endif %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1"><div role="alert"><h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2><div class="govuk-error-summary__body"><ul class="govuk-list govuk-error-summary__list"><li><a href="#donate">{{ donateMessage }}</a></li></ul></div></div></div>
  {% elseif status == "export-failed" %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1"><div role="alert"><h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2><div class="govuk-error-summary__body"><ul class="govuk-list govuk-error-summary__list"><li><a href="#transactions">{{ t("wallet_t1.export_failed") }}</a></li></ul></div></div></div>
  {% endif %}

  <span class="govuk-caption-l">{{ t("wallet.caption", { community: communityName }) }}</span>
  <h1 class="govuk-heading-xl">{{ t("wallet.title") }}</h1>
  <p class="govuk-body-l">{{ t("wallet.description") }}</p>
  <p class="govuk-body"><a class="govuk-link" href="{{ urlFor('/wallet/manage') }}">{{ t("govuk_alpha_wallet.nav.manage") }}</a></p>

  <dl class="nexus-alpha-stat-grid">
    <div class="nexus-alpha-stat"><dt>{{ t("wallet.balance_label") }}</dt><dd>{{ t("wallet.hours_value", { value: hoursValue(wallet.balance) }) }}</dd></div>
    <div class="nexus-alpha-stat"><dt>{{ t("wallet.earned_label") }}</dt><dd>{{ t("wallet.hours_value", { value: hoursValue(wallet.earned) }) }}</dd></div>
    <div class="nexus-alpha-stat"><dt>{{ t("wallet.spent_label") }}</dt><dd>{{ t("wallet.hours_value", { value: hoursValue(wallet.spent) }) }}</dd></div>
    {% if wallet.pendingIn > 0 %}<div class="nexus-alpha-stat"><dt>{{ t("wallet.pending_in_label") }}</dt><dd>{{ t("wallet.hours_value", { value: hoursValue(wallet.pendingIn) }) }} <strong class="govuk-tag govuk-tag--yellow">{{ t("wallet.pending_in_badge") }}</strong></dd></div>{% endif %}
  </dl>

  <section aria-labelledby="fund-heading" id="community-fund">
    <h2 class="govuk-heading-l govuk-!-margin-top-7" id="fund-heading">{{ t("wallet_t1.fund_heading") }}</h2>
    <p class="govuk-body">{{ t("wallet_t1.fund_description") }}</p>
    <dl class="govuk-summary-list">
      <div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("wallet_t1.fund_balance_label") }}</dt><dd class="govuk-summary-list__value">{{ t("wallet.hours_value", { value: hoursValue(fund.balance) }) }}</dd></div>
      <div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("wallet_t1.fund_donated_label") }}</dt><dd class="govuk-summary-list__value">{{ t("wallet.hours_value", { value: hoursValue(fund.donated) }) }}</dd></div>
    </dl>
  </section>

  <section aria-labelledby="donate-heading" id="donate">
    <h2 class="govuk-heading-l govuk-!-margin-top-7" id="donate-heading">{{ t("wallet_t1.donate_title") }}</h2>
    <p class="govuk-body">{{ t("wallet_t1.donate_description") }}</p>
    <div class="govuk-inset-text" role="note"><p class="govuk-body govuk-!-margin-bottom-0">{{ t("vol_clarity.donate_credits_not_money") }}</p></div>
    <div class="govuk-warning-text"><span class="govuk-warning-text__icon" aria-hidden="true">!</span><strong class="govuk-warning-text__text"><span class="govuk-visually-hidden">{{ t("states.warning") }}</span>{{ t("wallet_t1.donate_warning") }}</strong></div>
    <form method="post" action="{{ urlFor('/wallet/donate') }}">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="target" value="community_fund">
      <div class="govuk-form-group"><label class="govuk-label" for="donate-amount">{{ t("wallet_t1.donate_amount_label") }}</label><div id="donate-amount-hint" class="govuk-hint">{{ t("wallet_t1.donate_amount_hint") }}</div><input class="govuk-input govuk-input--width-5" id="donate-amount" name="amount" type="number" min="1" max="1000" step="1" inputmode="numeric" aria-describedby="donate-amount-hint" required></div>
      <div class="govuk-form-group"><label class="govuk-label" for="donate-message">{{ t("wallet_t1.donate_message_label") }}</label><div id="donate-message-hint" class="govuk-hint">{{ t("wallet_t1.donate_message_hint") }}</div><input class="govuk-input" id="donate-message" name="message" type="text" maxlength="255" aria-describedby="donate-message-hint"></div>
      <button class="govuk-button" data-module="govuk-button">{{ t("wallet_t1.donate_button") }}</button>
    </form>
  </section>

  <section aria-labelledby="transfer-heading" id="transfer">
    <h2 class="govuk-heading-l govuk-!-margin-top-7" id="transfer-heading">{{ t("wallet.transfer_title") }}</h2>
    <p class="govuk-body">{{ t("wallet.transfer_description") }}</p>
    <form method="get" action="{{ urlFor('/wallet') }}">
      <div class="govuk-form-group"><label class="govuk-label" for="recipient_q">{{ t("wallet.search_label") }}</label><div id="recipient-q-hint" class="govuk-hint">{{ t("wallet.search_hint") }}</div><input class="govuk-input govuk-!-width-two-thirds" id="recipient_q" name="recipient_q" type="search" value="{{ recipientQuery }}" aria-describedby="recipient-q-hint"></div>
      <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">{{ t("actions.search") }}</button>
    </form>
    {% if recipientQuery and not recipients.length %}<p class="govuk-body">{{ t("wallet.search_empty") }}</p>{% endif %}
    {% if recipients.length %}<h3 class="govuk-heading-m">{{ t("wallet.recipient_heading") }}</h3>{% endif %}
    {% for recipient in recipients %}
      <div class="nexus-alpha-card govuk-!-margin-bottom-4">
        <h4 class="govuk-heading-s govuk-!-margin-bottom-1">{{ recipient.name }}</h4>
        {% if recipient.location or recipient.memberSince %}<p class="govuk-hint govuk-!-font-size-16 govuk-!-margin-bottom-3">{% if recipient.location %}{{ recipient.location }}{% endif %}{% if recipient.location and recipient.memberSince %} · {% endif %}{% if recipient.memberSince %}{{ t("wallet.member_since", { date: recipient.memberSince }) }}{% endif %}</p>{% endif %}
        <form method="post" action="{{ urlFor('/wallet/transfer') }}">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="recipient_id" value="{{ recipient.id }}"><input type="hidden" name="idempotency_key" value="{{ recipient.idempotencyKey }}">
          <div class="govuk-form-group govuk-!-margin-bottom-3"><label class="govuk-label" for="amount-{{ recipient.id }}">{{ t("wallet.amount_label") }}</label><div id="amount-hint-{{ recipient.id }}" class="govuk-hint">{{ t("wallet.amount_hint") }}</div><input class="govuk-input govuk-input--width-5" id="amount-{{ recipient.id }}" name="amount" type="number" min="0.25" max="1000" step="0.25" inputmode="decimal" aria-describedby="amount-hint-{{ recipient.id }}" required></div>
          <div class="govuk-form-group govuk-!-margin-bottom-3"><label class="govuk-label" for="note-{{ recipient.id }}">{{ t("wallet.note_label") }}</label><div id="note-hint-{{ recipient.id }}" class="govuk-hint">{{ t("wallet.note_hint") }}</div><input class="govuk-input" id="note-{{ recipient.id }}" name="note" type="text" maxlength="255" aria-describedby="note-hint-{{ recipient.id }}"></div>
          <div class="govuk-form-group govuk-!-margin-bottom-3"><div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="confirm-{{ recipient.id }}" name="confirm" type="checkbox" value="1" required><label class="govuk-label govuk-checkboxes__label" for="confirm-{{ recipient.id }}">{{ t("ux.transfer_confirm_label") }}</label></div></div></div>
          <button class="govuk-button govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("wallet.send_button", { name: recipient.name }) }}</button>
        </form>
      </div>
    {% endfor %}
  </section>

  <section aria-labelledby="transactions-heading" id="transactions">
    <h2 class="govuk-heading-l govuk-!-margin-top-7" id="transactions-heading">{{ t("wallet.history_title") }}</h2>
    <p class="govuk-body"><a class="govuk-link" href="{{ urlFor('/wallet/export.csv') }}" download>{{ t("wallet_t1.export_button") }}</a> <span class="govuk-hint govuk-!-display-inline">— {{ t("wallet_t1.export_description") }}</span></p>
    <nav aria-label="{{ t('wallet_t1.filter_heading') }}" class="govuk-!-margin-bottom-4"><ul class="nexus-alpha-filter-nav">
      <li><a class="govuk-link" href="{{ urlFor('/wallet') }}#transactions"{% if txFilter == "all" %} aria-current="page"{% endif %}>{{ t("wallet_t1.filter_all") }}</a></li>
      <li><a class="govuk-link" href="{{ urlFor('/wallet?filter=earned') }}#transactions"{% if txFilter == "earned" %} aria-current="page"{% endif %}>{{ t("wallet_t1.filter_earned") }}</a></li>
      <li><a class="govuk-link" href="{{ urlFor('/wallet?filter=spent') }}#transactions"{% if txFilter == "spent" %} aria-current="page"{% endif %}>{{ t("wallet_t1.filter_spent") }}</a></li>
      <li><a class="govuk-link" href="{{ urlFor('/wallet?filter=pending') }}#transactions"{% if txFilter == "pending" %} aria-current="page"{% endif %}>{{ t("wallet_t1.filter_pending") }}</a></li>
    </ul></nav>
    {% if transactions.length %}
      <table class="govuk-table"><caption class="govuk-table__caption govuk-table__caption--s govuk-visually-hidden">{{ t("wallet.history_title") }}</caption><thead class="govuk-table__head"><tr class="govuk-table__row"><th scope="col" class="govuk-table__header">{{ t("wallet.when_label") }}</th><th scope="col" class="govuk-table__header">{{ t("wallet.with_label") }}</th><th scope="col" class="govuk-table__header">{{ t("wallet.description_label") }}</th><th scope="col" class="govuk-table__header govuk-table__header--numeric">{{ t("wallet.amount_col") }}</th></tr></thead><tbody class="govuk-table__body">
      {% for tx in transactions %}<tr class="govuk-table__row"><td class="govuk-table__cell">{{ tx.dateLabel or "—" }}</td><td class="govuk-table__cell">{{ tx.otherName }}</td><td class="govuk-table__cell">{{ tx.descriptionLabel or "—" }}</td><td class="govuk-table__cell govuk-table__cell--numeric">{% if tx.isCredit %}+{% else %}−{% endif %}{{ tx.amountLabel }} <span class="govuk-visually-hidden">{{ t("wallet.received") if tx.isCredit else t("wallet.sent_short") }}</span></td></tr>{% endfor %}
      </tbody></table>
    {% else %}<div class="govuk-inset-text"><p class="govuk-body">{{ t("wallet.history_empty") }}</p></div>{% endif %}
    {% if txNextCursor %}
      <nav class="govuk-pagination" aria-label="{{ t('wallet.history_title') }}">
        <div class="govuk-pagination__next">
          <a class="govuk-link govuk-pagination__link" href="{{ urlFor('/wallet?filter=' + txFilter + '&cursor=' + (txNextCursor | urlencode)) }}#transactions" rel="next">
            <span class="govuk-pagination__link-title">{{ t("wallet_t1.pagination_next") }}</span>
            <svg class="govuk-pagination__icon govuk-pagination__icon--next" xmlns="http://www.w3.org/2000/svg" height="13" width="15" aria-hidden="true" focusable="false" viewBox="0 0 15 13">
              <path d="m8.107-0.0078125-1.4136 1.414 4.2926 4.293h-12.986v2h12.896l-4.1855 3.9766 1.377 1.4492 6.7441-6.4062-6.7246-6.7266z"></path>
            </svg>
          </a>
        </div>
      </nav>
    {% endif %}
  </section>
{% endblock %}
