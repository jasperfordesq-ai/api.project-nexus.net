{% extends "layouts/base.njk" %}{% block content %}<a class="govuk-back-link" href="{{ urlFor('/events/' + (event.id | string)) }}">{{ t("govuk_alpha_events.common.back_to_event") }}</a>{% if status and status != 'invalid' %}<div class="{{ 'govuk-notification-banner govuk-notification-banner--success' if status in ['settings-saved','settings-published','form-saved','form-published','form-forked'] else 'govuk-error-summary' }}" role="alert" tabindex="-1"><h2 class="govuk-heading-m">{{ t("govuk_alpha_events.common.success_title" if status in ['settings-saved','settings-published','form-saved','form-published','form-forked'] else "govuk_alpha_events.common.error_title") }}</h2><p>{{ t("event_registration.messages." + status | replace('-', '_')) }}</p></div>{% endif %}<span class="govuk-caption-l">{{ event.title }}</span><h1 class="govuk-heading-xl">{{ t("event_registration.title") }}</h1><p class="govuk-body-l">{{ t("event_registration.description") }}</p>
<h2 class="govuk-heading-l">{{ t("event_registration.accessible.attendee_heading") }}</h2>
{% set active = activeRegistration %}
{% include "events/_registration-questionnaire.njk" %}
<h3 class="govuk-heading-m">{{ t("event_registration.accessible.your_invitations") }}</h3>
{% for invitation in attendee.invitations %}
  <div class="govuk-summary-card">
    <div class="govuk-summary-card__title-wrapper">
      <h4 class="govuk-summary-card__title">{{ t("event_registration.invitations.types.member") }}</h4>
      <strong class="govuk-tag">{{ t("event_registration.statuses." + invitation.status) }}</strong>
    </div>
    <div class="govuk-summary-card__content">
      {% if invitation.status == 'issued' %}
        <form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/registration/invitations/' + (invitation.id | string) + '/accept') }}">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}">
          <button class="govuk-button govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("event_registration.accessible.accept_invitation") }}</button>
        </form>
      {% endif %}
    </div>
  </div>
{% else %}
  <p class="govuk-body">{{ t("event_registration.invitations.empty") }}</p>
{% endfor %}
{% include "events/_registration-guests.njk" %}
{% if organizer %}{% include "events/_registration-organizer-settings.njk" %}{% include "events/_registration-organizer-workflows.njk" %}{% endif %}{% endblock %}
