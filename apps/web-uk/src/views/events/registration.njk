{% extends "layouts/base.njk" %}{% block content %}<a class="govuk-back-link" href="{{ urlFor('/events/' + (event.id | string)) }}">{{ t("govuk_alpha_events.common.back_to_event") }}</a>{% if status and status != 'invalid' %}<div class="{{ 'govuk-notification-banner govuk-notification-banner--success' if status in ['settings-saved','settings-published','form-saved','form-published','form-forked'] else 'govuk-error-summary' }}" role="alert" tabindex="-1"><h2 class="govuk-heading-m">{{ t("govuk_alpha_events.common.success_title" if status in ['settings-saved','settings-published','form-saved','form-published','form-forked'] else "govuk_alpha_events.common.error_title") }}</h2><p>{{ t("event_registration.messages." + status | replace('-', '_')) }}</p></div>{% endif %}<span class="govuk-caption-l">{{ event.title }}</span><h1 class="govuk-heading-xl">{{ t("event_registration.title") }}</h1><p class="govuk-body-l">{{ t("event_registration.description") }}</p>
<h2 class="govuk-heading-l">{{ t("event_registration.accessible.attendee_heading") }}</h2>
{% set active = activeRegistration %}
{% include "events/_registration-questionnaire.njk" %}
<h3 class="govuk-heading-m">{{ t("event_registration.accessible.your_invitations") }}</h3>
{% for invitation in attendee.invitations %}
  <div class="govuk-summary-card">
    <div class="govuk-summary-card__title-wrapper">
      <h4 class="govuk-summary-card__title">{{ t("event_registration.invitations.types.member") }}</h4>
      <strong class="govuk-tag">{{ t("event_registration.statuses." + invitation.status) }}</strong>
    </div>
    <div class="govuk-summary-card__content">
      {% if invitation.status == 'issued' %}
        <form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/registration/invitations/' + (invitation.id | string) + '/accept') }}">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}">
          <button class="govuk-button govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("event_registration.accessible.accept_invitation") }}</button>
        </form>
      {% endif %}
    </div>
  </div>
{% else %}
  <p class="govuk-body">{{ t("event_registration.invitations.empty") }}</p>
{% endfor %}
{% if active and attendee.settings.guests_enabled %}<h3 class="govuk-heading-m">{{ t("event_registration.accessible.add_guest") }}</h3><form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/registration/registrations/' + (active.id | string) + '/guests') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="expected_registration_version" value="{{ active.registration_version }}"><label class="govuk-label" for="guest-name">{{ t("event_registration.accessible.guest_name") }}</label><input class="govuk-input" id="guest-name" name="display_name" required><label class="govuk-label" for="guest-email">{{ t("event_registration.accessible.guest_email") }}</label><input class="govuk-input" id="guest-email" name="email" type="email"><div class="govuk-checkboxes"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="guest-consent" name="consent_accepted" type="checkbox" value="1" required><label class="govuk-label govuk-checkboxes__label" for="guest-consent">{{ t("event_registration.accessible.privacy_consent_label") }}</label></div></div><button class="govuk-button">{{ t("event_registration.accessible.add_guest") }}</button></form>{% endif %}{% for guest in attendee.guests %}<div class="govuk-summary-card"><div class="govuk-summary-card__title-wrapper"><h3 class="govuk-summary-card__title">{{ guest.display_name or t("event_registration.guests.name_hidden") }}</h3></div>{% if guest.status == 'captured' %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/registration/guests/' + (guest.id | string) + '/cancel') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="expected_revision" value="{{ guest.revision }}"><input class="govuk-input" name="reason" required><input id="guest-cancel-{{ guest.id }}" name="confirm_destructive" type="checkbox" value="1" required><label for="guest-cancel-{{ guest.id }}">{{ t("event_registration.guests.cancel_confirm_body", { name: guest.display_name }) }}</label><button class="govuk-button govuk-button--warning">{{ t("event_registration.guests.cancel") }}</button></form>{% endif %}</div>{% endfor %}
{% if organizer %}<hr class="govuk-section-break govuk-section-break--xl govuk-section-break--visible"><h2 class="govuk-heading-l">{{ t("event_registration.accessible.organizer_heading") }}</h2>{% set settings = organizer.settings or {} %}<h3 class="govuk-heading-m">{{ t("event_registration.settings.title") }}</h3><form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/registration/settings') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><input type="hidden" name="expected_revision" value="{{ settings.revision or 0 }}"><label class="govuk-label" for="registration-approval-mode">{{ t("event_registration.settings.approval_mode") }}</label><select class="govuk-select" id="registration-approval-mode" name="approval_mode"><option value="auto"{% if settings.approval_mode == "auto" %} selected{% endif %}>{{ t("event_registration.settings.approval_modes.auto") }}</option><option value="manual"{% if settings.approval_mode == "manual" %} selected{% endif %}>{{ t("event_registration.settings.approval_modes.manual") }}</option></select>{% for field in ["opens_at", "closes_at", "cancellation_cutoff_at"] %}<div class="govuk-form-group"><label class="govuk-label" for="registration-{{ field }}">{{ t("event_registration.settings." + ("cancellation_cutoff" if field == "cancellation_cutoff_at" else field)) }}</label><input class="govuk-input govuk-input--width-20" id="registration-{{ field }}" name="{{ field }}" type="datetime-local" value="{{ settings[field + '_utc'] or settings[field] or '' }}"></div>{% endfor %}<label class="govuk-label" for="registration-member-limit">{{ t("event_registration.settings.per_member_limit") }}</label><input class="govuk-input govuk-input--width-3" id="registration-member-limit" name="per_member_limit" type="number" min="1" max="10" value="{{ settings.per_member_limit or 1 }}"><div class="govuk-checkboxes"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="registration-guests-enabled" name="guests_enabled" type="checkbox" value="1"{% if settings.guests_enabled %} checked{% endif %}><label class="govuk-label govuk-checkboxes__label" for="registration-guests-enabled">{{ t("event_registration.settings.guests_enabled") }}</label></div></div><label class="govuk-label" for="registration-guest-limit">{{ t("event_registration.settings.max_guests") }}</label><input class="govuk-input govuk-input--width-3" id="registration-guest-limit" name="max_guests_per_registration" type="number" min="1" max="10" value="{{ settings.max_guests_per_registration or 1 }}"><label class="govuk-label" for="registration-guest-retention">{{ t("event_registration.settings.guest_retention") }}</label><input class="govuk-input govuk-input--width-5" id="registration-guest-retention" name="guest_retention_days" type="number" min="1" max="36500" value="{{ settings.guest_retention_days or 30 }}"><button class="govuk-button">{{ t("event_registration.settings.save") }}</button></form>{% if settings.status == "draft" %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/registration/settings/publish') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><input type="hidden" name="expected_revision" value="{{ settings.revision }}"><button class="govuk-button govuk-button--secondary">{{ t("event_registration.settings.publish") }}</button></form>{% endif %}
<h3 class="govuk-heading-m">{{ t("event_registration.forms.title") }}</h3><p><a class="govuk-link" href="{{ urlFor('/events/' + (event.id | string) + '/registration/forms/new') }}">{{ t("event_registration.forms.new") }}</a></p>{% for form in organizer.forms %}<div class="govuk-summary-card"><div class="govuk-summary-card__title-wrapper"><h4 class="govuk-summary-card__title">{{ form.name }}</h4><strong class="govuk-tag">{{ t("event_registration.statuses." + form.status) }}</strong></div><div class="govuk-summary-card__content">{% if form.status == "draft" %}<a class="govuk-button govuk-button--secondary" href="{{ urlFor('/events/' + (event.id | string) + '/registration/forms/' + (form.id | string)) }}">{{ t("event_registration.forms.edit") }}</a><form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/registration/forms/' + (form.id | string) + '/publish') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><input type="hidden" name="expected_form_revision" value="{{ form.revision }}"><input type="hidden" name="expected_settings_revision" value="{{ settings.revision }}"><button class="govuk-button">{{ t("event_registration.forms.publish") }}</button></form>{% else %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/registration/forms/' + (form.id | string) + '/fork') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><input type="hidden" name="expected_settings_revision" value="{{ settings.revision }}"><button class="govuk-button govuk-button--secondary">{{ t("event_registration.forms.create_revision") }}</button></form>{% endif %}</div></div>{% else %}<p class="govuk-body">{{ t("event_registration.forms.empty") }}</p>{% endfor %}{% include "events/_registration-organizer-workflows.njk" %}{% endif %}{% endblock %}
