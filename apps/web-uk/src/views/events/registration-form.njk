{% extends "layouts/base.njk" %}{% block content %}<a class="govuk-back-link" href="{{ urlFor('/events/' + (eventId | string) + '/registration') }}">{{ t("event_registration.title") }}</a><h1 class="govuk-heading-xl">{{ t("event_registration.forms.editor.edit_title" if form else "event_registration.forms.editor.create_title") }}</h1><p class="govuk-body-l">{{ t("event_registration.forms.editor.rules_description") }}</p><form method="post" action="{{ urlFor('/events/' + (eventId | string) + '/registration/forms/' + ((form.id | string) if form else 'new')) }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><input type="hidden" name="expected_settings_revision" value="{{ settingsRevision }}">{% if form %}<input type="hidden" name="expected_form_revision" value="{{ form.revision }}">{% endif %}<label class="govuk-label govuk-label--m" for="form-name">{{ t("event_registration.forms.editor.name") }}</label><input class="govuk-input" id="form-name" name="name" maxlength="255" value="{{ form.name or '' }}" required><label class="govuk-label" for="form-description">{{ t("event_registration.forms.editor.description") }}</label><textarea class="govuk-textarea" id="form-description" name="description" maxlength="2000">{{ form.description or '' }}</textarea>{% for row in questionRows %}{% set i = loop.index0 %}<fieldset class="govuk-fieldset govuk-!-margin-bottom-8"><legend class="govuk-fieldset__legend govuk-fieldset__legend--l">{{ t("event_registration.forms.editor.question", { number: loop.index }) }}</legend><div class="govuk-checkboxes"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="question-{{ i }}-enabled" name="questions[{{ i }}][enabled]" type="checkbox" value="1"{% if row.stable_key %} checked{% endif %}><label class="govuk-label govuk-checkboxes__label" for="question-{{ i }}-enabled">{{ t("event_registration.accessible.enabled") }}</label></div></div><input type="hidden" name="questions[{{ i }}][stable_key]" value="{{ row.stable_key or ('question_' + (loop.index | string)) }}"><label class="govuk-label" for="question-{{ i }}-type">{{ t("event_registration.forms.editor.type") }}</label><select class="govuk-select" id="question-{{ i }}-type" name="questions[{{ i }}][question_type]">{% for type in ["short_text","long_text","single_choice","multiple_choice","dietary","accessibility","consent","waiver"] %}<option value="{{ type }}"{% if row.question_type == type %} selected{% endif %}>{{ t("event_registration.question_types." + type) }}</option>{% endfor %}</select><label class="govuk-label" for="question-{{ i }}-prompt">{{ t("event_registration.forms.editor.prompt") }}</label><textarea class="govuk-textarea" id="question-{{ i }}-prompt" name="questions[{{ i }}][prompt]">{{ row.prompt or '' }}</textarea><label class="govuk-label" for="question-{{ i }}-purpose">{{ t("event_registration.forms.editor.purpose") }}</label><textarea class="govuk-textarea" id="question-{{ i }}-purpose" name="questions[{{ i }}][purpose]">{{ row.purpose or '' }}</textarea><input type="hidden" name="questions[{{ i }}][data_classification]" value="{{ row.data_classification or 'internal' }}"><label class="govuk-label" for="question-{{ i }}-retention">{{ t("event_registration.forms.editor.retention_days") }}</label><input class="govuk-input govuk-input--width-10" id="question-{{ i }}-retention" name="questions[{{ i }}][retention_days]" type="number" min="1" max="36500" value="{{ row.retention_days or 365 }}"><label class="govuk-label" for="question-{{ i }}-choices">{{ t("event_registration.forms.editor.choices") }}</label><textarea class="govuk-textarea" id="question-{{ i }}-choices" name="questions[{{ i }}][choices]">{% for choice in row.choice_options %}{{ choice }}{% if not loop.last %}
{% endif %}{% endfor %}</textarea></fieldset>{% endfor %}<button class="govuk-button">{{ t("event_registration.common.save") }}</button></form>{% endblock %}
