{% extends "layouts/base.njk" %}
{% block content %}
  <a class="govuk-back-link" href="{{ urlFor('/events/' + (event.id | string)) }}">{{ t("event_safety.govuk.back") }}</a>
  <span class="govuk-caption-l">{{ event.title }}</span>
  <h1 class="govuk-heading-xl">{{ t("event_safety.govuk.title") }}</h1>
  <p class="govuk-body-l">{{ t("event_safety.govuk.intro") }}</p>

  {% if status == "safety-updated" %}
    <div class="govuk-notification-banner govuk-notification-banner--success" role="alert"><div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">{{ t("govuk_alpha.states.success_title") }}</h2></div><div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ t("event_safety.govuk.updated") }}</p></div></div>
  {% elif status == "safety-failed" %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1"><div role="alert"><h2 class="govuk-error-summary__title">{{ t("govuk_alpha.states.error_title") }}</h2><div class="govuk-error-summary__body"><p>{{ t("event_safety.govuk.failed") }}</p></div></div></div>
  {% endif %}

  {% set requirements = safety.requirements %}
  {% set version = requirements.version if requirements else null %}
  {% set code = version.code_of_conduct if version else null %}
  {% set eligibility = safety.eligibility or {} %}
  {% set evidence = safety.evidence or {} %}
  {% set codeEvidence = evidence.code_of_conduct or {} %}
  {% set guardianEvidence = evidence.guardian_consent or {} %}
  {% set permissions = safety.permissions or {} %}
  {% set rollout = safety.rollout or {} %}
  <p class="govuk-body"><strong class="govuk-tag {% if rollout.mode == 'enforce' %}govuk-tag--green{% else %}govuk-tag--yellow{% endif %}">{{ t("event_safety.govuk.rollout." + (rollout.mode or "off")) }}</strong>{% if requirements %} <strong class="govuk-tag govuk-tag--grey">{{ t("event_safety.govuk.requirement_status." + (requirements.status or "draft")) }}</strong>{% endif %}</p>

  {% if permissions.manage_requirements %}
    <section aria-labelledby="safety-policy-heading" class="govuk-!-margin-bottom-8">
      <h2 class="govuk-heading-l" id="safety-policy-heading">{{ t("event_safety.govuk.policy_title") }}</h2><p class="govuk-body">{{ t("event_safety.govuk.policy_intro") }}</p>
      <form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/safety') }}">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="action" value="save_requirements"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><input type="hidden" name="expected_revision" value="{{ requirements.revision if requirements else '' }}">
        <div class="govuk-form-group"><label class="govuk-label" for="minimum-age">{{ t("event_safety.govuk.minimum_age") }}</label><div class="govuk-hint" id="minimum-age-hint">{{ t("event_safety.govuk.minimum_age_hint") }}</div><input class="govuk-input govuk-input--width-3" id="minimum-age" name="minimum_age" type="number" min="0" max="150" value="{{ version.minimum_age if version and version.minimum_age is not none else '' }}" aria-describedby="minimum-age-hint"></div>
        <fieldset class="govuk-fieldset govuk-!-margin-bottom-4"><legend class="govuk-fieldset__legend govuk-fieldset__legend--m">{{ t("event_safety.govuk.guardian_policy") }}</legend><div class="govuk-checkboxes"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="guardian-required" name="guardian_consent_required" type="checkbox" value="1"{% if version and version.guardian_consent_required %} checked{% endif %}><label class="govuk-label govuk-checkboxes__label" for="guardian-required">{{ t("event_safety.govuk.guardian_required") }}</label></div></div></fieldset>
        <div class="govuk-form-group"><label class="govuk-label" for="minor-threshold">{{ t("event_safety.govuk.minor_threshold") }}</label><div class="govuk-hint" id="minor-threshold-hint">{{ t("event_safety.govuk.minor_threshold_hint") }}</div><input class="govuk-input govuk-input--width-3" id="minor-threshold" name="minor_age_threshold" type="number" min="1" max="150" value="{{ version.minor_age_threshold if version and version.minor_age_threshold is not none else '' }}" aria-describedby="minor-threshold-hint"></div>
        <fieldset class="govuk-fieldset govuk-!-margin-bottom-4"><legend class="govuk-fieldset__legend govuk-fieldset__legend--m">{{ t("event_safety.govuk.code_policy") }}</legend><div class="govuk-checkboxes"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="code-required" name="code_of_conduct_required" type="checkbox" value="1"{% if version and version.code_of_conduct_required %} checked{% endif %}><label class="govuk-label govuk-checkboxes__label" for="code-required">{{ t("event_safety.govuk.code_required") }}</label></div></div></fieldset>
        <div class="govuk-form-group"><label class="govuk-label" for="code-version">{{ t("event_safety.govuk.code_version") }}</label><div class="govuk-hint" id="code-version-hint">{{ t("event_safety.govuk.code_version_hint") }}</div><input class="govuk-input" id="code-version" name="code_of_conduct_text_version" value="{{ code.text_version or version.code_of_conduct_text_version or '' }}" aria-describedby="code-version-hint"></div>
        <div class="govuk-form-group"><label class="govuk-label" for="code-text">{{ t("event_safety.govuk.code_text") }}</label><textarea class="govuk-textarea" id="code-text" name="code_of_conduct_text" rows="10">{{ code.text or version.code_of_conduct_text or '' }}</textarea></div>
        <button class="govuk-button">{{ t("event_safety.govuk.save_draft") }}</button>
      </form>
      {% if requirements and requirements.status == "draft" %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/safety') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="action" value="publish_requirements"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><input type="hidden" name="expected_revision" value="{{ requirements.revision }}"><input type="hidden" name="expected_version" value="{{ version.version_number or requirements.current_version }}"><button class="govuk-button govuk-button--secondary">{{ t("event_safety.govuk.publish") }}</button></form>{% endif %}
      {% if requirements and requirements.status == "published" %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/safety') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="action" value="archive_requirements"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><input type="hidden" name="expected_revision" value="{{ requirements.revision }}"><input type="hidden" name="expected_version" value="{{ version.version_number or requirements.current_version }}"><div class="govuk-warning-text"><span class="govuk-warning-text__icon" aria-hidden="true">!</span><strong class="govuk-warning-text__text"><span class="govuk-visually-hidden">{{ t("govuk_alpha.states.warning_prefix") }}</span>{{ t("event_safety.govuk.archive_warning") }}</strong></div><div class="govuk-checkboxes govuk-!-margin-bottom-4"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="confirm-archive" name="confirm_destructive" type="checkbox" value="1" required><label class="govuk-label govuk-checkboxes__label" for="confirm-archive">{{ t("event_safety.govuk.confirm_archive_checkbox") }}</label></div></div><button class="govuk-button govuk-button--warning">{{ t("event_safety.govuk.archive") }}</button></form>{% endif %}
    </section>
  {% endif %}

  <section aria-labelledby="attendee-safety-heading" class="govuk-!-margin-bottom-8">
    <h2 class="govuk-heading-l" id="attendee-safety-heading">{{ t("event_safety.govuk.attendee_title") }}</h2>
    <p class="govuk-body"><strong>{{ t("event_safety.govuk.eligibility." + (eligibility.decision or "not_evaluated")) }}</strong></p>
    {% if code %}<h3 class="govuk-heading-m">{{ t("event_safety.govuk.code_title") }}</h3><div class="govuk-inset-text">{{ code.text or version.code_of_conduct_text }}</div>{% endif %}
    {% if permissions.acknowledge_code_of_conduct %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/safety') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="action" value="acknowledge_code"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><input type="hidden" name="text_version" value="{{ code.text_version or version.code_of_conduct_text_version }}"><input type="hidden" name="text_hash" value="{{ code.text_hash or version.code_of_conduct_text_hash }}"><div class="govuk-checkboxes govuk-!-margin-bottom-4"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="confirm-code" name="confirmation" type="checkbox" value="1" required><label class="govuk-label govuk-checkboxes__label" for="confirm-code">{{ t("event_safety.govuk.confirm_code") }}</label></div></div><button class="govuk-button">{{ t("event_safety.govuk.acknowledge") }}</button></form>{% elif permissions.withdraw_code_of_conduct %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/safety') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="action" value="withdraw_code"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><input type="hidden" name="acknowledgement_id" value="{{ codeEvidence.acknowledgement_id }}"><div class="govuk-checkboxes govuk-!-margin-bottom-4"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="confirm-withdraw-code" name="confirm_destructive" type="checkbox" value="1" required><label class="govuk-label govuk-checkboxes__label" for="confirm-withdraw-code">{{ t("event_safety.govuk.confirm_withdraw_code") }}</label></div></div><button class="govuk-button govuk-button--warning">{{ t("event_safety.govuk.withdraw_acknowledgement") }}</button></form>{% endif %}
    {% if guardianEvidence.status %}<h3 class="govuk-heading-m">{{ t("event_safety.govuk.guardian_title") }}</h3><p class="govuk-body">{{ t("event_safety.govuk.guardian_status." + guardianEvidence.status) }}</p>{% endif %}
    {% if permissions.request_guardian_consent %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/safety') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="action" value="request_guardian_consent"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><div class="govuk-form-group"><label class="govuk-label" for="guardian-name">{{ t("event_safety.govuk.guardian_name") }}</label><input class="govuk-input" id="guardian-name" name="guardian_name" required></div><div class="govuk-form-group"><label class="govuk-label" for="guardian-email">{{ t("event_safety.govuk.guardian_email") }}</label><div class="govuk-hint" id="guardian-email-hint">{{ t("event_safety.govuk.guardian_privacy") }}</div><input class="govuk-input" id="guardian-email" name="guardian_email" type="email" required aria-describedby="guardian-email-hint"></div><div class="govuk-form-group"><label class="govuk-label" for="guardian-relationship">{{ t("event_safety.govuk.guardian_relationship") }}</label><select class="govuk-select" id="guardian-relationship" name="relationship_code" required>{% for relation in ["parent", "guardian", "legal_guardian", "carer"] %}<option value="{{ relation }}">{{ t("event_safety.govuk.relationships." + relation) }}</option>{% endfor %}</select></div><button class="govuk-button">{{ t("event_safety.govuk.request_guardian") }}</button></form>{% elif permissions.withdraw_guardian_consent %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/safety') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="action" value="withdraw_guardian_consent"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><input type="hidden" name="consent_id" value="{{ guardianEvidence.consent_id }}"><div class="govuk-checkboxes govuk-!-margin-bottom-4"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="confirm-withdraw-guardian" name="confirm_destructive" type="checkbox" value="1" required><label class="govuk-label govuk-checkboxes__label" for="confirm-withdraw-guardian">{{ t("event_safety.govuk.confirm_withdraw_guardian") }}</label></div></div><button class="govuk-button govuk-button--warning">{{ t("event_safety.govuk.withdraw_guardian") }}</button></form>{% endif %}
  </section>

  {% if permissions.review_participation %}<section aria-labelledby="reviews-heading"><h2 class="govuk-heading-l" id="reviews-heading">{{ t("event_safety.govuk.reviews_title") }}</h2><p class="govuk-body">{{ t("event_safety.govuk.reviews_intro") }}</p>
    {% if people.length %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/safety') }}" class="govuk-!-margin-bottom-7"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="action" value="record_review"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><input type="hidden" name="expected_version" value=""><div class="govuk-form-group"><label class="govuk-label" for="review-member">{{ t("event_safety.govuk.review_member") }}</label><select class="govuk-select" id="review-member" name="user_id" required><option value="">{{ t("event_safety.govuk.review_member_choose") }}</option>{% for person in people %}<option value="{{ person.id }}">{{ person.name or t("event_safety.govuk.member_fallback", { id: person.id }) }}</option>{% endfor %}</select></div><div class="govuk-form-group"><label class="govuk-label" for="review-decision">{{ t("event_safety.govuk.review_decision") }}</label><select class="govuk-select" id="review-decision" name="decision">{% for decision in ["deny", "remove"] %}<option value="{{ decision }}">{{ t("event_safety.govuk.decisions." + decision) }}</option>{% endfor %}</select></div><div class="govuk-form-group"><label class="govuk-label" for="review-reason">{{ t("event_safety.govuk.review_reason") }}</label><select class="govuk-select" id="review-reason" name="reason_code">{% for reason in ["safeguarding_policy", "minimum_age", "guardian_consent", "code_of_conduct", "conduct_violation", "safety_review", "user_block"] %}<option value="{{ reason }}">{{ t("event_safety.govuk.reasons." + reason) }}</option>{% endfor %}</select></div><div class="govuk-form-group"><label class="govuk-label" for="effective-from">{{ t("event_safety.govuk.effective_from") }}</label><input class="govuk-input" id="effective-from" name="effective_from" type="date" value="{{ today }}" required></div><div class="govuk-form-group"><label class="govuk-label" for="effective-until">{{ t("event_safety.govuk.effective_until") }}</label><div class="govuk-hint" id="effective-until-hint">{{ t("event_safety.govuk.effective_until_hint") }}</div><input class="govuk-input" id="effective-until" name="effective_until" type="date" aria-describedby="effective-until-hint"></div><div class="govuk-inset-text">{{ t("event_safety.govuk.no_notes") }}</div><button class="govuk-button">{{ t("event_safety.govuk.save_review") }}</button></form>{% else %}<p class="govuk-body">{{ t("event_safety.govuk.no_people") }}</p>{% endif %}
    <h3 class="govuk-heading-m">{{ t("event_safety.govuk.ledger_title") }}</h3>{% if not reviews.items.length %}<p class="govuk-body">{{ t("event_safety.govuk.ledger_empty") }}</p>{% endif %}{% for item in reviews.items %}<div class="govuk-summary-card"><div class="govuk-summary-card__title-wrapper"><h4 class="govuk-summary-card__title">{{ item.member.display_name or t("event_safety.govuk.member_fallback", { id: item.member.id }) }}</h4></div><div class="govuk-summary-card__content"><dl class="govuk-summary-list"><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("event_safety.govuk.review_decision") }}</dt><dd class="govuk-summary-list__value">{{ t("event_safety.govuk.decisions." + item.denial.decision) }}</dd></div><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("event_safety.govuk.review_reason") }}</dt><dd class="govuk-summary-list__value">{{ t("event_safety.govuk.reasons." + item.denial.reason_code) }}</dd></div><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("event_safety.govuk.review_status") }}</dt><dd class="govuk-summary-list__value">{{ t("event_safety.govuk.review_states." + item.denial.status) }}</dd></div></dl>{% if item.denial.status == "active" %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/safety') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="action" value="withdraw_review"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><input type="hidden" name="denial_id" value="{{ item.denial.id }}"><input type="hidden" name="expected_version" value="{{ item.denial.decision_version }}"><div class="govuk-checkboxes govuk-!-margin-bottom-4"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="confirm-withdraw-review-{{ item.denial.id }}" name="confirm_destructive" type="checkbox" value="1" required><label class="govuk-label govuk-checkboxes__label" for="confirm-withdraw-review-{{ item.denial.id }}">{{ t("event_safety.govuk.confirm_withdraw_review", { name: item.member.display_name }) }}</label></div></div><button class="govuk-button govuk-button--warning">{{ t("event_safety.govuk.withdraw_review") }}</button></form>{% endif %}</div></div>{% endfor %}
  </section>{% endif %}
{% endblock %}
