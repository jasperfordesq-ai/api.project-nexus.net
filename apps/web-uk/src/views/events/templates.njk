{% extends "layouts/base.njk" %}{% block content %}<a class="govuk-back-link" href="{{ urlFor('/events') }}">{{ t("govuk_alpha_events.common.back_to_events") }}</a><h1 class="govuk-heading-xl">{{ t("event_templates.title") }}</h1><p class="govuk-body-l">{{ t("event_templates.description") }}</p><form method="get" action="{{ urlFor('/events/templates') }}"><label class="govuk-label" for="template-filter">{{ t("event_templates.filter_label") }}</label><select class="govuk-select" id="template-filter" name="filter">{% for value in ["active","archived","all"] %}<option value="{{ value }}"{% if filter == value %} selected{% endif %}>{{ t("event_templates.filters." + value) }}</option>{% endfor %}</select><button class="govuk-button govuk-button--secondary">{{ t("event_templates.filter_button") }}</button></form>{% for template in templates %}<div class="govuk-summary-card"><div class="govuk-summary-card__title-wrapper"><h2 class="govuk-summary-card__title">{{ template.source_event.title }}</h2><strong class="govuk-tag">{{ t("event_templates.statuses." + template.status) }}</strong></div><div class="govuk-summary-card__content"><p>{{ t("event_templates.version", { version: template.current_version }) }}</p><div class="govuk-button-group">{% if template.capabilities.materialize %}<a class="govuk-button" href="{{ urlFor('/event-templates/' + (template.id | string) + '/materialize') }}">{{ t("event_templates.materialize") }}</a>{% endif %}{% if template.capabilities.view_audit %}<a class="govuk-button govuk-button--secondary" href="{{ urlFor('/event-templates/' + (template.id | string) + '/history') }}">{{ t("event_templates.audit_link") }}</a>{% endif %}{% if template.capabilities.revise %}<a class="govuk-button govuk-button--secondary" href="{{ urlFor('/events/' + (template.source_event.id | string) + '/template-preview?template_id=' + (template.id | string)) }}">{{ t("event_templates.revise") }}</a>{% endif %}</div></div></div>{% else %}<p class="govuk-body">{{ t("event_templates.empty") }}</p>{% endfor %}{% if pagination.next_cursor %}<a class="govuk-link" rel="next" href="{{ urlFor('/events/templates?filter=' + filter + '&cursor=' + (pagination.next_cursor | string)) }}">{{ t("event_templates.next") }}</a>{% endif %}{% endblock %}
