{% extends "layouts/base.njk" %}
{% block content %}
<a class="govuk-back-link" href="{{ urlFor('/events/' + (event.id | string)) }}">{{ t("govuk_alpha_events.communications.back_to_event") }}</a>
{% if status in ["created", "scheduled", "cancelled", "retried"] %}<div class="govuk-notification-banner govuk-notification-banner--success" role="alert"><div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">{{ t("govuk_alpha_events.common.success_title") }}</h2></div><div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ t("govuk_alpha_events.communications.success." + status) }}</p></div></div>{% elif status %}<div class="govuk-error-summary" role="alert" tabindex="-1"><h2 class="govuk-error-summary__title">{{ t("govuk_alpha_events.common.error_title") }}</h2><div class="govuk-error-summary__body"><p>{{ t("govuk_alpha_events.communications.validation_error" if status == "invalid" else "govuk_alpha_events.communications.save_error") }}</p></div></div>{% endif %}
<span class="govuk-caption-l">{{ event.title }}</span><h1 class="govuk-heading-xl">{{ t("govuk_alpha_events.communications.title") }}</h1><p class="govuk-body-l">{{ t("govuk_alpha_events.communications.intro") }}</p><div class="govuk-inset-text"><strong>{{ t("govuk_alpha_events.communications.privacy_title") }}</strong><br>{{ t("govuk_alpha_events.communications.privacy_description") }}</div>
<h2 class="govuk-heading-l">{{ t("govuk_alpha_events.communications.compose_title") }}</h2>
<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/communications/preview') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}">
<div class="govuk-form-group"><label class="govuk-label govuk-label--m" for="communication-variant">{{ t("govuk_alpha_events.communications.variant_label") }}</label><select class="govuk-select" id="communication-variant" name="variant" required>{% for variant in ["announcement", "follow_up", "review_request"] %}<option value="{{ variant }}"{% if draft.variant == variant %} selected{% endif %}>{{ t("govuk_alpha_events.communications.variants." + variant) }}</option>{% endfor %}</select></div>
<fieldset class="govuk-fieldset govuk-!-margin-bottom-6"><legend class="govuk-fieldset__legend govuk-fieldset__legend--m">{{ t("govuk_alpha_events.communications.segments_label") }}</legend><div class="govuk-checkboxes">{% for segment in ["registration_confirmed", "waitlist_active", "attendance_attended", "attendance_no_show"] %}<div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="segment-{{ segment }}" name="segments[]" type="checkbox" value="{{ segment }}"{% if segment in draft.segments %} checked{% endif %}><label class="govuk-label govuk-checkboxes__label" for="segment-{{ segment }}">{{ t("govuk_alpha_events.communications.segments." + segment) }}</label></div>{% endfor %}</div></fieldset>
<fieldset class="govuk-fieldset govuk-!-margin-bottom-6"><legend class="govuk-fieldset__legend govuk-fieldset__legend--m">{{ t("govuk_alpha_events.communications.channels_label") }}</legend><div class="govuk-checkboxes">{% for channel in ["email", "in_app", "push"] %}<div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="communication-channel-{{ channel }}" name="channels[]" type="checkbox" value="{{ channel }}"{% if channel in draft.channels %} checked{% endif %}><label class="govuk-label govuk-checkboxes__label" for="communication-channel-{{ channel }}">{{ t("govuk_alpha_events.communications.channels." + channel) }}</label></div>{% endfor %}</div></fieldset>
<div class="govuk-form-group"><label class="govuk-label govuk-label--m" for="communication-body">{{ t("govuk_alpha_events.communications.body_label") }}</label><textarea class="govuk-textarea" id="communication-body" name="body" rows="8" maxlength="20000" required>{{ draft.body }}</textarea></div><button class="govuk-button govuk-button--secondary">{{ t("govuk_alpha_events.communications.preview_button") }}</button></form>
{% if preview %}<div class="govuk-notification-banner" role="region" aria-labelledby="communication-preview-title"><div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title" id="communication-preview-title">{{ t("govuk_alpha_events.communications.preview_title") }}</h2></div><div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ t("govuk_alpha_events.communications.preview_summary", { recipients: preview.recipient_count, deliveries: preview.delivery_count }) }}</p><form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/communications') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><input type="hidden" name="preview_confirmed" value="1"><input type="hidden" name="variant" value="{{ draft.variant }}">{% for segment in draft.segments %}<input type="hidden" name="segments[]" value="{{ segment }}">{% endfor %}{% for channel in draft.channels %}<input type="hidden" name="channels[]" value="{{ channel }}">{% endfor %}<textarea name="body" hidden>{{ draft.body }}</textarea><button class="govuk-button">{{ t("govuk_alpha_events.communications.save_draft_button") }}</button></form></div></div>{% endif %}
<h2 class="govuk-heading-l">{{ t("govuk_alpha_events.communications.history_list_title") }}</h2>{% if not broadcasts.length %}<p class="govuk-body">{{ t("govuk_alpha_events.communications.empty") }}</p>{% endif %}
{% for broadcast in broadcasts %}<section class="govuk-!-margin-bottom-9" aria-labelledby="broadcast-{{ broadcast.id }}-title"><h3 class="govuk-heading-m" id="broadcast-{{ broadcast.id }}-title">{{ t("govuk_alpha_events.communications.variants." + broadcast.variant) }}</h3><strong class="govuk-tag">{{ t("govuk_alpha_events.communications.statuses." + broadcast.status) }}</strong><p class="govuk-body">{{ t("govuk_alpha_events.communications.version") }}: {{ broadcast.version }}</p><a class="govuk-button govuk-button--secondary" href="{{ urlFor('/events/' + (event.id | string) + '/communications?broadcast_id=' + (broadcast.id | string)) }}">{{ t("govuk_alpha_events.communications.view_audit") }}</a>
{% if broadcast.capabilities.schedule %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/communications/' + (broadcast.id | string) + '/schedule') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="expected_version" value="{{ broadcast.version }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><label class="govuk-label" for="schedule-{{ broadcast.id }}">{{ t("govuk_alpha_events.communications.schedule_label") }}</label><input class="govuk-input govuk-input--width-20" id="schedule-{{ broadcast.id }}" name="scheduled_at" type="datetime-local"><button class="govuk-button">{{ t("govuk_alpha_events.communications.schedule_button") }}</button></form>{% endif %}
{% if broadcast.capabilities.cancel %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/communications/' + (broadcast.id | string) + '/cancel') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="expected_version" value="{{ broadcast.version }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><label class="govuk-label" for="cancel-{{ broadcast.id }}">{{ t("govuk_alpha_events.communications.cancel_reason_label") }}</label><textarea class="govuk-textarea" id="cancel-{{ broadcast.id }}" name="reason" maxlength="500" required></textarea><button class="govuk-button govuk-button--warning">{{ t("govuk_alpha_events.communications.cancel_button") }}</button></form>{% endif %}
{% if broadcast.capabilities.retry %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/communications/' + (broadcast.id | string) + '/retry') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="expected_version" value="{{ broadcast.version }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><button class="govuk-button">{{ t("govuk_alpha_events.communications.retry_button") }}</button></form>{% endif %}</section>{% endfor %}
{% if detail %}<hr class="govuk-section-break govuk-section-break--xl govuk-section-break--visible"><h2 class="govuk-heading-l">{{ t("govuk_alpha_events.communications.audit_title") }}</h2><ol class="govuk-list govuk-list--number">{% for entry in detail.history %}<li>{{ t("govuk_alpha_events.communications.history_actions." + entry.action) }} — {{ t("govuk_alpha_events.communications.statuses." + entry.to_status) }}</li>{% endfor %}</ol>{% endif %}
{% endblock %}
