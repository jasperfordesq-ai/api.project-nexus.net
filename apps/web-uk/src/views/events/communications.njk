{% extends "layouts/base.njk" %}
{% block content %}
<a class="govuk-back-link" href="{{ urlFor('/events/' + (event.id | string)) }}">{{ t("govuk_alpha.events.communications.back_to_event") }}</a>
{% if status in ["created", "scheduled", "cancelled", "retried"] %}<div class="govuk-notification-banner govuk-notification-banner--success" role="alert"><div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">{{ t("govuk_alpha_events.common.success_title") }}</h2></div><div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ t("govuk_alpha.events.communications.success." + status) }}</p></div></div>{% elif status %}<div class="govuk-error-summary" role="alert" tabindex="-1"><h2 class="govuk-error-summary__title">{{ t("govuk_alpha_events.common.error_title") }}</h2><div class="govuk-error-summary__body"><p>{{ t("govuk_alpha.events.communications.validation_error" if status == "invalid" else "govuk_alpha.events.communications.save_error") }}</p></div></div>{% endif %}
<h1 class="govuk-heading-xl">{{ t("govuk_alpha.events.communications.title") }}</h1><p class="govuk-body-l">{{ t("govuk_alpha.events.communications.intro") }}</p><div class="govuk-inset-text"><strong>{{ t("govuk_alpha.events.communications.privacy_title") }}</strong><br>{{ t("govuk_alpha.events.communications.privacy_description") }}</div>
<h2 class="govuk-heading-l">{{ t("govuk_alpha.events.communications.compose_title") }}</h2>
<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/communications/preview') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}">
<div class="govuk-form-group"><label class="govuk-label govuk-label--m" for="communication-variant">{{ t("govuk_alpha.events.communications.variant_label") }}</label><select class="govuk-select" id="communication-variant" name="variant" required>{% for variant in ["announcement", "follow_up", "review_request"] %}<option value="{{ variant }}"{% if draft.variant == variant %} selected{% endif %}>{{ t("govuk_alpha.events.communications.variants." + variant) }}</option>{% endfor %}</select></div>
<fieldset class="govuk-fieldset govuk-!-margin-bottom-6"><legend class="govuk-fieldset__legend govuk-fieldset__legend--m">{{ t("govuk_alpha.events.communications.segments_label") }}</legend><div class="govuk-hint">{{ t("govuk_alpha.events.communications.segments_hint") }}</div><div class="govuk-checkboxes" data-module="govuk-checkboxes">{% for segment in ["registration_confirmed", "waitlist_active", "attendance_attended", "attendance_no_show"] %}<div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="communication-segment-{{ segment }}" name="segments[]" type="checkbox" value="{{ segment }}"{% if segment in draft.segments %} checked{% endif %}><label class="govuk-label govuk-checkboxes__label" for="communication-segment-{{ segment }}">{{ t("govuk_alpha.events.communications.segments." + segment) }}</label></div>{% endfor %}</div></fieldset>
<fieldset class="govuk-fieldset govuk-!-margin-bottom-6"><legend class="govuk-fieldset__legend govuk-fieldset__legend--m">{{ t("govuk_alpha.events.communications.channels_label") }}</legend><div class="govuk-checkboxes" data-module="govuk-checkboxes">{% for channel in ["email", "in_app", "push"] %}<div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="communication-channel-{{ channel }}" name="channels[]" type="checkbox" value="{{ channel }}"{% if channel in draft.channels %} checked{% endif %}><label class="govuk-label govuk-checkboxes__label" for="communication-channel-{{ channel }}">{{ t("govuk_alpha.events.communications.channels." + channel) }}</label></div>{% endfor %}</div></fieldset>
<div class="govuk-form-group"><label class="govuk-label govuk-label--m" for="communication-body">{{ t("govuk_alpha.events.communications.body_label") }}</label><div id="communication-body-hint" class="govuk-hint">{{ t("govuk_alpha.events.communications.body_hint") }}</div><textarea class="govuk-textarea" id="communication-body" name="body" rows="8" maxlength="20000" aria-describedby="communication-body-hint" required>{{ draft.body }}</textarea></div><button class="govuk-button govuk-button--secondary" data-module="govuk-button" type="submit">{{ t("govuk_alpha.events.communications.preview_button") }}</button></form>
{% if preview %}<div class="govuk-notification-banner" data-module="govuk-notification-banner" role="region" aria-labelledby="communication-preview-title"><div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title" id="communication-preview-title">{{ t("govuk_alpha.events.communications.preview_title") }}</h2></div><div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ t("govuk_alpha.events.communications.preview_summary", { recipients: preview.recipient_count, deliveries: preview.delivery_count }) }}</p><p class="govuk-body">{{ t("govuk_alpha.events.communications.preview_notice") }}</p><form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/communications') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><input type="hidden" name="preview_confirmed" value="1"><input type="hidden" name="variant" value="{{ draft.variant }}">{% for segment in draft.segments %}<input type="hidden" name="segments[]" value="{{ segment }}">{% endfor %}{% for channel in draft.channels %}<input type="hidden" name="channels[]" value="{{ channel }}">{% endfor %}<textarea name="body" hidden>{{ draft.body }}</textarea><button class="govuk-button" data-module="govuk-button" type="submit">{{ t("govuk_alpha.events.communications.save_draft_button") }}</button></form></div></div>{% endif %}
<h2 class="govuk-heading-l">{{ t("govuk_alpha.events.communications.history_list_title") }}</h2>{% if not broadcasts.length %}<p class="govuk-body">{{ t("govuk_alpha.events.communications.empty") }}</p>{% endif %}
{% for broadcast in broadcasts %}<section class="govuk-!-margin-bottom-9" aria-labelledby="broadcast-{{ broadcast.id }}-title"><h3 class="govuk-heading-m" id="broadcast-{{ broadcast.id }}-title">{{ t("govuk_alpha.events.communications.variants." + broadcast.variant) }}</h3><strong class="govuk-tag{% if broadcast.status in ['cancelled', 'failed'] %} govuk-tag--red{% elif broadcast.status == 'sent' %} govuk-tag--green{% endif %}">{{ t("govuk_alpha.events.communications.statuses." + broadcast.status) }}</strong><dl class="govuk-summary-list govuk-!-margin-top-4"><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha.events.communications.version") }}</dt><dd class="govuk-summary-list__value">{{ broadcast.versionLabel }}</dd></div><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha.events.communications.audience") }}</dt><dd class="govuk-summary-list__value">{% for segment in broadcast.audience.segments %}{{ t("govuk_alpha.events.communications.segments." + segment) }}{% if not loop.last %}, {% endif %}{% endfor %}<br>{{ t("govuk_alpha.events.communications.recipient_count", { count: broadcast.recipientCountLabel }) }}</dd></div><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha.events.communications.channels_label") }}</dt><dd class="govuk-summary-list__value">{% for channel in broadcast.channels %}{{ t("govuk_alpha.events.communications.channels." + channel) }}{% if not loop.last %}, {% endif %}{% endfor %}</dd></div><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha.events.communications.delivery") }}</dt><dd class="govuk-summary-list__value">{{ t("govuk_alpha.events.communications.delivery_summary", { delivered: broadcast.delivery.deliveredLabel, total: broadcast.delivery.totalLabel, suppressed: broadcast.delivery.suppressedLabel, dead: broadcast.delivery.deadLetteredLabel }) }}</dd></div><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha.events.communications.scheduled_for") }}</dt><dd class="govuk-summary-list__value">{{ broadcast.scheduledAtLabel }}</dd></div></dl><div class="govuk-button-group"><a class="govuk-button govuk-button--secondary" data-module="govuk-button" href="{{ urlFor('/events/' + (event.id | string) + '/communications?broadcast_id=' + (broadcast.id | string)) }}">{{ t("govuk_alpha.events.communications.view_audit") }}</a></div>
{% if broadcast.capabilities.schedule %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/communications/' + (broadcast.id | string) + '/schedule') }}" class="govuk-!-margin-bottom-6"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="expected_version" value="{{ broadcast.version }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><div class="govuk-form-group"><label class="govuk-label" for="schedule-{{ broadcast.id }}">{{ t("govuk_alpha.events.communications.schedule_label") }}</label><div id="schedule-{{ broadcast.id }}-hint" class="govuk-hint">{{ t("govuk_alpha.events.communications.schedule_hint") }}</div><input class="govuk-input govuk-input--width-20" id="schedule-{{ broadcast.id }}" name="scheduled_at" type="datetime-local" aria-describedby="schedule-{{ broadcast.id }}-hint"></div><button class="govuk-button" data-module="govuk-button" type="submit">{{ t("govuk_alpha.events.communications.schedule_button") }}</button></form>{% endif %}
{% if broadcast.capabilities.cancel %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/communications/' + (broadcast.id | string) + '/cancel') }}" class="govuk-!-margin-bottom-6"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="expected_version" value="{{ broadcast.version }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><div class="govuk-form-group"><label class="govuk-label" for="cancel-{{ broadcast.id }}">{{ t("govuk_alpha.events.communications.cancel_reason_label") }}</label><textarea class="govuk-textarea" id="cancel-{{ broadcast.id }}" name="reason" rows="2" maxlength="500" required></textarea></div><button class="govuk-button govuk-button--warning" data-module="govuk-button" type="submit">{{ t("govuk_alpha.events.communications.cancel_button") }}</button></form>{% endif %}
{% if broadcast.capabilities.retry %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/communications/' + (broadcast.id | string) + '/retry') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="expected_version" value="{{ broadcast.version }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><button class="govuk-button" data-module="govuk-button" type="submit">{{ t("govuk_alpha.events.communications.retry_button") }}</button></form>{% endif %}</section>{% endfor %}
{% if pagination.totalPages > 1 %}<nav class="govuk-pagination" aria-label="{{ t('govuk_alpha.events.communications.pagination') }}">{% if pagination.previousHref %}<div class="govuk-pagination__prev"><a class="govuk-link govuk-pagination__link" href="{{ urlFor(pagination.previousHref) }}">{{ t("govuk_alpha.events.communications.previous") }}</a></div>{% endif %}{% if pagination.nextHref %}<div class="govuk-pagination__next"><a class="govuk-link govuk-pagination__link" href="{{ urlFor(pagination.nextHref) }}">{{ t("govuk_alpha.events.communications.next") }}</a></div>{% endif %}</nav>{% endif %}
{% if detail %}<hr class="govuk-section-break govuk-section-break--xl govuk-section-break--visible"><h2 class="govuk-heading-l">{{ t("govuk_alpha.events.communications.audit_title") }}</h2><p class="govuk-body">{{ t("govuk_alpha.events.communications.audit_description") }}</p><ol class="govuk-list govuk-list--number">{% for entry in detail.history %}<li><strong>{{ t("govuk_alpha.events.communications.history_actions." + entry.action) }}</strong> — {{ t("govuk_alpha.events.communications.statuses." + entry.to_status) }}, {{ t("govuk_alpha.events.communications.audit_meta", { version: entry.version, date: entry.dateLabel }) }}</li>{% endfor %}</ol>
{% if detail.pagination.previousHref or detail.pagination.nextHref %}<nav class="govuk-pagination" aria-label="{{ t('govuk_alpha.events.communications.audit_title') }}">{% if detail.pagination.previousHref %}<div class="govuk-pagination__prev"><a class="govuk-link govuk-pagination__link" href="{{ urlFor(detail.pagination.previousHref) }}">{{ t("govuk_alpha.events.communications.previous") }}</a></div>{% endif %}{% if detail.pagination.nextHref %}<div class="govuk-pagination__next"><a class="govuk-link govuk-pagination__link" href="{{ urlFor(detail.pagination.nextHref) }}">{{ t("govuk_alpha.events.communications.next") }}</a></div>{% endif %}</nav>{% endif %}{% endif %}
{% endblock %}
