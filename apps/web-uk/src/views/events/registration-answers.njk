{% extends "layouts/base.njk" %}{% block content %}<a class="govuk-back-link" href="{{ urlFor('/events/' + (eventId | string) + '/registration') }}">{{ t("event_registration.title") }}</a><h1 class="govuk-heading-xl">{{ t("event_registration.accessible.review_submission", { id: submissionId }) }}</h1><div class="govuk-inset-text"><strong>{{ t("event_registration.submissions.audit_title") }}</strong><br>{{ t("event_registration.submissions.audit_description") }}</div>{% for key, answer in answers %}<div class="govuk-summary-card"><div class="govuk-summary-card__title-wrapper"><h2 class="govuk-summary-card__title">{{ questions[answer.question_id] or key }}</h2><strong class="govuk-tag">{{ t("event_registration.classifications." + (answer.classification or 'internal')) }}</strong></div><div class="govuk-summary-card__content">{% if answer.purged %}<p>{{ t("event_registration.submissions.purged") }}</p>{% elif answer.value is iterable and answer.value is not string %}<ul>{% for value in answer.value %}<li>{{ value }}</li>{% endfor %}</ul>{% else %}<p class="govuk-body govuk-!-white-space-pre-wrap">{{ answer.value }}</p>{% endif %}</div></div>{% else %}<p class="govuk-body">{{ t("event_registration.submissions.empty") }}</p>{% endfor %}{% endblock %}
