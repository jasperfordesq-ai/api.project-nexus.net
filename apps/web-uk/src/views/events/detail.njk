{% extends "layouts/base.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}

{% block beforeContent %}
  {{ super() }}
  {% set breadcrumbs = [
    { text: "Events", href: urlFor("/events") },
    { text: event.title }
  ] %}
  {% include "partials/breadcrumbs.njk" %}
{% endblock %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if successMessage %}
        {% set notificationMessage = successMessage %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      {% if errorMessage %}
        {% set notificationMessage = errorMessage %}
        {% set notificationType = null %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      <div class="app-page-header">
        <h1 class="govuk-heading-xl govuk-!-margin-bottom-2">{{ event.title }}</h1>
        {% if (event.isCancelled or event.is_cancelled) %}
          {{ govukTag({ text: "Cancelled", classes: "govuk-tag--red" }) }}
        {% elif event.isPast or event.is_past %}
          {{ govukTag({ text: "Past event", classes: "govuk-tag--grey" }) }}
        {% else %}
          {{ govukTag({ text: "Upcoming", classes: "govuk-tag--green" }) }}
        {% endif %}
      </div>

      {% if (event.isCancelled or event.is_cancelled) %}
        {{ govukWarningText({
          text: t("events.polish_events.cancelled_banner_heading"),
          iconFallbackText: "Warning"
        }) }}
      {% endif %}

      {% set coverImage = event.cover_image or event.coverImage %}
      {% if coverImage %}
        <figure class="nexus-alpha-detail-hero">
          <img src="{{ coverImage }}" alt="Photo for {{ event.title }}" width="640" height="360" decoding="async">
        </figure>
      {% endif %}

      {# Event details #}
      {% set organizer = event.createdBy or event.created_by or event.organizer %}
      {% set eventStartTime = event.start_time or event.startTime %}
      {% set eventEndTime = event.end_time or event.endTime %}
      {{ govukSummaryList({
        rows: [
          {
            key: { text: t("events.create_time_title") },
            value: {
              html: (eventStartTime | formatEventDate) +
                    ("<br>to " + (eventEndTime | formatEventDate) if eventEndTime else "")
            }
          } if eventStartTime,
          {
            key: { text: "Location" },
            value: { text: event.location or "Not specified" }
          },
          {
            key: { text: "Group" },
            value: {
              html: "<a href='" + urlFor("/groups/" + (event.group.id | string)) + "' class='govuk-link'>" + event.group.name + "</a>"
            }
          } if event.group,
          {
            key: { text: "Organised by" },
            value: {
              html: "<a href='" + urlFor("/members/" + (organizer.id | string)) + "' class='govuk-link'>" +
                    (organizer.firstName or organizer.first_name or "") + " " + (organizer.lastName or organizer.last_name or "") + "</a>"
            }
          } if organizer,
          {
            key: { text: t("events.create_capacity_title") },
            value: {
              text: (event.attendeeCount or event.attendee_count or 0) + " attending" +
                    (" / " + (event.maxAttendees or event.max_attendees) + " max" if event.maxAttendees or event.max_attendees else "")
            }
          }
        ] | selectattr("key") | list
      }) }}

      {% if event.description %}
        <h2 class="govuk-heading-m govuk-!-margin-top-6">About this event</h2>
        <div class="govuk-body app-formatted-text">
          {{ event.description | nl2br | safe }}
        </div>
      {% endif %}

      {% if isAuthenticated %}
        <p class="govuk-body govuk-!-margin-top-4">
          {% set reportType = "event" %}
          {% set reportId = event.id %}
          {% set returnTo = urlFor("/events/" + (event.id | string)) %}
          {% include "partials/report-link.njk" %}
        </p>
      {% endif %}

      {# RSVP section #}
      {% if isAuthenticated and not (event.isCancelled or event.is_cancelled) and not (event.isPast or event.is_past) %}
        <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

        <form action="{{ urlFor('/events/' + (event.id | string) + '/rsvp') }}" method="post">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          {{ govukRadios({
            name: "status",
            fieldset: {
              legend: {
                text: t("events.rsvp_title"),
                classes: "govuk-fieldset__legend--m",
                isPageHeading: false
              }
            },
            hint: { text: t("events.rsvp_hint") },
            items: [
              {
                value: "going",
                text: t("events.rsvp_status.going"),
                checked: not myRsvp or myRsvp.status == "going"
              },
              {
                value: "interested",
                text: t("events.rsvp_status.interested"),
                checked: myRsvp and myRsvp.status == "interested"
              },
              {
                value: "not_going",
                text: t("events.rsvp_status.not_going"),
                checked: myRsvp and myRsvp.status == "not_going"
              }
            ]
          }) }}
          {{ govukButton({ text: t("actions.rsvp") }) }}
        </form>
      {% elif not isAuthenticated and not (event.isCancelled or event.is_cancelled) and not (event.isPast or event.is_past) %}
        <div class="govuk-inset-text">
          <a class="govuk-link" href="{{ urlFor('/login') }}">{{ t("nav.login") }}</a>. {{ t("events.auth_required_detail", { community: tenantName or serviceName }) }}
        </div>
      {% endif %}

      {# Admin actions #}
      {% if event.canEdit or event.can_edit %}
        <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

        <h2 class="govuk-heading-m">Manage event</h2>

        <div class="app-action-buttons">
          {{ govukButton({
            text: t("events.edit_event"),
            href: urlFor("/events/" + (event.id | string) + "/edit"),
            classes: "govuk-button--secondary"
          }) }}

          {% if not (event.isCancelled or event.is_cancelled) %}
            <details class="govuk-details govuk-!-margin-bottom-2" data-module="govuk-details">
              <summary class="govuk-details__summary">
                <span class="govuk-details__summary-text">{{ t("events.cancel_event") }}</span>
              </summary>
              <div class="govuk-details__text">
                <p class="govuk-body">{{ t("events.cancel_confirm") }}</p>
                <form action="{{ urlFor('/events/' + (event.id | string) + '/cancel') }}" method="post">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <div class="govuk-form-group">
                    <label class="govuk-label" for="cancel-reason">{{ t("events.cancel_reason_label") }}</label>
                    <textarea class="govuk-textarea" id="cancel-reason" name="reason" rows="3"></textarea>
                  </div>
                  {{ govukButton({
                    text: t("events.cancel_event_button"),
                    classes: "govuk-button--warning govuk-!-margin-bottom-0"
                  }) }}
                </form>
              </div>
            </details>
          {% endif %}

          <details class="govuk-details govuk-!-margin-bottom-4" data-module="govuk-details">
            <summary class="govuk-details__summary"><span class="govuk-details__summary-text">{{ t("events.delete_event") }}</span></summary>
            <div class="govuk-details__text">
              <p class="govuk-body">{{ t("events.delete_confirm") }}</p>
              <form action="{{ urlFor('/events/' + (event.id | string) + '/delete') }}" method="post">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                {{ govukButton({ text: t("events.delete_event_button"), classes: "govuk-button--warning govuk-!-margin-bottom-0" }) }}
              </form>
            </div>
          </details>
        </div>
      {% endif %}

    </div>

    <div class="govuk-grid-column-one-third">
      {# Attendees sidebar #}
      <div class="app-sidebar-card">
        <h2 class="govuk-heading-m">Attendees</h2>

        {% if rsvpsByStatus.going.length > 0 %}
          <h3 class="govuk-heading-s govuk-!-margin-bottom-2">{{ t("events.attendees_label") }} ({{ rsvpsByStatus.going.length }})</h3>
          <ul class="app-attendee-list govuk-!-margin-bottom-4">
            {% for rsvp in rsvpsByStatus.going | take(8) %}
              <li class="app-attendee-list__item">
                {% set user = rsvp.user or rsvp %}
                {% include "partials/avatar.njk" %}
                <a href="{{ urlFor('/members/' + (user.id | string)) }}" class="govuk-link govuk-body-s">
                  {{ user.name or ((user.first_name or user.firstName or "") + " " + (user.last_name or user.lastName or "")) }}
                </a>
              </li>
            {% endfor %}
          </ul>
          {% if rsvpsByStatus.going.length > 8 %}
            <p class="govuk-body-s">and {{ rsvpsByStatus.going.length - 8 }} more...</p>
          {% endif %}
        {% endif %}

        {% if rsvpsByStatus.interested.length > 0 %}
          <h3 class="govuk-heading-s govuk-!-margin-bottom-2">{{ t("events.interested_label") }} ({{ rsvpsByStatus.interested.length }})</h3>
          <ul class="app-attendee-list govuk-!-margin-bottom-4">
            {% for rsvp in rsvpsByStatus.interested | take(5) %}
              <li class="app-attendee-list__item">
                {% set user = rsvp.user or rsvp %}
                {% include "partials/avatar.njk" %}
                <a href="{{ urlFor('/members/' + (user.id | string)) }}" class="govuk-link govuk-body-s">
                  {{ user.name or ((user.first_name or user.firstName or "") + " " + (user.last_name or user.lastName or "")) }}
                </a>
              </li>
            {% endfor %}
          </ul>
          {% if rsvpsByStatus.interested.length > 5 %}
            <p class="govuk-body-s">and {{ rsvpsByStatus.interested.length - 5 }} more...</p>
          {% endif %}
        {% endif %}

        {% if rsvpsByStatus.going.length == 0 and rsvpsByStatus.interested.length == 0 %}
          <p class="govuk-body-s">No RSVPs yet. Be the first to respond!</p>
        {% endif %}
      </div>
    </div>
  </div>
{% endblock %}
