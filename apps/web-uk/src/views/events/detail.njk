{% extends "layouts/base.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}

{% block beforeContent %}
  {{ super() }}
  {% set breadcrumbs = [
    { text: "Events", href: "/events" },
    { text: event.title }
  ] %}
  {% include "partials/breadcrumbs.njk" %}
{% endblock %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if successMessage %}
        {% set notificationMessage = successMessage %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      {% if errorMessage %}
        {% set notificationMessage = errorMessage %}
        {% set notificationType = null %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      <div class="app-page-header">
        <h1 class="govuk-heading-xl govuk-!-margin-bottom-2">{{ event.title }}</h1>
        {% if event.status == 'cancelled' %}
          {{ govukTag({ text: "Cancelled", classes: "govuk-tag--red" }) }}
        {% elif event.isPast or event.is_past %}
          {{ govukTag({ text: "Past event", classes: "govuk-tag--grey" }) }}
        {% else %}
          {{ govukTag({ text: "Upcoming", classes: "govuk-tag--green" }) }}
        {% endif %}
      </div>

      {% if event.status == 'cancelled' %}
        {{ govukWarningText({
          text: "This event has been cancelled.",
          iconFallbackText: "Warning"
        }) }}
      {% endif %}

      {# Event details #}
      {% set organizer = event.createdBy or event.created_by or event.organizer %}
      {{ govukSummaryList({
        rows: [
          {
            key: { text: "Date and time" },
            value: {
              html: ((event.startsAt or event.starts_at) | formatEventDate) +
                    ("<br>to " + ((event.endsAt or event.ends_at) | formatEventDate) if event.endsAt or event.ends_at else "")
            }
          } if event.startsAt or event.starts_at,
          {
            key: { text: "Location" },
            value: { text: event.location or "Not specified" }
          },
          {
            key: { text: "Group" },
            value: {
              html: "<a href='/groups/" + event.group.id + "' class='govuk-link'>" + event.group.name + "</a>"
            }
          } if event.group,
          {
            key: { text: "Organised by" },
            value: {
              html: "<a href='/members/" + organizer.id + "' class='govuk-link'>" +
                    (organizer.firstName or organizer.first_name or "") + " " + (organizer.lastName or organizer.last_name or "") + "</a>"
            }
          } if organizer,
          {
            key: { text: "Capacity" },
            value: {
              text: (event.attendeeCount or event.attendee_count or 0) + " attending" +
                    (" / " + (event.maxAttendees or event.max_attendees) + " max" if event.maxAttendees or event.max_attendees else "")
            }
          }
        ] | selectattr("key") | list
      }) }}

      {% if event.description %}
        <h2 class="govuk-heading-m govuk-!-margin-top-6">About this event</h2>
        <div class="govuk-body app-formatted-text">
          {{ event.description | nl2br | safe }}
        </div>
      {% endif %}

      <p class="govuk-body govuk-!-margin-top-4">
        {% set reportType = "event" %}
        {% set reportId = event.id %}
        {% set returnTo = "/events/" + (event.id | string) %}
        {% include "partials/report-link.njk" %}
      </p>

      {# RSVP section #}
      {% if event.status != 'cancelled' and not (event.isPast or event.is_past) %}
        <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

        <h2 class="govuk-heading-m">Your RSVP</h2>

        {% if myRsvp %}
          <p class="govuk-body">
            You're currently marked as:
            {% if myRsvp.status == 'going' %}
              {{ govukTag({ text: "Going", classes: "govuk-tag--green" }) }}
            {% elif myRsvp.status == 'maybe' %}
              {{ govukTag({ text: "Maybe", classes: "govuk-tag--yellow" }) }}
            {% else %}
              {{ govukTag({ text: "Not going", classes: "govuk-tag--grey" }) }}
            {% endif %}
          </p>
        {% endif %}

        {% set eventMaxAttendees = event.maxAttendees or event.max_attendees %}
        {% set eventAttendeeCount = event.attendeeCount or event.attendee_count or 0 %}
        {% set isFull = eventMaxAttendees and eventAttendeeCount >= eventMaxAttendees %}

        <div class="app-rsvp-buttons">
          {% if not isFull or (myRsvp and myRsvp.status == 'going') %}
            <form action="/events/{{ event.id }}/rsvp" method="post" style="display: inline;">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}">
              <input type="hidden" name="status" value="going">
              {{ govukButton({
                text: "Going",
                classes: "govuk-button--secondary" if myRsvp and myRsvp.status == 'going' else "",
                disabled: myRsvp and myRsvp.status == 'going'
              }) }}
            </form>
          {% endif %}

          <form action="/events/{{ event.id }}/rsvp" method="post" style="display: inline;">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <input type="hidden" name="status" value="maybe">
            {{ govukButton({
              text: "Maybe",
              classes: "govuk-button--secondary",
              disabled: myRsvp and myRsvp.status == 'maybe'
            }) }}
          </form>

          <form action="/events/{{ event.id }}/rsvp" method="post" style="display: inline;">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <input type="hidden" name="status" value="not_going">
            {{ govukButton({
              text: "Not going",
              classes: "govuk-button--secondary",
              disabled: myRsvp and myRsvp.status == 'not_going'
            }) }}
          </form>

          {% if myRsvp %}
            <form action="/events/{{ event.id }}/rsvp/remove" method="post" style="display: inline;">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}">
              {{ govukButton({
                text: "Remove RSVP",
                classes: "govuk-button--warning"
              }) }}
            </form>
          {% endif %}
        </div>

        {% if isFull and (not myRsvp or myRsvp.status != 'going') %}
          <p class="govuk-body govuk-!-margin-top-3">
            <strong>This event is full.</strong> You can still mark yourself as "Maybe" or "Not going".
          </p>
        {% endif %}
      {% endif %}

      {# Admin actions #}
      {% if event.canEdit or event.can_edit %}
        <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

        <h2 class="govuk-heading-m">Manage event</h2>

        <div class="app-action-buttons">
          {{ govukButton({
            text: "Edit event",
            href: "/events/" + event.id + "/edit",
            classes: "govuk-button--secondary"
          }) }}

          {% if event.status != 'cancelled' %}
            <form action="/events/{{ event.id }}/cancel" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to cancel this event?');">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}">
              {{ govukButton({
                text: "Cancel event",
                classes: "govuk-button--warning"
              }) }}
            </form>
          {% endif %}

          <form action="/events/{{ event.id }}/delete" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this event? This cannot be undone.');">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            {{ govukButton({
              text: "Delete event",
              classes: "govuk-button--warning"
            }) }}
          </form>
        </div>
      {% endif %}

    </div>

    <div class="govuk-grid-column-one-third">
      {# Attendees sidebar #}
      <div class="app-sidebar-card">
        <h2 class="govuk-heading-m">Attendees</h2>

        {% if rsvpsByStatus.going.length > 0 %}
          <h3 class="govuk-heading-s govuk-!-margin-bottom-2">
            Going ({{ rsvpsByStatus.going.length }})
          </h3>
          <ul class="app-attendee-list govuk-!-margin-bottom-4">
            {% for rsvp in rsvpsByStatus.going | take(8) %}
              <li class="app-attendee-list__item">
                {% set user = rsvp.user or rsvp %}
                {% include "partials/avatar.njk" %}
                <a href="/members/{{ user.id }}" class="govuk-link govuk-body-s">
                  {{ user.first_name or user.firstName }} {{ user.last_name or user.lastName }}
                </a>
              </li>
            {% endfor %}
          </ul>
          {% if rsvpsByStatus.going.length > 8 %}
            <p class="govuk-body-s">and {{ rsvpsByStatus.going.length - 8 }} more...</p>
          {% endif %}
        {% endif %}

        {% if rsvpsByStatus.maybe.length > 0 %}
          <h3 class="govuk-heading-s govuk-!-margin-bottom-2">
            Maybe ({{ rsvpsByStatus.maybe.length }})
          </h3>
          <ul class="app-attendee-list govuk-!-margin-bottom-4">
            {% for rsvp in rsvpsByStatus.maybe | take(5) %}
              <li class="app-attendee-list__item">
                {% set user = rsvp.user or rsvp %}
                {% include "partials/avatar.njk" %}
                <a href="/members/{{ user.id }}" class="govuk-link govuk-body-s">
                  {{ user.first_name or user.firstName }} {{ user.last_name or user.lastName }}
                </a>
              </li>
            {% endfor %}
          </ul>
          {% if rsvpsByStatus.maybe.length > 5 %}
            <p class="govuk-body-s">and {{ rsvpsByStatus.maybe.length - 5 }} more...</p>
          {% endif %}
        {% endif %}

        {% if rsvpsByStatus.going.length == 0 and rsvpsByStatus.maybe.length == 0 %}
          <p class="govuk-body-s">No RSVPs yet. Be the first to respond!</p>
        {% endif %}
      </div>
    </div>
  </div>
{% endblock %}
