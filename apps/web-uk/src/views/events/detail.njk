{% extends "layouts/base.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}

{% block beforeContent %}
  {{ super() }}
  <a class="govuk-back-link" href="{{ urlFor('/events') }}">{{ t("actions.back_to_events") }}</a>
{% endblock %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if status == "waitlist-offer-accepted" %}
        <div class="govuk-notification-banner govuk-notification-banner--success" role="alert"><div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">{{ t("govuk_alpha.states.success_title") }}</h2></div><div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ t("govuk_alpha.events.waitlist_offer_accepted") }}</p></div></div>
      {% elif status == "waitlist-offer-accept-failed" %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1"><div role="alert"><h2 class="govuk-error-summary__title">{{ t("govuk_alpha.states.error_title") }}</h2><div class="govuk-error-summary__body"><p>{{ t("govuk_alpha.events.waitlist_offer_accept_failed") }}</p></div></div></div>
      {% elif status == "event-archive-failed" %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1"><div role="alert"><h2 class="govuk-error-summary__title">{{ t("govuk_alpha.states.error_title") }}</h2><div class="govuk-error-summary__body"><p>{{ t("govuk_alpha.events.archive_failed") }}</p></div></div></div>
      {% elif status == "event-cancel-failed" %}
        <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1"><div role="alert"><h2 class="govuk-error-summary__title">{{ t("govuk_alpha.states.error_title") }}</h2><div class="govuk-error-summary__body"><p>{{ t("events.cancel_failed") }}</p></div></div></div>
      {% endif %}

      {% if successMessage %}
        {% set notificationMessage = successMessage %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      {% if errorMessage %}
        {% set notificationMessage = errorMessage %}
        {% set notificationType = null %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      {% if myRsvp and myRsvp.status == "going" %}
        <p class="govuk-body">
          <a class="govuk-link" href="{{ urlFor('/events/' + (event.id | string) + '/reminders') }}">{{ t("govuk_alpha_events.reminders.manage_link") }}</a>
          <span aria-hidden="true"> · </span>
          <a class="govuk-link" href="{{ urlFor('/events/' + (event.id | string) + '/check-in/credential') }}">{{ t("event_offline_checkin.attendee.manage_link") }}</a>
        </p>
      {% endif %}

      <div class="app-page-header">
        <span class="govuk-caption-l">{{ t("events.detail_title") }}</span>
        <h1 class="govuk-heading-xl">{{ event.title }}</h1>
        {% set permissions = event.permissions or {} %}
        {% if permissions.manage_people or permissions.check_in %}
          <nav class="govuk-button-group" aria-label="{{ t('govuk_alpha.events.operations_navigation') }}">
            {% if permissions.manage_people %}<a class="govuk-button govuk-button--secondary" href="{{ urlFor('/events/' + (event.id | string) + '/people') }}">{{ t("govuk_alpha.events.people_title") }}</a>{% endif %}
            {% if permissions.check_in %}<a class="govuk-button govuk-button--secondary" href="{{ urlFor('/events/' + (event.id | string) + '/check-in') }}">{{ t("govuk_alpha.events.check_in_title") }}</a>{% endif %}
          </nav>
        {% endif %}
        {% set attendeeCount = event.attendeeCount or event.attendee_count or 0 %}
        {% set interestedCount = event.interestedCount or event.interested_count or 0 %}
        {% set maxAttendees = event.maxAttendees or event.max_attendees %}
        {% set spotsLeft = event.spotsLeft if event.spotsLeft is defined else event.spots_left %}
        {% if maxAttendees and attendeeCount >= maxAttendees %}
          <p class="govuk-!-margin-bottom-4">{{ govukTag({ text: t("events.full"), classes: "govuk-tag--red" }) }}</p>
        {% elif spotsLeft is not none and spotsLeft is defined %}
          <p class="govuk-!-margin-bottom-4">{{ govukTag({ text: t("events.spots_left", { count: spotsLeft }), classes: "govuk-tag--green" }) }}</p>
        {% endif %}
      </div>

      {% if (event.isCancelled or event.is_cancelled) %}
        {{ govukWarningText({
          text: t("events.polish_events.cancelled_banner_heading"),
          iconFallbackText: "Warning"
        }) }}
        {% if event.cancellation_reason or event.cancellationReason %}
          <p class="govuk-body govuk-!-margin-top-1"><strong>{{ t("events.polish_events.cancelled_reason_prefix") }}</strong> {{ event.cancellation_reason or event.cancellationReason }}</p>
        {% endif %}
      {% endif %}

      {% if event.isArchived or event.is_archived %}
        <div class="govuk-inset-text">{{ t("govuk_alpha.events.archived_notice") }}</div>
      {% endif %}

      {% set coverImage = event.cover_image or event.coverImage %}
      {% if coverImage %}
        <figure class="nexus-alpha-detail-hero">
          <img src="{{ coverImage }}" alt="{{ t('events.image_alt', { title: event.title }) }}" width="640" height="360" decoding="async">
        </figure>
      {% endif %}

      {% if event.description %}
        <h2 class="govuk-heading-l">{{ t("events.description_title") }}</h2>
        <div class="govuk-body app-formatted-text">
          {{ event.description | nl2br | safe }}
        </div>
      {% endif %}

      {# Event information #}
      {% set organizer = event.createdBy or event.created_by or event.organizer or event.user %}
      {% set organizerName = organizer.name or (((organizer.firstName or organizer.first_name or "") + " " + (organizer.lastName or organizer.last_name or "")) | trim) if organizer else "" %}
      {% set eventStartTime = event.start_time or event.startTime %}
      {% set eventEndTime = event.end_time or event.endTime %}
      {% set onlineLink = event.online_link or event.onlineLink %}
      {% set videoUrl = event.video_url or event.videoUrl %}
      {% set category = event.category %}
      {% set categoryName = category.name if category else (event.category_name or event.categoryName) %}
      {% set canSeeVideo = (event.canEdit or event.can_edit) or (myRsvp and myRsvp.status in ["going", "interested"]) %}
      <h2 class="govuk-heading-l">{{ t("events.summary_title") }}</h2>
      <dl class="govuk-summary-list">
        {% if eventStartTime %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t("events.starts") }}</dt>
            <dd class="govuk-summary-list__value">{{ eventStartTime | formatEventDate }}</dd>
          </div>
        {% endif %}
        {% if eventEndTime %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t("events.ends") }}</dt>
            <dd class="govuk-summary-list__value">{{ eventEndTime | formatEventDate }}</dd>
          </div>
        {% endif %}
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">{{ t("events.location") }}</dt>
          <dd class="govuk-summary-list__value">{{ event.location or t("events.online") }}</dd>
        </div>
        {% if onlineLink %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t("events.online_link_label") }}</dt>
            <dd class="govuk-summary-list__value"><a class="govuk-link" href="{{ onlineLink }}" rel="noopener noreferrer">{{ t("events.online_link_text") }}</a></dd>
          </div>
        {% endif %}
        {% if videoUrl and canSeeVideo %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t("events.polish_events.video_url_summary_label") }}</dt>
            <dd class="govuk-summary-list__value"><a class="govuk-link" href="{{ videoUrl }}" rel="noopener noreferrer">{{ t("events.polish_events.video_url_link_text") }}</a></dd>
          </div>
        {% endif %}
        {% if organizer and organizer.id and organizerName %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t("events.organiser") }}</dt>
            <dd class="govuk-summary-list__value"><a href="{{ urlFor('/members/' + (organizer.id | string)) }}" class="govuk-link">{{ organizerName }}</a></dd>
          </div>
        {% endif %}
        {% if categoryName %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t("events.category") }}</dt>
            <dd class="govuk-summary-list__value">{{ categoryName }}</dd>
          </div>
        {% endif %}
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">{{ t("events.attendees_label") }}</dt>
          <dd class="govuk-summary-list__value">{{ tc("events.attendees", attendeeCount, { count: attendeeCount }) }}</dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">{{ t("events.interested_label") }}</dt>
          <dd class="govuk-summary-list__value">{{ tc("events.interested", interestedCount, { count: interestedCount }) }}</dd>
        </div>
      </dl>

      {% if isAuthenticated %}
        <p class="govuk-body govuk-!-margin-top-4">
          {% set reportType = "event" %}
          {% set reportId = event.id %}
          {% set returnTo = urlFor("/events/" + (event.id | string)) %}
          {% include "partials/report-link.njk" %}
        </p>
      {% endif %}

      {# RSVP section #}
      {% if isAuthenticated and not (event.isCancelled or event.is_cancelled) and not (event.isPast or event.is_past) %}
        <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

        {% if relationship and (relationship.offerActive or relationship.waitlistState == "offered") %}
          <section aria-labelledby="waitlist-heading"><h2 class="govuk-heading-m" id="waitlist-heading">{{ t("govuk_alpha.events.waitlist_offer_title") }}</h2><div class="govuk-inset-text"><p class="govuk-body govuk-!-margin-bottom-0">{{ t("govuk_alpha.events.waitlist_offer_description") }}</p></div><div class="govuk-button-group">
            {% if relationship.canAcceptOffer %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/waitlist/accept') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="idempotency_key" value="event-{{ event.id }}-waitlist-offer"><button class="govuk-button govuk-!-margin-bottom-0">{{ t("govuk_alpha.events.waitlist_offer_accept") }}</button></form>{% endif %}
            {% if relationship.canLeaveWaitlist %}<details class="govuk-details govuk-!-margin-bottom-0"><summary class="govuk-details__summary"><span class="govuk-details__summary-text">{{ t("govuk_alpha.events.waitlist_offer_decline") }}</span></summary><div class="govuk-details__text"><form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/waitlist/leave') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0">{{ t("govuk_alpha.events.waitlist_offer_decline") }}</button></form></div></details>{% endif %}
          </div></section>
        {% elif relationship and relationship.waitlistState == "waiting" %}
          <section aria-labelledby="waitlist-heading"><h2 class="govuk-heading-m" id="waitlist-heading">{{ t("govuk_alpha.events.waitlist_heading") }}</h2><div class="govuk-inset-text"><p class="govuk-body govuk-!-margin-bottom-1">{{ t("govuk_alpha.events.waitlist_on_list_note") }}</p>{% if relationship.waitlistPosition %}<p class="govuk-body govuk-!-margin-bottom-0 govuk-!-font-weight-bold">{{ t("govuk_alpha.events.waitlist_position", { position: relationship.waitlistPosition }) }}</p>{% endif %}</div>{% if relationship.canLeaveWaitlist %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/waitlist/leave') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><button class="govuk-button govuk-button--warning">{{ t("govuk_alpha.events.waitlist_leave") }}</button></form>{% endif %}</section>
        {% elif relationship and relationship.canJoinWaitlist %}
          <section aria-labelledby="waitlist-heading"><h2 class="govuk-heading-m" id="waitlist-heading">{{ t("govuk_alpha.events.waitlist_heading") }}</h2><p class="govuk-body">{{ t("govuk_alpha.events.waitlist_full_note") }}</p><form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/waitlist') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><button class="govuk-button">{{ t("govuk_alpha.events.waitlist_join") }}</button></form></section>
        {% endif %}

        {% if not relationship or not (relationship.offerActive or relationship.waitlistState == "offered") %}<form action="{{ urlFor('/events/' + (event.id | string) + '/rsvp') }}" method="post">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          {{ govukRadios({
            name: "status",
            fieldset: {
              legend: {
                text: t("events.rsvp_title"),
                classes: "govuk-fieldset__legend--m",
                isPageHeading: false
              }
            },
            hint: { text: t("events.rsvp_hint") },
            items: [
              {
                value: "going",
                text: t("events.rsvp_status.going"),
                checked: not myRsvp or myRsvp.status == "going"
              },
              {
                value: "interested",
                text: t("events.rsvp_status.interested"),
                checked: myRsvp and myRsvp.status == "interested"
              },
              {
                value: "not_going",
                text: t("events.rsvp_status.not_going"),
                checked: myRsvp and myRsvp.status == "not_going"
              }
            ]
          }) }}
          {{ govukButton({ text: t("actions.rsvp") }) }}
        </form>{% endif %}
      {% elif not isAuthenticated and not (event.isCancelled or event.is_cancelled) and not (event.isPast or event.is_past) %}
        <div class="govuk-inset-text">
          <a class="govuk-link" href="{{ urlFor('/login') }}">{{ t("nav.login") }}</a>. {{ t("events.auth_required_detail", { community: tenantName or serviceName }) }}
        </div>
      {% endif %}

      {# Admin actions #}
      {% if event.canEdit or event.can_edit %}
        <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

        <div class="app-action-buttons">
          {{ govukButton({
            text: t("events.edit_event"),
            href: urlFor("/events/" + (event.id | string) + "/edit"),
            classes: "govuk-button--secondary"
          }) }}

          {% if not (event.isCancelled or event.is_cancelled) %}
            <details class="govuk-details govuk-!-margin-bottom-2" data-module="govuk-details">
              <summary class="govuk-details__summary">
                <span class="govuk-details__summary-text">{{ t("events.cancel_event") }}</span>
              </summary>
              <div class="govuk-details__text">
                <p class="govuk-body">{{ t("events.cancel_confirm") }}</p>
                <form action="{{ urlFor('/events/' + (event.id | string) + '/cancel') }}" method="post">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}">
                  <div class="govuk-form-group">
                    <label class="govuk-label" for="cancel-reason">{{ t("events.cancel_reason_label") }}</label>
                    <textarea class="govuk-textarea" id="cancel-reason" name="reason" rows="3" maxlength="4000" required></textarea>
                  </div>
                  {{ govukButton({
                    text: t("events.cancel_event_button"),
                    classes: "govuk-button--warning govuk-!-margin-bottom-0"
                  }) }}
                </form>
              </div>
            </details>
          {% endif %}

          <details class="govuk-details govuk-!-margin-bottom-4" data-module="govuk-details">
            <summary class="govuk-details__summary"><span class="govuk-details__summary-text">{{ t("govuk_alpha.events.archive_event") }}</span></summary>
            <div class="govuk-details__text">
              <p class="govuk-body">{{ t("govuk_alpha.events.archive_confirm") }}</p>
              <form action="{{ urlFor('/events/' + (event.id | string) + '/delete') }}" method="post">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}">
                <div class="govuk-form-group">
                  <label class="govuk-label" for="archive-reason">{{ t("govuk_alpha.events.archive_reason_label") }}</label>
                  <textarea class="govuk-textarea" id="archive-reason" name="reason" rows="2" maxlength="4000" required></textarea>
                </div>
                {{ govukButton({ text: t("govuk_alpha.events.archive_event_button"), classes: "govuk-button--warning govuk-!-margin-bottom-0" }) }}
              </form>
            </div>
          </details>
        </div>
      {% endif %}

      {% if rsvpsByStatus.going.length > 0 or rsvpsByStatus.interested.length > 0 %}
        <h2 class="govuk-heading-l govuk-!-margin-top-8">{{ t("govuk_alpha.events.attendees_title") }}</h2>

        {% if rsvpsByStatus.going.length > 0 %}
          <h3 class="govuk-heading-s govuk-!-margin-bottom-2">{{ t("events.attendees_label") }} ({{ rsvpsByStatus.going.length }})</h3>
          <ul class="govuk-list govuk-!-margin-bottom-4">
            {% for rsvp in rsvpsByStatus.going %}
              <li>
                {% set user = rsvp.user or rsvp %}
                {% include "partials/avatar.njk" %}
                <a href="{{ urlFor('/members/' + (user.id | string)) }}" class="govuk-link govuk-body-s">
                  {{ user.name or ((user.first_name or user.firstName or "") + " " + (user.last_name or user.lastName or "")) }}
                </a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}

        {% if rsvpsByStatus.interested.length > 0 %}
          <h3 class="govuk-heading-s govuk-!-margin-bottom-2">{{ t("events.interested_label") }} ({{ rsvpsByStatus.interested.length }})</h3>
          <ul class="govuk-list govuk-!-margin-bottom-4">
            {% for rsvp in rsvpsByStatus.interested %}
              <li>
                {% set user = rsvp.user or rsvp %}
                {% include "partials/avatar.njk" %}
                <a href="{{ urlFor('/members/' + (user.id | string)) }}" class="govuk-link govuk-body-s">
                  {{ user.name or ((user.first_name or user.firstName or "") + " " + (user.last_name or user.lastName or "")) }}
                </a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}

      {% endif %}
    </div>
  </div>
{% endblock %}
