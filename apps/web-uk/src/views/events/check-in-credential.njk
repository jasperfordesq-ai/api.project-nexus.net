{% extends "layouts/base.njk" %}
{% block content %}
  <a class="govuk-back-link" href="{{ urlFor('/events/' + (event.id | string)) }}">{{ t("govuk_alpha.events.back_to_event") }}</a>
  <span class="govuk-caption-l">{{ event.title }}</span>
  <h1 class="govuk-heading-xl">{{ t("event_offline_checkin.attendee.title") }}</h1>
  <p class="govuk-body-l">{{ t("event_offline_checkin.attendee.intro") }}</p>
  <div class="govuk-inset-text">
    <p class="govuk-body">{{ t("event_offline_checkin.attendee.privacy") }}</p>
    <p class="govuk-body govuk-!-margin-bottom-0">{{ t("event_offline_checkin.privacy.no_wallet") }}</p>
  </div>

  {% if status %}
    {% set noticeKey = "event_offline_checkin.attendee.notice_failed" %}
    {% if status == "issued" %}{% set noticeKey = "event_offline_checkin.attendee.notice_issued" %}
    {% elif status == "replaced" %}{% set noticeKey = "event_offline_checkin.attendee.notice_replaced" %}
    {% elif status == "revoked" %}{% set noticeKey = "event_offline_checkin.attendee.notice_revoked" %}
    {% elif status == "already-active" %}{% set noticeKey = "event_offline_checkin.attendee.notice_already_active" %}
    {% elif status == "invalid" %}{% set noticeKey = "event_offline_checkin.attendee.notice_invalid" %}{% endif %}
    {% if status == "issued" or status == "replaced" or status == "revoked" %}
      <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="credential-notice-title">
        <div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title" id="credential-notice-title">{{ t("govuk_alpha.states.success_title") }}</h2></div>
        <div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ t(noticeKey) }}</p></div>
      </div>
    {% else %}
      <div class="govuk-error-summary" data-module="govuk-error-summary" role="alert" tabindex="-1">
        <h2 class="govuk-error-summary__title">{{ t("govuk_alpha.states.error_title") }}</h2>
        <div class="govuk-error-summary__body"><p>{{ t(noticeKey) }}</p></div>
      </div>
    {% endif %}
  {% endif %}

  {% if credential %}
    <section aria-labelledby="credential-status-heading" class="govuk-!-margin-bottom-7">
      <h2 class="govuk-heading-m" id="credential-status-heading">{{ t("event_offline_checkin.attendee.status_heading") }}</h2>
      <p class="govuk-body">
        <strong class="govuk-tag {% if credential.status == 'active' %}govuk-tag--green{% elif credential.status == 'revoked' %}govuk-tag--red{% else %}govuk-tag--grey{% endif %}">{{ t("event_offline_checkin.attendee.status_" + credential.status) }}</strong>
        {% if credential.expiresAt %}<span class="govuk-!-margin-left-2">{{ t("event_offline_checkin.attendee.expires", { date: formatLocaleDate(credential.expiresAt) }) }}</span>{% endif %}
      </p>
    </section>
  {% endif %}

  {% if oneShotToken %}
    <section aria-labelledby="one-shot-code-heading" class="govuk-!-margin-bottom-8">
      <h2 class="govuk-heading-l" id="one-shot-code-heading">{{ t("event_offline_checkin.attendee.one_shot_heading") }}</h2>
      <div class="govuk-warning-text"><span class="govuk-warning-text__icon" aria-hidden="true">!</span><strong class="govuk-warning-text__text"><span class="govuk-visually-hidden">{{ t("govuk_alpha.states.warning_prefix") }}</span>{{ t("event_offline_checkin.attendee.one_shot") }}</strong></div>
      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--s" for="attendee-checkin-code">{{ t("event_offline_checkin.attendee.code_label") }}</label>
        <div class="govuk-hint" id="attendee-checkin-code-hint">{{ t("event_offline_checkin.attendee.code_hint") }}</div>
        <textarea class="govuk-textarea" id="attendee-checkin-code" rows="8" readonly spellcheck="false" aria-describedby="attendee-checkin-code-hint">{{ oneShotToken }}</textarea>
      </div>
      <p class="govuk-body">{{ t("event_offline_checkin.attendee.print_hint") }}</p>
      <button type="button" class="govuk-button govuk-button--secondary" data-module="govuk-button" onclick="window.print()">{{ t("event_offline_checkin.attendee.print") }}</button>
    </section>
  {% endif %}

  {% if not credential or credential.status != "active" %}
    <form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/check-in/credential/issue') }}" class="govuk-!-margin-bottom-8">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}">
      <div class="govuk-checkboxes"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="issue-credential-confirm" name="confirmation" type="checkbox" value="1" required><label class="govuk-label govuk-checkboxes__label" for="issue-credential-confirm">{{ t("event_offline_checkin.attendee.issue_confirm") }}</label></div></div>
      <button class="govuk-button govuk-!-margin-top-4" data-module="govuk-button">{{ t("event_offline_checkin.attendee.issue") }}</button>
    </form>
  {% else %}
    <section aria-labelledby="replace-code-heading" class="govuk-!-margin-bottom-8">
      <h2 class="govuk-heading-m" id="replace-code-heading">{{ t("event_offline_checkin.attendee.replace") }}</h2><p class="govuk-body">{{ t("event_offline_checkin.attendee.replace_hint") }}</p>
      <form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/check-in/credential/rotate') }}">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="credential_id" value="{{ credential.id }}"><input type="hidden" name="expected_version" value="{{ credential.version }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}">
        <div class="govuk-checkboxes"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="replace-credential-confirm" name="confirmation" type="checkbox" value="1" required><label class="govuk-label govuk-checkboxes__label" for="replace-credential-confirm">{{ t("event_offline_checkin.attendee.replace_confirm") }}</label></div></div>
        <button class="govuk-button govuk-button--secondary govuk-!-margin-top-4" data-module="govuk-button">{{ t("event_offline_checkin.attendee.replace") }}</button>
      </form>
    </section>
    <section aria-labelledby="revoke-code-heading">
      <h2 class="govuk-heading-m" id="revoke-code-heading">{{ t("event_offline_checkin.attendee.revoke") }}</h2>
      <form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/check-in/credential/revoke') }}">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="credential_id" value="{{ credential.id }}"><input type="hidden" name="expected_version" value="{{ credential.version }}">
        <div class="govuk-form-group"><label class="govuk-label" for="revoke-credential-reason">{{ t("event_offline_checkin.attendee.reason") }}</label><div class="govuk-hint" id="revoke-credential-reason-hint">{{ t("event_offline_checkin.attendee.reason_hint") }}</div><textarea class="govuk-textarea" id="revoke-credential-reason" name="reason" rows="3" maxlength="500" required aria-describedby="revoke-credential-reason-hint"></textarea></div>
        <div class="govuk-checkboxes"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="revoke-credential-confirm" name="confirmation" type="checkbox" value="1" required><label class="govuk-label govuk-checkboxes__label" for="revoke-credential-confirm">{{ t("event_offline_checkin.attendee.revoke_confirm") }}</label></div></div>
        <button class="govuk-button govuk-button--warning govuk-!-margin-top-4" data-module="govuk-button">{{ t("event_offline_checkin.attendee.revoke") }}</button>
      </form>
    </section>
  {% endif %}
{% endblock %}
