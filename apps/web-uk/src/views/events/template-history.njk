{% extends "layouts/base.njk" %}{% block content %}<a class="govuk-back-link" href="{{ urlFor('/events/templates') }}">{{ t("event_templates.back_to_library") }}</a><span class="govuk-caption-xl">{{ template.source_event.title }}</span><h1 class="govuk-heading-xl">{{ t("event_templates.audit_title") }}</h1><p class="govuk-body-l">{{ t("event_templates.audit_intro") }}</p>{% for audit in audits %}<div class="govuk-summary-card"><div class="govuk-summary-card__title-wrapper"><h2 class="govuk-summary-card__title">{{ t("event_templates.audit_actions." + audit.action) }}</h2><strong class="govuk-tag govuk-tag--green">{{ t("event_templates.audit_immutable") }}</strong></div><div class="govuk-summary-card__content"><p>{{ t("event_templates.version", { version: audit.template_version }) }}</p><time datetime="{{ audit.created_at }}">{{ audit.created_at }}</time></div></div>{% else %}<p class="govuk-body">{{ t("event_templates.audit_empty") }}</p>{% endfor %}{% if pagination.next_cursor %}<a class="govuk-link" rel="next" href="{{ urlFor('/event-templates/' + (template.id | string) + '/history?cursor=' + (pagination.next_cursor | string)) }}">{{ t("event_templates.audit_load_more") }}</a>{% endif %}{% endblock %}
