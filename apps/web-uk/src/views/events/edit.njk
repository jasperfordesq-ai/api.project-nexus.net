{% extends "layouts/base.njk" %}

{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% block beforeContent %}
  {{ super() }}
  {% set breadcrumbs = [
    { text: "Events", href: urlFor("/events") },
    { text: event.title, href: urlFor("/events/" + (event.id | string)) },
    { text: t("jobs_t3.edit_button") }
  ] %}
  {% include "partials/breadcrumbs.njk" %}
{% endblock %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if errors and errors.length > 0 %}
        {{ govukErrorSummary({
          titleText: t("states.error_title"),
          errorList: errors
        }) }}
      {% endif %}

      <h1 class="govuk-heading-xl">{{ t("events.edit_event") }}</h1>

      <form action="{{ urlFor('/events/' + (event.id | string) + '/edit') }}" method="post" enctype="multipart/form-data" novalidate data-validate-form data-validation-error-title="{{ t('states.error_title') }}" data-validation-error-prefix="{{ t('states.error_prefix') }}">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        {% set titleError = errors | selectattr("href", "equalto", "#title") | first if errors else undefined %}
        {{ govukInput({
          id: "title",
          name: "title",
          value: event.title,
          label: {
            text: t("events.title_label"),
            classes: "govuk-label--m"
          },
          hint: {
            text: "Give your event a clear, descriptive title"
          },
          errorMessage: { text: titleError.text } if titleError else undefined,
          attributes: {
            "data-validate": "required maxLength:255",
            "data-label": t("events.title_label")
          }
        }) }}

        {% set descriptionError = errors | selectattr("href", "equalto", "#description") | first if errors else undefined %}
        {{ govukTextarea({
          id: "description",
          name: "description",
          value: event.description,
          label: {
            text: "Description",
            classes: "govuk-label--m"
          },
          hint: {
            text: "Tell people what the event is about, what to expect, and any important details"
          },
          rows: 6,
          errorMessage: { text: descriptionError.text } if descriptionError else undefined,
          attributes: {
            "data-validate": "required",
            "data-label": "Description",
            "required": "required"
          }
        }) }}

        {% set selectedCategoryId = event.category_id or event.categoryId or "" %}
        {% set categoryItems = [{value: "", text: t("events.no_category"), selected: not selectedCategoryId}] %}
        {% for category in categories or [] %}
          {% set categoryItems = (categoryItems.push({
            value: category.id | string,
            text: category.name,
            selected: selectedCategoryId and (category.id | string) == (selectedCategoryId | string)
          }), categoryItems) %}
        {% endfor %}
        {{ govukSelect({
          id: "category_id",
          name: "category_id",
          label: {
            text: "Category",
            classes: "govuk-label--m"
          },
          items: categoryItems
        }) }}

        {% if myGroups and myGroups.length > 0 %}
          {% set selectedGroupId = event.group_id or event.groupId or "" %}
          {% set groupItems = [{value: "", text: "No group (public event)", selected: not selectedGroupId}] %}
          {% for group in myGroups %}
            {% set groupItems = (groupItems.push({
              value: group.id | string,
              text: group.name,
              selected: selectedGroupId and (group.id | string) == (selectedGroupId | string)
            }), groupItems) %}
          {% endfor %}
          {{ govukSelect({
            id: "group_id",
            name: "group_id",
            label: {
              text: "Group",
              classes: "govuk-label--m"
            },
            hint: {
              text: "Choose one of your groups, or leave this as a public event"
            },
            items: groupItems
          }) }}
        {% endif %}

        <div class="govuk-form-group">
          <label class="govuk-label govuk-label--m" for="image">
            Image
          </label>
          <div id="image-hint" class="govuk-hint">
            Upload an optional JPG, PNG, GIF or WebP cover image.
          </div>
          {% set currentImage = event.cover_image or event.coverImage %}
          {% if currentImage %}
            <figure class="govuk-!-margin-bottom-4 govuk-!-margin-top-2">
              <img src="{{ currentImage }}" alt="Current image for {{ event.title }}" style="max-width:100%;max-height:240px;" loading="lazy">
            </figure>
          {% endif %}
          <input class="govuk-file-upload" id="image" name="image" type="file" accept="image/jpeg,image/png,image/gif,image/webp" aria-describedby="image-hint">
        </div>

        {{ govukInput({
          id: "location",
          name: "location",
          value: event.location,
          label: {
            text: "Location",
            classes: "govuk-label--m"
          },
          hint: {
            text: "Where will the event take place? Include address or online meeting details"
          }
        }) }}

        {% set isOnline = event.is_online or event.isOnline %}
        <div class="govuk-form-group">
          <div class="govuk-checkboxes" data-module="govuk-checkboxes">
            <div class="govuk-checkboxes__item">
              <input class="govuk-checkboxes__input" id="is_online" name="is_online" type="checkbox" value="1" data-aria-controls="is-online-conditional" {% if isOnline %}checked{% endif %}>
              <label class="govuk-label govuk-checkboxes__label" for="is_online">{{ t("events.is_online_label") }}</label>
            </div>
            <div class="govuk-checkboxes__conditional{% if not isOnline %} govuk-checkboxes__conditional--hidden{% endif %}" id="is-online-conditional">
              {{ govukInput({
                id: "online_link",
                name: "online_link",
                type: "url",
                value: event.online_link or event.onlineLink,
                label: {
                  text: t("events.online_link_label")
                }
              }) }}
            </div>
          </div>
        </div>

        {% set allowRemote = event.allow_remote_attendance or event.allowRemoteAttendance %}
        <div class="govuk-form-group">
          <div class="govuk-checkboxes" data-module="govuk-checkboxes">
            <div class="govuk-checkboxes__item">
              <input class="govuk-checkboxes__input" id="allow_remote_attendance" name="allow_remote_attendance" type="checkbox" value="1" aria-describedby="allow-remote-hint" data-aria-controls="remote-attendance-conditional" {% if allowRemote %}checked{% endif %}>
              <label class="govuk-label govuk-checkboxes__label" for="allow_remote_attendance">Allow people to attend remotely</label>
              <div id="allow-remote-hint" class="govuk-hint govuk-checkboxes__hint">Use this when an in-person event also has a remote option.</div>
            </div>
            <div class="govuk-checkboxes__conditional{% if not allowRemote %} govuk-checkboxes__conditional--hidden{% endif %}" id="remote-attendance-conditional">
              {{ govukInput({
                id: "video_url",
                name: "video_url",
                type: "url",
                value: event.video_url or event.videoUrl,
                label: {
                  text: "Video link"
                },
                hint: {
                  text: "Add the meeting or livestream URL."
                }
              }) }}
            </div>
          </div>
        </div>

        {% set startTimeError = errors | selectattr('href', 'equalto', '#start_time') | first if errors else undefined %}
        {{ govukInput({
          id: "start_time",
          name: "start_time",
          type: "datetime-local",
          value: startTime,
          label: {
            text: t("events.start_time_label"),
            classes: "govuk-label--m"
          },
          hint: { text: t("events.datetime_hint") },
          classes: "govuk-!-width-one-half",
          errorMessage: { text: startTimeError.text } if startTimeError else undefined,
          attributes: {
            "data-validate": "required",
            "data-label": t("events.start_time_label"),
            "required": "required"
          }
        }) }}

        {% set endTimeError = errors | selectattr('href', 'equalto', '#end_time') | first if errors else undefined %}
        {{ govukInput({
          id: "end_time",
          name: "end_time",
          type: "datetime-local",
          value: endTime,
          label: {
            text: t("events.end_time_label"),
            classes: "govuk-label--m"
          },
          hint: { text: t("events.end_time_hint") },
          classes: "govuk-!-width-one-half",
          errorMessage: { text: endTimeError.text } if endTimeError else undefined
        }) }}

        {{ govukInput({
          id: "max_attendees",
          name: "max_attendees",
          value: event.max_attendees,
          label: {
            text: t("events.max_attendees_label"),
            classes: "govuk-label--m"
          },
          hint: {
            text: "Optional - leave blank for unlimited capacity"
          },
          classes: "govuk-input--width-4",
          inputmode: "numeric",
          attributes: {
            "data-validate": "number min:1",
            "data-label": t("events.max_attendees_label")
          }
        }) }}

        <div class="govuk-button-group">
          {{ govukButton({
            text: "Save changes"
          }) }}
          <a href="{{ urlFor('/events/' + (event.id | string)) }}" class="govuk-link">{{ t("polish_federation.transfer_cancel") }}</a>
        </div>
      </form>

    </div>
  </div>
{% endblock %}
