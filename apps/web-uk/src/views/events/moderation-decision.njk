{% extends "layouts/base.njk" %}

{% set isApprove = decision == "approve" %}
{% set errorKey = "govuk_alpha_events.moderation." + error if error else "" %}

{% block beforeContent %}{{ super() }}<a class="govuk-back-link" href="{{ urlFor('/events/moderation') }}">{{ t("govuk_alpha_events.moderation.back_to_queue") }}</a>{% endblock %}

{% block mainContent %}
  <span class="govuk-caption-l">{{ t("govuk_alpha_events.moderation.caption") }}</span>
  <h1 class="govuk-heading-xl">{{ t("govuk_alpha_events.moderation.approve_title" if isApprove else "govuk_alpha_events.moderation.reject_title") }}</h1>
  {% if error %}<div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1"><div role="alert"><h2 class="govuk-error-summary__title">{{ t("govuk_alpha_events.common.error_title") }}</h2><div class="govuk-error-summary__body"><ul class="govuk-list govuk-error-summary__list"><li><a href="{{ '#reason' if error == 'reason_required' or error == 'reason_too_long' else '#confirmation' }}">{{ t(errorKey) }}</a></li></ul></div></div></div>{% endif %}
  <dl class="govuk-summary-list"><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_events.moderation.event") }}</dt><dd class="govuk-summary-list__value">{{ event.title }}</dd></div><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_events.moderation.organizer") }}</dt><dd class="govuk-summary-list__value">{{ event.organizerName }}</dd></div>{% if event.startLabel %}<div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_events.moderation.schedule") }}</dt><dd class="govuk-summary-list__value">{{ event.startLabel }}</dd></div>{% endif %}</dl>
  <div class="govuk-warning-text"><span class="govuk-warning-text__icon" aria-hidden="true">!</span><strong class="govuk-warning-text__text"><span class="govuk-visually-hidden">{{ t("govuk_alpha_events.common.warning") }}</span>{{ t("govuk_alpha_events.moderation.approve_warning" if isApprove else "govuk_alpha_events.moderation.reject_warning") }}</strong></div>
  <form method="post" action="{{ urlFor('/events/moderation/' + (event.id | string) + ('/approve' if isApprove else '/reject')) }}" novalidate><input type="hidden" name="_csrf" value="{{ csrfToken }}">
    {% if not isApprove %}<div class="govuk-form-group{% if error == 'reason_required' or error == 'reason_too_long' %} govuk-form-group--error{% endif %}"><label class="govuk-label govuk-label--m" for="reason">{{ t("govuk_alpha_events.moderation.reason_label") }}</label><div id="reason-hint" class="govuk-hint">{{ t("govuk_alpha_events.moderation.reason_hint") }}</div>{% if error == 'reason_required' or error == 'reason_too_long' %}<p id="reason-error" class="govuk-error-message"><span class="govuk-visually-hidden">{{ t("govuk_alpha_events.common.error_prefix") }}</span> {{ t(errorKey) }}</p>{% endif %}<textarea class="govuk-textarea" id="reason" name="reason" rows="5" maxlength="2000" aria-describedby="reason-hint{% if error == 'reason_required' or error == 'reason_too_long' %} reason-error{% endif %}">{{ reason }}</textarea></div>{% endif %}
    <div class="govuk-form-group{% if error == 'confirmation_required' %} govuk-form-group--error{% endif %}"><fieldset class="govuk-fieldset"{% if error == 'confirmation_required' %} aria-describedby="confirmation-error"{% endif %}><legend class="govuk-fieldset__legend govuk-fieldset__legend--m">{{ t("govuk_alpha_events.moderation.confirm_legend") }}</legend>{% if error == 'confirmation_required' %}<p id="confirmation-error" class="govuk-error-message"><span class="govuk-visually-hidden">{{ t("govuk_alpha_events.common.error_prefix") }}</span> {{ t(errorKey) }}</p>{% endif %}<div class="govuk-checkboxes" data-module="govuk-checkboxes"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="confirmation" name="confirmation" type="checkbox" value="{{ decision }}"><label class="govuk-label govuk-checkboxes__label" for="confirmation">{{ t("govuk_alpha_events.moderation.approve_confirmation" if isApprove else "govuk_alpha_events.moderation.reject_confirmation") }}</label></div></div></fieldset></div>
    <div class="govuk-button-group"><button class="govuk-button{% if not isApprove %} govuk-button--warning{% endif %}" data-module="govuk-button">{{ t("govuk_alpha_events.moderation.approve_button" if isApprove else "govuk_alpha_events.moderation.reject_button") }}</button><a class="govuk-link" href="{{ urlFor('/events/moderation') }}">{{ t("govuk_alpha_events.common.cancel") }}</a></div>
  </form>
{% endblock %}
