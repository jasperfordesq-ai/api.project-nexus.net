{% extends "layouts/base.njk" %}{% block content %}<a class="govuk-back-link" href="{{ urlFor('/events/' + (event.id | string)) }}">{{ t("govuk_alpha_events.common.back_to_event") }}</a><span class="govuk-caption-xl">{{ event.title }}</span><h1 class="govuk-heading-xl">{{ t("event_templates.capture_preview_title") }}</h1><p class="govuk-body-l">{{ t("event_templates.capture_preview_intro") }}</p><h2 class="govuk-heading-m">{{ t("event_templates.copied_title") }}</h2><ul class="govuk-list govuk-list--bullet">{% for field in (preview.copied_fields or []) %}<li>{{ t("event_templates.fields." + field) }}</li>{% endfor %}</ul><h2 class="govuk-heading-m">{{ t("event_templates.never_copied_title") }}</h2><ul class="govuk-list govuk-list--bullet">{% for field in (preview.skipped_fields or []) %}<li>{{ t("event_templates.fields." + field) }}</li>{% endfor %}</ul><form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/templates') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}">{% if template %}<input type="hidden" name="template_id" value="{{ template.id }}"><input type="hidden" name="expected_version" value="{{ template.current_version }}">{% endif %}<button class="govuk-button">{{ t("event_templates.confirm_revision" if template else "event_templates.confirm_capture") }}</button></form>{% endblock %}
