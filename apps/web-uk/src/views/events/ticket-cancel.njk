{% extends "layouts/base.njk" %}
{% block content %}
<a class="govuk-back-link" href="{{ urlFor('/events/' + (eventId | string) + '/tickets') }}">{{ t("event_tickets.back_to_tickets") }}</a>
{% if status %}<div class="govuk-error-summary" role="alert" tabindex="-1"><h2 class="govuk-error-summary__title">{{ t("govuk_alpha_events.common.error_title") }}</h2><div class="govuk-error-summary__body"><p>{{ t("event_tickets.validation_error" if status == "invalid" else "event_tickets.cancel_error") }}</p></div></div>{% endif %}
<span class="govuk-caption-l">{{ ticket.name }}</span><h1 class="govuk-heading-xl">{{ t("event_tickets.cancel_title") }}</h1><p class="govuk-body-l">{{ t("event_tickets.cancel_intro") }}</p><dl class="govuk-summary-list"><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("event_tickets.units") }}</dt><dd class="govuk-summary-list__value">{{ entitlement.units }}</dd></div><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("event_tickets.status_label") }}</dt><dd class="govuk-summary-list__value">{{ t("event_tickets.status." + entitlement.status) }}</dd></div></dl><div class="govuk-inset-text">{{ t("event_tickets.cancel_free_only") }}</div>
<form method="post" action="{{ urlFor('/events/' + (eventId | string) + '/tickets/entitlements/' + (entitlement.id | string) + '/cancel') }}" novalidate><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="expected_version" value="{{ entitlement.version }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><div class="govuk-form-group"><label class="govuk-label govuk-label--m" for="ticket-cancellation-reason">{{ t("event_tickets.reason_label") }}</label><div class="govuk-hint">{{ t("event_tickets.reason_hint") }}</div><textarea class="govuk-textarea" id="ticket-cancellation-reason" name="reason" rows="4" maxlength="500" required></textarea></div><button class="govuk-button govuk-button--warning">{{ t("event_tickets.confirm_cancel") }}</button></form>
{% endblock %}
