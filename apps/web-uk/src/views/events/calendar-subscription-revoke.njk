{% extends "layouts/base.njk" %}{% block content %}<a class="govuk-back-link" href="{{ urlFor('/events/calendar-subscriptions') }}">{{ t("govuk_alpha_events.calendar_subscription_revoke_back") }}</a>{% if status %}<div class="govuk-error-summary" role="alert" tabindex="-1"><h2 class="govuk-error-summary__title">{{ t("govuk_alpha_events.common.error_title") }}</h2><div class="govuk-error-summary__body"><p>{{ t("govuk_alpha_events.calendar_subscription_confirmation_required" if status == "invalid" else "govuk_alpha_events.calendar_subscription_revoke_failed") }}</p></div></div>{% endif %}<h1 class="govuk-heading-xl">{{ t("govuk_alpha_events.calendar_subscription_revoke_title") }}</h1><p class="govuk-body-l">{{ t("govuk_alpha_events.calendar_subscription_revoke_consequence") }}</p><dl class="govuk-summary-list"><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_events.calendar_subscription_label_summary") }}</dt><dd class="govuk-summary-list__value">{{ token.label or t("govuk_alpha_events.calendar_subscription_unnamed") }}</dd></div><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_events.calendar_subscription_prefix") }}</dt><dd class="govuk-summary-list__value"><code>{{ token.token_prefix }}</code></dd></div></dl><form method="post" action="{{ urlFor('/events/calendar-subscriptions/' + (token.id | string) + '/revoke') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><fieldset class="govuk-fieldset"><legend class="govuk-fieldset__legend govuk-fieldset__legend--m">{{ t("govuk_alpha_events.calendar_subscription_revoke_confirm_question") }}</legend><div class="govuk-checkboxes"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="confirm-revoke" name="confirm_revoke" type="checkbox" value="yes"><label class="govuk-label govuk-checkboxes__label" for="confirm-revoke">{{ t("govuk_alpha_events.calendar_subscription_revoke_confirm_label") }}</label></div></div></fieldset><button class="govuk-button govuk-button--warning">{{ t("govuk_alpha_events.calendar_subscription_revoke") }}</button></form>{% endblock %}
