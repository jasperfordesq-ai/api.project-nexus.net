{% macro agendaFields(prefix, session, timezone) %}
  <input type="hidden" name="timezone" value="{{ timezone }}">
  <div class="govuk-form-group"><label class="govuk-label govuk-label--s" for="{{ prefix }}-title">{{ t("govuk_alpha.events.agenda.fields.title") }}</label><input class="govuk-input" id="{{ prefix }}-title" name="title" maxlength="255" value="{{ session.title or '' }}" required></div>
  <div class="govuk-form-group"><label class="govuk-label govuk-label--s" for="{{ prefix }}-capacity">{{ t("event_agenda.capacity_label") }}</label><div class="govuk-hint" id="{{ prefix }}-capacity-hint">{{ t("event_agenda.capacity_hint") }}</div><input class="govuk-input govuk-input--width-5" id="{{ prefix }}-capacity" name="capacity" type="number" min="1" max="100000" value="{{ session.capacity.limit if session.capacity and session.capacity.limit else '' }}" aria-describedby="{{ prefix }}-capacity-hint"></div>
  <div class="govuk-form-group"><label class="govuk-label" for="{{ prefix }}-description">{{ t("govuk_alpha.events.agenda.fields.description") }}</label><textarea class="govuk-textarea" id="{{ prefix }}-description" name="description" rows="4" maxlength="4000">{{ session.description or '' }}</textarea></div>
  <div class="govuk-form-group"><label class="govuk-label" for="{{ prefix }}-type">{{ t("govuk_alpha.events.agenda.fields.type") }}</label><select class="govuk-select" id="{{ prefix }}-type" name="session_type">{% for value in ["session", "keynote", "workshop", "panel", "break", "networking", "other"] %}<option value="{{ value }}"{% if (session.type or 'session') == value %} selected{% endif %}>{{ t("govuk_alpha.events.agenda.types." + value) }}</option>{% endfor %}</select></div>
  <div class="govuk-form-group"><label class="govuk-label" for="{{ prefix }}-visibility">{{ t("govuk_alpha.events.agenda.fields.visibility") }}</label><select class="govuk-select" id="{{ prefix }}-visibility" name="visibility">{% for value in ["public", "registered", "staff"] %}<option value="{{ value }}"{% if (session.visibility or 'public') == value %} selected{% endif %}>{{ t("govuk_alpha.events.agenda.visibilities." + value) }}</option>{% endfor %}</select></div>
  <div class="govuk-form-group"><label class="govuk-label" for="{{ prefix }}-start">{{ t("govuk_alpha.events.agenda.fields.start") }}</label><input class="govuk-input" id="{{ prefix }}-start" name="start_at" type="datetime-local" value="{{ session.start_at_local or '' }}" required></div>
  <div class="govuk-form-group"><label class="govuk-label" for="{{ prefix }}-end">{{ t("govuk_alpha.events.agenda.fields.end") }}</label><input class="govuk-input" id="{{ prefix }}-end" name="end_at" type="datetime-local" value="{{ session.end_at_local or '' }}" required></div>
  <p class="govuk-hint">{{ t("govuk_alpha.events.agenda.timezone_hint", { timezone: timezone }) }}</p>
  <div class="govuk-form-group"><label class="govuk-label" for="{{ prefix }}-track">{{ t("govuk_alpha.events.agenda.fields.track") }}</label><input class="govuk-input" id="{{ prefix }}-track" name="track_name" maxlength="160" value="{{ session.track or '' }}"></div>
  <div class="govuk-form-group"><label class="govuk-label" for="{{ prefix }}-room">{{ t("govuk_alpha.events.agenda.fields.room") }}</label><input class="govuk-input" id="{{ prefix }}-room" name="room_name" maxlength="160" value="{{ session.room or '' }}"></div>
  <fieldset class="govuk-fieldset"><legend class="govuk-fieldset__legend govuk-fieldset__legend--s">{{ t("govuk_alpha.events.agenda.fields.speakers") }}</legend>{% for index in [0, 1, 2] %}{% set speaker = session.speakers[index] or {} %}<div class="govuk-grid-row"><div class="govuk-grid-column-one-half"><label class="govuk-label" for="{{ prefix }}-speaker-{{ index }}">{{ t("govuk_alpha.events.agenda.fields.speaker_name", { number: index + 1 }) }}</label><input class="govuk-input" id="{{ prefix }}-speaker-{{ index }}" name="speaker_name[]" maxlength="160" value="{{ speaker.display_name or '' }}"></div><div class="govuk-grid-column-one-half"><label class="govuk-label" for="{{ prefix }}-role-{{ index }}">{{ t("govuk_alpha.events.agenda.fields.speaker_role") }}</label><input class="govuk-input" id="{{ prefix }}-role-{{ index }}" name="speaker_role[]" maxlength="120" value="{{ speaker.role or '' }}"></div></div>{% endfor %}</fieldset>
  <fieldset class="govuk-fieldset govuk-!-margin-top-4"><legend class="govuk-fieldset__legend govuk-fieldset__legend--s">{{ t("event_agenda.resources_title") }}</legend><div class="govuk-hint">{{ t("event_agenda.resources_hint") }}</div>{% for index in [0, 1, 2] %}{% set resource = session.resources[index] or {} %}<fieldset class="govuk-fieldset govuk-!-margin-bottom-4"><legend class="govuk-fieldset__legend">{{ t("event_agenda.resource_number", { number: index + 1 }) }}</legend><label class="govuk-label" for="{{ prefix }}-resource-title-{{ index }}">{{ t("event_agenda.resource_title") }}</label><input class="govuk-input" id="{{ prefix }}-resource-title-{{ index }}" name="resource_title[]" value="{{ resource.title or '' }}"><label class="govuk-label" for="{{ prefix }}-resource-url-{{ index }}">{{ t("event_agenda.resource_url") }}</label><input class="govuk-input" id="{{ prefix }}-resource-url-{{ index }}" name="resource_url[]" type="url" value="{{ resource.url or '' }}"><select class="govuk-select" name="resource_type[]" aria-label="{{ t('event_agenda.resource_type') }} {{ index + 1 }}">{% for value in ["link", "document", "slides", "download", "stream", "recording"] %}<option value="{{ value }}"{% if (resource.type or 'link') == value %} selected{% endif %}>{{ t("event_agenda.resource_types." + value) }}</option>{% endfor %}</select><select class="govuk-select" name="resource_visibility[]" aria-label="{{ t('event_agenda.resource_visibility') }} {{ index + 1 }}">{% for value in ["public", "registered", "staff"] %}<option value="{{ value }}"{% if (resource.visibility or 'public') == value %} selected{% endif %}>{{ t("govuk_alpha.events.agenda.visibilities." + value) }}</option>{% endfor %}</select></fieldset>{% endfor %}</fieldset>
{% endmacro %}
