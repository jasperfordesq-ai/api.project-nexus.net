<h3 class="govuk-heading-m govuk-!-margin-top-7" id="registration-submissions">{{ t("event_registration.submissions.title") }}</h3>
{% for submission in (organizer.submissions or []) %}
<details class="govuk-details"><summary class="govuk-details__summary"><span class="govuk-details__summary-text">{{ t("event_registration.accessible.review_submission", { id: submission.id }) }}</span></summary><div class="govuk-details__text">
<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/registration/submissions/' + (submission.id | string) + '/review') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><div class="govuk-form-group"><label class="govuk-label" for="purpose-{{ submission.id }}">{{ t("event_registration.submissions.purpose") }}</label><textarea class="govuk-textarea" id="purpose-{{ submission.id }}" name="purpose" rows="3" required></textarea></div><input type="hidden" name="correlation_id" value="{{ idempotencyKey }}">{% if organizer.permissions and organizer.permissions.view_sensitive_answers %}<div class="govuk-checkboxes" data-module="govuk-checkboxes"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="sensitive-{{ submission.id }}" name="include_sensitive" type="checkbox" value="1"><label class="govuk-label govuk-checkboxes__label" for="sensitive-{{ submission.id }}">{{ t("event_registration.submissions.include_sensitive") }}</label></div></div>{% endif %}<button class="govuk-button govuk-!-margin-top-3" data-module="govuk-button" type="submit">{{ t("event_registration.submissions.open_answers") }}</button></form>
</div></details>
{% else %}<p class="govuk-body">{{ t("event_registration.submissions.empty") }}</p>{% endfor %}
{% set submissionPagination = registrationPagination.submissions or {} %}
{% if submissionPagination.previousHref or submissionPagination.nextHref %}
<nav class="govuk-pagination" aria-label="{{ t('event_registration.submissions.title') }}">
{% if submissionPagination.previousHref %}<div class="govuk-pagination__prev"><a class="govuk-link govuk-pagination__link" rel="prev" href="{{ urlFor(submissionPagination.previousHref) }}">{{ t("event_registration.common.previous") }}</a></div>{% endif %}
{% if submissionPagination.nextHref %}<div class="govuk-pagination__next"><a class="govuk-link govuk-pagination__link" rel="next" href="{{ urlFor(submissionPagination.nextHref) }}">{{ t("event_registration.common.next") }}</a></div>{% endif %}
</nav>
{% endif %}
{% if organizer.permissions and organizer.permissions.export_answers %}
<details class="govuk-details"><summary class="govuk-details__summary"><span class="govuk-details__summary-text">{{ t("event_registration.submissions.export") }}</span></summary><div class="govuk-details__text"><form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/registration/submissions/export') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><label class="govuk-label" for="export-purpose">{{ t("event_registration.submissions.purpose") }}</label><textarea class="govuk-textarea" id="export-purpose" name="purpose" rows="3" required></textarea><input type="hidden" name="correlation_id" value="{{ idempotencyKey }}"><button class="govuk-button govuk-button--secondary govuk-!-margin-top-3" data-module="govuk-button" type="submit">{{ t("event_registration.submissions.download_csv") }}</button></form></div></details>
{% endif %}

<h3 class="govuk-heading-m govuk-!-margin-top-7">{{ t("event_registration.invitations.builder_title") }}</h3>
<p class="govuk-body">{{ t("event_registration.invitations.builder_description") }}</p>
<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/registration/campaigns/preview') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><div class="govuk-form-group"><label class="govuk-label" for="campaign-type">{{ t("event_registration.invitations.type_label") }}</label><select class="govuk-select" id="campaign-type" name="campaign_type">{% for type in ["member","email","group","audience","csv"] %}<option value="{{ type }}">{{ t("event_registration.invitations.types." + type) }}</option>{% endfor %}</select></div><div class="govuk-form-group"><label class="govuk-label" for="campaign-source">{{ t("event_registration.accessible.source_value") }}</label><div class="govuk-hint">{{ t("event_registration.accessible.source_hint") }}</div><textarea class="govuk-textarea" id="campaign-source" name="source" rows="6" required></textarea></div><div class="govuk-form-group"><label class="govuk-label" for="campaign-locale">{{ t("event_registration.invitations.locale_label") }}</label><select class="govuk-select" id="campaign-locale" name="default_locale">{% for locale in ["en","ga","de","fr","it","pt","es","nl","pl","ja","ar"] %}<option value="{{ locale }}">{{ t("event_registration.locales." + locale) }}</option>{% endfor %}</select></div><button class="govuk-button" data-module="govuk-button" type="submit">{{ t("event_registration.invitations.preview") }}</button></form>
{% if campaignPreview %}
<div class="govuk-notification-banner" role="region" aria-labelledby="campaign-preview-title"><div class="govuk-notification-banner__header"><h4 class="govuk-notification-banner__title" id="campaign-preview-title">{{ t("event_registration.invitations.preview_title") }}</h4></div><div class="govuk-notification-banner__content"><p class="govuk-body">{{ t("event_registration.invitations.snapshot_notice") }}</p><p class="govuk-body">{{ t("event_registration.invitations.valid_count", { count: campaignPreview.valid_count }) }}</p></div></div>
<h4 class="govuk-heading-s">{{ t("event_registration.accessible.schedule_or_send") }}</h4>
<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/registration/campaigns/' + (campaignPreview.id | string) + '/issue') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><input type="hidden" name="expected_revision" value="{{ campaignPreview.revision }}"><label class="govuk-label" for="campaign-expiry">{{ t("event_registration.accessible.expiry") }}</label><input class="govuk-input govuk-input--width-20" id="campaign-expiry" name="expires_at" type="datetime-local" required><button class="govuk-button govuk-!-margin-top-3" data-module="govuk-button" type="submit">{{ t("event_registration.invitations.send_now") }}</button></form>
<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/registration/campaigns/' + (campaignPreview.id | string) + '/schedule') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><input type="hidden" name="expected_revision" value="{{ campaignPreview.revision }}"><label class="govuk-label" for="campaign-scheduled">{{ t("event_registration.invitations.scheduled_for") }}</label><input class="govuk-input govuk-input--width-20" id="campaign-scheduled" name="scheduled_for" type="datetime-local" required><button class="govuk-button govuk-button--secondary govuk-!-margin-top-3" data-module="govuk-button" type="submit">{{ t("event_registration.invitations.schedule") }}</button></form>
{% endif %}

<h3 class="govuk-heading-m govuk-!-margin-top-7" id="registration-campaigns">{{ t("event_registration.invitations.history_title") }}</h3>
{% for campaign in (organizer.campaigns or []) %}
<div class="govuk-summary-card"><div class="govuk-summary-card__title-wrapper"><h4 class="govuk-summary-card__title">{{ t("event_registration.invitations.types." + campaign.campaign_type) }}</h4><strong class="govuk-tag">{{ t("event_registration.statuses." + campaign.status) }}</strong></div><div class="govuk-summary-card__content"><p class="govuk-body">{{ t("event_registration.invitations.valid_count", { count: campaign.valid_count }) }}</p>{% if campaign.status in ["previewed","scheduled"] %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/registration/campaigns/' + (campaign.id | string) + '/cancel') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><input type="hidden" name="expected_revision" value="{{ campaign.revision }}"><label class="govuk-label" for="cancel-reason-{{ campaign.id }}">{{ t("event_registration.invitations.cancel_reason") }}</label><input class="govuk-input" id="cancel-reason-{{ campaign.id }}" name="reason" type="text" required><button class="govuk-button govuk-button--warning govuk-!-margin-top-3" data-module="govuk-button" type="submit">{{ t("event_registration.invitations.confirm_cancel") }}</button></form>{% endif %}</div></div>
{% else %}<p class="govuk-body">{{ t("event_registration.invitations.empty") }}</p>{% endfor %}
{% set campaignPagination = registrationPagination.campaigns or {} %}
{% if campaignPagination.previousHref or campaignPagination.nextHref %}
<nav class="govuk-pagination" aria-label="{{ t('event_registration.invitations.history_title') }}">
{% if campaignPagination.previousHref %}<div class="govuk-pagination__prev"><a class="govuk-link govuk-pagination__link" rel="prev" href="{{ urlFor(campaignPagination.previousHref) }}">{{ t("event_registration.common.previous") }}</a></div>{% endif %}
{% if campaignPagination.nextHref %}<div class="govuk-pagination__next"><a class="govuk-link govuk-pagination__link" rel="next" href="{{ urlFor(campaignPagination.nextHref) }}">{{ t("event_registration.common.next") }}</a></div>{% endif %}
</nav>
{% endif %}

<h3 class="govuk-heading-m govuk-!-margin-top-7" id="registration-guests">{{ t("event_registration.guests.title") }}</h3>
{% for guest in (organizer.guests or []) %}{% set attendance = guest.attendance or {} %}
<div class="govuk-summary-card"><div class="govuk-summary-card__title-wrapper"><h4 class="govuk-summary-card__title">{{ guest.display_name or t("event_registration.guests.name_hidden") }}</h4><strong class="govuk-tag">{{ t("event_registration.attendance." + (attendance.status or "not_checked_in")) }}</strong></div>{% if organizer.permissions and organizer.permissions.manage_attendance and guest.status == "captured" %}<div class="govuk-summary-card__content">{% set actions = ["check_out"] if attendance.status == "checked_in" else ([] if attendance.status in ["checked_out","attended"] else ["check_in","no_show"]) %}{% for action in actions %}<form class="govuk-!-display-inline-block" method="post" action="{{ urlFor('/events/' + (event.id | string) + '/registration/guests/' + (guest.id | string) + '/attendance/' + action) }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><input type="hidden" name="expected_version" value="{{ attendance.version or 0 }}"><button class="govuk-button govuk-button--secondary" data-module="govuk-button" type="submit">{{ t("event_registration.guests." + action) }}</button></form>{% endfor %}</div>{% endif %}</div>
{% else %}<p class="govuk-body">{{ t("event_registration.guests.empty") }}</p>{% endfor %}
{% set guestPagination = registrationPagination.guests or {} %}
{% if guestPagination.previousHref or guestPagination.nextHref %}
<nav class="govuk-pagination" aria-label="{{ t('event_registration.guests.title') }}">
{% if guestPagination.previousHref %}<div class="govuk-pagination__prev"><a class="govuk-link govuk-pagination__link" rel="prev" href="{{ urlFor(guestPagination.previousHref) }}">{{ t("event_registration.common.previous") }}</a></div>{% endif %}
{% if guestPagination.nextHref %}<div class="govuk-pagination__next"><a class="govuk-link govuk-pagination__link" rel="next" href="{{ urlFor(guestPagination.nextHref) }}">{{ t("event_registration.common.next") }}</a></div>{% endif %}
</nav>
{% endif %}

{% if organizer.permissions and organizer.permissions.manage_retention %}
<h3 class="govuk-heading-m govuk-!-margin-top-7">{{ t("event_registration.retention.title") }}</h3>
<div class="govuk-warning-text"><span class="govuk-warning-text__icon" aria-hidden="true">!</span><strong class="govuk-warning-text__text"><span class="govuk-visually-hidden">{{ t("govuk_alpha_events.common.warning") }}</span>{{ t("event_registration.retention.warning_description") }}</strong></div>
<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/registration/retention/preview') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><label class="govuk-label" for="retention-as-of">{{ t("event_registration.retention.as_of") }}</label><div class="govuk-hint">{{ t("event_registration.accessible.retention_as_of_hint") }}</div><input class="govuk-input govuk-input--width-20" id="retention-as-of" name="as_of" type="date" required><button class="govuk-button govuk-button--secondary govuk-!-margin-top-3" data-module="govuk-button" type="submit">{{ t("event_registration.retention.preview") }}</button></form>
{% if retentionRun %}<p class="govuk-body">{{ t("event_registration.retention.eligible") }}: {{ retentionRun.eligible_count }}</p><form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/registration/retention/' + (retentionRun.id | string) + '/apply') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><div class="govuk-checkboxes govuk-!-margin-bottom-4" data-module="govuk-checkboxes"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="retention-apply-confirm" name="confirm_destructive" type="checkbox" value="1" required><label class="govuk-label govuk-checkboxes__label" for="retention-apply-confirm">{{ t("event_registration.retention.confirm_apply") }}</label></div></div><button class="govuk-button govuk-button--warning" data-module="govuk-button" type="submit">{{ t("event_registration.retention.apply") }}</button></form>{% endif %}
{% endif %}
