{% extends "layouts/base.njk" %}
{% block content %}
<a class="govuk-back-link" href="{{ urlFor('/events/' + (eventId | string)) }}">{{ t("govuk_alpha_events.analytics.back_to_event") }}</a><span class="govuk-caption-l">{{ summary.event_title }}</span><h1 class="govuk-heading-xl">{{ t("govuk_alpha_events.analytics.title") }}</h1><p class="govuk-body-l">{{ t("govuk_alpha_events.analytics.intro") }}</p><p class="govuk-body-s">{{ t("govuk_alpha_events.analytics.generated_at", { date: summary.generated_at }) }}</p><div class="govuk-inset-text"><strong>{{ t("govuk_alpha_events.analytics.privacy_title") }}</strong><br>{{ t("govuk_alpha_events.analytics.privacy_note", { count: summary.privacy_threshold }) }}</div><a class="govuk-button govuk-button--secondary" href="{{ urlFor('/events/' + (eventId | string) + '/analytics/export.csv') }}">{{ t("govuk_alpha_events.analytics.export") }}</a>
{% for section, rows in sections %}<h2 class="govuk-heading-l">{{ t("govuk_alpha_events.analytics.sections." + section) }}</h2><table class="govuk-table"><caption class="govuk-table__caption govuk-visually-hidden">{{ t("govuk_alpha_events.analytics.sections." + section) }}</caption><thead><tr><th class="govuk-table__header" scope="col">{{ t("govuk_alpha_events.analytics.columns.metric") }}</th><th class="govuk-table__header govuk-table__header--numeric" scope="col">{{ t("govuk_alpha_events.analytics.columns.value") }}</th></tr></thead><tbody>{% for row in rows %}<tr><th class="govuk-table__header" scope="row">{{ t("govuk_alpha_events.analytics.metrics." + row[0]) }}</th><td class="govuk-table__cell govuk-table__cell--numeric">{% if row[1] == "suppressed" %}{{ t("govuk_alpha_events.analytics.suppressed") }}{% elif row[1] == "not_limited" %}{{ t("govuk_alpha_events.analytics.not_limited") }}{% elif row[1] == "finance_redacted" %}{{ t("govuk_alpha_events.analytics.finance_redacted") }}{% else %}{{ row[1] }}{% endif %}</td></tr>{% endfor %}</tbody></table>{% endfor %}
{% endblock %}
