{% extends "layouts/base.njk" %}
{% block content %}
  <a class="govuk-back-link" href="{{ urlFor('/events/' + (event.id | string)) }}">{{ t("govuk_alpha_events.reminders.back") }}</a>
  {% if status == "saved" or status == "reset" %}<div class="govuk-notification-banner govuk-notification-banner--success" role="alert"><div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">{{ t("govuk_alpha_events.common.success_title") }}</h2></div><div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ t("govuk_alpha_events.reminders.saved" if status == "saved" else "govuk_alpha_events.reminders.reset_success") }}</p></div></div>{% elif status == "conflict" %}<div class="govuk-notification-banner" role="alert"><div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">{{ t("govuk_alpha_events.common.warning") }}</h2></div><div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ t("govuk_alpha_events.reminders.conflict") }}</p></div></div>{% elif status == "invalid" or status == "failed" %}<div class="govuk-error-summary" role="alert" tabindex="-1"><h2 class="govuk-error-summary__title">{{ t("govuk_alpha_events.common.error_title") }}</h2><div class="govuk-error-summary__body"><p>{{ t("govuk_alpha_events.reminders.validation_error" if status == "invalid" else "govuk_alpha_events.reminders.save_error") }}</p></div></div>{% endif %}
  <span class="govuk-caption-l">{{ event.title }}</span><h1 class="govuk-heading-xl">{{ t("govuk_alpha_events.reminders.title") }}</h1><p class="govuk-body-l">{{ t("govuk_alpha_events.reminders.intro") }}</p><p class="govuk-body">{{ t("govuk_alpha_events.reminders.resolved", { source: t("govuk_alpha_events.reminders.source_" + source) }) }}</p>
  <form id="event-reminders-form" method="post" action="{{ urlFor('/events/' + (event.id | string) + '/reminders') }}" novalidate><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="expected_revision" value="{{ preferences.revision or 0 }}">
    <div class="govuk-checkboxes govuk-!-margin-bottom-6"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="reminders-enabled" name="reminders_enabled" type="checkbox" value="1"{% if enabled %} checked{% endif %}><label class="govuk-label govuk-checkboxes__label" for="reminders-enabled">{{ t("govuk_alpha_events.reminders.enabled") }}</label><div class="govuk-hint govuk-checkboxes__hint">{{ t("govuk_alpha_events.reminders.enabled_hint") }}</div></div></div>
    <fieldset class="govuk-fieldset govuk-!-margin-bottom-6"><legend class="govuk-fieldset__legend govuk-fieldset__legend--m">{{ t("govuk_alpha_events.reminders.timing") }}</legend><div class="govuk-hint">{{ t("govuk_alpha_events.reminders.timing_hint") }}</div><div class="govuk-checkboxes">{% for offset in [10080, 1440, 60] %}<div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="offset-{{ offset }}" name="offsets[]" type="checkbox" value="{{ offset }}"{% if offset in selectedOffsets %} checked{% endif %}><label class="govuk-label govuk-checkboxes__label" for="offset-{{ offset }}">{{ t("govuk_alpha_events.reminders.offset_" + offset) }}</label></div>{% endfor %}{% for offset in selectedOffsets %}{% if offset != 10080 and offset != 1440 and offset != 60 %}<div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="offset-{{ offset }}" name="offsets[]" type="checkbox" value="{{ offset }}" checked><label class="govuk-label govuk-checkboxes__label" for="offset-{{ offset }}">{{ t("govuk_alpha_events.reminders.custom_value", { count: offset }) }}</label></div>{% endif %}{% endfor %}</div><div class="govuk-form-group govuk-!-margin-top-4"><label class="govuk-label" for="custom-offset">{{ t("govuk_alpha_events.reminders.custom_label") }}</label><div class="govuk-hint" id="custom-offset-hint">{{ t("govuk_alpha_events.reminders.custom_hint", { min: limits.minimum, max: limits.maximum }) }}</div><input class="govuk-input govuk-input--width-10" id="custom-offset" name="custom_offset" type="number" min="{{ limits.minimum }}" max="{{ limits.maximum }}" aria-describedby="custom-offset-hint"></div></fieldset>
    <fieldset class="govuk-fieldset govuk-!-margin-bottom-6"><legend class="govuk-fieldset__legend govuk-fieldset__legend--m">{{ t("govuk_alpha_events.reminders.channels") }}</legend><div class="govuk-hint">{{ t("govuk_alpha_events.reminders.channels_hint") }}</div><div class="govuk-checkboxes">{% for channel in ["email", "in_app", "web_push", "fcm", "realtime"] %}<div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="channel-{{ channel }}" name="channel_{{ channel }}" type="checkbox" value="1"{% if channels[channel] %} checked{% endif %}><label class="govuk-label govuk-checkboxes__label" for="channel-{{ channel }}">{{ t("govuk_alpha_events.reminders.channel_" + channel) }}</label></div>{% endfor %}</div></fieldset>
    <button class="govuk-button">{{ t("govuk_alpha_events.reminders.save") }}</button>
  </form>
  <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible"><h2 class="govuk-heading-m">{{ t("govuk_alpha_events.reminders.reset_title") }}</h2><p class="govuk-body">{{ t("govuk_alpha_events.reminders.reset_hint") }}</p><form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/reminders/reset') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="expected_revision" value="{{ preferences.revision or 0 }}"><button class="govuk-button govuk-button--secondary">{{ t("govuk_alpha_events.reminders.reset") }}</button></form>
{% endblock %}
