{% extends "layouts/base.njk" %}
{% block content %}
<a class="govuk-back-link" href="{{ urlFor('/events/' + (event.id | string)) }}">{{ t("event_tickets.back_to_event") }}</a>
{% if status == "allocated" or status == "cancelled" %}<div class="govuk-notification-banner govuk-notification-banner--success" role="alert"><div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">{{ t("govuk_alpha_events.common.success_title") }}</h2></div><div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ t("event_tickets." + status) }}</p></div></div>{% elif status %}<div class="govuk-error-summary" role="alert" tabindex="-1"><h2 class="govuk-error-summary__title">{{ t("govuk_alpha_events.common.error_title") }}</h2><div class="govuk-error-summary__body"><p>{{ t("event_tickets.validation_error" if status == "invalid" else "event_tickets.allocate_error") }}</p></div></div>{% endif %}
<span class="govuk-caption-l">{{ event.title }}</span><h1 class="govuk-heading-xl">{{ t("event_tickets.title") }}</h1><p class="govuk-body-l">{{ t("event_tickets.intro") }}</p><div class="govuk-warning-text"><span class="govuk-warning-text__icon" aria-hidden="true">!</span><strong class="govuk-warning-text__text"><span class="govuk-visually-hidden">{{ t("govuk_alpha_events.common.warning") }}:</span>{{ t("event_tickets.gateway_disabled") }}</strong></div>
<h2 class="govuk-heading-l">{{ t("event_tickets.my_tickets") }}</h2>{% if not catalogue.own_entitlements.length %}<p class="govuk-body">{{ t("event_tickets.no_tickets") }}</p>{% endif %}
{% for entitlement in catalogue.own_entitlements %}<section class="govuk-!-margin-bottom-7"><h3 class="govuk-heading-m">{{ ticketNames[entitlement.ticket_type_id].name or t("event_tickets.ticket_fallback") }}</h3><dl class="govuk-summary-list"><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("event_tickets.units") }}</dt><dd class="govuk-summary-list__value">{{ entitlement.units }}</dd></div><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("event_tickets.status_label") }}</dt><dd class="govuk-summary-list__value">{{ t("event_tickets.status." + entitlement.status) }}</dd></div></dl>{% if entitlement.status == "confirmed" and entitlement.kind == "free" %}<a class="govuk-button govuk-button--warning" href="{{ urlFor('/events/' + (event.id | string) + '/tickets/entitlements/' + (entitlement.id | string) + '/cancel') }}">{{ t("event_tickets.cancel_ticket") }}</a>{% elif entitlement.status == "confirmed" %}<p class="govuk-body">{{ t("event_tickets.time_credit_cancel_disabled") }}</p>{% endif %}</section>{% endfor %}
<h2 class="govuk-heading-l">{{ t("event_tickets.catalogue") }}</h2>{% if not catalogue.ticket_types.length %}<p class="govuk-body">{{ t("event_tickets.catalogue_empty") }}</p>{% endif %}
{% for ticket in catalogue.ticket_types %}{% set availability = ticket.availability %}{% set maximum = availability.allocation_remaining if availability.allocation_remaining < availability.member_remaining else availability.member_remaining %}{% set canAllocate = catalogue.permissions.allocate_self and ticket.kind == "free" and ticket.status == "active" and availability.eligibility.eligible and availability.sales_window_open and availability.materialization_supported and maximum > 0 %}<section class="govuk-!-margin-bottom-8"><h3 class="govuk-heading-m">{{ ticket.name }}</h3>{% if ticket.description %}<p class="govuk-body">{{ ticket.description }}</p>{% endif %}<p class="govuk-body-s"><strong class="govuk-tag">{{ t("event_tickets.kind." + ticket.kind) }}</strong></p><dl class="govuk-summary-list govuk-summary-list--no-border"><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("event_tickets.remaining") }}</dt><dd class="govuk-summary-list__value">{{ availability.allocation_remaining }}</dd></div><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("event_tickets.member_limit") }}</dt><dd class="govuk-summary-list__value">{{ ticket.per_member_limit }}</dd></div></dl>
{% if ticket.kind == "time_credit" %}<div class="govuk-inset-text">{{ t("event_tickets.time_credit_disabled", { credits: ticket.unit_price_credits }) }}</div>{% elif canAllocate %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/tickets/' + (ticket.id | string) + '/allocate') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><label class="govuk-label" for="ticket-units-{{ ticket.id }}">{{ t("event_tickets.units_to_claim") }}</label><div class="govuk-hint">{{ t("event_tickets.units_hint", { count: maximum }) }}</div><input class="govuk-input govuk-input--width-3" id="ticket-units-{{ ticket.id }}" name="units" type="number" min="1" max="{{ maximum }}" value="1" required><button class="govuk-button">{{ t("event_tickets.claim_free") }}</button></form>{% elif not catalogue.permissions.allocate_self %}<p class="govuk-body">{{ t("event_tickets.registration_required") }}</p>{% elif not availability.eligibility.eligible %}<p class="govuk-body">{{ t("event_tickets.not_eligible") }}</p>{% elif not availability.sales_window_open %}<p class="govuk-body">{{ t("event_tickets.sales_closed") }}</p>{% else %}<p class="govuk-body">{{ t("event_tickets.sold_out") }}</p>{% endif %}</section>{% endfor %}
{% endblock %}
