{% extends "layouts/base.njk" %}{% block content %}<a class="govuk-back-link" href="{{ urlFor('/events/' + (event.id | string) + '/recurring-edit') }}">{{ t("govuk_alpha_events.recurring_edit.back_to_edit") }}</a><span class="govuk-caption-xl">{{ event.title }}</span><h1 class="govuk-heading-xl">{{ t("govuk_alpha_events.recurring_edit.preview_title") }}</h1><p class="govuk-body-l">{{ t("govuk_alpha_events.recurring_edit.preview_intro") }}</p><div class="govuk-warning-text"><span class="govuk-warning-text__icon" aria-hidden="true">!</span><strong class="govuk-warning-text__text"><span class="govuk-visually-hidden">{{ t("govuk_alpha_events.common.warning") }}</span>{{ t("govuk_alpha_events.recurring_edit.scope_all_warning") }}</strong></div><dl class="govuk-summary-list"><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_events.recurring_edit.affected_count") }}</dt><dd class="govuk-summary-list__value">{{ preview.impact.affected_count or preview.impact.occurrence_count or 0 }}</dd></div><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_events.recurring_edit.effective_from") }}</dt><dd class="govuk-summary-list__value">{{ preview.effective_from_utc }}</dd></div></dl>{% if preview.can_commit %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/recurring-edit/commit') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="preview_token" value="{{ preview.preview_token }}"><input type="hidden" name="patch_json" value="{{ patchJson }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><button class="govuk-button">{{ t("govuk_alpha_events.recurring_edit.commit_button") }}</button></form>{% else %}<div class="govuk-error-summary" role="alert" tabindex="-1"><h2 class="govuk-error-summary__title">{{ t("govuk_alpha_events.common.error_title") }}</h2><p>{{ t("govuk_alpha_events.recurring_edit.commit_blocked") }}</p></div>{% endif %}{% endblock %}
