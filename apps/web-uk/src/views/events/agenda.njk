{% extends "layouts/base.njk" %}
{% from "events/agenda-fields.njk" import agendaFields with context %}

{% block content %}
  <a class="govuk-back-link" href="{{ urlFor('/events/' + (event.id | string)) }}">{{ t("govuk_alpha.events.agenda.back_to_event") }}</a>
  {% set messages = { "agenda-created": "govuk_alpha.events.agenda.created", "agenda-updated": "govuk_alpha.events.agenda.updated", "agenda-cancelled": "govuk_alpha.events.agenda.cancelled_success", "agenda-reordered": "govuk_alpha.events.agenda.reordered", "agenda-session-registered": "event_agenda.registered_success", "agenda-session-withdrawn": "event_agenda.withdrawn_success" } %}
  {% if status == "agenda-failed" %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1"><div role="alert"><h2 class="govuk-error-summary__title">{{ t("govuk_alpha.states.error_title") }}</h2><div class="govuk-error-summary__body"><p>{{ t("govuk_alpha.events.agenda.save_error") }}</p></div></div></div>
  {% elif messages[status] %}
    <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert"><div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">{{ t("govuk_alpha.states.success_title") }}</h2></div><div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ t(messages[status]) }}</p></div></div>
  {% endif %}

  <span class="govuk-caption-l">{{ event.title }}</span>
  <h1 class="govuk-heading-xl">{{ t("govuk_alpha.events.agenda.title") }}</h1>
  <p class="govuk-body-l">{{ t("govuk_alpha.events.agenda.manager_intro" if agenda.permissions.manage else "govuk_alpha.events.agenda.viewer_intro") }}</p>

  {% if agenda.permissions.manage %}
    <details class="govuk-details" data-module="govuk-details">
      <summary class="govuk-details__summary"><span class="govuk-details__summary-text">{{ t("govuk_alpha.events.agenda.add_session") }}</span></summary>
      <div class="govuk-details__text"><form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/agenda') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="action" value="create"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}">{{ agendaFields("agenda-create", createSessionDefaults, agenda.timezone) }}<button class="govuk-button" data-module="govuk-button">{{ t("govuk_alpha.events.agenda.create_session") }}</button></form></div>
    </details>
  {% endif %}

  <h2 class="govuk-heading-l">{{ t("govuk_alpha.events.agenda.running_order") }}</h2>
  {% if not scheduledSessions.length %}
    <p class="govuk-body">{{ t("govuk_alpha.events.agenda.empty_manager" if agenda.permissions.manage else "govuk_alpha.events.agenda.empty_viewer") }}</p>
  {% else %}
    <ol class="govuk-list govuk-list--number">
      {% for session in scheduledSessions %}
        <li class="govuk-!-margin-bottom-6">
          <h3 class="govuk-heading-m govuk-!-margin-bottom-2">{{ session.title }}</h3>
          <p class="govuk-body-s govuk-!-margin-bottom-2"><strong class="govuk-tag">{{ t("govuk_alpha.events.agenda.types." + session.type) }}</strong> <strong class="govuk-tag govuk-tag--grey">{{ t("govuk_alpha.events.agenda.visibilities." + session.visibility) }}</strong></p>
          <dl class="govuk-summary-list govuk-summary-list--no-border">
            <div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha.events.agenda.when") }}</dt><dd class="govuk-summary-list__value">{{ session.startLabel }} – {{ session.endLabel }}</dd></div>
            {% if session.track %}<div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha.events.agenda.fields.track") }}</dt><dd class="govuk-summary-list__value">{{ session.track }}</dd></div>{% endif %}
            {% if session.room %}<div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha.events.agenda.fields.room") }}</dt><dd class="govuk-summary-list__value">{{ session.room }}</dd></div>{% endif %}
            <div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("event_agenda.capacity_label") }}</dt><dd class="govuk-summary-list__value">{% if session.capacity.limit == null %}{{ t("event_agenda.capacity_unlimited", { registered: session.capacity.registered }) }}{% else %}{{ t("event_agenda.capacity_limited", { registered: session.capacity.registered, limit: session.capacity.limit }) }}{% endif %}</dd></div>
            {% if session.speakers.length %}<div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha.events.agenda.fields.speakers") }}</dt><dd class="govuk-summary-list__value"><ul class="govuk-list govuk-list--bullet">{% for speaker in session.speakers %}<li>{{ speaker.display_name }}{% if speaker.role %}, {{ speaker.role }}{% endif %}</li>{% endfor %}</ul></dd></div>{% endif %}
          </dl>

          {% if session.description %}<p class="govuk-body">{{ session.description }}</p>{% endif %}
          {% if session.resources.length %}
            <h4 class="govuk-heading-s">{{ t("event_agenda.resources_title") }}</h4>
            <ul class="govuk-list govuk-list--bullet">{% for resource in session.resources %}<li><strong>{{ t("event_agenda.resource_types." + resource.type) }}:</strong> {% if resource.url %}<a class="govuk-link" href="{{ resource.url }}" target="_blank" rel="noopener noreferrer">{{ resource.title }}</a> <span class="govuk-visually-hidden">{{ t("event_agenda.opens_new_window") }}</span>{% else %}{{ resource.title }} — {{ t("event_agenda.resource_unavailable") }}{% endif %}</li>{% endfor %}</ul>
          {% endif %}

          {% if session.registration.can_register %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/agenda') }}" class="govuk-!-margin-bottom-4"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="action" value="register"><input type="hidden" name="session_id" value="{{ session.id }}"><input type="hidden" name="expected_version" value="{{ session.registration.version }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><button class="govuk-button" data-module="govuk-button">{{ t("event_agenda.register_action") }}</button></form>{% endif %}
          {% if session.registration.can_withdraw %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/agenda') }}" class="govuk-!-margin-bottom-4"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="action" value="withdraw"><input type="hidden" name="session_id" value="{{ session.id }}"><input type="hidden" name="expected_version" value="{{ session.registration.version }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><div class="govuk-checkboxes govuk-!-margin-bottom-4"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="agenda-session-{{ session.id }}-confirm-withdraw" name="confirm_destructive" value="1" type="checkbox" required><label class="govuk-label govuk-checkboxes__label" for="agenda-session-{{ session.id }}-confirm-withdraw">{{ t("event_agenda.withdraw_confirmation", { title: session.title }) }}</label></div></div><button class="govuk-button govuk-button--secondary" data-module="govuk-button">{{ t("event_agenda.withdraw_action") }}</button></form>{% endif %}
          {% if session.registration.state == "registered" %}<p class="govuk-body"><strong>{{ t("event_agenda.registered_state") }}</strong></p>{% elif session.registration.state == "ineligible" %}<p class="govuk-body">{{ t("event_agenda.ineligible_state") }}</p>{% elif not session.registration.can_register and not session.registration.can_withdraw and session.capacity.is_full %}<p class="govuk-body">{{ t("event_agenda.full_state") }}</p>{% endif %}

          {% if agenda.permissions.manage %}
            <div class="govuk-button-group">
              {% if not loop.first %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/agenda') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="action" value="move_up"><input type="hidden" name="session_id" value="{{ session.id }}"><input type="hidden" name="expected_agenda_version" value="{{ agenda.agenda_version }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}">{% for ordered in scheduledSessions %}<input type="hidden" name="ordered_session_ids[]" value="{{ ordered.id }}">{% endfor %}<button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("govuk_alpha.events.agenda.move_up", { title: session.title }) }}</button></form>{% endif %}
              {% if not loop.last %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/agenda') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="action" value="move_down"><input type="hidden" name="session_id" value="{{ session.id }}"><input type="hidden" name="expected_agenda_version" value="{{ agenda.agenda_version }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}">{% for ordered in scheduledSessions %}<input type="hidden" name="ordered_session_ids[]" value="{{ ordered.id }}">{% endfor %}<button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("govuk_alpha.events.agenda.move_down", { title: session.title }) }}</button></form>{% endif %}
            </div>
            <details class="govuk-details" data-module="govuk-details"><summary class="govuk-details__summary"><span class="govuk-details__summary-text">{{ t("govuk_alpha.events.agenda.edit_session", { title: session.title }) }}</span></summary><div class="govuk-details__text"><form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/agenda') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="action" value="update"><input type="hidden" name="session_id" value="{{ session.id }}"><input type="hidden" name="expected_version" value="{{ session.version }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}">{{ agendaFields("agenda-session-" + session.id, session, agenda.timezone) }}<button class="govuk-button" data-module="govuk-button">{{ t("govuk_alpha.events.agenda.save_changes") }}</button></form></div></details>
            <details class="govuk-details" data-module="govuk-details"><summary class="govuk-details__summary"><span class="govuk-details__summary-text">{{ t("govuk_alpha.events.agenda.cancel_session", { title: session.title }) }}</span></summary><div class="govuk-details__text"><form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/agenda') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="action" value="cancel"><input type="hidden" name="session_id" value="{{ session.id }}"><input type="hidden" name="expected_version" value="{{ session.version }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><div class="govuk-form-group"><label class="govuk-label" for="agenda-session-{{ session.id }}-cancel-reason">{{ t("govuk_alpha.events.agenda.cancellation_reason") }}</label><textarea class="govuk-textarea" id="agenda-session-{{ session.id }}-cancel-reason" name="reason" rows="3" maxlength="500" required></textarea></div><button class="govuk-button govuk-button--warning" data-module="govuk-button">{{ t("govuk_alpha.events.agenda.confirm_cancel") }}</button></form></div></details>
          {% endif %}
        </li>
      {% endfor %}
    </ol>
  {% endif %}

  {% if agenda.permissions.manage and cancelledSessions.length %}<h2 class="govuk-heading-l">{{ t("govuk_alpha.events.agenda.cancelled_sessions") }}</h2><ul class="govuk-list govuk-list--bullet">{% for session in cancelledSessions %}<li><strong>{{ session.title }}</strong>{% if session.cancellation_reason %} — {{ t("govuk_alpha.events.agenda.cancelled_reason", { reason: session.cancellation_reason }) }}{% endif %}</li>{% endfor %}</ul>{% endif %}
{% endblock %}
