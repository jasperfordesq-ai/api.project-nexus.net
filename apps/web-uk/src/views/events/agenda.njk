{% extends "layouts/base.njk" %}
{% from "events/agenda-fields.njk" import agendaFields with context %}
{% block content %}
  <a class="govuk-back-link" href="{{ urlFor('/events/' + (event.id | string)) }}">{{ t("govuk_alpha.events.agenda.back_to_event") }}</a>
  {% set messages = { "agenda-created": "govuk_alpha.events.agenda.created", "agenda-updated": "govuk_alpha.events.agenda.updated", "agenda-cancelled": "govuk_alpha.events.agenda.cancelled_success", "agenda-reordered": "govuk_alpha.events.agenda.reordered", "agenda-session-registered": "event_agenda.registered_success", "agenda-session-withdrawn": "event_agenda.withdrawn_success" } %}
  {% if messages[status] %}<div class="govuk-notification-banner govuk-notification-banner--success" role="alert"><div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">{{ t("govuk_alpha.states.success_title") }}</h2></div><div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ t(messages[status]) }}</p></div></div>{% elif status == "agenda-failed" %}<div class="govuk-error-summary" role="alert" tabindex="-1"><h2 class="govuk-error-summary__title">{{ t("govuk_alpha.states.error_title") }}</h2></div>{% endif %}
  <span class="govuk-caption-l">{{ event.title }}</span><h1 class="govuk-heading-xl">{{ t("govuk_alpha.events.agenda.title") }}</h1><p class="govuk-body-l">{{ t("govuk_alpha.events.agenda.manager_intro" if agenda.permissions.manage else "govuk_alpha.events.agenda.viewer_intro") }}</p>
  {% if agenda.permissions.manage %}<details class="govuk-details"><summary class="govuk-details__summary"><span class="govuk-details__summary-text">{{ t("govuk_alpha.events.agenda.add_session") }}</span></summary><div class="govuk-details__text"><form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/agenda') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="action" value="create"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}">{{ agendaFields("agenda-create", {}, agenda.timezone or "UTC") }}<button class="govuk-button">{{ t("govuk_alpha.events.agenda.create_session") }}</button></form></div></details>{% endif %}
  <h2 class="govuk-heading-l">{{ t("govuk_alpha.events.agenda.running_order") }}</h2>{% if not scheduledSessions.length %}<p class="govuk-body">{{ t("govuk_alpha.events.agenda.empty_manager" if agenda.permissions.manage else "govuk_alpha.events.agenda.empty_viewer") }}</p>{% endif %}
  <ol class="govuk-list govuk-list--number">{% for session in scheduledSessions %}<li class="govuk-!-margin-bottom-6"><h3 class="govuk-heading-m">{{ session.title }}</h3><p><strong class="govuk-tag">{{ t("govuk_alpha.events.agenda.types." + session.type) }}</strong> <strong class="govuk-tag govuk-tag--grey">{{ t("govuk_alpha.events.agenda.visibilities." + session.visibility) }}</strong></p><p class="govuk-body">{{ formatLocaleDate(session.start_at) }} – {{ formatLocaleDate(session.end_at) }}</p>{% if session.description %}<p class="govuk-body">{{ session.description }}</p>{% endif %}{% if session.capacity.limit %}<p class="govuk-body">{{ t("event_agenda.capacity_limited", { registered: session.capacity.registered, limit: session.capacity.limit }) }}</p>{% else %}<p class="govuk-body">{{ t("event_agenda.capacity_unlimited", { registered: session.capacity.registered }) }}</p>{% endif %}
  {% if session.registration.can_register %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/agenda') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="action" value="register"><input type="hidden" name="session_id" value="{{ session.id }}"><input type="hidden" name="expected_version" value="{{ session.registration.version }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><button class="govuk-button">{{ t("event_agenda.register_action") }}</button></form>{% endif %}{% if session.registration.can_withdraw %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/agenda') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="action" value="withdraw"><input type="hidden" name="session_id" value="{{ session.id }}"><input type="hidden" name="expected_version" value="{{ session.registration.version }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><div class="govuk-checkboxes"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="withdraw-{{ session.id }}" name="confirm_destructive" value="1" type="checkbox" required><label class="govuk-label govuk-checkboxes__label" for="withdraw-{{ session.id }}">{{ t("event_agenda.withdraw_confirmation", { title: session.title }) }}</label></div></div><button class="govuk-button govuk-button--secondary">{{ t("event_agenda.withdraw_action") }}</button></form>{% endif %}
  {% if agenda.permissions.manage %}<div class="govuk-button-group">{% for action in ["move_up", "move_down"] %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/agenda') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="action" value="{{ action }}"><input type="hidden" name="session_id" value="{{ session.id }}"><input type="hidden" name="expected_agenda_version" value="{{ agenda.agenda_version }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}">{% for ordered in scheduledSessions %}<input type="hidden" name="ordered_session_ids[]" value="{{ ordered.id }}">{% endfor %}<button class="govuk-button govuk-button--secondary">{{ t("govuk_alpha.events.agenda." + action, { title: session.title }) }}</button></form>{% endfor %}</div><details class="govuk-details"><summary class="govuk-details__summary">{{ t("govuk_alpha.events.agenda.edit_session", { title: session.title }) }}</summary><div class="govuk-details__text"><form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/agenda') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="action" value="update"><input type="hidden" name="session_id" value="{{ session.id }}"><input type="hidden" name="expected_version" value="{{ session.version }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}">{{ agendaFields("session-" + session.id, session, agenda.timezone or "UTC") }}<button class="govuk-button">{{ t("govuk_alpha.events.agenda.save_changes") }}</button></form></div></details><form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/agenda') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="action" value="cancel"><input type="hidden" name="session_id" value="{{ session.id }}"><input type="hidden" name="expected_version" value="{{ session.version }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><label class="govuk-label" for="cancel-{{ session.id }}">{{ t("govuk_alpha.events.agenda.cancellation_reason") }}</label><textarea class="govuk-textarea" id="cancel-{{ session.id }}" name="reason" maxlength="500" required></textarea><button class="govuk-button govuk-button--warning">{{ t("govuk_alpha.events.agenda.confirm_cancel") }}</button></form>{% endif %}</li>{% endfor %}</ol>
  {% if agenda.permissions.manage and cancelledSessions.length %}<h2 class="govuk-heading-l">{{ t("govuk_alpha.events.agenda.cancelled_sessions") }}</h2><ul class="govuk-list govuk-list--bullet">{% for session in cancelledSessions %}<li><strong>{{ session.title }}</strong>{% if session.cancellation_reason %} — {{ t("govuk_alpha.events.agenda.cancelled_reason", { reason: session.cancellation_reason }) }}{% endif %}</li>{% endfor %}</ul>{% endif %}
{% endblock %}
