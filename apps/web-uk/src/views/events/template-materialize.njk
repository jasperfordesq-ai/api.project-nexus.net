{% extends "layouts/base.njk" %}{% set fields = values.overrides %}{% block content %}<a class="govuk-back-link" href="{{ urlFor('/events/templates') }}">{{ t("event_templates.back_to_library") }}</a><span class="govuk-caption-xl">{{ template.source_event.title }}</span><h1 class="govuk-heading-xl">{{ t("event_templates.materialize_title") }}</h1><p class="govuk-body-l">{{ t("event_templates.materialize_description") }}</p><form method="post" action="{{ urlFor('/event-templates/' + (template.id | string) + '/materialize/preview') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="template_version" value="{{ values.template_version }}"><label class="govuk-label" for="template-title">{{ t("event_templates.fields.title") }}</label><input class="govuk-input" id="template-title" name="title" maxlength="255" value="{{ fields.title }}" required><label class="govuk-label" for="template-start">{{ t("event_templates.start_time") }}</label><input class="govuk-input" id="template-start" name="start_time" type="datetime-local" value="{{ values.start_time }}" required><label class="govuk-label" for="template-end">{{ t("event_templates.end_time") }}</label><input class="govuk-input" id="template-end" name="end_time" type="datetime-local" value="{{ values.end_time or '' }}"><label class="govuk-label" for="template-location">{{ t("event_templates.fields.location") }}</label><input class="govuk-input" id="template-location" name="location" value="{{ fields.location or '' }}"><label class="govuk-label" for="template-capacity">{{ t("event_templates.fields.max_attendees") }}</label><input class="govuk-input govuk-input--width-5" id="template-capacity" name="max_attendees" type="number" min="1" value="{{ fields.max_attendees or '' }}"><label class="govuk-label" for="template-timezone">{{ t("event_templates.fields.timezone") }}</label><input class="govuk-input" id="template-timezone" name="timezone" maxlength="64" value="{{ fields.timezone or 'UTC' }}" required><div class="govuk-checkboxes"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="template-all-day" name="all_day" type="checkbox" value="1"{% if fields.all_day %} checked{% endif %}><label class="govuk-label govuk-checkboxes__label" for="template-all-day">{{ t("event_templates.fields.all_day") }}</label></div></div><button class="govuk-button">{{ t("event_templates.preview_materialization") }}</button></form>{% if preview %}<h2 class="govuk-heading-l">{{ t("event_templates.materialization_preview_title") }}</h2><div class="govuk-inset-text">{{ t("event_templates.draft_only_notice") }}</div><form method="post" action="{{ urlFor('/event-templates/' + (template.id | string) + '/materialize') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}"><input type="hidden" name="template_version" value="{{ values.template_version }}"><input type="hidden" name="title" value="{{ fields.title }}"><input type="hidden" name="start_time" value="{{ values.start_time }}"><input type="hidden" name="end_time" value="{{ values.end_time or '' }}"><input type="hidden" name="location" value="{{ fields.location or '' }}"><input type="hidden" name="max_attendees" value="{{ fields.max_attendees or '' }}"><input type="hidden" name="timezone" value="{{ fields.timezone }}">{% if fields.all_day %}<input type="hidden" name="all_day" value="1">{% endif %}<button class="govuk-button">{{ t("event_templates.create_draft") }}</button></form>{% endif %}{% endblock %}
