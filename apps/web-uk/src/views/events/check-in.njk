{% extends "layouts/base.njk" %}
{% block content %}
  <a class="govuk-back-link" href="{{ urlFor('/events/' + (event.id | string)) }}">{{ t("govuk_alpha.events.back_to_event") }}</a>
  <span class="govuk-caption-l">{{ event.title }}</span>
  <h1 class="govuk-heading-xl">{{ t("govuk_alpha.events.check_in_title") }}</h1>
  <p class="govuk-body-l">{{ t("govuk_alpha.events.check_in_intro") }}</p>
  {% if status == "attendance-updated" %}<div class="govuk-notification-banner govuk-notification-banner--success" role="alert"><div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">{{ t("govuk_alpha.states.success_title") }}</h2></div><div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ t("govuk_alpha.events.attendance_updated") }}</p></div></div>
  {% elif status == "attendance-conflict" %}<div class="govuk-notification-banner" role="alert"><div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">{{ t("govuk_alpha.states.warning_prefix") }}</h2></div><div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ t("govuk_alpha.events.attendance_conflict") }}</p></div></div>
  {% elif status == "attendance-invalid" or status == "attendance-failed" %}<div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1"><div role="alert"><h2 class="govuk-error-summary__title">{{ t("govuk_alpha.states.error_title") }}</h2><div class="govuk-error-summary__body"><p>{{ t("govuk_alpha.events.attendance_failed") }}</p></div></div></div>{% endif %}
  <h2 class="govuk-heading-m">{{ t("govuk_alpha.events.check_in_metrics_title") }}</h2>
  <dl class="govuk-summary-list">{% for metric in ["confirmed", "checked_in", "checked_out", "no_show", "attended"] %}<div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha.events.people_metrics." + metric) }}</dt><dd class="govuk-summary-list__value">{{ metrics[metric] or 0 }}</dd></div>{% endfor %}</dl>
  <form method="get" action="{{ urlFor('/events/' + (event.id | string) + '/check-in') }}" class="govuk-!-margin-bottom-7"><fieldset class="govuk-fieldset"><legend class="govuk-fieldset__legend govuk-fieldset__legend--m"><h2 class="govuk-fieldset__heading">{{ t("govuk_alpha.events.check_in_search_title") }}</h2></legend><div class="govuk-form-group"><label class="govuk-label" for="attendance-search">{{ t("govuk_alpha.events.check_in_search_label") }}</label><input class="govuk-input govuk-!-width-two-thirds" id="attendance-search" name="search" type="search" value="{{ query.search }}"></div><div class="govuk-form-group"><label class="govuk-label" for="attendance-state">{{ t("govuk_alpha.events.people_filters.attendance_state") }}</label><select class="govuk-select" id="attendance-state" name="attendance_state"><option value="">{{ t("govuk_alpha.events.people_states.all") }}</option>{% for state in attendanceStates %}<option value="{{ state }}"{% if query.attendance_state == state %} selected{% endif %}>{{ t("govuk_alpha.events.people_states." + state) }}</option>{% endfor %}</select></div><button class="govuk-button">{{ t("govuk_alpha.actions.search") }}</button></fieldset></form>
  <p class="govuk-body" aria-live="polite">{{ tc("govuk_alpha.events.check_in_result_count", total, { count: total }) }}</p>
  {% if people.length == 0 %}<div class="govuk-inset-text">{{ t("govuk_alpha.events.check_in_empty") }}</div>{% endif %}
  {% for person in people %}<section class="govuk-!-margin-bottom-6" aria-labelledby="attendee-{{ person.id }}"><h2 class="govuk-heading-m" id="attendee-{{ person.id }}">{{ person.name or t("govuk_alpha.members.unknown_member") }}</h2><dl class="govuk-summary-list"><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha.events.people_registration") }}</dt><dd class="govuk-summary-list__value">{{ t("govuk_alpha.events.people_states." + person.registrationState) }}</dd></div><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha.events.people_attendance") }}</dt><dd class="govuk-summary-list__value">{{ t("govuk_alpha.events.people_states." + person.attendanceState) }}</dd></div></dl>
    {% set actions = person.attendanceActions %}{% if not actions.check_in and not actions.check_out and not actions.no_show and not actions.undo %}<p class="govuk-body">{{ t("govuk_alpha.events.attendance_no_action") }}</p>{% else %}<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/check-in/' + (person.id | string)) }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="expected_version" value="{{ person.attendanceVersion }}"><input type="hidden" name="idempotency_key" value="{{ event.id }}-{{ person.id }}-{{ person.attendanceVersion }}"><div class="govuk-form-group"><label class="govuk-label" for="attendance-action-{{ person.id }}">{{ t("govuk_alpha.events.attendance_action_label") }}</label><select class="govuk-select" id="attendance-action-{{ person.id }}" name="action" required>{% for action in ["check_in", "check_out", "no_show", "undo"] %}{% if actions[action] %}<option value="{{ action }}">{{ t("govuk_alpha.events.attendance_actions." + action) }}</option>{% endif %}{% endfor %}</select></div>{% if actions.undo %}<div class="govuk-form-group"><label class="govuk-label" for="attendance-reason-{{ person.id }}">{{ t("govuk_alpha.events.attendance_reason_label") }}</label><div class="govuk-hint" id="attendance-reason-hint-{{ person.id }}">{{ t("govuk_alpha.events.attendance_reason_hint") }}</div><textarea class="govuk-textarea" id="attendance-reason-{{ person.id }}" name="reason" rows="2" aria-describedby="attendance-reason-hint-{{ person.id }}"></textarea></div>{% endif %}<div class="govuk-checkboxes govuk-checkboxes--small"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="attendance-confirm-{{ person.id }}" name="confirmation" type="checkbox" value="1" required><label class="govuk-label govuk-checkboxes__label" for="attendance-confirm-{{ person.id }}">{{ t("govuk_alpha.events.attendance_confirmation", { name: person.name or t('govuk_alpha.members.unknown_member') }) }}</label></div></div><button class="govuk-button govuk-!-margin-top-3">{{ t("govuk_alpha.events.attendance_apply") }}</button></form>{% endif %}
  </section>{% endfor %}
  {% if previousHref or nextHref %}<nav class="govuk-pagination" aria-label="{{ t('govuk_alpha.events.check_in_pagination') }}">{% if previousHref %}<div class="govuk-pagination__prev"><a class="govuk-link govuk-pagination__link" rel="prev" href="{{ urlFor(previousHref) }}">{{ t("govuk_alpha.events.check_in_previous") }}</a></div>{% endif %}{% if nextHref %}<div class="govuk-pagination__next"><a class="govuk-link govuk-pagination__link" rel="next" href="{{ urlFor(nextHref) }}">{{ t("govuk_alpha.events.check_in_next") }}</a></div>{% endif %}</nav>{% endif %}
{% endblock %}
