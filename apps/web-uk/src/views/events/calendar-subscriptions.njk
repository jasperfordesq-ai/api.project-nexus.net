{% extends "layouts/base.njk" %}{% block content %}<a class="govuk-back-link" href="{{ urlFor('/events') }}">{{ t("govuk_alpha.events.calendar_subscriptions_back") }}</a>{% if status == "revoked" %}<div class="govuk-notification-banner govuk-notification-banner--success" role="alert"><div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">{{ t("govuk_alpha_events.common.success_title") }}</h2></div><div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ t("govuk_alpha.events.calendar_subscription_revoked") }}</p></div></div>{% elif status == "invalid" or status == "failed" %}<div class="govuk-error-summary" role="alert" tabindex="-1"><h2 class="govuk-error-summary__title">{{ t("govuk_alpha_events.common.error_title") }}</h2><div class="govuk-error-summary__body"><p>{{ t("govuk_alpha.events.calendar_subscription_label_invalid" if status == "invalid" else "govuk_alpha.events.calendar_subscription_create_failed") }}</p></div></div>{% endif %}<h1 class="govuk-heading-xl">{{ t("govuk_alpha.events.calendar_subscriptions_title") }}</h1><p class="govuk-body-l">{{ t("govuk_alpha.events.calendar_subscriptions_intro") }}</p><div class="govuk-inset-text">{{ t("govuk_alpha.events.calendar_subscriptions_privacy") }}</div>{% if createdFeedUrl %}<div class="govuk-notification-banner govuk-notification-banner--success" role="alert"><div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">{{ t("govuk_alpha_events.common.success_title") }}</h2></div><div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ t("govuk_alpha.events.calendar_subscription_created") }}</p><p class="govuk-body">{{ t("govuk_alpha.events.calendar_subscription_copy_once") }}</p><label class="govuk-label govuk-label--s" for="created-calendar-feed-url">{{ t("govuk_alpha.events.calendar_subscription_feed_url") }}</label><textarea class="govuk-textarea" id="created-calendar-feed-url" rows="4" readonly spellcheck="false" autocomplete="off">{{ createdFeedUrl }}</textarea></div></div>{% endif %}<h2 class="govuk-heading-l">{{ t("govuk_alpha.events.calendar_subscription_create_title") }}</h2><form method="post" action="{{ urlFor('/events/calendar-subscriptions') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><label class="govuk-label govuk-label--m" for="calendar-label">{{ t("govuk_alpha.events.calendar_subscription_label") }}</label><div class="govuk-hint">{{ t("govuk_alpha.events.calendar_subscription_label_hint") }}</div><input class="govuk-input govuk-input--width-20" id="calendar-label" name="label" maxlength="100" value="{{ label }}"><button class="govuk-button">{{ t("govuk_alpha.events.calendar_subscription_create") }}</button></form><h2 class="govuk-heading-l govuk-!-margin-top-8">{{ t("govuk_alpha.events.calendar_subscriptions_existing") }}</h2>{% if not tokens.length %}<p class="govuk-body">{{ t("govuk_alpha.events.calendar_subscriptions_none") }}</p>{% endif %}{% for token in tokens %}<article class="govuk-!-margin-bottom-7"><h3 class="govuk-heading-m">{{ token.label or t("govuk_alpha.events.calendar_subscription_unnamed") }}</h3><p class="govuk-body"><code>{{ token.token_prefix }}</code></p>{% if token.active %}<a class="govuk-button govuk-button--warning" href="{{ urlFor('/events/calendar-subscriptions/' + (token.id | string) + '/revoke') }}">{{ t("govuk_alpha.events.calendar_subscription_revoke") }}</a>{% endif %}</article>{% endfor %}{% endblock %}
