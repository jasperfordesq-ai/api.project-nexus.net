{% extends "layouts/base.njk" %}{% block content %}<a class="govuk-back-link" href="{{ urlFor('/events/' + (event.id | string)) }}">{{ t("event_lifecycle_history.back_to_event") }}</a><span class="govuk-caption-xl">{{ event.title }}</span><h1 class="govuk-heading-xl">{{ t("event_lifecycle_history.title") }}</h1><p class="govuk-body-l">{{ t("event_lifecycle_history.description") }}</p><div class="govuk-inset-text">{{ t("event_lifecycle_history.immutable_explanation") }}</div>{% if not entries.length %}<h2 class="govuk-heading-m">{{ t("event_lifecycle_history.empty_title") }}</h2><p class="govuk-body">{{ t("event_lifecycle_history.empty_description") }}</p>{% else %}<ol class="govuk-list" aria-label="{{ t('event_lifecycle_history.list_label') }}">{% for entry in entries %}<li class="govuk-summary-card govuk-!-margin-bottom-6"><div class="govuk-summary-card__title-wrapper"><h2 class="govuk-summary-card__title">{{ t("event_lifecycle_history.version", { version: entry.lifecycle_version }) }}</h2><strong class="govuk-tag govuk-tag--green">{{ t("event_lifecycle_history.immutable") }}</strong></div><div class="govuk-summary-card__content"><dl class="govuk-summary-list"><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("event_lifecycle_history.recorded_at") }}</dt><dd class="govuk-summary-list__value"><time datetime="{{ entry.created_at }}">{{ entry.created_at or t("event_lifecycle_history.timestamp_unknown") }}</time></dd></div>{% if "publication" in entry.evidence.axes_changed %}<div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("event_lifecycle_history.publication_label") }}</dt><dd class="govuk-summary-list__value">{{ t("event_lifecycle_history.transition", { from: t("event_lifecycle_history.states.publication." + entry.publication.from), to: t("event_lifecycle_history.states.publication." + entry.publication.to) }) }}</dd></div>{% endif %}{% if "operational" in entry.evidence.axes_changed %}<div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("event_lifecycle_history.operational_label") }}</dt><dd class="govuk-summary-list__value">{{ t("event_lifecycle_history.transition", { from: t("event_lifecycle_history.states.operational." + entry.operational.from), to: t("event_lifecycle_history.states.operational." + entry.operational.to) }) }}</dd></div>{% endif %}<div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("event_lifecycle_history.actor_label") }}</dt><dd class="govuk-summary-list__value">{{ entry.actor.display_name or t("event_lifecycle_history.unknown_actor", { id: entry.actor.id }) }}</dd></div>{% if entry.reason %}<div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("event_lifecycle_history.reason_label") }}</dt><dd class="govuk-summary-list__value">{{ entry.reason }}</dd></div>{% endif %}</dl></div></li>{% endfor %}</ol>{% endif %}{% if pagination.has_more and pagination.next_cursor %}<nav class="govuk-pagination govuk-pagination--block"><a class="govuk-link govuk-pagination__link" rel="next" href="{{ urlFor('/events/' + (event.id | string) + '/lifecycle-history?cursor=' + (pagination.next_cursor | urlencode) + '&per_page=' + (perPage | string)) }}">{{ t("event_lifecycle_history.load_more") }}</a></nav>{% endif %}{% endblock %}
