{% extends "layouts/base.njk" %}
{% block content %}
<a class="govuk-back-link" href="{{ urlFor('/events/' + (event.id | string)) }}">{{ t("govuk_alpha_events.common.back_to_event") }}</a>
<span class="govuk-caption-xl">{{ event.title }}</span>
<h1 class="govuk-heading-xl">{{ t("event_recurrence_blueprints.title") }}</h1>
<p class="govuk-body-l">{{ t("event_recurrence_blueprints.description") }}</p>
{% if status in ["created","replayed"] and statusVersion %}
<div class="govuk-notification-banner govuk-notification-banner--success" role="alert"><div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">{{ t("event_recurrence_blueprints.success_replay_title" if status == "replayed" else "event_recurrence_blueprints.success_created_title") }}</h2></div><div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">{{ t("event_recurrence_blueprints.success_replay_description" if status == "replayed" else "event_recurrence_blueprints.success_created_description", { version: statusVersion }) }}</p></div></div>
{% elif status %}<div class="govuk-error-summary" role="alert" tabindex="-1"><h2 class="govuk-error-summary__title">{{ t("govuk_alpha_events.common.error_title") }}</h2><div class="govuk-error-summary__body"><p>{{ t("event_recurrence_blueprints.no_sections_description" if status == "invalid" else "event_recurrence_blueprints.errors.preview_error.description") }}</p></div></div>{% endif %}
<div class="govuk-inset-text"><strong>{{ t("event_recurrence_blueprints.definition_only_title") }}</strong><br>{{ t("event_recurrence_blueprints.definition_only_description") }}</div>
<h2 class="govuk-heading-m">{{ t("event_recurrence_blueprints.effective_from_label") }}</h2><p class="govuk-body"><code>{{ recurrenceId }}</code></p><p class="govuk-hint">{{ t("event_recurrence_blueprints.effective_from_help") }}</p>
<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/recurrence-definition-blueprints/preview') }}">
<input type="hidden" name="_csrf" value="{{ csrfToken }}">
<fieldset class="govuk-fieldset" aria-describedby="definition-sections-hint"><legend class="govuk-fieldset__legend govuk-fieldset__legend--m">{{ t("event_recurrence_blueprints.sections_title") }}</legend><div id="definition-sections-hint" class="govuk-hint">{{ t("event_recurrence_blueprints.sections_description") }}</div><div class="govuk-checkboxes">
{% for section in ["agenda","ticket_types","registration","safety","staff"] %}<div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="definition-section-{{ section }}" name="sections" type="checkbox" value="{{ section }}"{% if selectedSections[section] %} checked{% endif %}{% if not allowedSections[section] %} disabled{% endif %}><label class="govuk-label govuk-checkboxes__label" for="definition-section-{{ section }}">{{ t("event_recurrence_blueprints.sections." + section + ".label") }}</label><div class="govuk-hint govuk-checkboxes__hint">{{ t("event_recurrence_blueprints.sections." + section + ".description") }}{% if not allowedSections[section] %} {{ t("event_recurrence_blueprints.section_not_permitted") }}{% endif %}</div></div>{% endfor %}
</div></fieldset><button class="govuk-button">{{ t("event_recurrence_blueprints.preview_button") }}</button></form>
{% if preview %}
<hr class="govuk-section-break govuk-section-break--xl govuk-section-break--visible"><h2 class="govuk-heading-l">{{ t("event_recurrence_blueprints.preview_title") }}</h2><p class="govuk-body">{{ t("event_recurrence_blueprints.preview_description") }}</p>
<dl class="govuk-summary-list">{% for key, count in (preview.counts or {}) %}{% if count %}<div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("event_recurrence_blueprints.counts." + key) }}</dt><dd class="govuk-summary-list__value">{{ count }}</dd></div>{% endif %}{% endfor %}</dl>
{% if preview.conflicts and preview.conflicts.length or not preview.can_commit %}<div class="govuk-error-summary" role="alert" tabindex="-1"><h2 class="govuk-error-summary__title">{{ t("event_recurrence_blueprints.conflicts_title") }}</h2><div class="govuk-error-summary__body"><p>{{ t("event_recurrence_blueprints.errors.preview_error.description") }}</p></div></div>{% else %}
<form method="post" action="{{ urlFor('/events/' + (event.id | string) + '/recurrence-definition-blueprints/commit') }}"><input type="hidden" name="_csrf" value="{{ csrfToken }}"><input type="hidden" name="preview_token" value="{{ preview.preview_token }}"><input type="hidden" name="idempotency_key" value="{{ idempotencyKey }}">{% for section in ["agenda","ticket_types","registration","safety","staff"] %}{% if preview.selected_sections[section] %}<input type="hidden" name="sections" value="{{ section }}">{% endif %}{% endfor %}<div class="govuk-checkboxes govuk-!-margin-bottom-5"><div class="govuk-checkboxes__item"><input class="govuk-checkboxes__input" id="confirm-definition-version" name="confirm_definition_version" type="checkbox" value="1" required><label class="govuk-label govuk-checkboxes__label" for="confirm-definition-version">{{ t("event_recurrence_blueprints.confirm_ack") }}</label><div class="govuk-hint govuk-checkboxes__hint">{{ t("event_recurrence_blueprints.confirm_ack_description") }}</div></div></div><button class="govuk-button">{{ t("event_recurrence_blueprints.commit_button") }}</button></form>
{% endif %}{% endif %}
<hr class="govuk-section-break govuk-section-break--xl govuk-section-break--visible"><h2 class="govuk-heading-l">{{ t("event_recurrence_blueprints.history_title") }}</h2><p class="govuk-body">{{ t("event_recurrence_blueprints.history_description") }}</p>
{% if historyError %}<div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1"><div role="alert"><h2 class="govuk-error-summary__title">{{ t("event_recurrence_blueprints.history_error_title") }}</h2><div class="govuk-error-summary__body"><p>{{ t("event_recurrence_blueprints.history_error_description") }}</p></div></div></div>{% elif history.items and history.items.length %}<ol class="govuk-list" aria-label="{{ t('event_recurrence_blueprints.history_list_label') }}">{% for item in history.items %}<li class="govuk-summary-card govuk-!-margin-bottom-6"><div class="govuk-summary-card__title-wrapper"><h3 class="govuk-summary-card__title">{{ t("event_recurrence_blueprints.history_version", { version: item.blueprint_version }) }}</h3></div><div class="govuk-summary-card__content"><dl class="govuk-summary-list"><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("event_recurrence_blueprints.immutable") }}</dt><dd class="govuk-summary-list__value">{{ t("govuk_alpha.cookie_settings.yes") }}</dd></div><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("event_lifecycle_history.recorded_at") }}</dt><dd class="govuk-summary-list__value">{{ item.recordedAtLabel }}</dd></div><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("event_recurrence_blueprints.effective_from_label") }}</dt><dd class="govuk-summary-list__value"><code>{{ item.effective_from_recurrence_id }}</code></dd></div><div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("event_recurrence_blueprints.history_sections") }}</dt><dd class="govuk-summary-list__value"><ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-0">{% for section in item.selectedSectionKeys %}<li>{{ t("event_recurrence_blueprints.sections." + section + ".label") }}</li>{% endfor %}</ul></dd></div>{% for count in item.countItems %}<div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("event_recurrence_blueprints.counts." + count.key) }}</dt><dd class="govuk-summary-list__value">{{ count.value }}</dd></div>{% endfor %}</dl></div></li>{% endfor %}</ol>{% else %}<h3 class="govuk-heading-m">{{ t("event_recurrence_blueprints.history_empty_title") }}</h3><p class="govuk-body">{{ t("event_recurrence_blueprints.history_empty_description") }}</p>{% endif %}
{% if history.next_before_version %}<nav class="govuk-pagination govuk-pagination--block" aria-label="{{ t("event_recurrence_blueprints.history_list_label") }}"><div class="govuk-pagination__next"><a class="govuk-link govuk-pagination__link" rel="next" href="{{ urlFor('/events/' + (event.id | string) + '/recurrence-definition-blueprints?before_version=' + (history.next_before_version | string)) }}"><span class="govuk-pagination__link-title">{{ t("event_recurrence_blueprints.history_load_more") }}</span></a></div></nav>{% endif %}
{% endblock %}
