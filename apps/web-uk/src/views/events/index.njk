{% extends "layouts/base.njk" %}

{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% from "govuk/components/pagination/macro.njk" import govukPagination %}
{% from "govuk/components/select/macro.njk" import govukSelect %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">

      {% if successMessage %}
        {% set notificationMessage = successMessage %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      {% if errorMessage %}
        {% set notificationMessage = errorMessage %}
        {% set notificationType = null %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      <div class="app-page-header">
        <h1 class="govuk-heading-xl govuk-!-margin-bottom-2">Events</h1>
        {% if isAuthenticated %}
          <div class="app-page-header__actions">
            {{ govukButton({
              text: t("actions.create_event"),
              href: urlFor("/events/new"),
              classes: "govuk-!-margin-bottom-0"
            }) }}
          </div>
        {% endif %}
      </div>

      <p class="govuk-body-l">Discover and join community events.</p>

      {# Search and filter form #}
      <form action="{{ urlFor('/events') }}" method="get" class="govuk-!-margin-bottom-6">
        <div class="app-search-bar">
          {{ govukInput({
            id: "search",
            name: "q",
            value: searchQuery,
            label: {
              text: t("events.search_label"),
              classes: "govuk-visually-hidden"
            },
            classes: "app-search-bar__input",
            attributes: {
              placeholder: "Search by event name or location..."
            }
          }) }}
          {{ govukButton({
            text: "Search",
            classes: "app-search-bar__button govuk-!-margin-bottom-0"
          }) }}
        </div>
        {% if groupId %}
          <input type="hidden" name="group_id" value="{{ groupId }}">
        {% endif %}
        <div class="govuk-!-margin-top-3 govuk-!-width-one-half">
          {{ govukSelect({
            id: "when",
            name: "when",
            label: { text: t("events.when_label") },
            items: [
              { value: "upcoming", text: t("events.when.upcoming"), selected: when == "upcoming" },
              { value: "past", text: t("events.when.past"), selected: when == "past" },
              { value: "all", text: t("events.when.all"), selected: when == "all" }
            ]
          }) }}
        </div>
      </form>

      {# Events list #}
      {% if events.length > 0 %}
        <div class="app-card-grid">
          {% for event in events %}
            <div class="app-card app-card--event">
              {% set coverImage = event.cover_image or event.coverImage %}
              {% if coverImage %}
                <div class="nexus-alpha-listing-row__media govuk-!-margin-bottom-3">
                  <img class="nexus-alpha-card-thumb" src="{{ coverImage }}" alt="Photo for {{ event.title }}" width="120" height="90" loading="lazy" decoding="async">
                </div>
              {% endif %}
              <div class="app-card__header">
                <h2 class="govuk-heading-m govuk-!-margin-bottom-1">
                  <a href="{{ urlFor('/events/' + (event.id | string)) }}" class="govuk-link govuk-link--no-visited-state">
                    {{ event.title }}
                  </a>
                </h2>
                {% if event.isCancelled or event.is_cancelled %}
                  {{ govukTag({ text: "Cancelled", classes: "govuk-tag--red" }) }}
                {% elif event.isPast or event.is_past %}
                  {{ govukTag({ text: "Past", classes: "govuk-tag--grey" }) }}
                {% else %}
                  {{ govukTag({ text: "Upcoming", classes: "govuk-tag--green" }) }}
                {% endif %}
              </div>

              <div class="app-card__body">
                {% if event.start_time or event.startTime %}
                  <p class="govuk-body-s govuk-!-margin-bottom-1">
                    <strong>When:</strong> {{ (event.start_time or event.startTime) | formatEventDate }}
                  </p>
                {% endif %}

                {% if event.location %}
                  <p class="govuk-body-s govuk-!-margin-bottom-1">
                    <strong>Where:</strong> {{ event.location }}
                  </p>
                {% endif %}

                {% if event.group %}
                  <p class="govuk-body-s govuk-!-margin-bottom-1">
                    <strong>Group:</strong>
                    <a href="{{ urlFor('/groups/' + (event.group.id | string)) }}" class="govuk-link">{{ event.group.name }}</a>
                  </p>
                {% endif %}

                {% if event.description %}
                  <p class="govuk-body-s govuk-!-margin-bottom-0 app-card__description">
                    {{ event.description | truncate(120) }}
                  </p>
                {% endif %}
              </div>

              <div class="app-card__footer">
                <span class="govuk-body-s">
                  {{ event.attendeeCount or event.attendee_count or 0 }} attending
                  {% if event.maxAttendees or event.max_attendees %}
                    / {{ event.maxAttendees or event.max_attendees }} max
                  {% endif %}
                </span>
              </div>
            </div>
          {% endfor %}
        </div>

        {# Laravel returns cursor pagination rather than page totals. #}
        {% if pagination.hasMore and pagination.cursor %}
          {{ govukPagination({
            next: {
              labelText: t("events.more_results_label"),
              href: urlFor("/events?when=" + when + ("&q=" + (searchQuery | urlencode) if searchQuery else "") + ("&group_id=" + groupId if groupId else "") + "&cursor=" + (pagination.cursor | urlencode))
            },
            landmarkLabel: t("events.pagination_label")
          }) }}
        {% endif %}
      {% else %}
        <div class="govuk-inset-text">
          <h2 class="govuk-heading-m">{{ t("states.empty_title") }}</h2>
          <p class="govuk-body">{{ t("events.empty") }}</p>
          {% if hasFilters %}
            <p class="govuk-body">
              <a class="govuk-link" href="{{ urlFor('/events') }}">{{ t("actions.clear_filters") }}</a>
            </p>
          {% endif %}
        </div>
      {% endif %}

    </div>
  </div>
{% endblock %}
