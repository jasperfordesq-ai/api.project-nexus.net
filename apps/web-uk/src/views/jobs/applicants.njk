{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a href="{{ urlFor('/jobs/mine') }}" class="govuk-back-link">My postings</a>

  <span class="govuk-caption-xl">{{ job.title }}</span>
  <h1 class="govuk-heading-xl">Applications</h1>
  <p class="govuk-body-l">Review and progress the people who have applied.</p>

  {% if successMessage %}
    {% set notificationMessage = successMessage %}
    {% set notificationType = "success" %}
    {% include "partials/notification-banner.njk" %}
  {% endif %}

  {% if errorMessage %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            <li>{{ errorMessage }}</li>
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  {% if analytics %}
    <h2 class="govuk-heading-m">Performance</h2>
    <dl class="govuk-summary-list govuk-!-margin-bottom-6">
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Total views</dt>
        <dd class="govuk-summary-list__value">{{ analytics.total_views or 0 }}</dd>
      </div>
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Unique viewers</dt>
        <dd class="govuk-summary-list__value">{{ analytics.unique_viewers or 0 }}</dd>
      </div>
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Applications</dt>
        <dd class="govuk-summary-list__value">{{ analytics.total_applications or 0 }}</dd>
      </div>
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Conversion rate</dt>
        <dd class="govuk-summary-list__value">{{ analytics.conversion_rate or 0 }}%</dd>
      </div>
    </dl>
  {% endif %}

  {% if loadError %}
    <div class="govuk-inset-text">
      <p class="govuk-body">Applications could not be loaded. Try again.</p>
    </div>
  {% endif %}

  <p class="govuk-!-margin-bottom-6">
    <a class="govuk-button govuk-button--secondary" data-module="govuk-button" href="{{ urlFor('/jobs/' ~ job.id ~ '/applications/export.csv') }}">Download applications (CSV)</a>
  </p>

  {% if applications.length == 0 %}
    <div class="govuk-inset-text">
      <p class="govuk-body">No one has applied to this opportunity yet.</p>
    </div>
  {% else %}
    <div class="nexus-alpha-card-list">
      {% for app in applications %}
        <article class="nexus-alpha-card">
          <div class="nexus-alpha-module-row">
            <h2 class="govuk-heading-s govuk-!-margin-bottom-1">{{ app.applicantName }}</h2>
            <strong class="govuk-tag govuk-tag--blue">{{ app.statusLabel }}</strong>
          </div>

          {% if app.appliedOnLabel %}
            <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">Applied on {{ app.appliedOnLabel }}</p>
          {% endif %}

          {% if app.coverLetter %}
            <p class="govuk-body">{{ app.coverLetter }}</p>
          {% endif %}

          <form method="post" action="{{ urlFor('/jobs/' ~ job.id ~ '/applications/' ~ app.id ~ '/status') }}" class="govuk-!-margin-top-2">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <div class="govuk-form-group govuk-!-margin-bottom-2">
              <label class="govuk-label" for="app-status-{{ app.id }}">Move to stage</label>
              <select class="govuk-select" id="app-status-{{ app.id }}" name="app_status">
                {% for option in statusOptions %}
                  <option value="{{ option.value }}"{% if app.status == option.value %} selected{% endif %}>{{ option.label }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="govuk-form-group govuk-!-margin-bottom-2">
              <label class="govuk-label" for="app-notes-{{ app.id }}">Notes for your records (optional)</label>
              <input class="govuk-input govuk-!-width-two-thirds" id="app-notes-{{ app.id }}" name="notes" type="text" maxlength="2000">
            </div>
            <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">Update</button>
          </form>
        </article>
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
