{% extends "layouts/base.njk" %}

{% block mainContent %}
  <span class="govuk-caption-xl">Project NEXUS Accessible</span>
  <h1 class="govuk-heading-xl">Job alerts</h1>
  <p class="govuk-body-l">Get notified when new opportunities match your interests.</p>

  <div class="govuk-tabs govuk-!-margin-top-2 govuk-!-margin-bottom-4">
    <h2 class="govuk-tabs__title">Jobs</h2>
    <ul class="govuk-tabs__list">
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="{{ urlFor('/jobs') }}">Browse opportunities</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="{{ urlFor('/jobs/saved') }}">Saved</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="{{ urlFor('/jobs/applications') }}">My applications</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="{{ urlFor('/jobs/responses') }}">Responses</a>
      </li>
      <li class="govuk-tabs__list-item govuk-tabs__list-item--selected">
        <a class="govuk-tabs__tab" href="{{ urlFor('/jobs/alerts') }}" aria-current="page">Job alerts</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="{{ urlFor('/jobs/mine') }}">My postings</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="{{ urlFor('/jobs/create') }}">Post a job</a>
      </li>
    </ul>
  </div>

  {% if successMessage %}
    {% set notificationMessage = successMessage %}
    {% set notificationType = "success" %}
    {% include "partials/notification-banner.njk" %}
  {% endif %}

  {% if errorMessage %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            <li>{{ errorMessage }}</li>
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  {% if loadError %}
    <div class="govuk-inset-text">
      <p class="govuk-body">Job alerts could not be loaded. Try again.</p>
    </div>
  {% endif %}

  <section class="govuk-!-margin-bottom-7">
    <h2 class="govuk-heading-m">Your alerts</h2>

    {% if alerts.length == 0 %}
      <div class="govuk-inset-text">
        <p class="govuk-body">You have no job alerts yet. Create one below.</p>
      </div>
    {% else %}
      <div class="nexus-alpha-card-list">
        {% for alert in alerts %}
          <article class="nexus-alpha-card">
            <div class="nexus-alpha-module-row">
              <h3 class="govuk-heading-s govuk-!-margin-bottom-1">{{ alert.primaryCriteria }}</h3>
              {% if alert.isActive %}
                <strong class="govuk-tag govuk-tag--green">Active</strong>
              {% else %}
                <strong class="govuk-tag govuk-tag--grey">Paused</strong>
              {% endif %}
            </div>

            {% if alert.secondaryCriteria.length %}
              <ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-3">
                {% for criterion in alert.secondaryCriteria %}
                  <li>{{ criterion }}</li>
                {% endfor %}
              </ul>
            {% endif %}

            <div class="nexus-alpha-actions">
              {% if alert.isActive %}
                <form method="post" action="{{ urlFor('/jobs/alerts/' ~ alert.id ~ '/pause') }}" class="nexus-alpha-linkform">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">Pause</button>
                </form>
              {% else %}
                <form method="post" action="{{ urlFor('/jobs/alerts/' ~ alert.id ~ '/resume') }}" class="nexus-alpha-linkform">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">Resume</button>
                </form>
              {% endif %}
              <form method="post" action="{{ urlFor('/jobs/alerts/' ~ alert.id ~ '/delete') }}" class="nexus-alpha-linkform">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <button type="submit" class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button">Delete</button>
              </form>
            </div>
          </article>
        {% endfor %}
      </div>
    {% endif %}
  </section>

  <form method="post" action="{{ urlFor('/jobs/alerts') }}" class="govuk-!-margin-bottom-6">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    <h2 class="govuk-heading-m">Create an alert</h2>

    <div class="govuk-form-group">
      <label class="govuk-label" for="keywords">Keywords (optional)</label>
      <div id="keywords-hint" class="govuk-hint">For example, gardening or admin.</div>
      <input class="govuk-input govuk-!-width-two-thirds" id="keywords" name="keywords" type="text" maxlength="255" aria-describedby="keywords-hint">
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label" for="categories">Categories (optional)</label>
      <input class="govuk-input govuk-!-width-two-thirds" id="categories" name="categories" type="text" maxlength="1000">
    </div>

    <div class="govuk-grid-row">
      <div class="govuk-grid-column-one-third">
        <div class="govuk-form-group">
          <label class="govuk-label" for="type">Type</label>
          <select class="govuk-select" id="type" name="type">
            <option value="">Any type</option>
            <option value="paid">Paid</option>
            <option value="volunteer">Volunteer</option>
            <option value="timebank">Time credits</option>
          </select>
        </div>
      </div>
      <div class="govuk-grid-column-one-third">
        <div class="govuk-form-group">
          <label class="govuk-label" for="commitment">Commitment</label>
          <select class="govuk-select" id="commitment" name="commitment">
            <option value="">Any commitment</option>
            <option value="full_time">Full time</option>
            <option value="part_time">Part time</option>
            <option value="flexible">Flexible</option>
            <option value="one_off">One-off</option>
          </select>
        </div>
      </div>
      <div class="govuk-grid-column-one-third">
        <div class="govuk-form-group">
          <label class="govuk-label" for="location">Location (optional)</label>
          <input class="govuk-input" id="location" name="location" type="text" maxlength="255">
        </div>
      </div>
    </div>

    <div class="govuk-checkboxes govuk-checkboxes--small govuk-!-margin-bottom-4" data-module="govuk-checkboxes">
      <div class="govuk-checkboxes__item">
        <input type="hidden" name="is_remote_only" value="0">
        <input class="govuk-checkboxes__input" id="is_remote_only" name="is_remote_only" type="checkbox" value="1">
        <label class="govuk-label govuk-checkboxes__label" for="is_remote_only">Remote opportunities only</label>
      </div>
    </div>

    <button type="submit" class="govuk-button" data-module="govuk-button">Create alert</button>
  </form>
{% endblock %}
