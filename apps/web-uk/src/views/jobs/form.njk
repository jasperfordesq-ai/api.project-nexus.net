{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a href="{{ urlFor('/jobs/mine') }}" class="govuk-back-link">{{ t("govuk_alpha.jobs_t3.nav_mine") }}</a>

  <span class="govuk-caption-xl">{{ t("govuk_alpha.jobs_t3.create_caption", { community: tenantName }) }}</span>
  <h1 class="govuk-heading-xl">{% if formMode == "edit" %}{{ t("govuk_alpha.jobs_t3.edit_title") }}{% else %}{{ t("govuk_alpha.jobs_t3.create_title") }}{% endif %}</h1>
  <p class="govuk-body-l">{% if formMode == "edit" %}{{ t("govuk_alpha.jobs_t3.edit_description") }}{% else %}{{ t("govuk_alpha.jobs_t3.create_description") }}{% endif %}</p>

  {% if jobFormErrors and jobFormErrors.length %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">{{ t("govuk_alpha.states.error_title") }}</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            {% for error in jobFormErrors %}
              <li><a href="#title">{{ error }}</a></li>
            {% endfor %}
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  <form method="post" action="{{ urlFor(formAction) }}">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--m" for="title">{{ t("govuk_alpha.jobs_t3.label_title") }}</label>
      <div id="title-hint" class="govuk-hint">{{ t("govuk_alpha.jobs_t3.hint_title") }}</div>
      <input class="govuk-input" id="title" name="title" type="text" value="{{ jobForm.title or "" }}" maxlength="255" aria-describedby="title-hint" required>
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--m" for="description">{{ t("govuk_alpha.jobs_t3.label_description") }}</label>
      <div id="description-hint" class="govuk-hint">{{ t("govuk_alpha.jobs_t3.hint_description") }}</div>
      <textarea class="govuk-textarea" id="description" name="description" rows="6" maxlength="5000" aria-describedby="description-hint">{{ jobForm.description or "" }}</textarea>
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--m" for="type">{{ t("govuk_alpha.jobs_t3.label_type") }}</label>
      <select class="govuk-select" id="type" name="type">
        <option value="volunteer"{% if not jobForm.type or jobForm.type == "volunteer" %} selected{% endif %}>{{ t("jobs.type_volunteer") }}</option>
        <option value="paid"{% if jobForm.type == "paid" %} selected{% endif %}>{{ t("jobs.type_paid") }}</option>
        <option value="timebank"{% if jobForm.type == "timebank" %} selected{% endif %}>{{ t("jobs.type_timebank") }}</option>
      </select>
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--m" for="commitment">{{ t("govuk_alpha.jobs_t3.label_commitment") }}</label>
      <select class="govuk-select" id="commitment" name="commitment">
        <option value="flexible"{% if not jobForm.commitment or jobForm.commitment == "flexible" %} selected{% endif %}>{{ t("jobs_t2.commitment_flexible") }}</option>
        <option value="full_time"{% if jobForm.commitment == "full_time" %} selected{% endif %}>{{ t("jobs_t2.commitment_full_time") }}</option>
        <option value="part_time"{% if jobForm.commitment == "part_time" %} selected{% endif %}>{{ t("jobs_t2.commitment_part_time") }}</option>
        <option value="one_off"{% if jobForm.commitment == "one_off" %} selected{% endif %}>{{ t("jobs_t2.commitment_one_off") }}</option>
      </select>
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label" for="category">{{ t("govuk_alpha.jobs_t3.label_category") }}</label>
      <input class="govuk-input govuk-!-width-two-thirds" id="category" name="category" type="text" value="{{ jobForm.category or "" }}" maxlength="100">
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label" for="location">{{ t("govuk_alpha.jobs_t3.label_location") }}</label>
      <input class="govuk-input govuk-!-width-two-thirds" id="location" name="location" type="text" value="{{ jobForm.location or "" }}" maxlength="255">
    </div>

    <div class="govuk-form-group">
      <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
        <div class="govuk-checkboxes__item">
          <input type="hidden" name="is_remote" value="0">
          <input class="govuk-checkboxes__input" id="is_remote" name="is_remote" type="checkbox" value="1"{% if jobForm.is_remote %} checked{% endif %}>
          <label class="govuk-label govuk-checkboxes__label" for="is_remote">{{ t("jobs_t3.label_remote") }}</label>
        </div>
      </div>
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label" for="skills_required">{{ t("jobs_t3.label_skills") }}</label>
      <div id="skills-hint" class="govuk-hint">{{ t("govuk_alpha.jobs_t3.hint_skills") }}</div>
      <input class="govuk-input govuk-!-width-two-thirds" id="skills_required" name="skills_required" type="text" value="{{ jobForm.skills_required or "" }}" maxlength="500" aria-describedby="skills-hint">
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label" for="deadline">{{ t("govuk_alpha.jobs_t3.label_deadline") }}</label>
      <div id="deadline-hint" class="govuk-hint">{{ t("jobs_t3.hint_deadline") }}</div>
      <input class="govuk-input govuk-input--width-10" id="deadline" name="deadline" type="date" value="{{ jobForm.deadline or "" }}" aria-describedby="deadline-hint">
    </div>

    <fieldset class="govuk-fieldset govuk-!-margin-bottom-4">
      <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">{{ t("govuk_alpha.jobs.salary_label") }}</legend>
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-one-third">
          <div class="govuk-form-group">
            <label class="govuk-label" for="salary_min">{{ t("jobs_t3.label_salary_min") }}</label>
            <input class="govuk-input" id="salary_min" name="salary_min" type="number" min="0" step="any" value="{{ jobForm.salary_min or "" }}" inputmode="decimal">
          </div>
        </div>
        <div class="govuk-grid-column-one-third">
          <div class="govuk-form-group">
            <label class="govuk-label" for="salary_max">{{ t("jobs_t3.label_salary_max") }}</label>
            <input class="govuk-input" id="salary_max" name="salary_max" type="number" min="0" step="any" value="{{ jobForm.salary_max or "" }}" inputmode="decimal">
          </div>
        </div>
        <div class="govuk-grid-column-one-third">
          <div class="govuk-form-group">
            <label class="govuk-label" for="salary_currency">{{ t("jobs_t3.label_salary_currency") }}</label>
            <div id="currency-hint" class="govuk-hint">{{ t("jobs_t3.hint_salary_currency") }}</div>
            <input class="govuk-input govuk-input--width-5" id="salary_currency" name="salary_currency" type="text" value="{{ jobForm.salary_currency or "" }}" maxlength="3" aria-describedby="currency-hint">
          </div>
        </div>
      </div>
      <div class="govuk-form-group">
        <label class="govuk-label" for="salary_type">{{ t("jobs_t3.label_salary_type") }}</label>
        <select class="govuk-select" id="salary_type" name="salary_type">
          <option value=""{% if not jobForm.salary_type %} selected{% endif %}>{{ t("jobs_t3.salary_type_none") }}</option>
          <option value="hourly"{% if jobForm.salary_type == "hourly" %} selected{% endif %}>{{ t("jobs_t3.salary_type_hourly") }}</option>
          <option value="monthly"{% if jobForm.salary_type == "monthly" %} selected{% endif %}>{{ t("jobs_t3.salary_type_monthly") }}</option>
          <option value="annual"{% if jobForm.salary_type == "annual" %} selected{% endif %}>{{ t("jobs_t3.salary_type_annual") }}</option>
        </select>
      </div>
      <div class="govuk-form-group">
        <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
          <div class="govuk-checkboxes__item">
            <input type="hidden" name="salary_negotiable" value="0">
            <input class="govuk-checkboxes__input" id="salary_negotiable" name="salary_negotiable" type="checkbox" value="1"{% if jobForm.salary_negotiable %} checked{% endif %}>
            <label class="govuk-label govuk-checkboxes__label" for="salary_negotiable">{{ t("jobs_t3.label_salary_negotiable") }}</label>
          </div>
        </div>
      </div>
    </fieldset>

    <div class="govuk-grid-row">
      <div class="govuk-grid-column-one-half">
        <div class="govuk-form-group">
          <label class="govuk-label" for="hours_per_week">{{ t("jobs_t3.label_hours") }}</label>
          <input class="govuk-input govuk-input--width-5" id="hours_per_week" name="hours_per_week" type="number" min="0" step="any" value="{{ jobForm.hours_per_week or "" }}" inputmode="decimal">
        </div>
      </div>
      <div class="govuk-grid-column-one-half">
        <div class="govuk-form-group">
          <label class="govuk-label" for="time_credits">{{ t("jobs_t3.label_credits") }}</label>
          <input class="govuk-input govuk-input--width-5" id="time_credits" name="time_credits" type="number" min="0" step="any" value="{{ jobForm.time_credits or "" }}" inputmode="decimal">
        </div>
      </div>
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label" for="contact_email">{{ t("govuk_alpha.jobs_t3.label_contact_email") }}</label>
      <input class="govuk-input govuk-!-width-two-thirds" id="contact_email" name="contact_email" type="email" value="{{ jobForm.contact_email or "" }}" maxlength="255" autocomplete="email">
    </div>

    <fieldset class="govuk-fieldset govuk-!-margin-bottom-4">
      <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">{{ t("govuk_alpha.jobs_t3.label_status") }}</legend>
      <div class="govuk-radios govuk-radios--inline" data-module="govuk-radios">
        <div class="govuk-radios__item">
          <input class="govuk-radios__input" id="status-open" name="status" type="radio" value="open"{% if not jobForm.status or jobForm.status == "open" %} checked{% endif %}>
          <label class="govuk-label govuk-radios__label" for="status-open">{{ t("jobs_t3.status_open_option") }}</label>
        </div>
        <div class="govuk-radios__item">
          <input class="govuk-radios__input" id="status-draft" name="status" type="radio" value="draft"{% if jobForm.status == "draft" %} checked{% endif %}>
          <label class="govuk-label govuk-radios__label" for="status-draft">{{ t("jobs_t3.status_draft_option") }}</label>
        </div>
      </div>
    </fieldset>

    <button type="submit" class="govuk-button" data-module="govuk-button">{% if formMode == "edit" %}{{ t("govuk_alpha.jobs_t3.submit_update") }}{% else %}{{ t("govuk_alpha.jobs_t3.submit_create") }}{% endif %}</button>
  </form>
{% endblock %}
