{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a class="govuk-back-link" href="/jobs/mine">Back to my opportunities</a>

  <span class="govuk-caption-xl">Get started as an employer</span>
  <h1 class="govuk-heading-xl">{% if hasPosted %}Post another opportunity{% else %}Welcome to posting opportunities{% endif %}</h1>

  {% if loadError %}
    <div class="govuk-warning-text">
      <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
      <strong class="govuk-warning-text__text">
        <span class="govuk-visually-hidden">Warning</span>
        We could not check your existing opportunities just now.
      </strong>
    </div>
  {% endif %}

  {% if hasPosted %}
    <p class="govuk-body-l">You already post opportunities here. Create another one whenever you are ready.</p>
  {% else %}
    <p class="govuk-body-l">Post opportunities to find the right people in your community. Whether you need paid staff, volunteers or timebank helpers, it is easy to connect with members.</p>
  {% endif %}

  <h2 class="govuk-heading-m">How it works</h2>
  <ol class="govuk-list govuk-list--number">
    <li>Describe the opportunity - title, what is involved and the kind of help you need.</li>
    <li>Choose the type: paid, volunteer or timebank, and the time commitment.</li>
    <li>Publish it. Members can then view and apply, and you manage applicants from your opportunities.</li>
  </ol>

  <h2 class="govuk-heading-m">Tips for more applicants</h2>
  <ul class="govuk-list govuk-list--bullet">
    <li>Add a detailed description with clear responsibilities.</li>
    <li>Include salary or time-credit information for transparency.</li>
    <li>List specific skills to attract qualified candidates.</li>
    <li>Share your opportunity on community channels.</li>
  </ul>

  <div class="govuk-inset-text">
    <p class="govuk-body">Including a pay or time-credit range improves candidate quality and supports pay transparency.</p>
  </div>

  <p class="govuk-button-group">
    <a class="govuk-button" data-module="govuk-button" href="/jobs/create">Post an opportunity</a>
    <a class="govuk-button govuk-button--secondary" data-module="govuk-button" href="/jobs/mine">View my opportunities</a>
    <a class="govuk-link" href="/jobs">Browse opportunities</a>
  </p>
{% endblock %}
