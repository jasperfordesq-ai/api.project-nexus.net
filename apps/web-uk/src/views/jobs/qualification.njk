{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a class="govuk-back-link" href="{{ urlFor('/jobs/' ~ qualification.jobId) }}">{{ t("govuk_alpha_jobs.shared.back_to_opportunity") }}</a>

  <span class="govuk-caption-xl">{{ qualification.jobTitle }}</span>
  <h1 class="govuk-heading-xl">{{ t("govuk_alpha_jobs.qualification.title") }}</h1>
  <p class="govuk-body-l">{{ t("govuk_alpha_jobs.qualification.description") }}</p>

  <div class="nexus-alpha-card govuk-!-margin-bottom-6">
    <h2 class="govuk-heading-m govuk-!-margin-bottom-2">{{ t("govuk_alpha_jobs.qualification.overall_match") }}</h2>
    <p class="govuk-heading-l govuk-!-margin-bottom-1">{{ qualification.percentage }}%
      <strong class="govuk-tag {{ qualification.levelTagClass }} govuk-!-margin-left-2">{{ qualification.levelLabel }}</strong>
    </p>
    <progress value="{{ qualification.percentage }}" max="100" aria-label="{{ t('govuk_alpha_jobs.qualification.overall_match') }}: {{ qualification.percentage }}%">{{ qualification.percentage }}%</progress>
    <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-top-1 govuk-!-margin-bottom-0">
      {{ t("govuk_alpha_jobs.qualification.matched_count", { matched: qualification.totalMatched, total: qualification.totalRequired }) }}
    </p>
  </div>

  <h2 class="govuk-heading-m">{{ t("govuk_alpha_jobs.qualification.skills_heading") }}</h2>
  {% if qualification.breakdown.length == 0 %}
    <p class="govuk-body">{{ t("govuk_alpha_jobs.qualification.no_skills") }}</p>
  {% else %}
    <ul class="govuk-list govuk-!-margin-bottom-6">
      {% for skill in qualification.breakdown %}
        <li>
          <strong class="govuk-tag {% if skill.matched %}govuk-tag--green{% else %}govuk-tag--grey{% endif %}">
            {% if skill.matched %}{{ t("govuk_alpha_jobs.qualification.skill_matched") }}{% else %}{{ t("govuk_alpha_jobs.qualification.skill_missing") }}{% endif %}
          </strong>
          <span class="govuk-!-margin-left-1">{{ skill.skill }}</span>
        </li>
      {% endfor %}
    </ul>
  {% endif %}

  {% if qualification.dimensions.length %}
    <h2 class="govuk-heading-m">{{ t("govuk_alpha_jobs.qualification.dimensions_heading") }}</h2>
    <table class="govuk-table govuk-!-margin-bottom-6">
      <caption class="govuk-table__caption govuk-visually-hidden">{{ t("govuk_alpha_jobs.qualification.dimensions_heading") }}</caption>
      <tbody class="govuk-table__body">
        {% for dimension in qualification.dimensions %}
          <tr class="govuk-table__row">
            <th scope="row" class="govuk-table__header govuk-!-font-weight-regular">
              {{ dimension.label }}
              {% if dimension.detail %}<br><span class="govuk-body-s nexus-alpha-meta">{{ dimension.detail }}</span>{% endif %}
            </th>
            <td class="govuk-table__cell">
              <progress value="{{ dimension.score }}" max="100" aria-label="{{ t('govuk_alpha_jobs.qualification.score_aria', { dimension: dimension.label }) }}">{{ dimension.score }}%</progress>
            </td>
            <td class="govuk-table__cell govuk-table__cell--numeric">{{ dimension.score }}%</td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% endif %}

  {% if qualification.aiSummary %}
    <h2 class="govuk-heading-m">{{ t("govuk_alpha_jobs.qualification.summary_heading") }}</h2>
    <div class="govuk-inset-text"><p class="govuk-body govuk-!-margin-bottom-0">{{ qualification.aiSummary }}</p></div>
  {% endif %}

  <ul class="govuk-list nexus-alpha-actions govuk-!-margin-top-4">
    <li><a class="govuk-button" data-module="govuk-button" href="{{ urlFor('/jobs/' ~ qualification.jobId) }}">{{ t("govuk_alpha_jobs.qualification.view_opportunity") }}</a></li>
  </ul>
{% endblock %}
