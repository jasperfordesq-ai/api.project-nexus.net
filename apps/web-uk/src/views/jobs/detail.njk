{% extends "layouts/base.njk" %}

{% block beforeContent %}
  {{ super() }}
  <a href="{{ urlFor('/jobs') }}" class="govuk-back-link">Back to opportunities</a>
{% endblock %}

{% block mainContent %}
  {% if successMessage %}
    {% set notificationMessage = successMessage %}
    {% set notificationType = "success" %}
    {% include "partials/notification-banner.njk" %}
  {% endif %}

  {% if status == "apply-failed" or status == "save-failed" or status == "renew-failed" or status == "cv-invalid" or status == "cv-too-large" or status == "cover-required" %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            <li>We could not complete that jobs action. Please try again.</li>
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  <span class="govuk-caption-xl">{{ job.posterName or "Project NEXUS Accessible" }}</span>
  <div class="nexus-alpha-module-row">
    <h1 class="govuk-heading-xl govuk-!-margin-bottom-2">{{ job.title }}</h1>
    <strong class="govuk-tag govuk-tag--blue">{{ job.typeLabel }}</strong>
  </div>

  {% if not job.isOwner %}
    {% if job.isSaved %}
      <form method="post" action="{{ urlFor('/jobs/' ~ job.id ~ '/unsave') }}" class="govuk-!-margin-bottom-4">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <input type="hidden" name="from" value="detail">
        <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">Remove from saved</button>
      </form>
    {% else %}
      <form method="post" action="{{ urlFor('/jobs/' ~ job.id ~ '/save') }}" class="govuk-!-margin-bottom-4">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <input type="hidden" name="from" value="detail">
        <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">Save opportunity</button>
      </form>
    {% endif %}
  {% endif %}

  <dl class="govuk-summary-list govuk-!-margin-bottom-6">
    {% if job.commitmentLabel %}
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Commitment</dt>
        <dd class="govuk-summary-list__value">{{ job.commitmentLabel }}</dd>
      </div>
    {% endif %}
    {% if job.locationLabel %}
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Location</dt>
        <dd class="govuk-summary-list__value">{{ job.locationLabel }}</dd>
      </div>
    {% endif %}
    {% if job.salaryLabel %}
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Pay</dt>
        <dd class="govuk-summary-list__value">{{ job.salaryLabel }}</dd>
      </div>
    {% endif %}
    {% if job.deadlineLabel %}
      <div class="govuk-summary-list__row">
        <dt class="govuk-summary-list__key">Closing date</dt>
        <dd class="govuk-summary-list__value">{{ job.deadlineLabel }}</dd>
      </div>
    {% endif %}
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Views</dt>
      <dd class="govuk-summary-list__value">{{ job.viewsCount }}</dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Applications received</dt>
      <dd class="govuk-summary-list__value">{{ job.applicationsCount }}</dd>
    </div>
  </dl>

  {% if job.description %}
    <h2 class="govuk-heading-l">About this opportunity</h2>
    <div class="govuk-body">{{ job.description | nl2br | safe }}</div>
  {% endif %}

  {% if job.skillsList.length %}
    <h2 class="govuk-heading-m">Skills</h2>
    <ul class="govuk-list nexus-alpha-tag-list">
      {% for skill in job.skillsList %}
        <li><strong class="govuk-tag govuk-tag--grey">{{ skill }}</strong></li>
      {% endfor %}
    </ul>
  {% endif %}

  {% if job.isOwner %}
    <div class="govuk-inset-text govuk-!-margin-top-6">This is your opportunity. Manage applications from your postings.</div>
    <div class="nexus-alpha-actions govuk-!-margin-bottom-2">
      <a class="govuk-link" href="{{ urlFor('/jobs/' ~ job.id ~ '/applications') }}">Manage applications</a>
      <a class="govuk-link" href="{{ urlFor('/jobs/' ~ job.id ~ '/edit') }}">Edit</a>
    </div>
    <form method="post" action="{{ urlFor('/jobs/' ~ job.id ~ '/renew') }}">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
      <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">Renew</button>
    </form>
  {% else %}
    <h2 class="govuk-heading-l govuk-!-margin-top-6" id="apply">Apply for this opportunity</h2>
    {% if job.hasApplied %}
      <div class="govuk-inset-text">
        <p class="govuk-body">You have already applied for this opportunity.</p>
      </div>
    {% else %}
      <form method="post" action="{{ urlFor('/jobs/' ~ job.id ~ '/apply') }}" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <div class="govuk-form-group">
          <label class="govuk-label" for="cover_letter">Why are you a good fit? (optional)</label>
          <textarea class="govuk-textarea" id="cover_letter" name="cover_letter" rows="5" maxlength="5000"></textarea>
        </div>
        <div class="govuk-form-group">
          <label class="govuk-label" for="cv">Upload your CV</label>
          <div id="cv-hint" class="govuk-hint">Upload a PDF, DOC or DOCX file.</div>
          <input class="govuk-file-upload" id="cv" name="cv" type="file" accept=".pdf,.doc,.docx,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document" aria-describedby="cv-hint">
        </div>
        <button type="submit" class="govuk-button" data-module="govuk-button">Apply</button>
      </form>
    {% endif %}
  {% endif %}
{% endblock %}
