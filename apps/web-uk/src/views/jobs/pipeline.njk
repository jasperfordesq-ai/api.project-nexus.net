{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a class="govuk-back-link" href="{{ urlFor('/jobs/mine') }}">Back to my opportunities</a>

  <span class="govuk-caption-xl">{{ job.title }}</span>
  <h1 class="govuk-heading-xl">Application pipeline</h1>
  <p class="govuk-body-l">Candidates are grouped by stage. Change a candidate's stage to move them through your pipeline.</p>

  {% if successMessage %}
    {% set notificationMessage = successMessage %}
    {% set notificationType = "success" %}
    {% include "partials/notification-banner.njk" %}
  {% endif %}

  {% if errorMessage %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            <li>{{ errorMessage }}</li>
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  <p class="govuk-!-margin-bottom-6">
    <a class="govuk-button govuk-button--secondary" data-module="govuk-button" href="{{ urlFor('/jobs/' ~ job.id ~ '/applications') }}">View full applicant list</a>
  </p>

  {% if not hasApplications %}
    <div class="govuk-inset-text">
      <p class="govuk-body">No applications yet for this opportunity.</p>
    </div>
  {% endif %}

  <div class="nexus-alpha-card-list">
    {% for column in pipelineColumns %}
      <section class="nexus-alpha-card">
        <div class="nexus-alpha-module-row">
          <h2 class="govuk-heading-m govuk-!-margin-bottom-1">{{ column.label }}</h2>
          <span class="govuk-body-s nexus-alpha-meta">{{ column.countLabel }}</span>
        </div>

        {% if column.applications.length == 0 %}
          <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-0">No candidates in this stage.</p>
        {% else %}
          {% for app in column.applications %}
            <article class="govuk-!-padding-top-3 govuk-!-margin-top-3 govuk-!-border-top">
              <h3 class="govuk-heading-s govuk-!-margin-bottom-1">{{ app.applicantName }}</h3>
              {% if app.appliedOnLabel %}
                <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">Applied {{ app.appliedOnLabel }}</p>
              {% endif %}
              {% if app.cvFilename %}
                <p class="govuk-body-s govuk-!-margin-bottom-2">
                  <a class="govuk-link" href="{{ urlFor('/jobs/applications/' ~ app.id ~ '/cv') }}">Download CV: {{ app.cvFilename }}</a>
                </p>
              {% endif %}

              <form method="post" action="{{ urlFor('/jobs/' ~ job.id ~ '/applications/' ~ app.id ~ '/status') }}">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <div class="govuk-form-group govuk-!-margin-bottom-2">
                  <label class="govuk-label" for="pipeline-status-{{ app.id }}">Move to stage</label>
                  <select class="govuk-select" id="pipeline-status-{{ app.id }}" name="app_status">
                    {% for option in statusOptions %}
                      <option value="{{ option.value }}"{% if app.status == option.value %} selected{% endif %}>{{ option.label }}</option>
                    {% endfor %}
                  </select>
                </div>
                <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">Move</button>
              </form>
            </article>
          {% endfor %}
        {% endif %}
      </section>
    {% endfor %}
  </div>
{% endblock %}
