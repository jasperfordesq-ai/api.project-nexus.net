{% extends "layouts/base.njk" %}

{% block mainContent %}
  <span class="govuk-caption-xl">Your responses from employers</span>
  <h1 class="govuk-heading-xl">Interviews and offers</h1>
  <p class="govuk-body-l">Interviews and offers from employers appear here. Respond to invitations and decide on offers.</p>

  <div class="govuk-tabs govuk-!-margin-top-2 govuk-!-margin-bottom-4">
    <h2 class="govuk-tabs__title">Jobs</h2>
    <ul class="govuk-tabs__list">
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="/jobs">Browse opportunities</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="/jobs/saved">Saved</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="/jobs/applications">My applications</a>
      </li>
      <li class="govuk-tabs__list-item govuk-tabs__list-item--selected">
        <a class="govuk-tabs__tab" href="/jobs/responses" aria-current="page">Responses</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="/jobs/alerts">Job alerts</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="/jobs/mine">My postings</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="/jobs/create">Post a job</a>
      </li>
    </ul>
  </div>

  {% if successMessage %}
    {% set notificationMessage = successMessage %}
    {% set notificationType = "success" %}
    {% include "partials/notification-banner.njk" %}
  {% endif %}

  {% if errorMessage %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            <li>{{ errorMessage }}</li>
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  {% if loadError %}
    <div class="govuk-inset-text">
      <p class="govuk-body">Responses could not be loaded. Try again.</p>
    </div>
  {% endif %}

  <section class="govuk-!-margin-bottom-7">
    <h2 class="govuk-heading-m">Interview invitations</h2>

    {% if interviews.length == 0 %}
      <div class="govuk-inset-text">
        <p class="govuk-body">You have no interview invitations yet.</p>
      </div>
    {% else %}
      <div class="nexus-alpha-card-list">
        {% for interview in interviews %}
          <article class="nexus-alpha-card">
            <div class="nexus-alpha-module-row">
              <h3 class="govuk-heading-s govuk-!-margin-bottom-1">{{ interview.typeLabel }}</h3>
              <strong class="govuk-tag govuk-tag--blue">{{ interview.statusLabel }}</strong>
            </div>

            <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">For: {{ interview.title }}</p>
            {% if interview.scheduledLabel %}
              <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">Scheduled for {{ interview.scheduledLabel }}</p>
            {% else %}
              <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">Date to be confirmed</p>
            {% endif %}
            {% if interview.durationLabel %}
              <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">Duration: {{ interview.durationLabel }}</p>
            {% endif %}
            {% if interview.details %}
              <h4 class="govuk-heading-s govuk-!-margin-bottom-1">Details</h4>
              <p class="govuk-body">{{ interview.details }}</p>
            {% endif %}
            {% if interview.vacancyId %}
              <p class="govuk-body-s"><a class="govuk-link" href="/jobs/{{ interview.vacancyId }}">View opportunity</a></p>
            {% endif %}

            {% if interview.canRespond %}
              <div class="nexus-alpha-actions">
                <form method="post" action="/jobs/interviews/{{ interview.id }}/accept" class="nexus-alpha-linkform">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <div class="govuk-form-group govuk-!-margin-bottom-2">
                    <label class="govuk-label" for="interview-accept-note-{{ interview.id }}">Note (optional)</label>
                    <div id="interview-accept-note-{{ interview.id }}-hint" class="govuk-hint">Add a short message for the employer.</div>
                    <textarea class="govuk-textarea" id="interview-accept-note-{{ interview.id }}" name="note" rows="2" maxlength="1000" aria-describedby="interview-accept-note-{{ interview.id }}-hint"></textarea>
                  </div>
                  <button type="submit" class="govuk-button govuk-!-margin-bottom-0" data-module="govuk-button">Accept interview</button>
                </form>
                <form method="post" action="/jobs/interviews/{{ interview.id }}/decline" class="nexus-alpha-linkform">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <button type="submit" class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button">Decline interview</button>
                </form>
              </div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    {% endif %}
  </section>

  <section class="govuk-!-margin-bottom-7">
    <h2 class="govuk-heading-m">Offers</h2>

    {% if offers.length == 0 %}
      <div class="govuk-inset-text">
        <p class="govuk-body">You have no offers yet.</p>
      </div>
    {% else %}
      <div class="nexus-alpha-card-list">
        {% for offer in offers %}
          <article class="nexus-alpha-card">
            <div class="nexus-alpha-module-row">
              <h3 class="govuk-heading-s govuk-!-margin-bottom-1">{{ offer.title }}</h3>
              <strong class="govuk-tag govuk-tag--blue">{{ offer.statusLabel }}</strong>
            </div>

            <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">{{ offer.salaryLine }}</p>
            {% if offer.startLabel %}
              <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">Start date: {{ offer.startLabel }}</p>
            {% endif %}
            {% if offer.expiresLabel %}
              <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">Respond by {{ offer.expiresLabel }}</p>
            {% endif %}
            {% if offer.messageText %}
              <h4 class="govuk-heading-s govuk-!-margin-bottom-1">Message from the employer</h4>
              <p class="govuk-body">{{ offer.messageText }}</p>
            {% endif %}
            {% if offer.vacancyId %}
              <p class="govuk-body-s"><a class="govuk-link" href="/jobs/{{ offer.vacancyId }}">View opportunity</a></p>
            {% endif %}

            {% if offer.canRespond %}
              <div class="govuk-warning-text govuk-!-margin-bottom-2">
                <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
                <strong class="govuk-warning-text__text">
                  <span class="govuk-visually-hidden">Warning</span>
                  Only respond when you are ready for the employer to be notified.
                </strong>
              </div>
              <div class="nexus-alpha-actions">
                <form method="post" action="/jobs/offers/{{ offer.id }}/accept" class="nexus-alpha-linkform">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <button type="submit" class="govuk-button govuk-!-margin-bottom-0" data-module="govuk-button">Accept offer</button>
                </form>
                <form method="post" action="/jobs/offers/{{ offer.id }}/reject" class="nexus-alpha-linkform">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <button type="submit" class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button">Decline offer</button>
                </form>
              </div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    {% endif %}
  </section>
{% endblock %}
