{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a class="govuk-back-link" href="{{ urlFor('/jobs/talent-search') }}">Find candidates</a>

  <div class="nexus-alpha-module-row govuk-!-margin-bottom-2">
    {% if candidate.avatarUrl %}
      <img class="nexus-alpha-avatar" src="{{ candidate.avatarUrl }}" alt="" aria-hidden="true" loading="lazy" decoding="async" width="64" height="64">
    {% else %}
      <span class="nexus-alpha-avatar nexus-alpha-avatar--placeholder" aria-hidden="true">{{ candidate.initial }}</span>
    {% endif %}
    <div>
      <h1 class="govuk-heading-xl govuk-!-margin-bottom-1">{{ candidate.name }}</h1>
      <p class="govuk-body-l govuk-!-margin-bottom-0">{{ candidate.headline }}</p>
    </div>
  </div>

  <p class="govuk-body-s nexus-alpha-meta">
    {% if candidate.location %}{{ candidate.location }}{% endif %}
    {% if candidate.lastActiveLabel %}{% if candidate.location %} - {% endif %}Last active {{ candidate.lastActiveLabel }}{% endif %}
    {% if candidate.memberSinceLabel %} - Member since {{ candidate.memberSinceLabel }}{% endif %}
  </p>

  {% if candidate.skills.length %}
    <h2 class="govuk-heading-m">Skills</h2>
    <ul class="govuk-list nexus-alpha-tag-list govuk-!-margin-bottom-6">
      {% for skill in candidate.skills %}
        <li><strong class="govuk-tag govuk-tag--grey">{{ skill }}</strong></li>
      {% endfor %}
    </ul>
  {% else %}
    <p class="govuk-body">No skills listed</p>
  {% endif %}

  {% if candidate.summary %}
    <h2 class="govuk-heading-m">Summary</h2>
    <div class="govuk-body govuk-!-margin-bottom-6">{{ candidate.summary | nl2br | safe }}</div>
  {% endif %}

  {% if candidate.bio %}
    <h2 class="govuk-heading-m">About</h2>
    <div class="govuk-body govuk-!-margin-bottom-6">{{ candidate.bio | nl2br | safe }}</div>
  {% endif %}
{% endblock %}
