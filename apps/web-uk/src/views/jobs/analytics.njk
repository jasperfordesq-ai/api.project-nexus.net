{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a class="govuk-back-link" href="{{ urlFor('/jobs/' ~ job.id ~ '/applications') }}">{{ t("govuk_alpha_jobs.shared.back_to_my_postings") }}</a>

  <span class="govuk-caption-xl">{{ job.title or t("govuk_alpha.jobs.title") }}</span>
  <h1 class="govuk-heading-xl">{{ t("govuk_alpha_jobs.analytics.title") }}</h1>
  <p class="govuk-body-l">{{ t("govuk_alpha_jobs.analytics.description") }}</p>

  <ul class="govuk-list nexus-alpha-actions govuk-!-margin-bottom-6">
    <li><a class="govuk-link" href="{{ urlFor('/jobs/' ~ job.id ~ '/pipeline') }}">{{ t("govuk_alpha_jobs.analytics.view_pipeline") }}</a></li>
    <li><a class="govuk-link" href="{{ urlFor('/jobs/' ~ job.id ~ '/applications/export.csv') }}">{{ t("govuk_alpha_jobs.analytics.export_csv") }}</a></li>
    <li><a class="govuk-link" href="{{ urlFor('/jobs/' ~ job.id) }}">{{ t("govuk_alpha_jobs.shared.view_opportunity") }}</a></li>
  </ul>

  <h2 class="govuk-heading-m">{{ t("govuk_alpha_jobs.analytics.key_metrics_heading") }}</h2>
  <dl class="govuk-summary-list govuk-!-margin-bottom-6">
    <div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_jobs.analytics.total_views") }}</dt><dd class="govuk-summary-list__value">{{ analytics.totalViewsLabel }}</dd></div>
    <div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_jobs.analytics.unique_viewers") }}</dt><dd class="govuk-summary-list__value">{{ analytics.uniqueViewersLabel }}</dd></div>
    <div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_jobs.analytics.total_applications") }}</dt><dd class="govuk-summary-list__value">{{ analytics.totalApplicationsLabel }}</dd></div>
    <div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_jobs.analytics.conversion_rate") }}</dt><dd class="govuk-summary-list__value">{{ analytics.conversionRate }}%</dd></div>
    {% if analytics.averageTimeToApplyHours != null %}<div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_jobs.analytics.avg_time_to_apply") }}</dt><dd class="govuk-summary-list__value">{{ analytics.averageTimeToApplyHours }} {{ t("govuk_alpha_jobs.analytics.hours") }}</dd></div>{% endif %}
    {% if analytics.timeToFillDays != null %}<div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_jobs.analytics.time_to_fill") }}</dt><dd class="govuk-summary-list__value">{{ analytics.timeToFillDays }} {{ t("govuk_alpha_jobs.analytics.days") }}</dd></div>{% endif %}
  </dl>

  {% if analytics.referralStats or analytics.scorecardAverage != null %}
    <h2 class="govuk-heading-m">{{ t("govuk_alpha_jobs.analytics.referral_heading") }}</h2>
    <dl class="govuk-summary-list govuk-!-margin-bottom-6">
      {% if analytics.referralStats %}
        <div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_jobs.analytics.referral_shares") }}</dt><dd class="govuk-summary-list__value">{{ analytics.referralStats.totalSharesLabel }}</dd></div>
        <div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_jobs.analytics.referral_apps") }}</dt><dd class="govuk-summary-list__value">{{ analytics.referralStats.referralApplicationsLabel }}</dd></div>
        <div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_jobs.analytics.referral_conversion") }}</dt><dd class="govuk-summary-list__value">{{ analytics.referralStats.referralConversionPct }}%</dd></div>
      {% endif %}
      {% if analytics.scorecardAverage != null %}<div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_jobs.analytics.scorecard_avg") }}</dt><dd class="govuk-summary-list__value">{{ analytics.scorecardAverage }}%</dd></div>{% endif %}
    </dl>
  {% endif %}

  <h2 class="govuk-heading-m">{{ t("govuk_alpha_jobs.analytics.views_over_time") }}</h2>
  {% if analytics.viewsByDay.length == 0 %}
    <p class="govuk-body">{{ t("govuk_alpha_jobs.analytics.no_views_yet") }}</p>
  {% else %}
    <table class="govuk-table govuk-!-margin-bottom-6">
      <caption class="govuk-table__caption govuk-visually-hidden">{{ t("govuk_alpha_jobs.analytics.views_over_time") }}</caption>
      <tbody class="govuk-table__body">{% for row in analytics.viewsByDay %}<tr class="govuk-table__row"><th scope="row" class="govuk-table__header govuk-!-font-weight-regular">{{ row.label }}</th><td class="govuk-table__cell"><progress value="{{ row.count }}" max="{{ analytics.maxViews }}" aria-label="{{ t('govuk_alpha_jobs.analytics.views_on_date', { date: row.label }) }}">{{ row.count }}</progress></td><td class="govuk-table__cell govuk-table__cell--numeric">{{ row.count }}</td></tr>{% endfor %}</tbody>
    </table>
  {% endif %}

  {% if analytics.weeklyTrend.length %}
    <h2 class="govuk-heading-m">{{ t("govuk_alpha_jobs.analytics.weekly_trend") }}</h2>
    <table class="govuk-table govuk-!-margin-bottom-6">
      <caption class="govuk-table__caption govuk-visually-hidden">{{ t("govuk_alpha_jobs.analytics.weekly_trend") }}</caption>
      <tbody class="govuk-table__body">{% for row in analytics.weeklyTrend %}<tr class="govuk-table__row"><th scope="row" class="govuk-table__header govuk-!-font-weight-regular">{{ row.label }}</th><td class="govuk-table__cell"><progress value="{{ row.count }}" max="{{ analytics.maxWeekly }}" aria-label="{{ t('govuk_alpha_jobs.analytics.applications_in_week', { week: row.label }) }}">{{ row.count }}</progress></td><td class="govuk-table__cell govuk-table__cell--numeric">{{ row.count }}</td></tr>{% endfor %}</tbody>
    </table>
  {% endif %}

  <h2 class="govuk-heading-m">{{ t("govuk_alpha_jobs.analytics.applications_by_stage") }}</h2>
  {% if analytics.applicationsByStage.length == 0 %}
    <p class="govuk-body">{{ t("govuk_alpha_jobs.analytics.no_applications_yet") }}</p>
  {% else %}
    <table class="govuk-table govuk-!-margin-bottom-6">
      <caption class="govuk-table__caption govuk-visually-hidden">{{ t("govuk_alpha_jobs.analytics.applications_by_stage") }}</caption>
      <thead class="govuk-table__head"><tr class="govuk-table__row"><th scope="col" class="govuk-table__header">{{ t("govuk_alpha_jobs.analytics.applications_by_stage") }}</th><th scope="col" class="govuk-table__header"></th><th scope="col" class="govuk-table__header govuk-table__header--numeric">{{ t("govuk_alpha_jobs.analytics.total_applications") }}</th></tr></thead>
      <tbody class="govuk-table__body">{% for row in analytics.applicationsByStage %}<tr class="govuk-table__row"><th scope="row" class="govuk-table__header govuk-!-font-weight-regular">{{ row.label }}</th><td class="govuk-table__cell"><progress value="{{ row.count }}" max="{{ analytics.totalApplications if analytics.totalApplications > 0 else 1 }}" aria-label="{{ row.label }}: {{ row.percentage }}%">{{ row.percentage }}%</progress></td><td class="govuk-table__cell govuk-table__cell--numeric">{{ row.count }} ({{ row.percentage }}%)</td></tr>{% endfor %}</tbody>
    </table>
  {% endif %}

  <h2 class="govuk-heading-m">{{ t("govuk_alpha_jobs.analytics.predictions_heading") }}</h2>
  {% if not predictions or predictions.similarJobsAnalyzed == 0 %}
    <p class="govuk-body">{{ t("govuk_alpha_jobs.analytics.no_predictions") }}</p>
  {% else %}
    <p class="govuk-body-s nexus-alpha-meta">{{ t("govuk_alpha_jobs.analytics.predictions_based_on", { count: predictions.similarJobsAnalyzed }) }}</p>
    <dl class="govuk-summary-list govuk-!-margin-bottom-6">
      <div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_jobs.analytics.expected_apps") }}</dt><dd class="govuk-summary-list__value">{{ predictions.expectedApplications.value }} <span class="govuk-!-margin-left-2"><strong class="govuk-tag {{ 'govuk-tag--green' if predictions.expectedApplications.aboveAverage else 'govuk-tag--yellow' }}">{{ t("govuk_alpha_jobs.analytics.above_average") if predictions.expectedApplications.aboveAverage else t("govuk_alpha_jobs.analytics.below_average") }}</strong></span> <span class="govuk-body-s nexus-alpha-meta">{{ t("govuk_alpha_jobs.analytics.current_label") }}: {{ predictions.expectedApplications.current }}</span></dd></div>
      <div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_jobs.analytics.estimated_time_to_fill") }}</dt><dd class="govuk-summary-list__value">{% if predictions.estimatedTimeToFill.value != null %}{{ t("govuk_alpha_jobs.analytics.days_value", { count: predictions.estimatedTimeToFill.value }) }}{% else %}{{ t("govuk_alpha_jobs.analytics.not_available") }}{% endif %} <span class="govuk-body-s nexus-alpha-meta">{{ t("govuk_alpha_jobs.analytics.posted_days_ago", { days: predictions.estimatedTimeToFill.daysPosted }) }}</span></dd></div>
      <div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_jobs.analytics.conversion_comparison") }}</dt><dd class="govuk-summary-list__value">{{ t("govuk_alpha_jobs.analytics.yours") }}: {{ predictions.conversionRate.yours }}% &middot; {{ t("govuk_alpha_jobs.analytics.market_average") }}: {{ predictions.conversionRate.average }}% <span class="govuk-!-margin-left-2"><strong class="govuk-tag {{ 'govuk-tag--green' if predictions.conversionRate.aboveAverage else 'govuk-tag--yellow' }}">{{ t("govuk_alpha_jobs.analytics.above_average") if predictions.conversionRate.aboveAverage else t("govuk_alpha_jobs.analytics.below_average") }}</strong></span></dd></div>
      {% if predictions.salaryComparison %}<div class="govuk-summary-list__row"><dt class="govuk-summary-list__key">{{ t("govuk_alpha_jobs.analytics.salary_comparison") }}</dt><dd class="govuk-summary-list__value">{{ t("govuk_alpha_jobs.analytics.yours") }}: {{ predictions.salaryComparison.yourSalary }} &middot; {{ t("govuk_alpha_jobs.analytics.market_average") }}: {{ predictions.salaryComparison.marketAverage }} <span class="govuk-!-margin-left-2"><strong class="govuk-tag {{ 'govuk-tag--green' if predictions.salaryComparison.diffPercent >= 0 else 'govuk-tag--red' }}">{% if predictions.salaryComparison.diffPercent > 0 %}+{% endif %}{{ predictions.salaryComparison.diffPercent }}% {% if predictions.salaryComparison.diffPercent > 0 %}{{ t("govuk_alpha_jobs.analytics.salary_above") }}{% elseif predictions.salaryComparison.diffPercent < 0 %}{{ t("govuk_alpha_jobs.analytics.salary_below") }}{% else %}{{ t("govuk_alpha_jobs.analytics.salary_at") }}{% endif %}</strong></span></dd></div>{% endif %}
    </dl>
  {% endif %}
{% endblock %}
