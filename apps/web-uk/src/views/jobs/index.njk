{% extends "layouts/base.njk" %}

{% block mainContent %}
  <span class="govuk-caption-xl">Project NEXUS Accessible</span>
  <h1 class="govuk-heading-xl">Jobs</h1>
  <p class="govuk-body-l">Roles and opportunities in this community.</p>

  <div class="govuk-tabs govuk-!-margin-top-2 govuk-!-margin-bottom-4">
    <h2 class="govuk-tabs__title">Jobs</h2>
    <ul class="govuk-tabs__list">
      <li class="govuk-tabs__list-item govuk-tabs__list-item--selected">
        <a class="govuk-tabs__tab" href="{{ urlFor('/jobs') }}" aria-current="page">Browse opportunities</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="{{ urlFor('/jobs/saved') }}">Saved</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="{{ urlFor('/jobs/applications') }}">My applications</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="{{ urlFor('/jobs/responses') }}">Responses</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="{{ urlFor('/jobs/alerts') }}">Job alerts</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="{{ urlFor('/jobs/mine') }}">My postings</a>
      </li>
      <li class="govuk-tabs__list-item">
        <a class="govuk-tabs__tab" href="{{ urlFor('/jobs/create') }}">Post a job</a>
      </li>
    </ul>
  </div>

  {% if successMessage %}
    {% set notificationMessage = successMessage %}
    {% set notificationType = "success" %}
    {% include "partials/notification-banner.njk" %}
  {% endif %}

  {% if loadError %}
    <div class="govuk-inset-text">
      <p class="govuk-body">Opportunities could not be loaded. Try again.</p>
    </div>
  {% endif %}

  <form method="get" action="{{ urlFor('/jobs') }}" class="govuk-!-margin-bottom-6">
    <div class="govuk-form-group">
      <label class="govuk-label" for="q">Find an opportunity</label>
      <div id="q-hint" class="govuk-hint">Search by title.</div>
      <input class="govuk-input govuk-!-width-two-thirds" id="q" name="q" type="search" value="{{ filters.q }}" aria-describedby="q-hint">
    </div>

    <div class="govuk-grid-row">
      <div class="govuk-grid-column-one-third">
        <div class="govuk-form-group">
          <label class="govuk-label" for="type">Type</label>
          <select class="govuk-select" id="type" name="type">
            <option value=""{% if filters.type == "" %} selected{% endif %}>All types</option>
            <option value="paid"{% if filters.type == "paid" %} selected{% endif %}>Paid</option>
            <option value="volunteer"{% if filters.type == "volunteer" %} selected{% endif %}>Volunteer</option>
            <option value="timebank"{% if filters.type == "timebank" %} selected{% endif %}>Time credits</option>
          </select>
        </div>
      </div>
      <div class="govuk-grid-column-one-third">
        <div class="govuk-form-group">
          <label class="govuk-label" for="commitment">Commitment</label>
          <select class="govuk-select" id="commitment" name="commitment">
            <option value=""{% if filters.commitment == "" %} selected{% endif %}>Any commitment</option>
            <option value="full_time"{% if filters.commitment == "full_time" %} selected{% endif %}>Full time</option>
            <option value="part_time"{% if filters.commitment == "part_time" %} selected{% endif %}>Part time</option>
            <option value="flexible"{% if filters.commitment == "flexible" %} selected{% endif %}>Flexible</option>
            <option value="one_off"{% if filters.commitment == "one_off" %} selected{% endif %}>One-off</option>
          </select>
        </div>
      </div>
      <div class="govuk-grid-column-one-third">
        <div class="govuk-form-group">
          <label class="govuk-label" for="sort">Sort by</label>
          <select class="govuk-select" id="sort" name="sort">
            <option value="newest"{% if filters.sort == "newest" %} selected{% endif %}>Newest</option>
            <option value="deadline"{% if filters.sort == "deadline" %} selected{% endif %}>Closing soonest</option>
            <option value="salary_desc"{% if filters.sort == "salary_desc" %} selected{% endif %}>Highest pay</option>
          </select>
        </div>
      </div>
    </div>

    <div class="govuk-checkboxes govuk-checkboxes--small govuk-!-margin-bottom-4" data-module="govuk-checkboxes">
      <div class="govuk-checkboxes__item">
        <input class="govuk-checkboxes__input" id="remote" name="remote" type="checkbox" value="1"{% if filters.remote %} checked{% endif %}>
        <label class="govuk-label govuk-checkboxes__label" for="remote">Remote only</label>
      </div>
    </div>

    <div class="nexus-alpha-actions">
      <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">Apply filters</button>
      <a class="govuk-link" href="{{ urlFor('/jobs') }}">Clear filters</a>
    </div>
  </form>

  {% if jobs.length == 0 %}
    <div class="govuk-inset-text">
      <p class="govuk-body">There are no open opportunities right now.</p>
    </div>
  {% else %}
    <p class="govuk-body govuk-!-font-weight-bold">{{ resultsLabel }}</p>

    <div class="nexus-alpha-card-list">
      {% for job in jobs %}
        <article class="nexus-alpha-card">
          <div class="nexus-alpha-module-row">
            <h3 class="govuk-heading-s govuk-!-margin-bottom-1">
              <a class="govuk-link" href="{{ urlFor('/jobs/' ~ job.id) }}">{{ job.title }}</a>
            </h3>
            <strong class="govuk-tag govuk-tag--blue">{{ job.typeLabel }}</strong>
          </div>

          {% if job.posterName %}
            <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">Posted by {{ job.posterName }}</p>
          {% endif %}

          <ul class="govuk-list nexus-alpha-tag-list govuk-!-margin-bottom-1">
            {% if job.commitmentLabel %}
              <li><strong class="govuk-tag govuk-tag--grey">{{ job.commitmentLabel }}</strong></li>
            {% endif %}
            {% if job.isRemote %}
              <li><strong class="govuk-tag govuk-tag--turquoise">Remote</strong></li>
            {% endif %}
            {% if job.isFeatured %}
              <li><strong class="govuk-tag govuk-tag--yellow">Featured</strong></li>
            {% endif %}
            {% if job.hasApplied %}
              <li><strong class="govuk-tag govuk-tag--green">Applied</strong></li>
            {% endif %}
            {% if job.isSaved %}
              <li><strong class="govuk-tag govuk-tag--purple">Saved</strong></li>
            {% endif %}
          </ul>

          <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">
            {% if job.locationLabel %}{{ job.locationLabel }}{% endif %}
            {% if job.salaryLabel %} &middot; {{ job.salaryLabel }}{% endif %}
            {% if job.deadlineLabel %} &middot; Closing date: {{ job.deadlineLabel }}{% endif %}
          </p>

          <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-0">
            {{ job.viewsLabel }} &middot; {{ job.applicationsLabel }}
          </p>
        </article>
      {% endfor %}
    </div>

    {% if jobsMeta.has_more and nextHref %}
      <nav class="govuk-pagination govuk-pagination--block govuk-!-margin-top-6" aria-label="Pagination">
        <div class="govuk-pagination__next">
          <a class="govuk-link govuk-pagination__link" rel="next" href="{{ urlFor(nextHref) }}">
            <span class="govuk-pagination__link-title">Load more</span>
            <span class="govuk-visually-hidden">:</span>
            <span class="govuk-pagination__link-label">More results</span>
          </a>
        </div>
      </nav>
    {% endif %}
  {% endif %}
{% endblock %}
