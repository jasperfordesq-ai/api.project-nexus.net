{% extends "layouts/base.njk" %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <a class="govuk-back-link" href="/resources/library">Back to resource library</a>

      <span class="govuk-caption-l">Community resources</span>
      <h1 class="govuk-heading-xl">Upload a resource</h1>
      <p class="govuk-body-l">Share files, guides and templates with your community.</p>

      {% if status %}
        {{ govukErrorSummary({
          titleText: status.title,
          errorList: [{ text: status.message, href: "#file" }]
        }) }}
      {% endif %}

      <form method="post" action="/resources/upload" enctype="multipart/form-data" novalidate>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        <div class="govuk-form-group">
          <label class="govuk-label govuk-label--m" for="title">Title</label>
          <div id="title-hint" class="govuk-hint">Use a clear name so members can recognise the resource.</div>
          <input class="govuk-input" id="title" name="title" type="text" maxlength="255" aria-describedby="title-hint">
        </div>

        <div class="govuk-form-group">
          <label class="govuk-label govuk-label--m" for="description">Description</label>
          <div id="description-hint" class="govuk-hint">Summarise what the resource helps people do.</div>
          <textarea class="govuk-textarea" id="description" name="description" rows="4" aria-describedby="description-hint"></textarea>
        </div>

        {% if flatCategories and flatCategories.length %}
          <div class="govuk-form-group">
            <label class="govuk-label" for="category_id">Category</label>
            <div id="category_id-hint" class="govuk-hint">Choose where this resource should appear in the library.</div>
            <select class="govuk-select" id="category_id" name="category_id" aria-describedby="category_id-hint">
              <option value="">No category</option>
              {% for category in flatCategories %}
                <option value="{{ category.id }}">{{ category.name }}</option>
              {% endfor %}
            </select>
          </div>
        {% endif %}

        <div class="govuk-form-group">
          <label class="govuk-label govuk-label--m" for="file">File</label>
          <div id="file-hint" class="govuk-hint">The file must be smaller than {{ maxSizeLabel }}. Allowed types: {{ allowedLabel }}.</div>
          <input class="govuk-file-upload" id="file" name="file" type="file" accept=".pdf,.doc,.docx,.xls,.xlsx,.txt,.csv,.jpg,.png,.gif,.webp" aria-describedby="file-hint">
        </div>

        <div class="govuk-button-group">
          <button class="govuk-button" data-module="govuk-button" type="submit">Upload resource</button>
          <a class="govuk-link" href="/resources/library">Cancel</a>
        </div>
      </form>
    </div>
  </div>
{% endblock %}
