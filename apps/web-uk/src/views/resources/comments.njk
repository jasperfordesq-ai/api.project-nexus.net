{% extends "layouts/base.njk" %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% macro renderComment(comment, resourceId, currentUserId, csrfToken) %}
  <li id="comment-{{ comment.id }}" class="nexus-alpha-comment">
    <p class="nexus-alpha-meta govuk-body-s govuk-!-margin-bottom-1">
      <strong>{{ comment.authorName }}</strong>
      {% if comment.createdAt %} &middot; {{ comment.createdAt }}{% endif %}
    </p>
    <p class="govuk-body govuk-!-margin-bottom-2">{{ comment.content }}</p>

    {% if currentUserId and comment.userId == currentUserId %}
      <form method="post" action="{{ urlFor('/resources/' + (resourceId | string) + '/comments/' + (comment.id | string) + '/delete') }}" class="govuk-!-display-inline">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <button type="submit" class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button" aria-label="Delete this comment">Delete</button>
      </form>
    {% endif %}

    {% if comment.replies and comment.replies.length %}
      <ol class="govuk-list nexus-alpha-comments-list govuk-!-margin-top-3 govuk-!-padding-left-4">
        {% for reply in comment.replies %}
          {{ renderComment(reply, resourceId, currentUserId, csrfToken) }}
        {% endfor %}
      </ol>
    {% endif %}
  </li>
{% endmacro %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <a class="govuk-back-link" href="{{ urlFor('/resources/library') }}">Back to resource library</a>

      {% if status %}
        {% if status.type == "success" %}
          {{ govukNotificationBanner({
            type: "success",
            titleText: status.title,
            text: status.message
          }) }}
        {% else %}
          {{ govukErrorSummary({
            titleText: status.title,
            errorList: [{ text: status.message, href: "#" + (status.anchor or "comments") }]
          }) }}
        {% endif %}
      {% endif %}

      <span class="govuk-caption-l">Discussion</span>
      <h1 class="govuk-heading-xl">{{ resourceTitle }}</h1>

      <section id="resource-reactions" class="govuk-!-margin-bottom-6">
        <h2 class="govuk-heading-m">Reactions</h2>
        <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1" aria-live="polite">
          {% if reactions.total == 1 %}1 reaction{% elif reactions.total > 1 %}{{ reactions.total }} reactions{% else %}No reactions{% endif %}
        </p>
        <fieldset class="govuk-fieldset">
          <legend class="govuk-fieldset__legend govuk-fieldset__legend--s govuk-visually-hidden">Reactions</legend>
          <div class="nexus-alpha-actions govuk-button-group govuk-!-margin-bottom-2">
            {% for reactionType, reactionLabel in reactionLabels %}
              {% set typeCount = reactions.counts[reactionType] or 0 %}
              <form method="post" action="{{ urlFor('/resources/' + (resourceId | string) + '/react') }}" class="nexus-alpha-reaction-form">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <input type="hidden" name="emoji" value="{{ reactionType }}">
                <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0{% if reactions.userReaction == reactionType %} nexus-alpha-reaction--active{% endif %}" data-module="govuk-button" aria-pressed="{% if reactions.userReaction == reactionType %}true{% else %}false{% endif %}">
                  {{ reactionLabel }}{% if typeCount > 0 %} ({{ typeCount }}){% endif %}
                  <span class="govuk-visually-hidden"> for this resource</span>
                </button>
              </form>
            {% endfor %}
          </div>
        </fieldset>
      </section>

      <hr class="govuk-section-break govuk-section-break--visible govuk-section-break--l">

      <section id="comments">
        <h2 class="govuk-heading-l">Comments <span class="govuk-!-font-weight-regular">({{ commentsTotal }})</span></h2>

        {% if not comments.length %}
          <div class="govuk-inset-text"><p class="govuk-body">No comments yet. Be the first to comment.</p></div>
        {% else %}
          <ol class="govuk-list nexus-alpha-comments-list">
            {% for comment in comments %}
              {{ renderComment(comment, resourceId, currentUserId, csrfToken) }}
            {% endfor %}
          </ol>
        {% endif %}

        <h3 class="govuk-heading-m govuk-!-margin-top-6">Add a comment</h3>
        <form method="post" action="{{ urlFor('/resources/' + (resourceId | string) + '/comments/add') }}">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <div class="govuk-form-group{% if status and status.anchor == 'body' %} govuk-form-group--error{% endif %}">
            <label class="govuk-label govuk-label--s" for="body">Your comment</label>
            <div id="body-hint" class="govuk-hint">Share your thoughts about this resource.</div>
            {% if status and status.anchor == 'body' %}
              <p id="body-error" class="govuk-error-message"><span class="govuk-visually-hidden">There is a problem:</span> {{ status.message }}</p>
            {% endif %}
            <textarea class="govuk-textarea" id="body" name="body" rows="4" maxlength="5000" aria-describedby="body-hint{% if status and status.anchor == 'body' %} body-error{% endif %}"></textarea>
          </div>
          <button type="submit" class="govuk-button" data-module="govuk-button">Post comment</button>
        </form>
      </section>
    </div>
  </div>
{% endblock %}
