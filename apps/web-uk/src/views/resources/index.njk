{% extends "layouts/base.njk" %}

{% block mainContent %}
  <span class="govuk-caption-xl">This community</span>
  <h1 class="govuk-heading-xl">Resources</h1>
  <p class="govuk-body-l">Guides and reference materials shared with the community.</p>

  <p class="govuk-body govuk-!-margin-bottom-6">
    <a class="govuk-link" href="{{ urlFor('/resources/library') }}">Open the full resource library</a>
  </p>

  <form method="get" action="{{ urlFor('/resources') }}" class="govuk-!-margin-bottom-6">
    <div class="govuk-form-group">
      <label class="govuk-label" for="q">Find a resource</label>
      <div id="q-hint" class="govuk-hint">Search by title.</div>
      <input class="govuk-input govuk-!-width-two-thirds" id="q" name="q" type="search" value="{{ resourcesQuery }}" aria-describedby="q-hint">
    </div>
    <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">Search</button>
  </form>

  {% if not resources.length %}
    <div class="govuk-inset-text"><p class="govuk-body">There are no resources yet.</p></div>
  {% else %}
    <div class="nexus-alpha-card-list">
      {% for resource in resources %}
        <article class="nexus-alpha-card" id="resource-{{ resource.id }}">
          <div class="nexus-alpha-module-row">
            <h2 class="govuk-heading-s govuk-!-margin-bottom-1">{{ resource.title }}</h2>
            {% if resource.type %}<strong class="govuk-tag govuk-tag--grey">{{ resource.type }}</strong>{% endif %}
          </div>

          {% if resource.description %}
            <p class="govuk-body govuk-!-margin-bottom-2">{{ resource.description }}</p>
          {% endif %}

          {% if resource.href %}
            <a class="govuk-link" href="{{ resource.href }}" rel="noopener" aria-label="Download {{ resource.title }}">Download</a>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% endif %}
{% endblock %}
