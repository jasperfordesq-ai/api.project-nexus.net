{% extends "layouts/base.njk" %}

{% block mainContent %}
  <a class="govuk-back-link" href="{{ urlFor('/resources/library') }}">Back to resource library</a>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <span class="govuk-caption-l">Resource library</span>
      <h1 class="govuk-heading-xl">Delete resource</h1>

      <div class="govuk-warning-text">
        <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
        <strong class="govuk-warning-text__text">
          <span class="govuk-visually-hidden">Warning:</span>
          {{ t("polish_discovery.delete_post_warning") }}
        </strong>
      </div>

      <p class="govuk-body">Are you sure you want to delete {{ resourceTitle }}?</p>

      <form method="post" action="{{ urlFor('/resources/' + (resourceId | string) + '/delete') }}" novalidate>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <div class="govuk-button-group">
          <button class="govuk-button govuk-button--warning" data-module="govuk-button" type="submit">Delete resource</button>
          <a class="govuk-link" href="{{ urlFor('/resources/library') }}">{{ t("polish_federation.transfer_cancel") }}</a>
        </div>
      </form>
    </div>
  </div>
{% endblock %}
