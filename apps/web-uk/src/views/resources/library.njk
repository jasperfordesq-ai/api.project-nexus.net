{% extends "layouts/base.njk" %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% macro categoryList(categories, selectedCategory, searchQuery, reorderMode) %}
  {% for category in categories %}
    <li>
      <a class="govuk-link{% if selectedCategory == category.id %} govuk-!-font-weight-bold{% endif %}"
         {% if selectedCategory == category.id %}aria-current="true"{% endif %}
         href="/resources/library?{% if searchQuery %}q={{ searchQuery | urlencode }}&amp;{% endif %}category_id={{ category.id }}{% if reorderMode %}&amp;reorder=1{% endif %}">
        {{ category.name }}{% if category.resourceCount > 0 %} <span class="nexus-alpha-meta">({{ category.resourceCount }})</span>{% endif %}
      </a>
      {% if category.children and category.children.length %}
        <ul class="govuk-list govuk-!-margin-bottom-0 govuk-!-margin-left-3">
          {{ categoryList(category.children, selectedCategory, searchQuery, reorderMode) }}
        </ul>
      {% endif %}
    </li>
  {% endfor %}
{% endmacro %}

{% block mainContent %}
  {% if status %}
    {% if status.type == "success" %}
      {{ govukNotificationBanner({
        type: "success",
        titleText: status.title,
        text: status.message
      }) }}
    {% else %}
      {{ govukErrorSummary({
        titleText: status.title,
        errorList: [{ text: status.message, href: "#q" }]
      }) }}
    {% endif %}
  {% endif %}

  <span class="govuk-caption-xl">Resources in this community</span>
  <h1 class="govuk-heading-xl">Resource library</h1>
  <p class="govuk-body-l">Browse and download files, guides and templates shared by the community.</p>

  <div class="govuk-button-group govuk-!-margin-bottom-6">
    <a class="govuk-button" href="/resources/upload" role="button" draggable="false" data-module="govuk-button">Upload a resource</a>
    {% if isAdmin %}
      {% if reorderMode %}
        <a class="govuk-link" href="{{ reorderOffHref }}">Done reordering</a>
      {% else %}
        <a class="govuk-link" href="{{ reorderOnHref }}">Reorder resources</a>
      {% endif %}
    {% endif %}
    <a class="govuk-link" href="/resources">Switch to the simple list</a>
  </div>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-one-third">
      <nav class="nexus-alpha-card" aria-label="Categories">
        <h2 class="govuk-heading-s">Categories</h2>
        {% set categories = categoryTree if categoryTree and categoryTree.length else flatCategories %}
        {% if not categories.length %}
          <p class="govuk-body-s nexus-alpha-meta">No categories yet.</p>
        {% else %}
          <ul class="govuk-list govuk-!-margin-bottom-0">
            <li>
              <a class="govuk-link{% if not selectedCategory %} govuk-!-font-weight-bold{% endif %}"
                 {% if not selectedCategory %}aria-current="true"{% endif %}
                 href="/resources/library{% if searchQuery or reorderMode %}?{% if searchQuery %}q={{ searchQuery | urlencode }}{% endif %}{% if searchQuery and reorderMode %}&amp;{% endif %}{% if reorderMode %}reorder=1{% endif %}{% endif %}">
                All categories
              </a>
            </li>
            {{ categoryList(categories, selectedCategory, searchQuery, reorderMode) }}
          </ul>
        {% endif %}
      </nav>
    </div>

    <div class="govuk-grid-column-two-thirds">
      <form method="get" action="/resources/library" class="govuk-!-margin-bottom-6">
        {% if selectedCategory %}
          <input type="hidden" name="category_id" value="{{ selectedCategory }}">
        {% endif %}
        {% if reorderMode %}
          <input type="hidden" name="reorder" value="1">
        {% endif %}
        <div class="govuk-form-group">
          <label class="govuk-label" for="q">Search resources</label>
          <div id="q-hint" class="govuk-hint">Search by title or description.</div>
          <input class="govuk-input govuk-!-width-two-thirds" id="q" name="q" type="search" value="{{ searchQuery }}" aria-describedby="q-hint">
        </div>
        <div class="govuk-button-group">
          <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">Search</button>
          {% if hasFilters %}
            <a class="govuk-link" href="{{ clearHref }}">Clear search</a>
          {% endif %}
        </div>
      </form>

      <p class="govuk-body nexus-alpha-result-count" aria-live="polite">{{ resourceCountText }}</p>

      {% if not resources.length %}
        <div class="govuk-inset-text">
          <h2 class="govuk-heading-m">No resources found</h2>
          <p class="govuk-body">{% if hasFilters %}No resources match your search. Try a different word or clear the filters.{% else %}No resources have been shared yet.{% endif %}</p>
          <h3 class="govuk-heading-s">You can share:</h3>
          <ul class="govuk-list govuk-list--bullet">
            <li>How-to guides and instructions</li>
            <li>Reusable templates and forms</li>
            <li>Documents, spreadsheets and images</li>
          </ul>
        </div>
      {% else %}
        <div class="nexus-alpha-card-list">
          {% for resource in resources %}
            <article class="nexus-alpha-card" id="resource-{{ resource.id }}">
              <div class="nexus-alpha-module-row">
                <h3 class="govuk-heading-s govuk-!-margin-bottom-1">{{ resource.title }}</h3>
                <strong class="govuk-tag govuk-tag--grey">{{ resource.fileExtension }}</strong>
              </div>

              {% if resource.category %}
                <p class="govuk-!-margin-bottom-2"><strong class="govuk-tag govuk-tag--grey">{{ resource.category.name }}</strong></p>
              {% endif %}

              {% if resource.description %}
                <p class="govuk-body govuk-!-margin-bottom-2">{{ resource.description }}</p>
              {% endif %}

              <dl class="nexus-alpha-inline-list govuk-!-margin-bottom-2">
                {% if resource.uploaderName %}
                  <div>
                    <dt>Uploaded by</dt>
                    <dd>{{ resource.uploaderName }}</dd>
                  </div>
                {% endif %}
                {% if resource.fileSize %}
                  <div>
                    <dt>Size</dt>
                    <dd>{{ resource.fileSize }}</dd>
                  </div>
                {% endif %}
                {% if resource.createdAt %}
                  <div>
                    <dt>Uploaded</dt>
                    <dd>{{ resource.createdAt }}</dd>
                  </div>
                {% endif %}
                <div>
                  <dt>Downloads</dt>
                  <dd>{{ resource.downloads }}</dd>
                </div>
              </dl>

              <div class="nexus-alpha-actions">
                {% if resource.downloadHref %}
                  <a class="govuk-link govuk-link--no-visited-state" href="{{ resource.downloadHref }}" aria-label="Download {{ resource.title }}">Download</a>
                {% endif %}
                {% if resource.canManage %}
                  <a class="govuk-link" href="/resources/{{ resource.id }}/delete" aria-label="Delete {{ resource.title }}">Delete</a>
                {% endif %}
              </div>

              <div class="nexus-alpha-actions govuk-!-margin-top-2" aria-label="Social interactions">
                <form method="post" action="/resources/{{ resource.id }}/react" class="nexus-alpha-reaction-form govuk-!-display-inline">
                  <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                  <input type="hidden" name="emoji" value="like">
                  <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button" aria-label="Like {{ resource.title }}">
                    Like{% if resource.likeCount > 0 %} ({{ resource.likeCount }}){% endif %}
                  </button>
                </form>
                <a class="govuk-link" href="{{ resource.commentsHref }}" aria-label="View comments for {{ resource.title }}">
                  {% if resource.commentCount == 1 %}1 comment{% elif resource.commentCount > 1 %}{{ resource.commentCount }} comments{% else %}No comments{% endif %}
                </a>
              </div>

              {% if reorderMode and isAdmin %}
                <div class="nexus-alpha-actions govuk-!-margin-top-2">
                  {% if loop.index0 > 0 %}
                    <form method="post" action="/resources/reorder" class="govuk-!-display-inline">
                      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                      <input type="hidden" name="resource_id" value="{{ resource.id }}">
                      <input type="hidden" name="direction" value="up">
                      <input type="hidden" name="q" value="{{ searchQuery }}">
                      <input type="hidden" name="category_id" value="{{ selectedCategory or '' }}">
                      <input type="hidden" name="reorder" value="1">
                      <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button" aria-label="Move {{ resource.title }} up">Move up</button>
                    </form>
                  {% endif %}
                  {% if loop.index < resources.length %}
                    <form method="post" action="/resources/reorder" class="govuk-!-display-inline">
                      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                      <input type="hidden" name="resource_id" value="{{ resource.id }}">
                      <input type="hidden" name="direction" value="down">
                      <input type="hidden" name="q" value="{{ searchQuery }}">
                      <input type="hidden" name="category_id" value="{{ selectedCategory or '' }}">
                      <input type="hidden" name="reorder" value="1">
                      <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button" aria-label="Move {{ resource.title }} down">Move down</button>
                    </form>
                  {% endif %}
                </div>
              {% endif %}
            </article>
          {% endfor %}
        </div>

        {% if loadMoreHref %}
          <nav class="govuk-pagination govuk-pagination--block govuk-!-margin-top-6" aria-label="Load more resources">
            <div class="govuk-pagination__next">
              <a class="govuk-link govuk-pagination__link" rel="next" href="{{ loadMoreHref }}">
                <span class="govuk-pagination__link-title">Load more resources</span>
              </a>
            </div>
          </nav>
        {% endif %}
      {% endif %}
    </div>
  </div>
{% endblock %}
