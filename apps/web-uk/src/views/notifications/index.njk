{% extends "layouts/base.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if successMessage %}
        {% set notificationMessage = successMessage %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      {% if status == "marked-read" or status == "notification-deleted" or status == "notification-marked-read" or status == "all-notifications-deleted" or status == "group-marked-read" %}
        <div class="govuk-notification-banner govuk-notification-banner--success" role="alert" aria-labelledby="notification-status-title" data-module="govuk-notification-banner">
          <div class="govuk-notification-banner__header">
            <h2 class="govuk-notification-banner__title" id="notification-status-title">{{ t("states.success_title") }}</h2>
          </div>
          <div class="govuk-notification-banner__content">
            <p class="govuk-notification-banner__heading">{{ t("notifications.states." + status) }}</p>
          </div>
        </div>
      {% endif %}

      <span class="govuk-caption-xl">{{ t("notifications.caption", { community: communityName }) }}</span>
      <h1 class="govuk-heading-xl">
        {{ t("notifications.title") }}
        {% if unreadCount > 0 %}
          <span class="govuk-tag govuk-tag--blue govuk-!-margin-left-2">{{ t("notifications.unread_count", { count: unreadCount }) }}</span>
        {% endif %}
      </h1>
      <p class="govuk-body-l">{{ t("notifications.description") }}</p>

      <div class="govuk-!-margin-bottom-6">
        <div class="app-notification-filters">
          <a href="{{ urlFor('/notifications') }}" class="govuk-link govuk-link--no-visited-state{% if not showUnreadOnly %} govuk-!-font-weight-bold{% endif %}"{% if not showUnreadOnly %} aria-current="page"{% endif %}>{{ t("notifications.all_filter") }}</a>
          <span class="govuk-!-margin-left-2 govuk-!-margin-right-2">|</span>
          <a href="{{ urlFor('/notifications?filter=unread') }}" class="govuk-link govuk-link--no-visited-state{% if showUnreadOnly %} govuk-!-font-weight-bold{% endif %}"{% if showUnreadOnly %} aria-current="page"{% endif %}>{{ t("notifications.unread_filter") }}{% if unreadCount > 0 %} ({{ unreadCount }}){% endif %}</a>
        </div>

        {% if unreadCount > 0 %}
          <form method="post" action="{{ urlFor('/notifications/read-all') }}" class="govuk-!-margin-top-3" style="display: inline">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <button type="submit" class="govuk-button govuk-button--secondary" data-module="govuk-button">
              {{ t("notifications.mark_all_read") }}
            </button>
          </form>
        {% endif %}

        {% if notifications and notifications.length > 0 %}
          <details class="govuk-details govuk-!-margin-top-3" data-module="govuk-details">
            <summary class="govuk-details__summary"><span class="govuk-details__summary-text">{{ t("notifications.delete_all") }}</span></summary>
            <div class="govuk-details__text">
              <div class="govuk-warning-text">
                <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
                <strong class="govuk-warning-text__text"><span class="govuk-warning-text__assistive">{{ t("states.warning_prefix") }}</span> {{ t("notifications.delete_all_warning") }}</strong>
              </div>
              <form method="post" action="{{ urlFor('/notifications/delete-all') }}">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <button type="submit" class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("polish_discovery.notifications_delete_confirm_button") }}</button>
              </form>
            </div>
          </details>
        {% endif %}
      </div>

      {% if notifications and notifications.length > 0 %}
        <ul class="govuk-list app-notification-list">
          {% for notification in notifications %}
            {% set notificationLink = notification.link if notification.link else null %}
            {% set isGrouped = notification.isGrouped %}
            {% set notificationUnread = notification.unread %}
            {% set notificationText = notification.displayText %}
            {% set notificationWhen = notification.displayWhen %}

            <li class="app-notification-item{% if notificationUnread %} app-notification-item--unread{% endif %}">
              <div class="app-notification-content">
                <div class="app-notification-icon app-notification-icon--{{ notification.type }}">
                  {% if notification.type == 'connection_request' %}
                    <span aria-hidden="true">👤</span>
                  {% elif notification.type == 'connection_accepted' %}
                    <span aria-hidden="true">✓</span>
                  {% elif notification.type == 'connection_declined' %}
                    <span aria-hidden="true">✕</span>
                  {% elif notification.type == 'message_received' %}
                    <span aria-hidden="true">💬</span>
                  {% elif notification.type == 'transfer_received' %}
                    <span aria-hidden="true">💰</span>
                  {% else %}
                    <span aria-hidden="true">🔔</span>
                  {% endif %}
                </div>

                <div class="app-notification-body">
                  <p class="govuk-body govuk-!-margin-bottom-1">
                    <strong class="govuk-tag govuk-tag--{{ notification.categoryColour }}">{{ notification.categoryLabel }}</strong>
                    {% if notificationLink %}
                      <a class="govuk-link govuk-link--no-visited-state" href="{{ urlFor(notificationLink) }}"><strong class="govuk-!-font-weight-bold">{{ notificationText }}</strong></a>
                    {% else %}
                      <strong class="govuk-!-font-weight-bold">{{ notificationText }}</strong>
                    {% endif %}
                    {% if isGrouped %}<span class="govuk-tag govuk-tag--purple">{{ t("notifications.group_tag", { count: notification.group_count or 1 }) }}</span>{% endif %}
                    {% if notificationUnread %}
                      <span class="govuk-tag govuk-tag--blue app-notification-badge">{{ t("notifications.new_tag") }}</span>
                    {% endif %}
                  </p>
                  {% if isGrouped and notification.actors and notification.actors.length > 0 %}
                    {% set actorNames = notification.actors | join(", ", "name") %}
                    <p class="govuk-body-s govuk-!-margin-bottom-1">
                      {% if (notification.remaining_count or 0) > 0 %}
                        {{ t("notifications.actors_and_more", { names: actorNames, count: notification.remaining_count }) }}
                      {% else %}
                        {{ t("notifications.actors_label", { names: actorNames }) }}
                      {% endif %}
                    </p>
                  {% endif %}
                  <p class="govuk-body-s govuk-!-margin-bottom-0 app-notification-time">
                    {{ notificationWhen }}
                  </p>
                </div>

                <div class="app-notification-actions">
                  {% if isGrouped and notificationUnread and notification.group_key %}
                    <form method="post" action="{{ urlFor('/notifications/group/read') }}" style="display: inline">
                      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                      <input type="hidden" name="group_key" value="{{ notification.group_key }}">
                      <button type="submit" class="govuk-link app-link-button">{{ t("notifications.mark_group_read") }}</button>
                    </form>
                  {% elif not isGrouped and notificationUnread %}
                    <form method="post" action="{{ urlFor('/notifications/' + (notification.id | string) + '/read') }}" style="display: inline">
                      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                      <button type="submit" class="govuk-link app-link-button">{{ t("notifications.mark_read") }}</button>
                    </form>
                  {% endif %}

                  {% if not isGrouped %}
                    <form method="post" action="{{ urlFor('/notifications/' + (notification.id | string) + '/delete') }}" style="display: inline" class="govuk-!-margin-left-2">
                      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                      <button type="submit" class="govuk-link app-link-button app-link-button--warning">{{ t("notifications.delete") }}</button>
                    </form>
                  {% endif %}
                </div>
              </div>
            </li>
          {% endfor %}
        </ul>

        {% if meta.has_more and meta.cursor %}
          <p class="govuk-body govuk-!-margin-top-4">
            <a class="govuk-link" rel="next" href="{{ urlFor('/notifications?' + ('filter=unread&' if showUnreadOnly else '') + 'cursor=' + (meta.cursor | urlencode)) }}">{{ t("notifications.load_more") }}</a>
          </p>
        {% endif %}

      {% else %}
        <div class="govuk-inset-text"><p class="govuk-body">{{ t("notifications.empty") }}</p></div>
      {% endif %}

    </div>
  </div>
{% endblock %}
