{% extends "layouts/base.njk" %}

{% block mainContent %}
  {% if successMessage %}
    {% set notificationMessage = successMessage %}
    {% set notificationType = "success" %}
    {% include "partials/notification-banner.njk" %}
  {% endif %}

  {% if status == "marked-read" or status == "notification-deleted" or status == "notification-marked-read" or status == "all-notifications-deleted" %}
    <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="notification-status-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="notification-status-title">{{ t("states.success_title") }}</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ t("notifications.states." + status) }}</p>
      </div>
    </div>
  {% endif %}

  <span class="govuk-caption-xl">{{ t("notifications.caption", { community: communityName }) }}</span>
  <h1 class="govuk-heading-xl">{{ t("notifications.title") }}</h1>
  <p class="govuk-body-l">{{ t("notifications.description") }}</p>

  <div class="govuk-!-margin-bottom-4">
    <p class="govuk-body govuk-!-margin-bottom-2">
      <a class="govuk-link govuk-link--no-visited-state{% if not showUnreadOnly %} govuk-!-font-weight-bold{% endif %}" href="{{ urlFor('/notifications') }}"{% if not showUnreadOnly %} aria-current="true"{% endif %}>{{ t("notifications.all_filter") }}</a>
      &nbsp;&middot;&nbsp;
      <a class="govuk-link govuk-link--no-visited-state{% if showUnreadOnly %} govuk-!-font-weight-bold{% endif %}" href="{{ urlFor('/notifications?filter=unread') }}"{% if showUnreadOnly %} aria-current="true"{% endif %}>{{ t("notifications.unread_filter") }}{% if unreadCount > 0 %} ({{ unreadCount }}){% endif %}</a>
    </p>
    <div class="govuk-button-group govuk-!-margin-bottom-2">
      {% if unreadCount > 0 %}
        <form method="post" action="{{ urlFor('/notifications/read-all') }}">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("notifications.mark_all_read") }}</button>
        </form>
      {% endif %}
    </div>
    {% if notifications and notifications.length > 0 %}
      <details class="govuk-details govuk-!-margin-bottom-2" data-module="govuk-details">
        <summary class="govuk-details__summary"><span class="govuk-details__summary-text">{{ t("notifications.delete_all") }}</span></summary>
        <div class="govuk-details__text">
          <div class="govuk-warning-text">
            <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
            <strong class="govuk-warning-text__text"><span class="govuk-visually-hidden">{{ t("states.warning_prefix") }}</span> {{ t("polish_discovery.notifications_delete_confirm_warning") }}</strong>
          </div>
          <form method="post" action="{{ urlFor('/notifications/delete-all') }}">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <button class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("polish_discovery.notifications_delete_confirm_button") }}</button>
          </form>
        </div>
      </details>
    {% endif %}
  </div>

  {% if notifications and notifications.length > 0 %}
    {% for notification in notifications %}
      {% set notificationLink = notification.link if notification.link else null %}
      <div class="nexus-alpha-card govuk-!-margin-bottom-3">
        <div class="nexus-alpha-module-row">
          <p class="govuk-body govuk-!-margin-bottom-1">
            <strong class="govuk-tag govuk-tag--{{ notification.categoryColour }}">{{ notification.categoryLabel }}</strong>
            {% if notification.isGrouped %}<strong class="govuk-tag govuk-tag--purple">{{ t("notifications.group_tag", { count: notification.group_count or 1 }) }}</strong>{% endif %}
            {% if notification.unread %}<strong class="govuk-tag govuk-tag--blue">{{ t("notifications.new_tag") }}</strong>{% endif %}
            {% if notificationLink %}<a class="govuk-link govuk-link--no-visited-state" href="{{ urlFor(notificationLink) }}">{{ notification.displayText }}</a>{% else %}{{ notification.displayText }}{% endif %}
          </p>
          <div class="nexus-alpha-actions">
            {% if notification.isGrouped and notification.unread and notification.group_key %}
              <form method="post" action="{{ urlFor('/notifications/group/read') }}" class="nexus-alpha-linkform">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <input type="hidden" name="group_key" value="{{ notification.group_key }}">
                <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("notifications.mark_group_read") }}</button>
              </form>
            {% elif not notification.isGrouped and notification.unread %}
              <form method="post" action="{{ urlFor('/notifications/' + (notification.id | string) + '/read') }}" class="nexus-alpha-linkform">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("notifications.mark_read") }}</button>
              </form>
            {% endif %}
            {% if not notification.isGrouped %}
              <form method="post" action="{{ urlFor('/notifications/' + (notification.id | string) + '/delete') }}" class="nexus-alpha-linkform">
                <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                <button class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" data-module="govuk-button">{{ t("notifications.delete") }}</button>
              </form>
            {% endif %}
          </div>
        </div>
        {% if notification.isGrouped and notification.actors and notification.actors.length > 0 %}
          {% set actorNames = notification.actors | join(", ", "name") %}
          <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-1">
            {% if (notification.remaining_count or 0) > 0 %}{{ t("notifications.actors_and_more", { names: actorNames, count: notification.remaining_count }) }}{% else %}{{ t("notifications.actors_label", { names: actorNames }) }}{% endif %}
          </p>
        {% endif %}
        {% if notification.displayWhen %}<p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-0">{{ notification.displayWhen }}</p>{% endif %}
      </div>
    {% endfor %}

    {% if meta.has_more and meta.cursor %}
      <p class="govuk-body govuk-!-margin-top-4">
        <a class="govuk-link" href="{{ urlFor('/notifications?' + ('filter=unread&' if showUnreadOnly else '') + 'cursor=' + (meta.cursor | urlencode)) }}">{{ t("notifications.load_more") }}</a>
      </p>
    {% endif %}
  {% else %}
    <div class="govuk-inset-text"><p class="govuk-body">{{ t("notifications.empty") }}</p></div>
  {% endif %}
{% endblock %}
