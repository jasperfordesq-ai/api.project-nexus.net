{% extends "layouts/base.njk" %}

{% block pageTitle %}{{ t("auth.forgot_title") }} - {{ serviceName }}{% endblock %}

{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <a class="govuk-back-link" href="{{ urlFor('/login') }}">{{ t("auth.back_to_sign_in") }}</a>

      {% if forgotSent %}
        <h1 class="govuk-heading-xl">{{ t("auth.forgot_sent_title") }}</h1>
        <p class="govuk-body-l">{{ t("auth.forgot_sent_detail") }}</p>
        <p class="govuk-body">
          <a class="govuk-link" href="{{ urlFor('/login/forgot-password') }}">{{ t("auth.forgot_resend") }}</a>
        </p>
        <p class="govuk-body">
          <a class="govuk-link" href="{{ urlFor('/login') }}">{{ t("auth.back_to_sign_in") }}</a>
        </p>
      {% else %}

        {% if errors and errors.length %}
          {{ govukErrorSummary({
            titleText: t("states.error_title"),
            errorList: errors
          }) }}
        {% endif %}

        <h1 class="govuk-heading-xl">{{ t("auth.forgot_title") }}</h1>

        <p class="govuk-body-l">
          {{ t("auth.forgot_description") }}
        </p>

      <form method="post" action="{{ urlFor(formAction or '/login/forgot-password') }}" novalidate>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        {{ govukInput({
          label: {
            text: t("auth.forgot_email_label"),
            classes: "govuk-label--m"
          },
          hint: {
            text: t("auth.forgot_email_hint")
          },
          id: "email",
          name: "email",
          type: "email",
          autocomplete: "email",
          spellcheck: false,
          value: values.email if values else "",
          errorMessage: { text: fieldErrors.email } if fieldErrors.email else undefined
        }) }}

        {% if tenantSlug %}
          <input type="hidden" name="tenant_slug" value="{{ tenantSlug }}">
        {% else %}
          {{ govukInput({
            label: {
              text: "Community code",
              classes: "govuk-label--m"
            },
            hint: {
              text: "The code for your community (e.g. 'acme')"
            },
            id: "tenant_slug",
            name: "tenant_slug",
            value: values.tenant_slug if values else "",
            errorMessage: { text: fieldErrors.tenant_slug } if fieldErrors.tenant_slug else undefined
          }) }}
        {% endif %}

        {# Turnstile widget removed from forgot-password 2026-05-15 — was silently dropping legit requests #}

        {{ govukButton({
          text: t("auth.forgot_submit")
        }) }}
      </form>

        <p class="govuk-body govuk-!-margin-top-6">
          <a href="{{ urlFor('/login') }}" class="govuk-link">{{ t("auth.back_to_sign_in") }}</a>
        </p>
      {% endif %}

    </div>
  </div>
{% endblock %}
