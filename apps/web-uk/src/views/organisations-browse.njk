{% extends "layouts/base.njk" %}

{% block mainContent %}
  <span class="govuk-caption-xl">Organisations in {{ tenantName }}</span>
  <h1 class="govuk-heading-xl">{{ t("vol_org.browse_link") }}</h1>
  <p class="govuk-body-l">Find volunteer organisations in your community and the opportunities they offer.</p>

  {% if error %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            <li><a href="#q">We could not load the organisations. Please try again.</a></li>
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  <div class="govuk-button-group">
    {% if manageableCount > 0 %}
      <a class="govuk-button govuk-button--secondary" data-module="govuk-button" href="{{ urlFor('/organisations/manage') }}">Manage my organisations</a>
    {% endif %}
    <a class="govuk-button" data-module="govuk-button" href="{{ urlFor('/organisations/register') }}">{{ t("organisations.register_title") }}</a>
  </div>

  <form method="get" action="{{ urlFor('/organisations/browse') }}" class="govuk-!-margin-bottom-7">
    <div class="govuk-form-group">
      <label class="govuk-label" for="q">Search organisations</label>
      <div id="q-hint" class="govuk-hint">Search by name or description.</div>
      <input class="govuk-input govuk-!-width-two-thirds" id="q" name="q" type="search" value="{{ organisationsQuery }}" aria-describedby="q-hint">
    </div>
    <button class="govuk-button govuk-button--secondary" data-module="govuk-button" type="submit">Search</button>
  </form>

  {% if organisations and organisations.length %}
    <p class="govuk-body">
      {% if organisations.length == 1 %}
        1 organisation
      {% else %}
        {{ organisations.length }} organisations
      {% endif %}
    </p>

    <div class="nexus-alpha-card-list govuk-!-margin-bottom-7">
      {% for organisation in organisations %}
        <article class="nexus-alpha-card">
          <h2 class="govuk-heading-m govuk-!-margin-bottom-2">
            <a class="govuk-link" href="{{ urlFor('/organisations/' + (organisation.id | string)) }}">{{ organisation.name }}</a>
          </h2>

          {% if organisation.summary %}
            <p class="govuk-body">{{ organisation.summary }}</p>
          {% endif %}

          <ul class="govuk-list govuk-list--spaced govuk-!-margin-bottom-4">
            <li>
              {% if organisation.opportunityCount == 0 %}
                No opportunities
              {% elseif organisation.opportunityCount == 1 %}
                1 opportunity
              {% else %}
                {{ organisation.opportunityCount }} opportunities
              {% endif %}
            </li>
            {% if organisation.volunteerCount > 0 %}
              <li>{{ organisation.volunteerCount }} volunteers</li>
            {% endif %}
            {% if organisation.totalHours > 0 %}
              <li>{{ organisation.totalHours }} hours logged</li>
            {% endif %}
            {% if organisation.averageRating > 0 %}
              <li>{{ organisation.averageRating }} out of 5</li>
            {% endif %}
            {% if organisation.hasWebsite %}
              <li>Has a website</li>
            {% endif %}
          </ul>

          <a class="govuk-link" href="{{ urlFor('/organisations/' + (organisation.id | string)) }}">{{ t("organisations.view") }}</a>
        </article>
      {% endfor %}
    </div>

    {% if hasMore and loadMoreHref %}
      <p class="govuk-body">
        <a class="govuk-link" href="{{ urlFor(loadMoreHref) }}">Load more organisations</a>
      </p>
    {% endif %}
  {% else %}
    <div class="govuk-inset-text">
      <h2 class="govuk-heading-m">No organisations found</h2>
      {% if organisationsQuery %}
        <p class="govuk-body">No organisations match your search. Try a different word or clear the search.</p>
      {% else %}
        <p class="govuk-body">No organisations have been listed yet.</p>
      {% endif %}
    </div>
  {% endif %}
{% endblock %}
