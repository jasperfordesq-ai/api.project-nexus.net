{% extends "layouts/base.njk" %}

{% block mainContent %}
  {% set hasErrors = errors and (errors.summary or errors.description or errors.impact) %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <span class="govuk-caption-l">{{ t("report_problem.caption", { service: tenantName }) }}</span>
      <h1 class="govuk-heading-xl">{{ t("report_problem.title") }}</h1>

      {% if status == 'sent' %}
        <div class="govuk-panel govuk-panel--confirmation">
          <h2 class="govuk-panel__title">{{ t("report_problem.success_title") }}</h2>
          {% if reference %}
            <div class="govuk-panel__body">{{ t("report_problem.success_body", { ref: reference }) }}</div>
          {% endif %}
        </div>
        <p class="govuk-body govuk-!-margin-top-6">
          <a class="govuk-link" href="{{ urlFor(pageUrl or '/') }}">{{ t("report_problem.back") }}</a>
        </p>
      {% else %}
        {% if hasErrors %}
          <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
            <div role="alert">
              <h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2>
              <div class="govuk-error-summary__body">
                <ul class="govuk-list govuk-error-summary__list">
                  {% if errors.summary %}<li><a href="#summary">{{ errors.summary }}</a></li>{% endif %}
                  {% if errors.description %}<li><a href="#description">{{ errors.description }}</a></li>{% endif %}
                  {% if errors.impact %}<li><a href="#impact">{{ errors.impact }}</a></li>{% endif %}
                </ul>
              </div>
            </div>
          </div>
        {% elif status == 'failed' %}
          <div class="govuk-notification-banner" data-module="govuk-notification-banner" role="region" aria-labelledby="report-error-title">
            <div class="govuk-notification-banner__header">
              <h2 class="govuk-notification-banner__title" id="report-error-title">{{ t("states.error_title") }}</h2>
            </div>
            <div class="govuk-notification-banner__content">
              <p class="govuk-notification-banner__heading">{{ t("contact.error_fallback") }}</p>
            </div>
          </div>
        {% endif %}

        <p class="govuk-body-l">{{ t("report_problem.intro") }}</p>

        <form method="post" action="{{ urlFor('/report-a-problem') }}" novalidate>
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <input type="hidden" name="page_url" value="{{ pageUrl }}">

          <p class="govuk-body">
            {{ t("report_problem.page_label") }}:
            <span class="govuk-!-font-weight-bold">{{ pageUrl }}</span>
          </p>

          <div class="govuk-form-group{% if errors.summary %} govuk-form-group--error{% endif %}">
            <label class="govuk-label govuk-label--s" for="summary">{{ t("report_problem.summary_label") }}</label>
            <div id="summary-hint" class="govuk-hint">{{ t("report_problem.summary_hint") }}</div>
            {% if errors.summary %}
              <p id="summary-error" class="govuk-error-message"><span class="govuk-visually-hidden">{{ t("states.error_prefix") }}</span> {{ errors.summary }}</p>
            {% endif %}
            <input class="govuk-input{% if errors.summary %} govuk-input--error{% endif %}" id="summary" name="summary" type="text" maxlength="180" value="{{ values.summary or '' }}" aria-describedby="summary-hint{% if errors.summary %} summary-error{% endif %}">
          </div>

          <div class="govuk-form-group{% if errors.description %} govuk-form-group--error{% endif %}">
            <label class="govuk-label govuk-label--s" for="description">{{ t("report_problem.description_label") }}</label>
            <div id="description-hint" class="govuk-hint">{{ t("report_problem.description_hint") }}</div>
            {% if errors.description %}
              <p id="description-error" class="govuk-error-message"><span class="govuk-visually-hidden">{{ t("states.error_prefix") }}</span> {{ errors.description }}</p>
            {% endif %}
            <textarea class="govuk-textarea{% if errors.description %} govuk-textarea--error{% endif %}" id="description" name="description" rows="5" maxlength="5000" aria-describedby="description-hint{% if errors.description %} description-error{% endif %}">{{ values.description or '' }}</textarea>
          </div>

          <div class="govuk-form-group{% if errors.impact %} govuk-form-group--error{% endif %}">
            <fieldset class="govuk-fieldset" aria-describedby="{% if errors.impact %}impact-error{% endif %}">
              <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">{{ t("report_problem.impact_legend") }}</legend>
              {% if errors.impact %}
                <p id="impact-error" class="govuk-error-message"><span class="govuk-visually-hidden">{{ t("states.error_prefix") }}</span> {{ errors.impact }}</p>
              {% endif %}
              <div class="govuk-radios" data-module="govuk-radios" id="impact">
                {% for impact in impacts %}
                  <div class="govuk-radios__item">
                    <input class="govuk-radios__input" id="impact-{{ impact }}" name="impact" type="radio" value="{{ impact }}" {% if values.impact == impact %}checked{% endif %}>
                    <label class="govuk-label govuk-radios__label" for="impact-{{ impact }}">
                      {{ t("report_problem.impacts." + impact) }}
                    </label>
                  </div>
                {% endfor %}
              </div>
            </fieldset>
          </div>

          <button class="govuk-button" data-module="govuk-button" type="submit">{{ t("report_problem.submit") }}</button>
        </form>
      {% endif %}
    </div>
  </div>
{% endblock %}
