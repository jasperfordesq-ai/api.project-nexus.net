{% extends "layouts/base.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <span class="govuk-caption-l">{{ communityName }}</span>
      <h1 class="govuk-heading-xl">Knowledge base</h1>
      <p class="govuk-body-l">Guides and articles to help you get the most out of {{ communityName }}.</p>

      <form method="get" action="/kb" class="govuk-!-margin-bottom-6">
        <div class="govuk-form-group">
          <label class="govuk-label" for="q">Search the knowledge base</label>
          <div id="q-hint" class="govuk-hint">Search by title or content.</div>
          <input class="govuk-input govuk-!-width-two-thirds" id="q" name="q" type="search" value="{{ searchQuery }}" aria-describedby="q-hint">
        </div>
        <button class="govuk-button govuk-button--secondary" data-module="govuk-button" type="submit">Search</button>
      </form>

      <h2 class="govuk-heading-m">Articles</h2>

      {% if articles and articles.length %}
        <ul class="govuk-list nexus-alpha-card-list">
          {% for article in articles %}
            <li class="nexus-alpha-card">
              <h3 class="govuk-heading-s govuk-!-margin-bottom-1">
                <a class="govuk-link" href="/kb/{{ article.id }}">{{ article.title }}</a>
              </h3>
              {% if article.contentPreview %}
                <p class="govuk-body govuk-!-margin-bottom-1">{{ article.contentPreview }}</p>
              {% endif %}
              <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-0">
                {% if article.categoryName %}{{ article.categoryName }} &middot; {% endif %}{{ article.viewsLabel }}
              </p>
            </li>
          {% endfor %}
        </ul>

        {% if nextHref %}
          <nav class="govuk-pagination govuk-pagination--block" role="navigation" aria-label="More articles">
            <div class="govuk-pagination__next">
              <a class="govuk-link govuk-pagination__link" href="{{ nextHref }}" rel="next">
                <span class="govuk-pagination__link-title">Load more</span>
              </a>
            </div>
          </nav>
        {% endif %}
      {% else %}
        <div class="govuk-inset-text">
          {% if searchQuery %}No articles match your search.{% else %}No articles have been published yet.{% endif %}
        </div>
      {% endif %}
    </div>
  </div>
{% endblock %}
