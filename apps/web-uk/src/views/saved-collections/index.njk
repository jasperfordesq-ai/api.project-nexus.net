{% extends "layouts/base.njk" %}

{% block content %}
  {% set nameError = status == "collection-name-required" %}

  {% if nameError %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <ul class="govuk-list govuk-error-summary__list">
            <li><a href="#collection-name">{{ errorMessage }}</a></li>
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  <span class="govuk-caption-xl">Your saved collections at {{ tenant.name or tenant.slug or "Community" }}</span>
  <h1 class="govuk-heading-xl">My collections</h1>

  {% if successMessage %}
    <div class="govuk-notification-banner govuk-notification-banner--success" data-module="govuk-notification-banner" role="alert" aria-labelledby="saved-collections-status-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="saved-collections-status-title">There is a problem</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ successMessage }}</p>
      </div>
    </div>
  {% elseif errorMessage and not nameError %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">There is a problem</h2>
        <div class="govuk-error-summary__body">
          <p class="govuk-body">{{ errorMessage }}</p>
        </div>
      </div>
    </div>
  {% endif %}

  <p class="govuk-body-l">Group the listings, posts, events and other items you have saved into collections.</p>
  <p class="govuk-body"><a class="govuk-link" href="{{ urlFor('/saved') }}">Back to saved items</a></p>

  {% if collections and collections.length %}
    <ul class="govuk-list nexus-alpha-card-list">
      {% for collection in collections %}
        <li class="nexus-alpha-card">
          <h2 class="govuk-heading-m govuk-!-margin-bottom-1">
            <span class="nexus-alpha-avatar" style="background-color: {{ collection.color }}; width: 1rem; height: 1rem; display: inline-block; border-radius: 50%; vertical-align: middle;" aria-hidden="true"></span>
            <a class="govuk-link" href="{{ urlFor('/me/collections/' + (collection.id | string)) }}">{{ collection.name }}</a>
          </h2>
          <p class="govuk-body nexus-alpha-meta">
            {{ collection.countLabel }}
            <strong class="govuk-tag {% if collection.isPublic %}govuk-tag--blue{% else %}govuk-tag--grey{% endif %} govuk-!-margin-left-1">{{ collection.visibilityLabel }}</strong>
          </p>
          {% if collection.description %}
            <p class="govuk-body">{{ collection.description }}</p>
          {% endif %}
          <p class="govuk-body govuk-!-margin-bottom-0">
            <a class="govuk-link" href="{{ urlFor('/me/collections/' + (collection.id | string)) }}">View collection</a>
          </p>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <div class="govuk-inset-text">
      <h2 class="govuk-heading-m">You have no collections yet</h2>
      <p class="govuk-body">Create a collection to start grouping the items you save.</p>
    </div>
  {% endif %}

  <hr class="govuk-section-break govuk-section-break--visible govuk-section-break--l">
  <h2 class="govuk-heading-l">Create a collection</h2>
  <form method="post" action="{{ urlFor('/me/collections') }}">
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
    <div class="govuk-form-group{% if nameError %} govuk-form-group--error{% endif %}">
      <label class="govuk-label" for="collection-name">Collection name</label>
      <div id="collection-name-hint" class="govuk-hint">For example, "Skills I want to learn" or "Events to attend".</div>
      {% if nameError %}
        <p id="collection-name-error" class="govuk-error-message"><span class="govuk-visually-hidden">There is a problem:</span> {{ errorMessage }}</p>
      {% endif %}
      <input class="govuk-input govuk-!-width-two-thirds" id="collection-name" name="name" type="text" maxlength="255" aria-describedby="collection-name-hint{% if nameError %} collection-name-error{% endif %}">
    </div>

    <div class="govuk-form-group">
      <label class="govuk-label" for="collection-description">Description (optional)</label>
      <textarea class="govuk-textarea govuk-!-width-two-thirds" id="collection-description" name="description" rows="3"></textarea>
    </div>

    <div class="govuk-form-group">
      <fieldset class="govuk-fieldset">
        <legend class="govuk-fieldset__legend govuk-visually-hidden">Make this collection public</legend>
        <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
          <div class="govuk-checkboxes__item">
            <input class="govuk-checkboxes__input" id="collection-public" name="is_public" type="checkbox" value="1" aria-describedby="collection-public-hint">
            <label class="govuk-label govuk-checkboxes__label" for="collection-public">Make this collection public</label>
            <div id="collection-public-hint" class="govuk-hint govuk-checkboxes__hint">Public collections can be seen by other members on your profile.</div>
          </div>
        </div>
      </fieldset>
    </div>

    <button type="submit" class="govuk-button" data-module="govuk-button">Create collection</button>
  </form>
{% endblock %}
