{% extends "layouts/base.njk" %}

{% block mainContent %}
  {% if statusMessage %}
    <div class="govuk-notification-banner{% if statusMessage.type == 'success' %} govuk-notification-banner--success{% endif %}" role="region" aria-labelledby="matches-status-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="matches-status-title">{{ "Success" if statusMessage.type == "success" else "Important" }}</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ statusMessage.text }}</p>
      </div>
    </div>
  {% endif %}

  <span class="govuk-caption-xl">Community</span>
  <h1 class="govuk-heading-xl">Your matches</h1>
  <p class="govuk-body-l">Members whose offers and requests fit yours, ranked by how well they match.</p>
  <p class="govuk-body"><a class="govuk-link" href="/matches/board">Open the matches board</a></p>

  <dl class="govuk-summary-list govuk-!-margin-bottom-6">
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Total matches</dt>
      <dd class="govuk-summary-list__value">{{ stats.total }}</dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Average score</dt>
      <dd class="govuk-summary-list__value">{{ stats.avgScore }}%</dd>
    </div>
  </dl>

  <nav aria-label="Filter by source" class="govuk-!-margin-bottom-6">
    <ul class="nexus-alpha-filter-nav">
      <li><a class="govuk-link{% if activeSource == 'all' %} govuk-link--no-visited-state{% endif %}" href="/matches?source=all"{% if activeSource == 'all' %} aria-current="true"{% endif %}>All matches</a></li>
      <li><a class="govuk-link{% if activeSource == 'listing' %} govuk-link--no-visited-state{% endif %}" href="/matches?source=listing"{% if activeSource == 'listing' %} aria-current="true"{% endif %}>Listings</a></li>
      <li><a class="govuk-link{% if activeSource == 'group' %} govuk-link--no-visited-state{% endif %}" href="/matches?source=group"{% if activeSource == 'group' %} aria-current="true"{% endif %}>Groups</a></li>
      <li><a class="govuk-link{% if activeSource == 'volunteering' %} govuk-link--no-visited-state{% endif %}" href="/matches?source=volunteering"{% if activeSource == 'volunteering' %} aria-current="true"{% endif %}>Volunteering</a></li>
      <li><a class="govuk-link{% if activeSource == 'event' %} govuk-link--no-visited-state{% endif %}" href="/matches?source=event"{% if activeSource == 'event' %} aria-current="true"{% endif %}>Events</a></li>
    </ul>
  </nav>

  {% if matches.length %}
    <div class="nexus-alpha-card-list govuk-!-margin-top-4">
      {% for match in matches %}
        <article class="nexus-alpha-card">
          <div class="nexus-alpha-module-row">
            <h2 class="govuk-heading-m govuk-!-margin-bottom-1">
              {% if match.module == 'listing' and match.listingId %}
                <a class="govuk-link" href="/listings/{{ match.listingId }}">{{ match.title }}</a>
              {% else %}
                {{ match.title }}
              {% endif %}
            </h2>
            <strong class="govuk-tag govuk-tag--grey">{{ match.moduleLabel }}</strong>
            {% if match.module == 'listing' %}
              <strong class="govuk-tag {% if match.type == 'request' %}govuk-tag--purple{% else %}govuk-tag--blue{% endif %}">{{ match.typeLabel }}</strong>
            {% endif %}
          </div>
          <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-2">by {{ match.userName }}{% if match.category %} - {{ match.category }}{% endif %}</p>
          {% if match.description %}
            <p class="govuk-body govuk-!-margin-bottom-2">{{ match.description }}</p>
          {% endif %}
          <p class="govuk-body govuk-!-margin-bottom-2"><strong class="govuk-tag govuk-tag--green">{{ match.pct }}% match</strong></p>
          {% if match.reasons.length %}
            <h3 class="govuk-heading-s govuk-!-margin-bottom-1">Why this matches</h3>
            <ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-2">
              {% for reason in match.reasons %}
                <li>{{ reason }}</li>
              {% endfor %}
            </ul>
          {% endif %}
          {% if match.module == 'listing' and match.listingId %}
            <form method="post" action="/matches/{{ match.listingId }}/dismiss" class="govuk-!-margin-top-2">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}">
              <input type="hidden" name="reason" value="not_relevant">
              <button class="govuk-button govuk-button--secondary govuk-!-font-size-16" data-module="govuk-button" type="submit">Not relevant</button>
            </form>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% else %}
    <div class="govuk-inset-text">We have no matches for you yet. Add a listing describing what you can offer or what you need, and check back soon.</div>
    <a class="govuk-button" href="/listings/new" role="button" draggable="false" data-module="govuk-button">Add a listing</a>
  {% endif %}
{% endblock %}
