{% extends "layouts/base.njk" %}

{% block mainContent %}
  {% if statusMessage %}
    <div class="govuk-notification-banner{% if statusMessage.type == 'success' %} govuk-notification-banner--success{% endif %}" role="region" aria-labelledby="matches-board-status-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="matches-board-status-title">{{ t("govuk_alpha_connections.common.success_title") if statusMessage.type == "success" else t("govuk_alpha_connections.common.error_title") }}</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ statusMessage.text }}</p>
      </div>
    </div>
  {% endif %}

  <span class="govuk-caption-xl" id="matches-top">{{ t("govuk_alpha_connections.matches.caption", { community: tenantName }) }}</span>
  <h1 class="govuk-heading-xl">{{ t("govuk_alpha_connections.matches.title") }}</h1>
  <p class="govuk-body-l">{{ t("govuk_alpha_connections.matches.description") }}</p>

  <dl class="govuk-summary-list govuk-!-margin-bottom-6">
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">{{ t("govuk_alpha_connections.matches.stats_total") }}</dt>
      <dd class="govuk-summary-list__value">{{ stats.total }}</dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">{{ t("govuk_alpha_connections.matches.stats_avg_score") }}</dt>
      <dd class="govuk-summary-list__value">{{ stats.avgScore }}%</dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">{{ t("govuk_alpha_connections.matches.stats_hot") }} <span class="govuk-hint govuk-!-font-size-16 govuk-!-margin-bottom-0">{{ t("govuk_alpha_connections.matches.stats_hot_hint") }}</span></dt>
      <dd class="govuk-summary-list__value">{{ stats.hotMatches }}</dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">{{ t("govuk_alpha_connections.matches.stats_source_types") }}</dt>
      <dd class="govuk-summary-list__value">{{ stats.sourceTypes }}</dd>
    </div>
  </dl>

  <nav aria-label="{{ t('govuk_alpha_connections.matches.source_legend') }}" class="govuk-!-margin-bottom-6">
    <ul class="nexus-alpha-filter-nav">
      <li><a class="govuk-link{% if activeSource == 'all' %} govuk-link--no-visited-state{% endif %}" href="{{ urlFor('/matches/board?source=all#matches-top') }}"{% if activeSource == 'all' %} aria-current="true"{% endif %}>{{ t("govuk_alpha_connections.matches.source_count", { label: sourceLabels.all, count: stats.total }) }}</a></li>
      {% if stats.sourceCounts.listing > 0 %}<li><a class="govuk-link{% if activeSource == 'listing' %} govuk-link--no-visited-state{% endif %}" href="{{ urlFor('/matches/board?source=listing#matches-top') }}"{% if activeSource == 'listing' %} aria-current="true"{% endif %}>{{ t("govuk_alpha_connections.matches.source_count", { label: sourceLabels.listing, count: stats.sourceCounts.listing }) }}</a></li>{% endif %}
      {% if stats.sourceCounts.group > 0 %}<li><a class="govuk-link{% if activeSource == 'group' %} govuk-link--no-visited-state{% endif %}" href="{{ urlFor('/matches/board?source=group#matches-top') }}"{% if activeSource == 'group' %} aria-current="true"{% endif %}>{{ t("govuk_alpha_connections.matches.source_count", { label: sourceLabels.group, count: stats.sourceCounts.group }) }}</a></li>{% endif %}
      {% if stats.sourceCounts.volunteering > 0 %}<li><a class="govuk-link{% if activeSource == 'volunteering' %} govuk-link--no-visited-state{% endif %}" href="{{ urlFor('/matches/board?source=volunteering#matches-top') }}"{% if activeSource == 'volunteering' %} aria-current="true"{% endif %}>{{ t("govuk_alpha_connections.matches.source_count", { label: sourceLabels.volunteering, count: stats.sourceCounts.volunteering }) }}</a></li>{% endif %}
      {% if stats.sourceCounts.event > 0 %}<li><a class="govuk-link{% if activeSource == 'event' %} govuk-link--no-visited-state{% endif %}" href="{{ urlFor('/matches/board?source=event#matches-top') }}"{% if activeSource == 'event' %} aria-current="true"{% endif %}>{{ t("govuk_alpha_connections.matches.source_count", { label: sourceLabels.event, count: stats.sourceCounts.event }) }}</a></li>{% endif %}
    </ul>
  </nav>

  {% if errorMessage %}
    <div class="govuk-error-summary" data-module="govuk-error-summary" tabindex="-1">
      <div role="alert">
        <h2 class="govuk-error-summary__title">{{ t("states.error_title") }}</h2>
        <div class="govuk-error-summary__body"><p class="govuk-body">{{ errorMessage }}</p></div>
      </div>
    </div>
  {% elif matches.length %}
    <div class="nexus-alpha-card-list govuk-!-margin-top-4">
      {% for match in matches %}
        <article class="nexus-alpha-card">
          <div class="nexus-alpha-module-row">
            <h2 class="govuk-heading-m govuk-!-margin-bottom-1">
              {% if match.href %}
                <a class="govuk-link" href="{{ urlFor(match.href) }}">{{ match.title }}</a>
              {% else %}
                {{ match.title }}
              {% endif %}
            </h2>
            <strong class="govuk-tag govuk-tag--grey">{{ match.moduleLabel }}</strong>
            {% if match.module == 'listing' %}
              <strong class="govuk-tag {% if match.type == 'request' %}govuk-tag--purple{% else %}govuk-tag--blue{% endif %}">{{ match.typeLabel }}</strong>
            {% endif %}
          </div>

          <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-2">{{ t("govuk_alpha_connections.matches.by_label", { name: match.userName }) }}{% if match.category %} - {{ match.category }}{% endif %}{% if match.matchedWhen %} - {{ t("govuk_alpha_connections.matches.matched_when", { when: match.matchedWhen }) }}{% endif %}</p>
          {% if match.description %}
            <p class="govuk-body govuk-!-margin-bottom-2">{{ match.description }}</p>
          {% endif %}

          <div class="govuk-!-margin-bottom-2">
            <strong class="govuk-tag {% if match.pct >= 80 %}govuk-tag--green{% elif match.pct >= 60 %}govuk-tag--yellow{% else %}govuk-tag--grey{% endif %}">{{ t("govuk_alpha_connections.matches.score_label", { percent: match.pct }) }}</strong>
            <progress max="100" value="{{ match.pct }}" aria-label="{{ t('govuk_alpha_connections.matches.score_bar_label', { percent: match.pct }) }}">{{ match.pct }}%</progress>
          </div>

          {% if match.reasons.length %}
            <h3 class="govuk-heading-s govuk-!-margin-bottom-1">{{ t("govuk_alpha_connections.matches.reasons_label") }}</h3>
            <ul class="govuk-list nexus-alpha-inline-list govuk-!-margin-bottom-2">
              {% for reason in match.reasons %}
                {% if loop.index <= 3 %}
                  <li><strong class="govuk-tag govuk-tag--blue">{{ reason }}</strong></li>
                {% endif %}
              {% endfor %}
              {% if match.reasons.length > 3 %}
                <li><strong class="govuk-tag govuk-tag--grey">{{ t("govuk_alpha_connections.matches.reasons_more", { count: match.reasons.length - 3 }) }}</strong></li>
              {% endif %}
            </ul>
          {% endif %}

          {% if match.module == 'listing' and match.listingId %}
            <div class="govuk-warning-text govuk-!-margin-top-2 govuk-!-margin-bottom-2">
              <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
              <strong class="govuk-warning-text__text">
                <span class="govuk-visually-hidden">{{ t("govuk_alpha_connections.common.error_title") }}</span>
                {{ t("govuk_alpha_connections.matches.dismiss_warning") }}
              </strong>
            </div>
            <form method="post" action="{{ urlFor('/matches/board/' + (match.listingId | string) + '/dismiss') }}">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}">
              <input type="hidden" name="source" value="{{ activeSource }}">
              <fieldset class="govuk-fieldset">
                <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">{{ t("govuk_alpha_connections.matches.dismiss_reason_label") }}</legend>
                <div class="govuk-radios govuk-radios--small" data-module="govuk-radios">
                  <div class="govuk-radios__item">
                    <input class="govuk-radios__input" id="dismiss-{{ match.listingId }}-not-relevant" name="reason" type="radio" value="not_relevant" checked>
                    <label class="govuk-label govuk-radios__label" for="dismiss-{{ match.listingId }}-not-relevant">{{ t("govuk_alpha_connections.matches.reason_not_relevant") }}</label>
                  </div>
                  <div class="govuk-radios__item">
                    <input class="govuk-radios__input" id="dismiss-{{ match.listingId }}-too-far" name="reason" type="radio" value="too_far">
                    <label class="govuk-label govuk-radios__label" for="dismiss-{{ match.listingId }}-too-far">{{ t("govuk_alpha_connections.matches.reason_too_far") }}</label>
                  </div>
                  <div class="govuk-radios__item">
                    <input class="govuk-radios__input" id="dismiss-{{ match.listingId }}-already-done" name="reason" type="radio" value="already_done">
                    <label class="govuk-label govuk-radios__label" for="dismiss-{{ match.listingId }}-already-done">{{ t("govuk_alpha_connections.matches.reason_already_done") }}</label>
                  </div>
                  <div class="govuk-radios__item">
                    <input class="govuk-radios__input" id="dismiss-{{ match.listingId }}-other" name="reason" type="radio" value="other">
                    <label class="govuk-label govuk-radios__label" for="dismiss-{{ match.listingId }}-other">{{ t("govuk_alpha_connections.matches.reason_other") }}</label>
                  </div>
                </div>
              </fieldset>
              <button class="govuk-button govuk-button--secondary govuk-!-margin-top-2" data-module="govuk-button" type="submit">{{ t("govuk_alpha_connections.matches.dismiss_button") }}<span class="govuk-visually-hidden">{{ t("govuk_alpha_connections.matches.dismiss_sr", { title: match.title }) }}</span></button>
            </form>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% else %}
    <div class="govuk-inset-text">
      <h2 class="govuk-heading-m govuk-!-margin-bottom-1">{% if activeSource == 'all' %}{{ t("govuk_alpha_connections.matches_empty.title_all") }}{% else %}{{ t("govuk_alpha_connections.matches_empty.title_filtered", { source: sourceLabels[activeSource] }) }}{% endif %}</h2>
      <p class="govuk-body">{{ t("govuk_alpha_connections.matches_empty.body") }}</p>
    </div>
    <a class="govuk-button" href="{{ urlFor('/listings') }}" role="button" draggable="false" data-module="govuk-button">{{ t("govuk_alpha_connections.matches_empty.browse_listings") }}</a>
  {% endif %}

  <p class="govuk-body govuk-!-margin-top-6">
    <a class="govuk-link" href="{{ urlFor('/matches') }}">{{ t("govuk_alpha_connections.matches.back_to_matches") }}</a>
  </p>
{% endblock %}
