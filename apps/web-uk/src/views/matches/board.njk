{% extends "layouts/base.njk" %}

{% block mainContent %}
  {% if statusMessage %}
    <div class="govuk-notification-banner{% if statusMessage.type == 'success' %} govuk-notification-banner--success{% endif %}" role="region" aria-labelledby="matches-board-status-title">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="matches-board-status-title">{{ "Success" if statusMessage.type == "success" else "Important" }}</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">{{ statusMessage.text }}</p>
      </div>
    </div>
  {% endif %}

  <span class="govuk-caption-xl" id="matches-top">Suggested matches</span>
  <h1 class="govuk-heading-xl">Your matches</h1>
  <p class="govuk-body-l">Members and opportunities that complement your listings, ranked by how well they fit your profile.</p>

  <dl class="govuk-summary-list govuk-!-margin-bottom-6">
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Total matches</dt>
      <dd class="govuk-summary-list__value">{{ stats.total }}</dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Average match score</dt>
      <dd class="govuk-summary-list__value">{{ stats.avgScore }}%</dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Strong matches <span class="govuk-hint govuk-!-font-size-16 govuk-!-margin-bottom-0">Matches scoring 80% or higher.</span></dt>
      <dd class="govuk-summary-list__value">{{ stats.hotMatches }}</dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Match sources</dt>
      <dd class="govuk-summary-list__value">{{ stats.sourceTypes }}</dd>
    </div>
  </dl>

  <nav aria-label="Filter matches by source" class="govuk-!-margin-bottom-6">
    <ul class="nexus-alpha-filter-nav">
      <li><a class="govuk-link{% if activeSource == 'all' %} govuk-link--no-visited-state{% endif %}" href="/matches/board?source=all#matches-top"{% if activeSource == 'all' %} aria-current="true"{% endif %}>All ({{ stats.total }})</a></li>
      {% if stats.sourceCounts.listing > 0 %}<li><a class="govuk-link{% if activeSource == 'listing' %} govuk-link--no-visited-state{% endif %}" href="/matches/board?source=listing#matches-top"{% if activeSource == 'listing' %} aria-current="true"{% endif %}>Listings ({{ stats.sourceCounts.listing }})</a></li>{% endif %}
      {% if stats.sourceCounts.group > 0 %}<li><a class="govuk-link{% if activeSource == 'group' %} govuk-link--no-visited-state{% endif %}" href="/matches/board?source=group#matches-top"{% if activeSource == 'group' %} aria-current="true"{% endif %}>Groups ({{ stats.sourceCounts.group }})</a></li>{% endif %}
      {% if stats.sourceCounts.volunteering > 0 %}<li><a class="govuk-link{% if activeSource == 'volunteering' %} govuk-link--no-visited-state{% endif %}" href="/matches/board?source=volunteering#matches-top"{% if activeSource == 'volunteering' %} aria-current="true"{% endif %}>Volunteering ({{ stats.sourceCounts.volunteering }})</a></li>{% endif %}
      {% if stats.sourceCounts.event > 0 %}<li><a class="govuk-link{% if activeSource == 'event' %} govuk-link--no-visited-state{% endif %}" href="/matches/board?source=event#matches-top"{% if activeSource == 'event' %} aria-current="true"{% endif %}>Events ({{ stats.sourceCounts.event }})</a></li>{% endif %}
    </ul>
  </nav>

  {% if matches.length %}
    <div class="nexus-alpha-card-list govuk-!-margin-top-4">
      {% for match in matches %}
        <article class="nexus-alpha-card">
          <div class="nexus-alpha-module-row">
            <h2 class="govuk-heading-m govuk-!-margin-bottom-1">
              {% if match.module == 'listing' and match.listingId %}
                <a class="govuk-link" href="/listings/{{ match.listingId }}">{{ match.title }}</a>
              {% elif match.module == 'group' and match.groupId %}
                <a class="govuk-link" href="/groups/{{ match.groupId }}">{{ match.title }}</a>
              {% elif match.module == 'event' and match.eventId %}
                <a class="govuk-link" href="/events/{{ match.eventId }}">{{ match.title }}</a>
              {% else %}
                {{ match.title }}
              {% endif %}
            </h2>
            <strong class="govuk-tag govuk-tag--grey">{{ match.moduleLabel }}</strong>
            {% if match.module == 'listing' %}
              <strong class="govuk-tag {% if match.type == 'request' %}govuk-tag--purple{% else %}govuk-tag--blue{% endif %}">{{ "Request" if match.type == "request" else "Offer" }}</strong>
            {% endif %}
          </div>

          <p class="govuk-body-s nexus-alpha-meta govuk-!-margin-bottom-2">By {{ match.userName }}{% if match.category %} - {{ match.category }}{% endif %}{% if match.createdAt %} - Matched {{ match.createdAt | formatDate }}{% endif %}</p>
          {% if match.description %}
            <p class="govuk-body govuk-!-margin-bottom-2">{{ match.description }}</p>
          {% endif %}

          <div class="govuk-!-margin-bottom-2">
            <strong class="govuk-tag {% if match.pct >= 80 %}govuk-tag--green{% elif match.pct >= 60 %}govuk-tag--yellow{% else %}govuk-tag--grey{% endif %}">{{ match.pct }}% match</strong>
            <progress max="100" value="{{ match.pct }}" aria-label="Match score: {{ match.pct }}%">{{ match.pct }}%</progress>
          </div>

          {% if match.reasons.length %}
            <h3 class="govuk-heading-s govuk-!-margin-bottom-1">Why this matches</h3>
            <ul class="govuk-list nexus-alpha-inline-list govuk-!-margin-bottom-2">
              {% for reason in match.reasons %}
                {% if loop.index <= 3 %}
                  <li><strong class="govuk-tag govuk-tag--blue">{{ reason }}</strong></li>
                {% endif %}
              {% endfor %}
              {% if match.reasons.length > 3 %}
                <li><strong class="govuk-tag govuk-tag--grey">+{{ match.reasons.length - 3 }} more</strong></li>
              {% endif %}
            </ul>
          {% endif %}

          {% if match.module == 'listing' and match.listingId %}
            <div class="govuk-warning-text govuk-!-margin-top-2 govuk-!-margin-bottom-2">
              <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
              <strong class="govuk-warning-text__text">
                <span class="govuk-visually-hidden">There is a problem</span>
                Hiding a match tells us it was not useful, so we show you fewer like it. You will not be notified and the other member will not know.
              </strong>
            </div>
            <form method="post" action="/matches/board/{{ match.listingId }}/dismiss">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}">
              <input type="hidden" name="source" value="{{ activeSource }}">
              <fieldset class="govuk-fieldset">
                <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Why are you not interested?</legend>
                <div class="govuk-radios govuk-radios--small" data-module="govuk-radios">
                  <div class="govuk-radios__item">
                    <input class="govuk-radios__input" id="dismiss-{{ match.listingId }}-not-relevant" name="reason" type="radio" value="not_relevant" checked>
                    <label class="govuk-label govuk-radios__label" for="dismiss-{{ match.listingId }}-not-relevant">Not relevant to me</label>
                  </div>
                  <div class="govuk-radios__item">
                    <input class="govuk-radios__input" id="dismiss-{{ match.listingId }}-too-far" name="reason" type="radio" value="too_far">
                    <label class="govuk-label govuk-radios__label" for="dismiss-{{ match.listingId }}-too-far">Too far away</label>
                  </div>
                  <div class="govuk-radios__item">
                    <input class="govuk-radios__input" id="dismiss-{{ match.listingId }}-already-done" name="reason" type="radio" value="already_done">
                    <label class="govuk-label govuk-radios__label" for="dismiss-{{ match.listingId }}-already-done">Already done or sorted</label>
                  </div>
                  <div class="govuk-radios__item">
                    <input class="govuk-radios__input" id="dismiss-{{ match.listingId }}-other" name="reason" type="radio" value="other">
                    <label class="govuk-label govuk-radios__label" for="dismiss-{{ match.listingId }}-other">Another reason</label>
                  </div>
                </div>
              </fieldset>
              <button class="govuk-button govuk-button--secondary govuk-!-margin-top-2" data-module="govuk-button" type="submit">Hide this match</button>
            </form>
          {% endif %}
        </article>
      {% endfor %}
    </div>
  {% else %}
    <div class="govuk-inset-text">
      <h2 class="govuk-heading-m govuk-!-margin-bottom-1">{% if activeSource == 'all' %}No matches yet{% else %}No {{ sourceLabels[activeSource] }} matches yet{% endif %}</h2>
      <p class="govuk-body">As you add listings and update your profile, we will suggest members and opportunities that fit. Browse listings to get started.</p>
    </div>
    <a class="govuk-button" href="/listings" role="button" draggable="false" data-module="govuk-button">Browse listings</a>
  {% endif %}

  <p class="govuk-body govuk-!-margin-top-6">
    <a class="govuk-link" href="/matches">Back to matches</a>
  </p>
{% endblock %}
