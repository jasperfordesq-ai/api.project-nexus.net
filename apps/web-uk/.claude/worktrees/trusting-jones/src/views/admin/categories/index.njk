{% extends "layouts/base.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% block beforeContent %}
  {{ super() }}
  <nav class="govuk-breadcrumbs" aria-label="Breadcrumb">
    <ol class="govuk-breadcrumbs__list">
      <li class="govuk-breadcrumbs__list-item">
        <a class="govuk-breadcrumbs__link" href="/dashboard">Dashboard</a>
      </li>
      <li class="govuk-breadcrumbs__list-item">
        <a class="govuk-breadcrumbs__link" href="/admin">Admin</a>
      </li>
      <li class="govuk-breadcrumbs__list-item" aria-current="page">Categories</li>
    </ol>
  </nav>
{% endblock %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">

      {% if successMessage %}
        {% set notificationMessage = successMessage %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      {% if errorMessage %}
        {% set notificationMessage = errorMessage %}
        {% set notificationType = null %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
          <h1 class="govuk-heading-xl">
            <span class="govuk-caption-xl">Administration</span>
            Categories
          </h1>
        </div>
        <div class="govuk-grid-column-one-third" style="text-align: right; padding-top: 20px;">
          {{ govukButton({
            text: "Add category",
            href: "/admin/categories/new"
          }) }}
        </div>
      </div>

      {% if categories and categories.length > 0 %}
        <table class="govuk-table">
          <caption class="govuk-table__caption govuk-table__caption--m govuk-visually-hidden">Categories list</caption>
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">Name</th>
              <th scope="col" class="govuk-table__header">Slug</th>
              <th scope="col" class="govuk-table__header">Listings</th>
              <th scope="col" class="govuk-table__header">Order</th>
              <th scope="col" class="govuk-table__header">Status</th>
              <th scope="col" class="govuk-table__header">Actions</th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for cat in categories %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">
                  <strong>{{ cat.name }}</strong>
                  {% if cat.description %}
                    <br><span class="govuk-body-s">{{ cat.description | truncate(50) }}</span>
                  {% endif %}
                </td>
                <td class="govuk-table__cell"><code>{{ cat.slug }}</code></td>
                <td class="govuk-table__cell">{{ cat.listing_count or 0 }}</td>
                <td class="govuk-table__cell">{{ cat.sort_order }}</td>
                <td class="govuk-table__cell">
                  {% if cat.is_active %}
                    {{ govukTag({ text: "Active", classes: "govuk-tag--green" }) }}
                  {% else %}
                    {{ govukTag({ text: "Inactive", classes: "govuk-tag--grey" }) }}
                  {% endif %}
                </td>
                <td class="govuk-table__cell">
                  <a href="/admin/categories/{{ cat.id }}/edit" class="govuk-link">Edit</a>
                  {% if (cat.listing_count or 0) == 0 %}
                    |
                    <form method="post" action="/admin/categories/{{ cat.id }}/delete" style="display: inline;">
                      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                      <button type="submit" class="govuk-link app-link-button" onclick="return confirm('Are you sure you want to delete this category?')">Delete</button>
                    </form>
                  {% endif %}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        <p class="govuk-body">No categories found.</p>
        <p class="govuk-body">
          <a href="/admin/categories/new" class="govuk-link">Create your first category</a>
        </p>
      {% endif %}

    </div>
  </div>
{% endblock %}
