{% extends "layouts/base.njk" %}

{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if errors and errors.length %}
        {{ govukErrorSummary({
          titleText: "There is a problem",
          errorList: errors
        }) }}
      {% endif %}

      <h1 class="govuk-heading-xl">Set a new password</h1>

      <p class="govuk-body">
        Enter your new password below.
      </p>

      <form method="post" action="/reset-password" novalidate>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <input type="hidden" name="token" value="{{ resetToken }}">

        {{ govukInput({
          label: {
            text: "New password",
            classes: "govuk-label--m"
          },
          hint: {
            text: "Must be at least 8 characters"
          },
          id: "password",
          name: "password",
          type: "password",
          autocomplete: "new-password",
          errorMessage: { text: fieldErrors.password } if fieldErrors.password else undefined
        }) }}

        {{ govukInput({
          label: {
            text: "Confirm new password",
            classes: "govuk-label--m"
          },
          id: "confirm_password",
          name: "confirm_password",
          type: "password",
          autocomplete: "new-password",
          errorMessage: { text: fieldErrors.confirm_password } if fieldErrors.confirm_password else undefined
        }) }}

        {{ govukButton({
          text: "Reset password"
        }) }}
      </form>

      <p class="govuk-body govuk-!-margin-top-6">
        <a href="/login" class="govuk-link">Back to sign in</a>
      </p>

    </div>
  </div>
{% endblock %}
