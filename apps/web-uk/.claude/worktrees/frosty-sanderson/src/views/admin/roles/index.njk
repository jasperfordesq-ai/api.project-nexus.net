{% extends "layouts/base.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/tag/macro.njk" import govukTag %}
{% block beforeContent %}
  {{ super() }}
  <nav class="govuk-breadcrumbs" aria-label="Breadcrumb">
    <ol class="govuk-breadcrumbs__list">
      <li class="govuk-breadcrumbs__list-item">
        <a class="govuk-breadcrumbs__link" href="/dashboard">Dashboard</a>
      </li>
      <li class="govuk-breadcrumbs__list-item">
        <a class="govuk-breadcrumbs__link" href="/admin">Admin</a>
      </li>
      <li class="govuk-breadcrumbs__list-item" aria-current="page">Roles</li>
    </ol>
  </nav>
{% endblock %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">

      {% if successMessage %}
        {% set notificationMessage = successMessage %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      {% if errorMessage %}
        {% set notificationMessage = errorMessage %}
        {% set notificationType = null %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
          <h1 class="govuk-heading-xl">
            <span class="govuk-caption-xl">Administration</span>
            Roles
          </h1>
        </div>
        <div class="govuk-grid-column-one-third" style="text-align: right; padding-top: 20px;">
          {{ govukButton({
            text: "Add role",
            href: "/admin/roles/new"
          }) }}
        </div>
      </div>

      {% if roles and roles.length > 0 %}
        <table class="govuk-table">
          <caption class="govuk-table__caption govuk-table__caption--m govuk-visually-hidden">Roles list</caption>
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header">Name</th>
              <th scope="col" class="govuk-table__header">Description</th>
              <th scope="col" class="govuk-table__header">Permissions</th>
              <th scope="col" class="govuk-table__header">Type</th>
              <th scope="col" class="govuk-table__header">Actions</th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for role in roles %}
              {% set perms = role.permissions | parseJson if role.permissions is string else (role.permissions or []) %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">
                  <strong>{{ role.name }}</strong>
                </td>
                <td class="govuk-table__cell">{{ role.description or "-" }}</td>
                <td class="govuk-table__cell">
                  {% if perms and perms.length > 0 %}
                    {% for perm in perms | slice(0, 3) %}
                      {{ govukTag({ text: perm, classes: "govuk-tag--grey govuk-!-margin-right-1" }) }}
                    {% endfor %}
                    {% if perms.length > 3 %}
                      <span class="govuk-body-s">+{{ perms.length - 3 }} more</span>
                    {% endif %}
                  {% else %}
                    <span class="govuk-body-s">No permissions</span>
                  {% endif %}
                </td>
                <td class="govuk-table__cell">
                  {% if role.is_system %}
                    {{ govukTag({ text: "System", classes: "govuk-tag--yellow" }) }}
                  {% else %}
                    {{ govukTag({ text: "Custom", classes: "govuk-tag--blue" }) }}
                  {% endif %}
                </td>
                <td class="govuk-table__cell">
                  {% if not role.is_system %}
                    <a href="/admin/roles/{{ role.id }}/edit" class="govuk-link">Edit</a>
                    |
                    <form method="post" action="/admin/roles/{{ role.id }}/delete" style="display: inline;">
                      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                      <button type="submit" class="govuk-link app-link-button" onclick="return confirm('Are you sure you want to delete this role?')">Delete</button>
                    </form>
                  {% else %}
                    <span class="govuk-body-s govuk-!-font-weight-regular">System role</span>
                  {% endif %}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% else %}
        <p class="govuk-body">No roles found.</p>
        <p class="govuk-body">
          <a href="/admin/roles/new" class="govuk-link">Create your first custom role</a>
        </p>
      {% endif %}

    </div>
  </div>
{% endblock %}
