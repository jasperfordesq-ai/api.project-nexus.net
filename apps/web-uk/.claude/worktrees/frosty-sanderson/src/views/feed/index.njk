{% extends "layouts/base.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% from "govuk/components/pagination/macro.njk" import govukPagination %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if successMessage %}
        {% set notificationMessage = successMessage %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      {% if errorMessage %}
        {% set notificationMessage = errorMessage %}
        {% set notificationType = null %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      <div class="app-page-header">
        <h1 class="govuk-heading-xl govuk-!-margin-bottom-2">Feed</h1>
        <div class="app-page-header__actions">
          {{ govukButton({
            text: "Create a post",
            href: "/feed/new" + ("?group_id=" + groupId if groupId else ""),
            classes: "govuk-!-margin-bottom-0"
          }) }}
        </div>
      </div>

      {# Group filter #}
      {% if myGroups.length > 0 %}
        {% set groupItems = [{value: "", text: "All posts", selected: not groupId}] %}
        {% for group in myGroups %}
          {% set groupItems = (groupItems.push({
            value: group.id | string,
            text: group.name,
            selected: groupId and (group.id | string) == (groupId | string)
          }), groupItems) %}
        {% endfor %}
        <form action="/feed" method="get" class="govuk-!-margin-bottom-6">
          <div class="app-filter-row">
            {{ govukSelect({
              id: "group_id",
              name: "group_id",
              label: {
                text: "Filter by group"
              },
              items: groupItems,
              formGroup: {
                classes: "govuk-!-margin-bottom-0"
              }
            }) }}
            {{ govukButton({
              text: "Filter",
              classes: "govuk-button--secondary govuk-!-margin-bottom-0 govuk-!-margin-left-2"
            }) }}
            {% if groupId %}
              <a href="/feed" class="govuk-link govuk-!-margin-left-3">Clear filter</a>
            {% endif %}
          </div>
        </form>
      {% endif %}

      {# Posts list #}
      {% if posts.length > 0 %}
        <div class="app-feed">
          {% for post in posts %}
            <article class="app-post {% if post.is_pinned %}app-post--pinned{% endif %}">
              {% if post.is_pinned %}
                <div class="app-post__pinned-badge">
                  {{ govukTag({ text: "Pinned", classes: "govuk-tag--yellow" }) }}
                </div>
              {% endif %}

              <header class="app-post__header">
                <div class="app-post__author">
                  {% set user = post.user %}
                  {% include "partials/avatar.njk" %}
                  <div class="app-post__author-info">
                    <a href="/members/{{ post.user.id }}" class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold">
                      {{ post.user.first_name or post.user.firstName }} {{ post.user.last_name or post.user.lastName }}
                    </a>
                    <span class="govuk-body-s govuk-!-margin-bottom-0 app-post__meta">
                      {{ post.created_at | formatDate }}
                      {% if post.group %}
                        in <a href="/groups/{{ post.group.id }}" class="govuk-link">{{ post.group.name }}</a>
                      {% endif %}
                    </span>
                  </div>
                </div>
              </header>

              <div class="app-post__content">
                <p class="govuk-body">{{ post.content | truncate(500) }}</p>
                {% if post.image_url %}
                  <img src="{{ post.image_url }}" alt="Image attached to post by {{ post.user.first_name or post.user.firstName }}" class="app-post__image">
                {% endif %}
              </div>

              <footer class="app-post__footer">
                <div class="app-post__actions">
                  {# Like button #}
                  {% if post.is_liked %}
                    <form action="/feed/{{ post.id }}/unlike" method="post" class="app-post__action-form">
                      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                      <input type="hidden" name="return_to" value="/feed{% if groupId %}?group_id={{ groupId }}{% endif %}">
                      <button type="submit" class="app-link-button app-post__action-button app-post__action-button--active">
                        <span aria-hidden="true">&#9829;</span> {{ post.like_count }} Like{{ 's' if post.like_count != 1 else '' }}
                      </button>
                    </form>
                  {% else %}
                    <form action="/feed/{{ post.id }}/like" method="post" class="app-post__action-form">
                      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                      <input type="hidden" name="return_to" value="/feed{% if groupId %}?group_id={{ groupId }}{% endif %}">
                      <button type="submit" class="app-link-button app-post__action-button">
                        <span aria-hidden="true">&#9825;</span> {{ post.like_count }} Like{{ 's' if post.like_count != 1 else '' }}
                      </button>
                    </form>
                  {% endif %}

                  {# Comment link #}
                  <a href="/feed/{{ post.id }}" class="govuk-link app-post__action-button">
                    <span aria-hidden="true">&#128172;</span> {{ post.comment_count }} Comment{{ 's' if post.comment_count != 1 else '' }}
                  </a>
                </div>

                <a href="/feed/{{ post.id }}" class="govuk-link">View post</a>
              </footer>
            </article>
          {% endfor %}
        </div>

        {# Pagination #}
        {% if pagination.total_pages > 1 %}
          {% set paginationItems = [] %}
          {% for i in range(1, pagination.total_pages + 1) %}
            {% set paginationItems = (paginationItems.push({
              number: i,
              href: "/feed?page=" + i + ("&group_id=" + groupId if groupId else ""),
              current: i == pagination.page
            }), paginationItems) %}
          {% endfor %}

          {{ govukPagination({
            previous: {
              href: "/feed?page=" + (pagination.page - 1) + ("&group_id=" + groupId if groupId else "")
            } if pagination.page > 1 else undefined,
            next: {
              href: "/feed?page=" + (pagination.page + 1) + ("&group_id=" + groupId if groupId else "")
            } if pagination.page < pagination.total_pages else undefined,
            items: paginationItems
          }) }}
        {% endif %}
      {% else %}
        <div class="app-empty-state">
          <p class="govuk-heading-m app-empty-state__heading">No posts yet</p>
          <p class="govuk-body app-empty-state__message">
            {% if groupId %}
              This group doesn't have any posts yet. Be the first to share something!
            {% else %}
              The feed is empty. Create a post to get the conversation started.
            {% endif %}
          </p>
          {{ govukButton({
            text: "Create a post",
            href: "/feed/new" + ("?group_id=" + groupId if groupId else "")
          }) }}
        </div>
      {% endif %}

    </div>

    <div class="govuk-grid-column-one-third">
      {# Sidebar - My Groups #}
      {% if myGroups.length > 0 %}
        <div class="app-sidebar-card">
          <h2 class="govuk-heading-m">My groups</h2>
          <ul class="govuk-list">
            {% for group in myGroups | slice(0, 5) %}
              <li>
                <a href="/feed?group_id={{ group.id }}" class="govuk-link">{{ group.name }}</a>
              </li>
            {% endfor %}
          </ul>
          {% if myGroups.length > 5 %}
            <p class="govuk-body-s">
              <a href="/groups/my" class="govuk-link">View all {{ myGroups.length }} groups</a>
            </p>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
{% endblock %}
