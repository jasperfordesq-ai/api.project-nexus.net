{% extends "layouts/base.njk" %}

{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">Too many requests</h1>
      <p class="govuk-body">You've made too many requests in a short period of time.</p>
      <p class="govuk-body">
        {% if retryAfter %}
          Please wait {{ retryAfter }} minute{{ 's' if retryAfter != 1 else '' }} before trying again.
        {% else %}
          Please wait a few minutes before trying again.
        {% endif %}
      </p>
      <p class="govuk-body">
        <a href="/" class="govuk-link">Go to the home page</a>
      </p>
    </div>
  </div>
{% endblock %}
