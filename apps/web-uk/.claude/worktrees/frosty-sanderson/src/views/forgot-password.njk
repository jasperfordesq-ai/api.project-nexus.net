{% extends "layouts/base.njk" %}

{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% block mainContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if successMessage %}
        {% set notificationMessage = successMessage %}
        {% set notificationType = "success" %}
        {% include "partials/notification-banner.njk" %}
      {% endif %}

      {% if errors and errors.length %}
        {{ govukErrorSummary({
          titleText: "There is a problem",
          errorList: errors
        }) }}
      {% endif %}

      <h1 class="govuk-heading-xl">Reset your password</h1>

      <p class="govuk-body">
        Enter your email address and community code. If an account exists, we'll send you a link to reset your password.
      </p>

      <form method="post" action="/forgot-password" novalidate>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        {{ govukInput({
          label: {
            text: "Email address",
            classes: "govuk-label--m"
          },
          id: "email",
          name: "email",
          type: "email",
          autocomplete: "email",
          spellcheck: false,
          value: values.email if values else "",
          errorMessage: { text: fieldErrors.email } if fieldErrors.email else undefined
        }) }}

        {{ govukInput({
          label: {
            text: "Community code",
            classes: "govuk-label--m"
          },
          hint: {
            text: "The code for your community (e.g. 'acme')"
          },
          id: "tenant_slug",
          name: "tenant_slug",
          value: values.tenant_slug if values else "",
          errorMessage: { text: fieldErrors.tenant_slug } if fieldErrors.tenant_slug else undefined
        }) }}

        {{ govukButton({
          text: "Send reset link"
        }) }}
      </form>

      <p class="govuk-body govuk-!-margin-top-6">
        <a href="/login" class="govuk-link">Back to sign in</a>
      </p>

    </div>
  </div>
{% endblock %}
