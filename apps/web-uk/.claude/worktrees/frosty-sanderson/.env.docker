# =============================================================================
# NEXUS UK Frontend - Docker Environment Configuration
# =============================================================================
# This file is ONLY used when running via Docker Compose.
# For non-Docker development, use .env instead.
# =============================================================================

# Server port (internal to container)
PORT=3001

# Backend API URL - uses Docker's host.docker.internal to reach host machine
# The backend API runs on port 5080 on your host machine
API_BASE_URL=http://host.docker.internal:5080

# Cookie signing secret (change in production!)
COOKIE_SECRET=docker-dev-cookie-secret-minimum-32-characters

# Session secret (change in production!)
SESSION_SECRET=docker-dev-session-secret-minimum-32-chars

# Environment
NODE_ENV=development
