# =============================================================================
# Project NEXUS - Production environment template
# =============================================================================
# Use this only as a redacted key reference for an explicitly configured secret
# store or process environment. Neither ASP.NET nor default Compose
# automatically loads a file named .env.production. NEVER commit real values.
# Canonical application variable names use the ASP.NET Core double-underscore
# convention so they map onto nested IConfiguration keys (for example,
# Cors__AllowedOrigins__0 -> Cors:AllowedOrigins:0). Legacy Compose-only
# interpolation variables are isolated near the end of this file.
#
# This is a key-name reference, not a deployment recipe. Read
# docs/system/CONFIGURATION.md and docs/system/OPERATIONS.md before planning a
# release; production actions still require explicit authorization.
# =============================================================================


# -----------------------------------------------------------------------------
# REQUIRED BY STARTUP OR PRODUCTION POLICY
# -----------------------------------------------------------------------------

# Startup-guard enforced: JWT signing secret consumed directly by the
# application. Min 16 chars. Must NOT be a known placeholder
# (CHANGE_ME / dev-only-secret / etc - the bootstrap explicitly rejects these).
Jwt__Secret=REPLACE_ME_WITH_AT_LEAST_32_RANDOM_BYTES_BASE64

# Policy-required: the current startup guard does not
# yet fail fast when they are empty. Empty values disable issuer/audience token
# validation in AuthExtensions.
Jwt__Issuer=https://api.project-nexus.net
Jwt__Audience=project-nexus-clients

# Startup-guard enforced: complete application connection string consumed by
# the Production startup guard and design-time factory. Use a dedicated database
# and least-privilege application role; do not reuse the development names below.
ConnectionStrings__DefaultConnection=Host=REPLACE_ME_DB_HOST;Port=5432;Database=REPLACE_ME_DB_NAME;Username=REPLACE_ME_DB_USER;Password=REPLACE_ME_STRONG_DB_PASSWORD

# CORS allowed origins. HTTPS only, no trailing slash. Add as many as you need
# (indices must be contiguous starting at 0).
Cors__AllowedOrigins__0=https://platform.project-nexus.net
Cors__AllowedOrigins__1=https://uk.project-nexus.net
Cors__AllowedOrigins__2=https://admin.project-nexus.net

# FIDO2 / WebAuthn passkey origins. Must be HTTPS in Production and must match
# the CORS origins above. ServerDomain is the RP ID (apex domain users access).
Fido2__ServerDomain=project-nexus.net
Fido2__ServerName=Project NEXUS
Fido2__Origins__0=https://platform.project-nexus.net
Fido2__Origins__1=https://uk.project-nexus.net
Fido2__Origins__2=https://admin.project-nexus.net

# Persistent upload root for the API runtime user. Provision ownership,
# permissions, persistence, backup, and restore evidence separately.
FileUpload__UploadsRoot=/var/lib/project-nexus/uploads


# -----------------------------------------------------------------------------
# STRONGLY RECOMMENDED - specific features fail or are disabled without these
# -----------------------------------------------------------------------------

# Stripe - donations + Stripe Identity for ID verification.
Stripe__SecretKey=sk_live_REPLACE_ME

# Stripe webhook secrets. Generic secret applies to all webhook endpoints
# unless a per-endpoint override is set. The donation webhook falls back to
# the generic secret if its specific variant is unset.
Stripe__WebhookSecret=whsec_REPLACE_ME
Stripe__WebhookSecret_Donations=whsec_REPLACE_ME_DONATIONS

# Registration / identity-provider webhook HMAC secret. Production returns
# HTTP 503 from the webhook endpoint when this is unset (fail-closed).
Registration__WebhookSecret=REPLACE_ME_RANDOM_HMAC_SECRET

# SendGrid - primary email transport. Sender must be a verified sender in
# SendGrid (single sender or authenticated domain).
SendGrid__ApiKey=SG.REPLACE_ME
SendGrid__SenderEmail=no-reply@project-nexus.net
SendGrid__Enabled=true

# Gmail OAuth2 - fallback email transport. The FallbackEmailService decorator
# routes here when SendGrid returns non-success.
Gmail__ClientId=REPLACE_ME.apps.googleusercontent.com
Gmail__ClientSecret=REPLACE_ME
Gmail__RefreshToken=REPLACE_ME
Gmail__SenderEmail=no-reply@project-nexus.net
Gmail__Enabled=true

# Web-Push VAPID keys. Subject is a mailto: or https: URL identifying the app.
# Generate with `npx web-push generate-vapid-keys` and keep the private key secret.
Vapid__PublicKey=REPLACE_ME_BASE64URL_PUBLIC
Vapid__PrivateKey=REPLACE_ME_BASE64URL_PRIVATE
Vapid__Subject=mailto:ops@project-nexus.net

# Firebase Cloud Messaging - legacy HTTP API server key for native push.
Firebase__ServerKey=REPLACE_ME_FCM_SERVER_KEY

# Sentry error tracking DSN.
Sentry__Dsn=https://REPLACE_ME@oXXXXXX.ingest.sentry.io/REPLACE_ME

# OpenTelemetry OTLP exporter endpoint. Leave UNSET to fall back to a
# Prometheus scrape endpoint exposed at /metrics instead.
Otel__Endpoint=https://otlp.your-observability-vendor.example/v1


# -----------------------------------------------------------------------------
# OPTIONAL - feature-gated; safe to leave unset if the feature is off
# -----------------------------------------------------------------------------

# Meilisearch - semantic search. Enabled flag must be true for the integration
# to start; BaseUrl + ApiKey are then required.
Meilisearch__Enabled=true
Meilisearch__BaseUrl=https://search.project-nexus.net
Meilisearch__ApiKey=REPLACE_ME_MEILISEARCH_MASTER_KEY

# AI provider routing. One of: ollama | anthropic | openai | gemini.
# Falls back to a no-op NullAiProvider when the selected provider is unconfigured
# AND Ai__NullFallbackEnabled is true.
Ai__Provider=anthropic
Ai__Anthropic__ApiKey=sk-ant-REPLACE_ME
Ai__OpenAI__ApiKey=sk-REPLACE_ME
Ai__Gemini__ApiKey=REPLACE_ME
Ai__NullFallbackEnabled=true

# RabbitMQ - only required if the message-queue integration is enabled. The
# current options binder consumes individual fields, not a single Uri.
# The current publisher exposes no TLS/SSL option. Keep this disabled unless a
# verified private plaintext broker path exists; do not point port 5671 at it.
RabbitMq__Enabled=false
RabbitMq__Host=rabbit.project-nexus.net
RabbitMq__Port=5672
RabbitMq__Username=nexus
RabbitMq__Password=REPLACE_ME
RabbitMq__VirtualHost=/
RabbitMq__ExchangeName=nexus.events


# -----------------------------------------------------------------------------
# LEGACY / SIDECAR vars (kept for backwards compatibility with compose.yml)
# -----------------------------------------------------------------------------

# Legacy root-Compose interpolation only. The current root/compose.prod path is
# not an approved production topology and maps development database defaults;
# these short names are not substitutes for the canonical application keys
# above.
JWT_SECRET=REPLACE_ME_LEGACY_COMPOSE_JWT_SECRET

# Cookie/session secrets for the UK frontend sidecar.
COOKIE_SECRET=REPLACE_ME_RANDOM
SESSION_SECRET=REPLACE_ME_RANDOM

# RabbitMQ basic auth (when running the bundled RabbitMQ container).
RABBITMQ_USER=nexus
RABBITMQ_PASS=REPLACE_ME


# -----------------------------------------------------------------------------
