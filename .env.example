#
# Example environment file for local development.
# Copy to `.env` and fill in real values. Never commit `.env`.

# JWT secret — minimum 32 bytes (256 bits) for HS256.
# Required: app fails to start without this.
JWT_SECRET=TestSecretKeyForDevelopment123ThisNeedsToBeAtLeast32Characters!

# RabbitMQ credentials (used by both the rabbitmq service and the api client).
# Defaults to "guest"/"guest" for local-only dev. Override these in any
# environment that is reachable beyond localhost — RabbitMQ ships with the
# guest account hard-restricted to localhost connections, but a real
# deployment should still set strong unique credentials here.
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Sentry (backend — optional; leave Sentry__Dsn blank to disable)
Sentry__Dsn=
Sentry__Environment=development
Sentry__TracesSampleRate=0.1
